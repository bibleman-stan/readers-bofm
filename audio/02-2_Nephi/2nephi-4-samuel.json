{
  "book": "2nephi",
  "chapter": 4,
  "voice": {
    "provider": "elevenlabs",
    "voice_id": "ddDFRErfhdc2asyySOG5",
    "model_id": "eleven_multilingual_v2",
    "settings": {
      "stability": 0.5,
      "similarity_boost": 0.75,
      "style": 0.35,
      "use_speaker_boost": true
    },
    "name": "Samuel"
  },
  "pauses": {
    "line_ms": 180,
    "verse_ms": 500
  },
  "duration": 487.497,
  "lines": [
    {
      "start": 0.0,
      "end": 3.204,
      "type": "line",
      "text": "And now, I, Nephi, speak concerning the prophecies",
      "verse": "4:1",
      "lineIndex": 1
    },
    {
      "start": 3.384,
      "end": 5.474,
      "type": "line",
      "text": "of which my father hath spoken,",
      "verse": "4:1",
      "lineIndex": 2
    },
    {
      "start": 5.654,
      "end": 8.58,
      "type": "line",
      "text": "concerning Joseph, who was carried into Egypt.",
      "verse": "4:1",
      "lineIndex": 3
    },
    {
      "start": 9.26,
      "end": 12.604,
      "type": "line",
      "text": "For behold, he truly prophesied concerning all his seed.",
      "verse": "4:2",
      "lineIndex": 4
    },
    {
      "start": 12.784,
      "end": 14.92,
      "type": "line",
      "text": "And the prophecies which he wrote,",
      "verse": "4:2",
      "lineIndex": 5
    },
    {
      "start": 15.1,
      "end": 16.958,
      "type": "line",
      "text": "there are not many greater.",
      "verse": "4:2",
      "lineIndex": 6
    },
    {
      "start": 17.138,
      "end": 19.46,
      "type": "line",
      "text": "And he prophesied concerning us,",
      "verse": "4:2",
      "lineIndex": 7
    },
    {
      "start": 19.64,
      "end": 21.73,
      "type": "line",
      "text": "and our future generations;",
      "verse": "4:2",
      "lineIndex": 8
    },
    {
      "start": 21.91,
      "end": 24.975,
      "type": "line",
      "text": "and they are written upon the plates of brass.",
      "verse": "4:2",
      "lineIndex": 9
    },
    {
      "start": 25.655,
      "end": 29.51,
      "type": "line",
      "text": "Wherefore, after my father had made an end of speaking",
      "verse": "4:3",
      "lineIndex": 10
    },
    {
      "start": 29.69,
      "end": 32.151,
      "type": "line",
      "text": "concerning the prophecies of Joseph,",
      "verse": "4:3",
      "lineIndex": 11
    },
    {
      "start": 32.331,
      "end": 34.328,
      "type": "line",
      "text": "he called the children of Laman,",
      "verse": "4:3",
      "lineIndex": 12
    },
    {
      "start": 34.508,
      "end": 36.551,
      "type": "line",
      "text": "his sons, and his daughters,",
      "verse": "4:3",
      "lineIndex": 13
    },
    {
      "start": 36.731,
      "end": 38.356,
      "type": "line",
      "text": "and said unto them:",
      "verse": "4:3",
      "lineIndex": 14
    },
    {
      "start": 38.536,
      "end": 40.719,
      "type": "line",
      "text": "Behold, my sons, and my daughters,",
      "verse": "4:3",
      "lineIndex": 15
    },
    {
      "start": 40.899,
      "end": 44.661,
      "type": "line",
      "text": "who are the sons and the daughters of my firstborn,",
      "verse": "4:3",
      "lineIndex": 16
    },
    {
      "start": 44.841,
      "end": 47.906,
      "type": "line",
      "text": "I would that ye should give ear unto my words.",
      "verse": "4:3",
      "lineIndex": 17
    },
    {
      "start": 48.586,
      "end": 50.815,
      "type": "line",
      "text": "For the Lord God hath said that:",
      "verse": "4:4",
      "lineIndex": 18
    },
    {
      "start": 50.995,
      "end": 53.735,
      "type": "line",
      "text": "Inasmuch as ye shall keep my commandments",
      "verse": "4:4",
      "lineIndex": 19
    },
    {
      "start": 53.915,
      "end": 55.773,
      "type": "line",
      "text": "ye shall prosper in the land;",
      "verse": "4:4",
      "lineIndex": 20
    },
    {
      "start": 55.953,
      "end": 59.018,
      "type": "line",
      "text": "and inasmuch as ye will not keep my commandments",
      "verse": "4:4",
      "lineIndex": 21
    },
    {
      "start": 59.198,
      "end": 61.474,
      "type": "line",
      "text": "ye shall be cut off from my presence.",
      "verse": "4:4",
      "lineIndex": 22
    },
    {
      "start": 62.154,
      "end": 64.708,
      "type": "line",
      "text": "But behold, my sons and my daughters,",
      "verse": "4:5",
      "lineIndex": 24
    },
    {
      "start": 64.888,
      "end": 66.978,
      "type": "line",
      "text": "I cannot go down to my grave",
      "verse": "4:5",
      "lineIndex": 25
    },
    {
      "start": 67.158,
      "end": 69.526,
      "type": "line",
      "text": "save I should leave a blessing upon you;",
      "verse": "4:5",
      "lineIndex": 26
    },
    {
      "start": 69.706,
      "end": 73.746,
      "type": "line",
      "text": "for behold, I know that if ye are brought up in the way ye should go",
      "verse": "4:5",
      "lineIndex": 27
    },
    {
      "start": 73.926,
      "end": 75.691,
      "type": "line",
      "text": "ye will not depart from it.",
      "verse": "4:5",
      "lineIndex": 28
    },
    {
      "start": 76.371,
      "end": 78.182,
      "type": "line",
      "text": "Wherefore, if ye are cursed,",
      "verse": "4:6",
      "lineIndex": 29
    },
    {
      "start": 78.362,
      "end": 81.102,
      "type": "line",
      "text": "behold, I leave my blessing upon you,",
      "verse": "4:6",
      "lineIndex": 30
    },
    {
      "start": 81.282,
      "end": 83.558,
      "type": "line",
      "text": "that the cursing may be taken from you",
      "verse": "4:6",
      "lineIndex": 31
    },
    {
      "start": 83.738,
      "end": 86.896,
      "type": "line",
      "text": "and be answered upon the heads of your parents.",
      "verse": "4:6",
      "lineIndex": 32
    },
    {
      "start": 87.576,
      "end": 89.526,
      "type": "line",
      "text": "Wherefore, because of my blessing",
      "verse": "4:7",
      "lineIndex": 33
    },
    {
      "start": 89.706,
      "end": 92.864,
      "type": "line",
      "text": "the Lord God will not suffer that ye shall perish;",
      "verse": "4:7",
      "lineIndex": 34
    },
    {
      "start": 93.044,
      "end": 95.877,
      "type": "line",
      "text": "wherefore, he will be merciful unto you",
      "verse": "4:7",
      "lineIndex": 35
    },
    {
      "start": 96.057,
      "end": 98.007,
      "type": "line",
      "text": "and unto your seed forever.",
      "verse": "4:7",
      "lineIndex": 36
    },
    {
      "start": 98.687,
      "end": 103.006,
      "type": "line",
      "text": "And it came to pass that after my father had made an end of speaking",
      "verse": "4:8",
      "lineIndex": 37
    },
    {
      "start": 103.186,
      "end": 105.833,
      "type": "line",
      "text": "to the sons and daughters of Laman,",
      "verse": "4:8",
      "lineIndex": 38
    },
    {
      "start": 106.013,
      "end": 110.1,
      "type": "line",
      "text": "he caused the sons and daughters of Lemuel to be brought before him.",
      "verse": "4:8",
      "lineIndex": 39
    },
    {
      "start": 110.78,
      "end": 112.916,
      "type": "line",
      "text": "And he spake unto them, saying:",
      "verse": "4:9",
      "lineIndex": 40
    },
    {
      "start": 113.096,
      "end": 115.279,
      "type": "line",
      "text": "Behold, my sons and my daughters,",
      "verse": "4:9",
      "lineIndex": 41
    },
    {
      "start": 115.459,
      "end": 118.896,
      "type": "line",
      "text": "who are the sons and the daughters of my second son;",
      "verse": "4:9",
      "lineIndex": 42
    },
    {
      "start": 119.076,
      "end": 121.584,
      "type": "line",
      "text": "behold I leave unto you the same blessing",
      "verse": "4:9",
      "lineIndex": 43
    },
    {
      "start": 121.764,
      "end": 125.061,
      "type": "line",
      "text": "which I left unto the sons and daughters of Laman;",
      "verse": "4:9",
      "lineIndex": 44
    },
    {
      "start": 125.241,
      "end": 128.91,
      "type": "line",
      "text": "wherefore, thou shalt not utterly be destroyed;",
      "verse": "4:9",
      "lineIndex": 45
    },
    {
      "start": 129.09,
      "end": 131.551,
      "type": "line",
      "text": "but in the end thy seed shall be blessed.",
      "verse": "4:9",
      "lineIndex": 46
    },
    {
      "start": 132.231,
      "end": 136.782,
      "type": "line",
      "text": "And it came to pass that when my father had made an end of speaking unto them,",
      "verse": "4:10",
      "lineIndex": 47
    },
    {
      "start": 136.962,
      "end": 139.702,
      "type": "line",
      "text": "behold, he spake unto the sons of Ishmael,",
      "verse": "4:10",
      "lineIndex": 48
    },
    {
      "start": 139.882,
      "end": 141.832,
      "type": "line",
      "text": "yea, and even all his household.",
      "verse": "4:10",
      "lineIndex": 49
    },
    {
      "start": 142.512,
      "end": 145.67,
      "type": "line",
      "text": "And after he had made an end of speaking unto them,",
      "verse": "4:11",
      "lineIndex": 50
    },
    {
      "start": 145.85,
      "end": 147.615,
      "type": "line",
      "text": "he spake unto Sam, saying:",
      "verse": "4:11",
      "lineIndex": 51
    },
    {
      "start": 147.795,
      "end": 150.489,
      "type": "line",
      "text": "Blessed art thou, and thy seed;",
      "verse": "4:11",
      "lineIndex": 52
    },
    {
      "start": 150.669,
      "end": 154.709,
      "type": "line",
      "text": "for thou shalt inherit the land like unto thy brother Nephi.",
      "verse": "4:11",
      "lineIndex": 53
    },
    {
      "start": 154.889,
      "end": 157.768,
      "type": "line",
      "text": "And thy seed shall be numbered with his seed;",
      "verse": "4:11",
      "lineIndex": 54
    },
    {
      "start": 157.948,
      "end": 160.827,
      "type": "line",
      "text": "and thou shalt be even like unto thy brother,",
      "verse": "4:11",
      "lineIndex": 55
    },
    {
      "start": 161.007,
      "end": 163.422,
      "type": "line",
      "text": "and thy seed like unto his seed;",
      "verse": "4:11",
      "lineIndex": 56
    },
    {
      "start": 163.602,
      "end": 166.203,
      "type": "line",
      "text": "and thou shalt be blessed in all thy days.",
      "verse": "4:11",
      "lineIndex": 57
    },
    {
      "start": 166.883,
      "end": 171.341,
      "type": "line",
      "text": "And it came to pass after my father, Lehi, had spoken unto all his household,",
      "verse": "4:12",
      "lineIndex": 58
    },
    {
      "start": 171.521,
      "end": 176.165,
      "type": "line",
      "text": "according to the feelings of his heart and the Spirit of the Lord which was in him,",
      "verse": "4:12",
      "lineIndex": 59
    },
    {
      "start": 176.345,
      "end": 180.339,
      "type": "line",
      "text": "he waxed old. And it came to pass that he died, and was buried.",
      "verse": "4:12",
      "lineIndex": 60
    },
    {
      "start": 181.019,
      "end": 184.781,
      "type": "line",
      "text": "And it came to pass that not many days after his death,",
      "verse": "4:13",
      "lineIndex": 61
    },
    {
      "start": 184.961,
      "end": 186.679,
      "type": "line",
      "text": "Laman and Lemuel",
      "verse": "4:13",
      "lineIndex": 62
    },
    {
      "start": 186.859,
      "end": 189.46,
      "type": "line",
      "text": "and the sons of Ishmael were angry with me",
      "verse": "4:13",
      "lineIndex": 63
    },
    {
      "start": 189.64,
      "end": 192.008,
      "type": "line",
      "text": "because of the admonitions of the Lord.",
      "verse": "4:13",
      "lineIndex": 64
    },
    {
      "start": 192.688,
      "end": 195.799,
      "type": "line",
      "text": "For I, Nephi, was constrained to speak unto them,",
      "verse": "4:14",
      "lineIndex": 65
    },
    {
      "start": 195.979,
      "end": 197.465,
      "type": "line",
      "text": "according to his word;",
      "verse": "4:14",
      "lineIndex": 66
    },
    {
      "start": 197.645,
      "end": 200.153,
      "type": "line",
      "text": "for I had spoken many things unto them,",
      "verse": "4:14",
      "lineIndex": 67
    },
    {
      "start": 200.333,
      "end": 202.701,
      "type": "line",
      "text": "and also my father, before his death;",
      "verse": "4:14",
      "lineIndex": 68
    },
    {
      "start": 202.881,
      "end": 206.132,
      "type": "line",
      "text": "many of which sayings are written upon mine other plates;",
      "verse": "4:14",
      "lineIndex": 69
    },
    {
      "start": 206.312,
      "end": 210.213,
      "type": "line",
      "text": "for a more history part are written upon mine other plates.",
      "verse": "4:14",
      "lineIndex": 70
    },
    {
      "start": 210.893,
      "end": 213.865,
      "type": "line",
      "text": "And upon these I write the things of my soul,",
      "verse": "4:15",
      "lineIndex": 72
    },
    {
      "start": 214.045,
      "end": 215.81,
      "type": "line",
      "text": "and many of the scriptures",
      "verse": "4:15",
      "lineIndex": 73
    },
    {
      "start": 215.99,
      "end": 218.591,
      "type": "line",
      "text": "which are engraven upon the plates of brass.",
      "verse": "4:15",
      "lineIndex": 74
    },
    {
      "start": 218.771,
      "end": 221.232,
      "type": "line",
      "text": "For my soul delighteth in the scriptures,",
      "verse": "4:15",
      "lineIndex": 75
    },
    {
      "start": 221.412,
      "end": 223.595,
      "type": "line",
      "text": "and my heart pondereth them,",
      "verse": "4:15",
      "lineIndex": 76
    },
    {
      "start": 223.775,
      "end": 227.49,
      "type": "line",
      "text": "and writeth them for the learning and the profit of my children.",
      "verse": "4:15",
      "lineIndex": 77
    },
    {
      "start": 228.17,
      "end": 231.328,
      "type": "line",
      "text": "Behold, my soul delighteth in the things of the Lord;",
      "verse": "4:16",
      "lineIndex": 78
    },
    {
      "start": 231.508,
      "end": 234.712,
      "type": "line",
      "text": "and my heart pondereth continually upon the things",
      "verse": "4:16",
      "lineIndex": 79
    },
    {
      "start": 234.892,
      "end": 236.657,
      "type": "line",
      "text": "which I have seen and heard.",
      "verse": "4:16",
      "lineIndex": 80
    },
    {
      "start": 237.337,
      "end": 240.866,
      "type": "line",
      "text": "Nevertheless, notwithstanding the great goodness of the Lord,",
      "verse": "4:17",
      "lineIndex": 81
    },
    {
      "start": 241.046,
      "end": 243.693,
      "type": "line",
      "text": "in showing me his great and marvelous works,",
      "verse": "4:17",
      "lineIndex": 82
    },
    {
      "start": 243.873,
      "end": 245.638,
      "type": "line",
      "text": "my heart exclaimeth:",
      "verse": "4:17",
      "lineIndex": 83
    },
    {
      "start": 245.818,
      "end": 247.536,
      "type": "line",
      "text": "O wretched man that I am!",
      "verse": "4:17",
      "lineIndex": 84
    },
    {
      "start": 247.716,
      "end": 250.502,
      "type": "line",
      "text": "Yea, my heart sorroweth because of my flesh;",
      "verse": "4:17",
      "lineIndex": 85
    },
    {
      "start": 250.682,
      "end": 253.468,
      "type": "line",
      "text": "my soul grieveth because of mine iniquities.",
      "verse": "4:17",
      "lineIndex": 86
    },
    {
      "start": 254.148,
      "end": 256.006,
      "type": "line",
      "text": "I am encompassed about,",
      "verse": "4:18",
      "lineIndex": 87
    },
    {
      "start": 256.186,
      "end": 258.787,
      "type": "line",
      "text": "because of the temptations and the sins",
      "verse": "4:18",
      "lineIndex": 88
    },
    {
      "start": 258.967,
      "end": 261.243,
      "type": "line",
      "text": "which do so easily beset me.",
      "verse": "4:18",
      "lineIndex": 89
    },
    {
      "start": 261.923,
      "end": 263.966,
      "type": "line",
      "text": "And when I desire to rejoice,",
      "verse": "4:19",
      "lineIndex": 90
    },
    {
      "start": 264.146,
      "end": 266.654,
      "type": "line",
      "text": "my heart groaneth because of my sins;",
      "verse": "4:19",
      "lineIndex": 91
    },
    {
      "start": 266.834,
      "end": 269.62,
      "type": "line",
      "text": "nevertheless, I know in whom I have trusted.",
      "verse": "4:19",
      "lineIndex": 92
    },
    {
      "start": 270.3,
      "end": 272.343,
      "type": "line",
      "text": "My God hath been my support;",
      "verse": "4:20",
      "lineIndex": 93
    },
    {
      "start": 272.523,
      "end": 274.009,
      "type": "line",
      "text": "he hath led me",
      "verse": "4:20",
      "lineIndex": 94
    },
    {
      "start": 274.189,
      "end": 276.836,
      "type": "line",
      "text": "through mine afflictions in the wilderness;",
      "verse": "4:20",
      "lineIndex": 95
    },
    {
      "start": 277.016,
      "end": 278.734,
      "type": "line",
      "text": "and he hath preserved me",
      "verse": "4:20",
      "lineIndex": 96
    },
    {
      "start": 278.914,
      "end": 281.7,
      "type": "line",
      "text": "upon the waters of the great deep.",
      "verse": "4:20",
      "lineIndex": 97
    },
    {
      "start": 282.38,
      "end": 284.423,
      "type": "line",
      "text": "He hath filled me with his love,",
      "verse": "4:21",
      "lineIndex": 98
    },
    {
      "start": 284.603,
      "end": 287.111,
      "type": "line",
      "text": "even unto the consuming of my flesh.",
      "verse": "4:21",
      "lineIndex": 99
    },
    {
      "start": 287.791,
      "end": 290.067,
      "type": "line",
      "text": "He hath confounded mine enemies,",
      "verse": "4:22",
      "lineIndex": 100
    },
    {
      "start": 290.247,
      "end": 292.662,
      "type": "line",
      "text": "unto the causing of them to quake before me.",
      "verse": "4:22",
      "lineIndex": 101
    },
    {
      "start": 293.342,
      "end": 295.85,
      "type": "line",
      "text": "Behold, he hath heard my cry by day,",
      "verse": "4:23",
      "lineIndex": 102
    },
    {
      "start": 296.03,
      "end": 297.841,
      "type": "line",
      "text": "and he hath given me knowledge",
      "verse": "4:23",
      "lineIndex": 103
    },
    {
      "start": 298.021,
      "end": 300.157,
      "type": "line",
      "text": "by visions in the night-time.",
      "verse": "4:23",
      "lineIndex": 104
    },
    {
      "start": 300.837,
      "end": 302.834,
      "type": "line",
      "text": "And by day have I waxed bold",
      "verse": "4:24",
      "lineIndex": 105
    },
    {
      "start": 303.014,
      "end": 305.197,
      "type": "line",
      "text": "in mighty prayer before him;",
      "verse": "4:24",
      "lineIndex": 106
    },
    {
      "start": 305.377,
      "end": 307.885,
      "type": "line",
      "text": "yea, my voice have I sent up on high;",
      "verse": "4:24",
      "lineIndex": 107
    },
    {
      "start": 308.065,
      "end": 310.759,
      "type": "line",
      "text": "and angels came down and ministered unto me.",
      "verse": "4:24",
      "lineIndex": 108
    },
    {
      "start": 311.439,
      "end": 313.529,
      "type": "line",
      "text": "And upon the wings of his Spirit",
      "verse": "4:25",
      "lineIndex": 110
    },
    {
      "start": 313.709,
      "end": 315.845,
      "type": "line",
      "text": "hath my body been carried away",
      "verse": "4:25",
      "lineIndex": 111
    },
    {
      "start": 316.025,
      "end": 317.975,
      "type": "line",
      "text": "upon exceedingly high mountains.",
      "verse": "4:25",
      "lineIndex": 112
    },
    {
      "start": 318.155,
      "end": 320.802,
      "type": "line",
      "text": "And mine eyes have beheld great things,",
      "verse": "4:25",
      "lineIndex": 113
    },
    {
      "start": 320.982,
      "end": 323.072,
      "type": "line",
      "text": "yea, even too great for man;",
      "verse": "4:25",
      "lineIndex": 114
    },
    {
      "start": 323.252,
      "end": 326.967,
      "type": "line",
      "text": "therefore I was bidden that I should not write them.",
      "verse": "4:25",
      "lineIndex": 115
    },
    {
      "start": 327.647,
      "end": 330.201,
      "type": "line",
      "text": "O then, if I have seen so great things,",
      "verse": "4:26",
      "lineIndex": 116
    },
    {
      "start": 330.381,
      "end": 333.771,
      "type": "line",
      "text": "if the Lord in his condescension unto the children of men",
      "verse": "4:26",
      "lineIndex": 117
    },
    {
      "start": 333.951,
      "end": 336.459,
      "type": "line",
      "text": "hath visited men in so much mercy,",
      "verse": "4:26",
      "lineIndex": 118
    },
    {
      "start": 336.639,
      "end": 338.264,
      "type": "line",
      "text": "why should my heart weep",
      "verse": "4:26",
      "lineIndex": 119
    },
    {
      "start": 338.444,
      "end": 341.138,
      "type": "line",
      "text": "and my soul linger in the valley of sorrow,",
      "verse": "4:26",
      "lineIndex": 120
    },
    {
      "start": 341.318,
      "end": 342.99,
      "type": "line",
      "text": "and my flesh waste away,",
      "verse": "4:26",
      "lineIndex": 121
    },
    {
      "start": 343.17,
      "end": 345.074,
      "type": "line",
      "text": "and my strength slacken,",
      "verse": "4:26",
      "lineIndex": 122
    },
    {
      "start": 345.254,
      "end": 346.926,
      "type": "line",
      "text": "because of mine afflictions?",
      "verse": "4:26",
      "lineIndex": 123
    },
    {
      "start": 347.606,
      "end": 349.789,
      "type": "line",
      "text": "And why should I yield to sin,",
      "verse": "4:27",
      "lineIndex": 124
    },
    {
      "start": 349.969,
      "end": 351.641,
      "type": "line",
      "text": "because of my flesh?",
      "verse": "4:27",
      "lineIndex": 125
    },
    {
      "start": 351.821,
      "end": 354.7,
      "type": "line",
      "text": "Yea, why should I give way to temptations,",
      "verse": "4:27",
      "lineIndex": 126
    },
    {
      "start": 354.88,
      "end": 357.666,
      "type": "line",
      "text": "that the evil one have place in my heart",
      "verse": "4:27",
      "lineIndex": 127
    },
    {
      "start": 357.846,
      "end": 360.4,
      "type": "line",
      "text": "to destroy my peace and afflict my soul?",
      "verse": "4:27",
      "lineIndex": 128
    },
    {
      "start": 360.58,
      "end": 362.948,
      "type": "line",
      "text": "Why am I angry because of mine enemy?",
      "verse": "4:27",
      "lineIndex": 129
    },
    {
      "start": 363.628,
      "end": 365.021,
      "type": "line",
      "text": "Awake, my soul!",
      "verse": "4:28",
      "lineIndex": 130
    },
    {
      "start": 365.201,
      "end": 366.873,
      "type": "line",
      "text": "No longer droop in sin.",
      "verse": "4:28",
      "lineIndex": 131
    },
    {
      "start": 367.053,
      "end": 368.678,
      "type": "line",
      "text": "Rejoice, O my heart,",
      "verse": "4:28",
      "lineIndex": 132
    },
    {
      "start": 368.858,
      "end": 371.923,
      "type": "line",
      "text": "and give place no more for the enemy of my soul.",
      "verse": "4:28",
      "lineIndex": 133
    },
    {
      "start": 372.603,
      "end": 374.182,
      "type": "line",
      "text": "Do not anger again",
      "verse": "4:29",
      "lineIndex": 134
    },
    {
      "start": 374.362,
      "end": 376.08,
      "type": "line",
      "text": "because of mine enemies.",
      "verse": "4:29",
      "lineIndex": 135
    },
    {
      "start": 376.26,
      "end": 378.071,
      "type": "line",
      "text": "Do not slacken my strength",
      "verse": "4:29",
      "lineIndex": 136
    },
    {
      "start": 378.251,
      "end": 380.294,
      "type": "line",
      "text": "because of mine afflictions.",
      "verse": "4:29",
      "lineIndex": 137
    },
    {
      "start": 380.974,
      "end": 382.599,
      "type": "line",
      "text": "Rejoice, O my heart,",
      "verse": "4:30",
      "lineIndex": 138
    },
    {
      "start": 382.779,
      "end": 384.59,
      "type": "line",
      "text": "and cry unto the Lord, and say:",
      "verse": "4:30",
      "lineIndex": 139
    },
    {
      "start": 384.77,
      "end": 386.999,
      "type": "line",
      "text": "O Lord, I will praise thee forever;",
      "verse": "4:30",
      "lineIndex": 140
    },
    {
      "start": 387.179,
      "end": 389.362,
      "type": "line",
      "text": "yea, my soul will rejoice in thee,",
      "verse": "4:30",
      "lineIndex": 141
    },
    {
      "start": 389.542,
      "end": 392.236,
      "type": "line",
      "text": "my God, and the rock of my salvation.",
      "verse": "4:30",
      "lineIndex": 142
    },
    {
      "start": 392.916,
      "end": 393.845,
      "type": "line",
      "text": "O Lord,",
      "verse": "4:31",
      "lineIndex": 143
    },
    {
      "start": 394.025,
      "end": 395.836,
      "type": "line",
      "text": "wilt thou redeem my soul?",
      "verse": "4:31",
      "lineIndex": 144
    },
    {
      "start": 396.016,
      "end": 399.174,
      "type": "line",
      "text": "Wilt thou deliver me out of the hands of mine enemies?",
      "verse": "4:31",
      "lineIndex": 145
    },
    {
      "start": 399.354,
      "end": 403.069,
      "type": "line",
      "text": "Wilt thou make me that I may shake at the appearance of sin?",
      "verse": "4:31",
      "lineIndex": 146
    },
    {
      "start": 403.749,
      "end": 405.56,
      "type": "line",
      "text": "May the gates of hell",
      "verse": "4:32",
      "lineIndex": 147
    },
    {
      "start": 405.74,
      "end": 407.83,
      "type": "line",
      "text": "be shut continually before me,",
      "verse": "4:32",
      "lineIndex": 148
    },
    {
      "start": 408.01,
      "end": 410.193,
      "type": "line",
      "text": "because that my heart is broken",
      "verse": "4:32",
      "lineIndex": 149
    },
    {
      "start": 410.373,
      "end": 412.045,
      "type": "line",
      "text": "and my spirit is contrite!",
      "verse": "4:32",
      "lineIndex": 150
    },
    {
      "start": 412.225,
      "end": 414.268,
      "type": "line",
      "text": "O Lord, wilt thou not shut",
      "verse": "4:32",
      "lineIndex": 151
    },
    {
      "start": 414.448,
      "end": 417.188,
      "type": "line",
      "text": "the gates of thy righteousness before me,",
      "verse": "4:32",
      "lineIndex": 152
    },
    {
      "start": 417.368,
      "end": 420.34,
      "type": "line",
      "text": "that I may walk in the path of the low valley,",
      "verse": "4:32",
      "lineIndex": 153
    },
    {
      "start": 420.52,
      "end": 422.749,
      "type": "line",
      "text": "that I may be strict in the plain road!",
      "verse": "4:32",
      "lineIndex": 154
    },
    {
      "start": 423.429,
      "end": 424.358,
      "type": "line",
      "text": "O Lord,",
      "verse": "4:33",
      "lineIndex": 155
    },
    {
      "start": 424.538,
      "end": 426.581,
      "type": "line",
      "text": "wilt thou encircle me around",
      "verse": "4:33",
      "lineIndex": 156
    },
    {
      "start": 426.761,
      "end": 428.758,
      "type": "line",
      "text": "in the robe of thy righteousness!",
      "verse": "4:33",
      "lineIndex": 157
    },
    {
      "start": 428.938,
      "end": 429.867,
      "type": "line",
      "text": "O Lord,",
      "verse": "4:33",
      "lineIndex": 158
    },
    {
      "start": 430.047,
      "end": 433.53,
      "type": "line",
      "text": "wilt thou make a way for mine escape before mine enemies!",
      "verse": "4:33",
      "lineIndex": 159
    },
    {
      "start": 433.71,
      "end": 436.264,
      "type": "line",
      "text": "Wilt thou make my path straight before me!",
      "verse": "4:33",
      "lineIndex": 160
    },
    {
      "start": 436.444,
      "end": 439.138,
      "type": "line",
      "text": "Wilt thou not place a stumbling block in my way\u2014",
      "verse": "4:33",
      "lineIndex": 161
    },
    {
      "start": 439.318,
      "end": 442.151,
      "type": "line",
      "text": "but that thou wouldst clear my way before me,",
      "verse": "4:33",
      "lineIndex": 162
    },
    {
      "start": 442.331,
      "end": 445.675,
      "type": "line",
      "text": "and hedge not up my way, but the ways of mine enemy.",
      "verse": "4:33",
      "lineIndex": 163
    },
    {
      "start": 446.355,
      "end": 447.284,
      "type": "line",
      "text": "O Lord,",
      "verse": "4:34",
      "lineIndex": 164
    },
    {
      "start": 447.464,
      "end": 448.997,
      "type": "line",
      "text": "I have trusted in thee,",
      "verse": "4:34",
      "lineIndex": 165
    },
    {
      "start": 449.177,
      "end": 451.36,
      "type": "line",
      "text": "and I will trust in thee forever.",
      "verse": "4:34",
      "lineIndex": 166
    },
    {
      "start": 451.54,
      "end": 454.512,
      "type": "line",
      "text": "I will not put my trust in the arm of flesh;",
      "verse": "4:34",
      "lineIndex": 167
    },
    {
      "start": 454.692,
      "end": 456.782,
      "type": "line",
      "text": "for I know that cursed is he",
      "verse": "4:34",
      "lineIndex": 168
    },
    {
      "start": 456.962,
      "end": 459.563,
      "type": "line",
      "text": "that putteth his trust in the arm of flesh.",
      "verse": "4:34",
      "lineIndex": 169
    },
    {
      "start": 459.743,
      "end": 462.669,
      "type": "line",
      "text": "Yea, cursed is he that putteth his trust in man",
      "verse": "4:34",
      "lineIndex": 170
    },
    {
      "start": 462.849,
      "end": 464.799,
      "type": "line",
      "text": "or maketh flesh his arm.",
      "verse": "4:34",
      "lineIndex": 171
    },
    {
      "start": 465.479,
      "end": 468.683,
      "type": "line",
      "text": "Yea, I know that God will give liberally to him that asketh.",
      "verse": "4:35",
      "lineIndex": 172
    },
    {
      "start": 468.863,
      "end": 470.396,
      "type": "line",
      "text": "Yea, my God will give me,",
      "verse": "4:35",
      "lineIndex": 173
    },
    {
      "start": 470.576,
      "end": 472.109,
      "type": "line",
      "text": "if I ask not amiss;",
      "verse": "4:35",
      "lineIndex": 174
    },
    {
      "start": 472.289,
      "end": 474.983,
      "type": "line",
      "text": "therefore I will lift up my voice unto thee;",
      "verse": "4:35",
      "lineIndex": 175
    },
    {
      "start": 475.163,
      "end": 477.16,
      "type": "line",
      "text": "yea, I will cry unto thee,",
      "verse": "4:35",
      "lineIndex": 176
    },
    {
      "start": 477.34,
      "end": 479.616,
      "type": "line",
      "text": "my God, the rock of my righteousness.",
      "verse": "4:35",
      "lineIndex": 177
    },
    {
      "start": 479.796,
      "end": 483.047,
      "type": "line",
      "text": "Behold, my voice shall forever ascend up unto thee,",
      "verse": "4:35",
      "lineIndex": 178
    },
    {
      "start": 483.227,
      "end": 485.735,
      "type": "line",
      "text": "my rock and mine everlasting God.",
      "verse": "4:35",
      "lineIndex": 179
    },
    {
      "start": 485.915,
      "end": 486.844,
      "type": "line",
      "text": "Amen.",
      "verse": "4:35",
      "lineIndex": 180
    }
  ]
}