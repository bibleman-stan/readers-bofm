    "verse_ms": 500
  },
  "duration": 718.641,
  "lines": [
    {
      "start": 0.0,
      "end": 1.44,
      "type": "line",
      "text": "Hearken unto me,",
      "verse": "8:1",
      "lineIndex": 1
    },
    {
      "start": 1.62,
      "end": 4.035,
      "type": "line",
      "text": "ye that follow after righteousness.",
      "verse": "8:1",
      "lineIndex": 2
    },
    {
      "start": 4.215,
      "end": 7.234,
      "type": "line",
      "text": "Look unto the rock from whence ye are hewn,",
      "verse": "8:1",
      "lineIndex": 3
    },
    {
      "start": 7.414,
      "end": 10.897,
      "type": "line",
      "text": "and to the hole of the pit from whence ye are digged.",
      "verse": "8:1",
      "lineIndex": 4
    },
    {
      "start": 11.077,
      "end": 23.941,
      "type": "line",
      "text": "Hearken to unto me, ye that follow after righteousness. ye that seek the Lord: Look unto the rock from whence ye are hewn, and to the hole of the pit from whence ye are digged.",
      "verse": "8:1",
      "lineIndex": 5
    },
    {
      "start": 24.621,
      "end": 27.407,
      "type": "line",
      "text": "Look unto Abraham, your father,",
      "verse": "8:2",
      "lineIndex": 6
    },
    {
      "start": 27.587,
      "end": 30.327,
      "type": "line",
      "text": "and unto Sarah, she that bare you;",
      "verse": "8:2",
      "lineIndex": 7
    },
    {
      "start": 30.507,
      "end": 33.386,
      "type": "line",
      "text": "for I called him alone, and blessed him.",
      "verse": "8:2",
      "lineIndex": 8
    },
    {
      "start": 33.566,
      "end": 43.086,
      "type": "line",
      "text": "Look unto Abraham, your father, and unto Sarah, she that bare you; for I called him alone, and blessed him. and increased him.",
      "verse": "8:2",
      "lineIndex": 9
    },
    {
      "start": 43.766,
      "end": 45.949,
      "type": "line",
      "text": "For the Lord shall comfort Zion,",
      "verse": "8:3",
      "lineIndex": 10
    },
    {
      "start": 46.129,
      "end": 48.915,
      "type": "line",
      "text": "he will comfort all her waste places;",
      "verse": "8:3",
      "lineIndex": 11
    },
    {
      "start": 49.095,
      "end": 52.439,
      "type": "line",
      "text": "and he will make her wilderness like Eden,",
      "verse": "8:3",
      "lineIndex": 12
    },
    {
      "start": 52.619,
      "end": 55.545,
      "type": "line",
      "text": "and her desert like the garden of the Lord.",
      "verse": "8:3",
      "lineIndex": 13
    },
    {
      "start": 55.725,
      "end": 58.697,
      "type": "line",
      "text": "Joy and gladness shall be found therein,",
      "verse": "8:3",
      "lineIndex": 14
    },
    {
      "start": 58.877,
      "end": 61.571,
      "type": "line",
      "text": "thanksgiving and the voice of melody.",
      "verse": "8:3",
      "lineIndex": 15
    },
    {
      "start": 61.751,
      "end": 80.095,
      "type": "line",
      "text": "For the Lord shall comfort Zion, he will comfort all her waste places; and he will make her wilderness like Eden, and her desert like the garden of the Lord. Joy and gladness shall be found therein, thanksgiving and the voice of melody.",
      "verse": "8:3",
      "lineIndex": 16
    },
    {
      "start": 80.775,
      "end": 82.725,
      "type": "line",
      "text": "Hearken unto me, my people;",
      "verse": "8:4",
      "lineIndex": 18
    },
    {
      "start": 82.905,
      "end": 85.831,
      "type": "line",
      "text": "and give ear unto me, O my nation;",
      "verse": "8:4",
      "lineIndex": 19
    },
    {
      "start": 86.011,
      "end": 88.24,
      "type": "line",
      "text": "for a law shall proceed from me,",
      "verse": "8:4",
      "lineIndex": 20
    },
    {
      "start": 88.42,
      "end": 92.925,
      "type": "line",
      "text": "and I will make my judgment to rest for a light for the people.",
      "verse": "8:4",
      "lineIndex": 21
    },
    {
      "start": 93.105,
      "end": 104.947,
      "type": "line",
      "text": "Hearken unto me, my people; and give ear unto me, O my nation; for a law shall proceed from me, and I will make my judgment to rest for a light of for the people.",
      "verse": "8:4",
      "lineIndex": 22
    },
    {
      "start": 105.627,
      "end": 107.577,
      "type": "line",
      "text": "My righteousness is near;",
      "verse": "8:5",
      "lineIndex": 23
    },
    {
      "start": 107.757,
      "end": 110.079,
      "type": "line",
      "text": "my salvation is gone forth,",
      "verse": "8:5",
      "lineIndex": 24
    },
    {
      "start": 110.259,
      "end": 113.37,
      "type": "line",
      "text": "and mine arm shall judge the people.",
      "verse": "8:5",
      "lineIndex": 25
    },
    {
      "start": 113.55,
      "end": 115.779,
      "type": "line",
      "text": "The isles shall wait upon me,",
      "verse": "8:5",
      "lineIndex": 26
    },
    {
      "start": 115.959,
      "end": 118.745,
      "type": "line",
      "text": "and on mine arm shall they trust.",
      "verse": "8:5",
      "lineIndex": 27
    },
    {
      "start": 118.925,
      "end": 130.535,
      "type": "line",
      "text": "My righteousness is near; my salvation is gone forth, and mine arms arm shall judge the people. The isles shall wait upon me, and on mine arm shall they trust.",
      "verse": "8:5",
      "lineIndex": 28
    },
    {
      "start": 131.215,
      "end": 133.491,
      "type": "line",
      "text": "Lift up your eyes to the heavens,",
      "verse": "8:6",
      "lineIndex": 29
    },
    {
      "start": 133.671,
      "end": 136.225,
      "type": "line",
      "text": "and look upon the earth beneath;",
      "verse": "8:6",
      "lineIndex": 30
    },
    {
      "start": 136.405,
      "end": 139.424,
      "type": "line",
      "text": "for the heavens shall vanish away like smoke,",
      "verse": "8:6",
      "lineIndex": 31
    },
    {
      "start": 139.604,
      "end": 142.623,
      "type": "line",
      "text": "and the earth shall wax old like a garment;",
      "verse": "8:6",
      "lineIndex": 32
    },
    {
      "start": 142.803,
      "end": 146.936,
      "type": "line",
      "text": "and they that dwell therein shall die in like manner.",
      "verse": "8:6",
      "lineIndex": 33
    },
    {
      "start": 147.116,
      "end": 149.81,
      "type": "line",
      "text": "But my salvation shall be forever,",
      "verse": "8:6",
      "lineIndex": 34
    },
    {
      "start": 149.99,
      "end": 153.101,
      "type": "line",
      "text": "and my righteousness shall not be abolished.",
      "verse": "8:6",
      "lineIndex": 35
    },
    {
      "start": 153.281,
      "end": 174.55,
      "type": "line",
      "text": "Lift up your eyes to the heavens, and look upon the earth beneath; for the heavens shall vanish away like smoke, and the earth shall wax old like a garment; and they that dwell therein shall die in like manner. But my salvation shall be for ever, forever, and my righteousness shall not be abolished.",
      "verse": "8:6",
      "lineIndex": 36
    },
    {
      "start": 175.23,
      "end": 178.62,
      "type": "line",
      "text": "Hearken unto me, ye that know righteousness,",
      "verse": "8:7",
      "lineIndex": 37
    },
    {
      "start": 178.8,
      "end": 181.726,
      "type": "line",
      "text": "the people in whose heart I have written my law,",
      "verse": "8:7",
      "lineIndex": 38
    },
    {
      "start": 181.906,
      "end": 184.321,
      "type": "line",
      "text": "fear ye not the reproach of men,",
      "verse": "8:7",
      "lineIndex": 39
    },
    {
      "start": 184.501,
      "end": 186.823,
      "type": "line",
      "text": "neither be ye afraid of their revilings.",
      "verse": "8:7",
      "lineIndex": 40
    },
    {
      "start": 187.003,
      "end": 200.145,
      "type": "line",
      "text": "Hearken unto me, ye that know righteousness, the people in whose heart is I have written my law, fear ye not the reproach of men, neither be ye afraid of their revilings.",
      "verse": "8:7",
      "lineIndex": 41
    },
    {
      "start": 200.825,
      "end": 203.983,
      "type": "line",
      "text": "For the moth shall eat them up like a garment,",
      "verse": "8:8",
      "lineIndex": 42
    },
    {
      "start": 204.163,
      "end": 206.857,
      "type": "line",
      "text": "and the worm shall eat them like wool.",
      "verse": "8:8",
      "lineIndex": 43
    },
    {
      "start": 207.037,
      "end": 209.823,
      "type": "line",
      "text": "But my righteousness shall be forever,",
      "verse": "8:8",
      "lineIndex": 44
    },
    {
      "start": 210.003,
      "end": 213.718,
      "type": "line",
      "text": "and my salvation from generation to generation.",
      "verse": "8:8",
      "lineIndex": 45
    },
    {
      "start": 213.898,
      "end": 226.994,
      "type": "line",
      "text": "For the moth shall eat them up like a garment, and the worm shall eat them like wool. But my righteousness shall be for ever, forever, and my salvation from generation to generation.",
      "verse": "8:8",
      "lineIndex": 46
    },
    {
      "start": 227.674,
      "end": 229.532,
      "type": "line",
      "text": "Awake, awake!",
      "verse": "8:9",
      "lineIndex": 48
    },
    {
      "start": 229.712,
      "end": 231.012,
      "type": "line",
      "text": "Put on strength,",
      "verse": "8:9",
      "lineIndex": 49
    },
    {
      "start": 231.192,
      "end": 232.678,
      "type": "line",
      "text": "O arm of the Lord;",
      "verse": "8:9",
      "lineIndex": 50
    },
    {
      "start": 232.858,
      "end": 235.273,
      "type": "line",
      "text": "awake as in the ancient days.",
      "verse": "8:9",
      "lineIndex": 51
    },
    {
      "start": 235.453,
      "end": 238.007,
      "type": "line",
      "text": "Art thou not he that hath cut Rahab,",
      "verse": "8:9",
      "lineIndex": 52
    },
    {
      "start": 238.187,
      "end": 240.137,
      "type": "line",
      "text": "and wounded the dragon?",
      "verse": "8:9",
      "lineIndex": 53
    },
    {
      "start": 240.317,
      "end": 256.942,
      "type": "line",
      "text": "Awake, awake! Put on strength, O arm of the Lord; awake as in the ancient days. in the generations of old. Art thou not it he that hath cut Rahab, and wounded the dragon?",
      "verse": "8:9",
      "lineIndex": 54
    },
    {
      "start": 257.622,
      "end": 260.362,
      "type": "line",
      "text": "Art thou not he who hath dried the sea,",
      "verse": "8:10",
      "lineIndex": 55
    },
    {
      "start": 260.542,
      "end": 262.91,
      "type": "line",
      "text": "the waters of the great deep;",
      "verse": "8:10",
      "lineIndex": 56
    },
    {
      "start": 263.09,
      "end": 266.062,
      "type": "line",
      "text": "that hath made the depths of the sea a way",
      "verse": "8:10",
      "lineIndex": 57
    },
    {
      "start": 266.242,
      "end": 268.146,
      "type": "line",
      "text": "for the ransomed to pass over?",
      "verse": "8:10",
      "lineIndex": 58
    },
    {
      "start": 268.326,
      "end": 278.961,
      "type": "line",
      "text": "Art thou not it which he who hath dried the sea, the waters of the great deep; that hath made the depths of the sea a way for the ransomed to pass over?",
      "verse": "8:10",
      "lineIndex": 59
    },
    {
      "start": 279.641,
      "end": 282.845,
      "type": "line",
      "text": "Therefore, the redeemed of the Lord shall return,",
      "verse": "8:11",
      "lineIndex": 60
    },
    {
      "start": 283.025,
      "end": 285.579,
      "type": "line",
      "text": "and come with singing unto Zion;",
      "verse": "8:11",
      "lineIndex": 61
    },
    {
      "start": 285.759,
      "end": 290.775,
      "type": "line",
      "text": "and everlasting joy and holiness shall be upon their heads;",
      "verse": "8:11",
      "lineIndex": 62
    },
    {
      "start": 290.955,
      "end": 293.788,
      "type": "line",
      "text": "and they shall obtain gladness and joy;",
      "verse": "8:11",
      "lineIndex": 63
    },
    {
      "start": 293.968,
      "end": 296.615,
      "type": "line",
      "text": "sorrow and mourning shall flee away.",
      "verse": "8:11",
      "lineIndex": 64
    },
    {
      "start": 296.795,
      "end": 314.256,
      "type": "line",
      "text": "Therefore, the redeemed of the Lord shall return, and come with singing unto Zion; and everlasting joy and holiness shall be upon their head: heads; and they shall obtain gladness and joy; and sorrow and mourning shall flee away.",
      "verse": "8:11",
      "lineIndex": 65
    },
    {
      "start": 314.936,
      "end": 316.051,
      "type": "line",
      "text": "I am he;",
      "verse": "8:12",
      "lineIndex": 66
    },
    {
      "start": 316.231,
      "end": 318.832,
      "type": "line",
      "text": "yea, I am he that comforteth you.",
      "verse": "8:12",
      "lineIndex": 67
    },
    {
      "start": 319.012,
      "end": 321.334,
      "type": "line",
      "text": "Behold, who art thou,",
      "verse": "8:12",
      "lineIndex": 68
    },
    {
      "start": 321.514,
      "end": 323.929,
      "type": "line",
      "text": "that thou shouldst be afraid of man,",
      "verse": "8:12",
      "lineIndex": 69
    },
    {
      "start": 324.109,
      "end": 325.363,
      "type": "line",
      "text": "who shall die,",
      "verse": "8:12",
      "lineIndex": 70
    },
    {
      "start": 325.543,
      "end": 327.168,
      "type": "line",
      "text": "and of the son of man,",
      "verse": "8:12",
      "lineIndex": 71
    },
    {
      "start": 327.348,
      "end": 330.088,
      "type": "line",
      "text": "who shall be made like unto grass?",
      "verse": "8:12",
      "lineIndex": 72
    },
    {
      "start": 330.268,
      "end": 347.219,
      "type": "line",
      "text": "I even am he; yea, I am he that comforteth you. Behold, who art thou, that thou shouldest shouldst be afraid of a man, that who shall die, and of the son of man, which who shall be made as like unto grass?",
      "verse": "8:12",
      "lineIndex": 73
    },
    {
      "start": 347.899,
      "end": 350.453,
      "type": "line",
      "text": "And forgettest the Lord thy maker,",
      "verse": "8:13",
      "lineIndex": 74
    },
    {
      "start": 350.633,
      "end": 353.094,
      "type": "line",
      "text": "that hath stretched forth the heavens,",
      "verse": "8:13",
      "lineIndex": 75
    },
    {
      "start": 353.274,
      "end": 356.153,
      "type": "line",
      "text": "and laid the foundations of the earth,",
      "verse": "8:13",
      "lineIndex": 76
    },
    {
      "start": 356.333,
      "end": 359.491,
      "type": "line",
      "text": "and hast feared continually every day,",
      "verse": "8:13",
      "lineIndex": 77
    },
    {
      "start": 359.671,
      "end": 361.9,
      "type": "line",
      "text": "because of the fury of the oppressor,",
      "verse": "8:13",
      "lineIndex": 78
    },
    {
      "start": 362.08,
      "end": 364.309,
      "type": "line",
      "text": "as if he were ready to destroy?",
      "verse": "8:13",
      "lineIndex": 79
    },
    {
      "start": 364.489,
      "end": 367.415,
      "type": "line",
      "text": "And where is the fury of the oppressor?",
      "verse": "8:13",
      "lineIndex": 80
    },
    {
      "start": 367.595,
      "end": 384.824,
      "type": "line",
      "text": "And forgettest the Lord thy maker, that hath stretched forth the heavens, and laid the foundations of the earth, and hast feared continually every day, because of the fury of the oppressor, as if he were ready to destroy? And where is the fury of the oppressor?",
      "verse": "8:13",
      "lineIndex": 81
    },
    {
      "start": 385.504,
      "end": 389.126,
      "type": "line",
      "text": "The captive exile hasteneth, that he may be loosed,",
      "verse": "8:14",
      "lineIndex": 82
    },
    {
      "start": 389.306,
      "end": 392.139,
      "type": "line",
      "text": "and that he should not die in the pit,",
      "verse": "8:14",
      "lineIndex": 83
    },
    {
      "start": 392.319,
      "end": 394.316,
      "type": "line",
      "text": "nor that his bread should fail.",
      "verse": "8:14",
      "lineIndex": 84
    },
    {
      "start": 394.496,
      "end": 403.923,
      "type": "line",
      "text": "The captive exile hasteneth, that he may be loosed, and that he should not die in the pit, nor that his bread should fail.",
      "verse": "8:14",
      "lineIndex": 85
    },
    {
      "start": 404.603,
      "end": 406.879,
      "type": "line",
      "text": "But I am the Lord thy God,",
      "verse": "8:15",
      "lineIndex": 86
    },
    {
      "start": 407.059,
      "end": 408.684,
      "type": "line",
      "text": "whose waves roared;",
      "verse": "8:15",
      "lineIndex": 87
    },
    {
      "start": 408.864,
      "end": 411.558,
      "type": "line",
      "text": "the Lord of Hosts is my name.",
      "verse": "8:15",
      "lineIndex": 88
    },
    {
      "start": 411.738,
      "end": 419.679,
      "type": "line",
      "text": "But I am the Lord thy God, that divided the sea, whose waves roared; the Lord of Hosts is his my name.",
      "verse": "8:15",
      "lineIndex": 89
    },
    {
      "start": 420.359,
      "end": 423.378,
      "type": "line",
      "text": "And I have put my words in thy mouth,",
      "verse": "8:16",
      "lineIndex": 90
    },
    {
      "start": 423.558,
      "end": 427.32,
      "type": "line",
      "text": "and have covered thee in the shadow of mine hand,",
      "verse": "8:16",
      "lineIndex": 91
    },
    {
      "start": 427.5,
      "end": 429.776,
      "type": "line",
      "text": "that I may plant the heavens",
      "verse": "8:16",
      "lineIndex": 92
    },
    {
      "start": 429.956,
      "end": 432.928,
      "type": "line",
      "text": "and lay the foundations of the earth,",
      "verse": "8:16",
      "lineIndex": 93
    },
    {
      "start": 433.108,
      "end": 434.966,
      "type": "line",
      "text": "and say unto Zion:",
      "verse": "8:16",
      "lineIndex": 94
    },
    {
      "start": 435.146,
      "end": 438.675,
      "type": "line",
      "text": "Behold, thou art my people.",
      "verse": "8:16",
      "lineIndex": 95
    },
    {
      "start": 438.855,
      "end": 456.781,
      "type": "line",
      "text": "And I have put my words in thy mouth, and I have covered thee in the shadow of mine hand, that I may plant the heavens and lay the foundations of the earth, and say unto Zion: Behold, thou art my people.",
      "verse": "8:16",
      "lineIndex": 96
    },
    {
      "start": 457.461,
      "end": 462.662,
      "type": "line",
      "text": "Awake, awake,",
      "verse": "8:17",
      "lineIndex": 98
    },
    {
      "start": 462.842,
      "end": 463.957,
      "type": "line",
      "text": "stand up,",
      "verse": "8:17",
      "lineIndex": 99
    },
    {
      "start": 464.137,
      "end": 465.205,
      "type": "line",
      "text": "O Jerusalem,",
      "verse": "8:17",
      "lineIndex": 100
    },
    {
      "start": 465.385,
      "end": 469.379,
      "type": "line",
      "text": "which hast drunk at the hand of the Lord the cup of his fury\u2014",
      "verse": "8:17",
      "lineIndex": 101
    },
    {
      "start": 469.559,
      "end": 477.547,
      "type": "line",
      "text": "thou hast drunken the dregs of the cup of trembling wrung out\u2014",
      "verse": "8:17",
      "lineIndex": 102
    },
    {
      "start": 477.727,
      "end": 492.727,
      "type": "line",
      "text": "Awake, awake, stand up, O Jerusalem, which hast drunk at the hand of the Lord the cup of his fury; thou fury--thou hast drunken the dregs of the cup of trembling and wrung them out--",
      "verse": "8:17",
      "lineIndex": 103
    },
    {
      "start": 493.407,
      "end": 495.032,
      "type": "line",
      "text": "And none to guide her",
      "verse": "8:18",
      "lineIndex": 104
    },
    {
      "start": 495.212,
      "end": 498.37,
      "type": "line",
      "text": "among all the sons she hath brought forth;",
      "verse": "8:18",
      "lineIndex": 105
    },
    {
      "start": 498.55,
      "end": 501.151,
      "type": "line",
      "text": "neither that taketh her by the hand,",
      "verse": "8:18",
      "lineIndex": 106
    },
    {
      "start": 501.331,
      "end": 504.35,
      "type": "line",
      "text": "of all the sons she hath brought up.",
      "verse": "8:18",
      "lineIndex": 107
    },
    {
      "start": 504.53,
      "end": 515.861,
      "type": "line",
      "text": "There is And none to guide her among all the sons whom she hath brought forth; neither is there any that taketh her by the hand, of all the sons that she hath brought up.",
      "verse": "8:18",
      "lineIndex": 108
    },
    {
      "start": 516.541,
      "end": 518.956,
      "type": "line",
      "text": "These two sons are come unto thee,",
      "verse": "8:19",
      "lineIndex": 109
    },
    {
      "start": 519.136,
      "end": 523.78,
      "type": "line",
      "text": "who shall be sorry for thee\u2014",
      "verse": "8:19",
      "lineIndex": 110
    },
    {
      "start": 523.96,
      "end": 526.282,
      "type": "line",
      "text": "thy desolation and destruction,",
      "verse": "8:19",
      "lineIndex": 111
    },
    {
      "start": 526.462,
      "end": 534.264,
      "type": "line",
      "text": "and the famine and the sword\u2014",
      "verse": "8:19",
      "lineIndex": 112
    },
    {
      "start": 534.444,
      "end": 536.72,
      "type": "line",
      "text": "and by whom shall I comfort thee?",
      "verse": "8:19",
      "lineIndex": 113
    },
    {
      "start": 536.9,
      "end": 549.532,
      "type": "line",
      "text": "These two things sons are come unto thee, who shall be sorry for thee? thee--thy desolation and destruction, and the famine and the sword: sword--and by whom shall I comfort thee?",
      "verse": "8:19",
      "lineIndex": 114
    },
    {
      "start": 550.212,
      "end": 552.952,
      "type": "line",
      "text": "Thy sons have fainted, save these two;",
      "verse": "8:20",
      "lineIndex": 115
    },
    {
      "start": 553.132,
      "end": 556.058,
      "type": "line",
      "text": "they lie at the head of all the streets;",
      "verse": "8:20",
      "lineIndex": 116
    },
    {
      "start": 556.238,
      "end": 558.188,
      "type": "line",
      "text": "as a wild bull in a net,",
      "verse": "8:20",
      "lineIndex": 117
    },
    {
      "start": 558.368,
      "end": 560.783,
      "type": "line",
      "text": "they are full of the fury of the Lord,",
      "verse": "8:20",
      "lineIndex": 118
    },
    {
      "start": 560.963,
      "end": 562.588,
      "type": "line",
      "text": "the rebuke of thy God.",
      "verse": "8:20",
      "lineIndex": 119
    },
    {
      "start": 562.768,
      "end": 575.91,
      "type": "line",
      "text": "Thy sons have fainted, save these two; they lie at the head of all the streets; as a wild bull in a net, they are full of the fury of the Lord, the rebuke of thy God.",
      "verse": "8:20",
      "lineIndex": 120
    },
    {
      "start": 576.59,
      "end": 578.401,
      "type": "line",
      "text": "Therefore hear now this,",
      "verse": "8:21",
      "lineIndex": 121
    },
    {
      "start": 578.581,
      "end": 582.482,
      "type": "line",
      "text": "thou afflicted, and drunken, and not with wine:",
      "verse": "8:21",
      "lineIndex": 122
    },
    {
      "start": 582.662,
      "end": 588.606,
      "type": "line",
      "text": "Therefore hear now this, thou afflicted, and drunken, but and not with wine:",
      "verse": "8:21",
      "lineIndex": 123
    },
    {
      "start": 589.286,
      "end": 591.515,
      "type": "line",
      "text": "Thus saith thy Lord, the Lord",
      "verse": "8:22",
      "lineIndex": 124
    },
    {
      "start": 591.695,
      "end": 595.596,
      "type": "line",
      "text": "and thy God pleadeth the cause of his people;",
      "verse": "8:22",
      "lineIndex": 125
    },
    {
      "start": 595.776,
      "end": 600.652,
      "type": "line",
      "text": "behold, I have taken out of thine hand the cup of trembling,",
      "verse": "8:22",
      "lineIndex": 126
    },
    {
      "start": 600.832,
      "end": 603.154,
      "type": "line",
      "text": "the dregs of the cup of my fury;",
      "verse": "8:22",
      "lineIndex": 127
    },
    {
      "start": 603.334,
      "end": 605.61,
      "type": "line",
      "text": "thou shalt no more drink it again.",
      "verse": "8:22",
      "lineIndex": 128
    },
    {
      "start": 605.79,
      "end": 621.022,
      "type": "line",
      "text": "Thus saith thy Lord, the Lord and thy God that pleadeth the cause of his people; behold, I have taken out of thine hand the cup of trembling, even the dregs of the cup of my fury; thou shalt no more drink it again.",
      "verse": "8:22",
      "lineIndex": 129
    },
    {
      "start": 621.702,
      "end": 625.742,
      "type": "line",
      "text": "But I will put it into the hand of them that afflict thee;",
      "verse": "8:23",
      "lineIndex": 130
    },
    {
      "start": 625.922,
      "end": 627.733,
      "type": "line",
      "text": "who have said to thy soul:",
      "verse": "8:23",
      "lineIndex": 131
    },
    {
      "start": 627.913,
      "end": 634.229,
      "type": "line",
      "text": "Bow down, that we may go over\u2014",
      "verse": "8:23",
      "lineIndex": 132
    },
    {
      "start": 634.409,
      "end": 637.938,
      "type": "line",
      "text": "and thou hast laid thy body as the ground",
      "verse": "8:23",
      "lineIndex": 133
    },
    {
      "start": 638.118,
      "end": 640.951,
      "type": "line",
      "text": "and as the street to them that went over.",
      "verse": "8:23",
      "lineIndex": 134
    },
    {
      "start": 641.131,
      "end": 656.642,
      "type": "line",
      "text": "But I will put it into the hand of them that afflict thee; which who have said to thy soul: Bow down, that we may go over: and over--and thou hast laid thy body as the ground and as the street to them that went over.",
      "verse": "8:23",
      "lineIndex": 135
    },
    {
      "start": 657.322,
      "end": 662.523,
      "type": "line",
      "text": "Awake, awake,",
      "verse": "8:24",
      "lineIndex": 137
    },
    {
      "start": 662.703,
      "end": 664.236,
      "type": "line",
      "text": "put on thy strength,",
      "verse": "8:24",
      "lineIndex": 138
    },
    {
      "start": 664.416,
      "end": 665.438,
      "type": "line",
      "text": "O Zion;",
      "verse": "8:24",
      "lineIndex": 139
    },
    {
      "start": 665.618,
      "end": 667.801,
      "type": "line",
      "text": "put on thy beautiful garments,",
      "verse": "8:24",
      "lineIndex": 140
    },
    {
      "start": 667.981,
      "end": 670.396,
      "type": "line",
      "text": "O Jerusalem, the holy city;",
      "verse": "8:24",
      "lineIndex": 141
    },
    {
      "start": 670.576,
      "end": 674.291,
      "type": "line",
      "text": "for henceforth there shall no more come into thee",
      "verse": "8:24",
      "lineIndex": 142
    },
    {
      "start": 674.471,
      "end": 677.536,
      "type": "line",
      "text": "the uncircumcised and the unclean.",
      "verse": "8:24",
      "lineIndex": 143
    },
    {
      "start": 677.716,
      "end": 694.295,
      "type": "line",
      "text": "Awake, awake, put on thy strength, O Zion; put on thy beautiful garments, O Jerusalem, the holy city; for henceforth there shall no more come into thee the uncircumcised and the unclean.",
      "verse": "8:24",
      "lineIndex": 144
    },
    {
      "start": 694.975,
      "end": 697.065,
      "type": "line",
      "text": "Shake thyself from the dust;",
      "verse": "8:25",
      "lineIndex": 145
    },
    {
      "start": 697.245,
      "end": 699.288,
      "type": "line",
      "text": "arise, sit down,",
      "verse": "8:25",
      "lineIndex": 146
    },
    {
      "start": 699.468,
      "end": 700.536,
      "type": "line",
      "text": "O Jerusalem;",
      "verse": "8:25",
      "lineIndex": 147
    },
    {
      "start": 700.716,
      "end": 703.363,
      "type": "line",
      "text": "loose thyself from the bands of thy neck,",
      "verse": "8:25",
      "lineIndex": 148
    },
    {
      "start": 703.543,
      "end": 705.772,
      "type": "line",
      "text": "O captive daughter of Zion.",
      "verse": "8:25",
      "lineIndex": 149
    },
    {
      "start": 705.952,
      "end": 717.98,
      "type": "line",
      "text": "Shake thyself from the dust; arise, and sit down, O Jerusalem; loose thyself from the bands of thy neck, O captive daughter of Zion.",
      "verse": "8:25",
      "lineIndex": 150
    }
  ]
}