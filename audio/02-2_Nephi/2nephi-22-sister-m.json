      "lineIndex": 13
    },
    {
      "start": 50.846,
      "end": 52.982,
      "type": "line",
      "text": "out of the wells of salvation.",
      "verse": "22:3",
      "lineIndex": 14
    },
    {
      "start": 53.162,
      "end": 58.27,
      "type": "line",
      "text": "Therefore, with joy shall ye draw water out of the wells of salvation.",
      "verse": "22:3",
      "lineIndex": 15
    },
    {
      "start": 58.95,
      "end": 61.272,
