{
  "book": "2nephi",
  "chapter": 2,
  "voice": {
    "provider": "elevenlabs",
    "voice_id": "ddDFRErfhdc2asyySOG5",
    "model_id": "eleven_multilingual_v2",
    "settings": {
      "stability": 0.5,
      "similarity_boost": 0.75,
      "style": 0.35,
      "use_speaker_boost": true
    },
    "name": "Samuel"
  },
  "pauses": {
    "line_ms": 180,
    "verse_ms": 500
  },
  "duration": 556.542,
  "lines": [
    {
      "start": 0.0,
      "end": 2.508,
      "type": "line",
      "text": "And now, Jacob, I speak unto you:",
      "verse": "2:1",
      "lineIndex": 1
    },
    {
      "start": 2.688,
      "end": 4.36,
      "type": "line",
      "text": "Thou art my firstborn",
      "verse": "2:1",
      "lineIndex": 2
    },
    {
      "start": 4.54,
      "end": 7.419,
      "type": "line",
      "text": "in the days of my tribulation in the wilderness.",
      "verse": "2:1",
      "lineIndex": 3
    },
    {
      "start": 7.599,
      "end": 9.549,
      "type": "line",
      "text": "And behold, in thy childhood",
      "verse": "2:1",
      "lineIndex": 4
    },
    {
      "start": 9.729,
      "end": 13.166,
      "type": "line",
      "text": "thou hast suffered afflictions and much sorrow,",
      "verse": "2:1",
      "lineIndex": 5
    },
    {
      "start": 13.346,
      "end": 15.668,
      "type": "line",
      "text": "because of the rudeness of thy brethren.",
      "verse": "2:1",
      "lineIndex": 6
    },
    {
      "start": 16.348,
      "end": 19.506,
      "type": "line",
      "text": "Nevertheless, Jacob, my firstborn in the wilderness,",
      "verse": "2:2",
      "lineIndex": 7
    },
    {
      "start": 19.686,
      "end": 21.915,
      "type": "line",
      "text": "thou knowest the greatness of God;",
      "verse": "2:2",
      "lineIndex": 8
    },
    {
      "start": 22.095,
      "end": 25.439,
      "type": "line",
      "text": "and he shall consecrate thine afflictions for thy gain.",
      "verse": "2:2",
      "lineIndex": 9
    },
    {
      "start": 26.119,
      "end": 28.487,
      "type": "line",
      "text": "Wherefore, thy soul shall be blessed,",
      "verse": "2:3",
      "lineIndex": 11
    },
    {
      "start": 28.667,
      "end": 32.011,
      "type": "line",
      "text": "and thou shalt dwell safely with thy brother, Nephi;",
      "verse": "2:3",
      "lineIndex": 12
    },
    {
      "start": 32.191,
      "end": 35.674,
      "type": "line",
      "text": "and thy days shall be spent in the service of thy God.",
      "verse": "2:3",
      "lineIndex": 13
    },
    {
      "start": 35.854,
      "end": 38.64,
      "type": "line",
      "text": "Wherefore, I know that thou art redeemed,",
      "verse": "2:3",
      "lineIndex": 14
    },
    {
      "start": 38.82,
      "end": 41.514,
      "type": "line",
      "text": "because of the righteousness of thy Redeemer;",
      "verse": "2:3",
      "lineIndex": 15
    },
    {
      "start": 41.694,
      "end": 44.62,
      "type": "line",
      "text": "for thou hast beheld that in the fulness of time",
      "verse": "2:3",
      "lineIndex": 16
    },
    {
      "start": 44.8,
      "end": 47.354,
      "type": "line",
      "text": "he cometh to bring salvation unto men.",
      "verse": "2:3",
      "lineIndex": 17
    },
    {
      "start": 48.034,
      "end": 50.635,
      "type": "line",
      "text": "And thou hast beheld in thy youth his glory;",
      "verse": "2:4",
      "lineIndex": 18
    },
    {
      "start": 50.815,
      "end": 55.97,
      "type": "line",
      "text": "wherefore, thou art blessed even as they unto whom he shall minister in the flesh;",
      "verse": "2:4",
      "lineIndex": 19
    },
    {
      "start": 56.15,
      "end": 59.726,
      "type": "line",
      "text": "for the Spirit is the same, yesterday, today, and forever.",
      "verse": "2:4",
      "lineIndex": 20
    },
    {
      "start": 59.906,
      "end": 62.646,
      "type": "line",
      "text": "And the way is prepared from the fall of man,",
      "verse": "2:4",
      "lineIndex": 21
    },
    {
      "start": 62.826,
      "end": 64.266,
      "type": "line",
      "text": "and salvation is free.",
      "verse": "2:4",
      "lineIndex": 22
    },
    {
      "start": 64.946,
      "end": 68.801,
      "type": "line",
      "text": "And men are instructed sufficiently that they know good from evil.",
      "verse": "2:5",
      "lineIndex": 24
    },
    {
      "start": 68.981,
      "end": 70.978,
      "type": "line",
      "text": "And the law is given unto men.",
      "verse": "2:5",
      "lineIndex": 25
    },
    {
      "start": 71.158,
      "end": 73.666,
      "type": "line",
      "text": "And by the law no flesh is justified;",
      "verse": "2:5",
      "lineIndex": 26
    },
    {
      "start": 73.846,
      "end": 76.075,
      "type": "line",
      "text": "or, by the law men are cut off.",
      "verse": "2:5",
      "lineIndex": 27
    },
    {
      "start": 76.255,
      "end": 78.577,
      "type": "line",
      "text": "Yea, by the temporal law they were cut off;",
      "verse": "2:5",
      "lineIndex": 28
    },
    {
      "start": 78.757,
      "end": 83.215,
      "type": "line",
      "text": "and also, by the spiritual law they perish from that which is good,",
      "verse": "2:5",
      "lineIndex": 29
    },
    {
      "start": 83.395,
      "end": 85.392,
      "type": "line",
      "text": "and become miserable forever.",
      "verse": "2:5",
      "lineIndex": 30
    },
    {
      "start": 86.072,
      "end": 90.112,
      "type": "line",
      "text": "Wherefore, redemption cometh in and through the Holy Messiah;",
      "verse": "2:6",
      "lineIndex": 32
    },
    {
      "start": 90.292,
      "end": 92.707,
      "type": "line",
      "text": "for he is full of grace and truth.",
      "verse": "2:6",
      "lineIndex": 33
    },
    {
      "start": 93.387,
      "end": 96.731,
      "type": "line",
      "text": "Behold, he offereth himself a sacrifice for sin,",
      "verse": "2:7",
      "lineIndex": 34
    },
    {
      "start": 96.911,
      "end": 99.233,
      "type": "line",
      "text": "to answer the ends of the law,",
      "verse": "2:7",
      "lineIndex": 35
    },
    {
      "start": 99.413,
      "end": 101.874,
      "type": "line",
      "text": "unto all those who have a broken heart",
      "verse": "2:7",
      "lineIndex": 36
    },
    {
      "start": 102.054,
      "end": 103.679,
      "type": "line",
      "text": "and a contrite spirit;",
      "verse": "2:7",
      "lineIndex": 37
    },
    {
      "start": 103.859,
      "end": 107.063,
      "type": "line",
      "text": "and unto none else can the ends of the law be answered.",
      "verse": "2:7",
      "lineIndex": 38
    },
    {
      "start": 107.743,
      "end": 109.833,
      "type": "line",
      "text": "Wherefore, how great the importance",
      "verse": "2:8",
      "lineIndex": 39
    },
    {
      "start": 110.013,
      "end": 114.564,
      "type": "line",
      "text": "to make these things known unto the inhabitants of the earth,",
      "verse": "2:8",
      "lineIndex": 40
    },
    {
      "start": 114.744,
      "end": 117.577,
      "type": "line",
      "text": "that they may know that there is no flesh",
      "verse": "2:8",
      "lineIndex": 41
    },
    {
      "start": 117.757,
      "end": 120.358,
      "type": "line",
      "text": "that can dwell in the presence of God,",
      "verse": "2:8",
      "lineIndex": 42
    },
    {
      "start": 120.538,
      "end": 122.628,
      "type": "line",
      "text": "save it be through the merits,",
      "verse": "2:8",
      "lineIndex": 43
    },
    {
      "start": 122.808,
      "end": 124.015,
      "type": "line",
      "text": "and mercy,",
      "verse": "2:8",
      "lineIndex": 44
    },
    {
      "start": 124.195,
      "end": 125.263,
      "type": "line",
      "text": "and grace",
      "verse": "2:8",
      "lineIndex": 45
    },
    {
      "start": 125.443,
      "end": 126.929,
      "type": "line",
      "text": "of the Holy Messiah,",
      "verse": "2:8",
      "lineIndex": 46
    },
    {
      "start": 127.109,
      "end": 130.22,
      "type": "line",
      "text": "who layeth down his life according to the flesh,",
      "verse": "2:8",
      "lineIndex": 47
    },
    {
      "start": 130.4,
      "end": 133.279,
      "type": "line",
      "text": "and taketh it again by the power of the Spirit,",
      "verse": "2:8",
      "lineIndex": 48
    },
    {
      "start": 133.459,
      "end": 136.756,
      "type": "line",
      "text": "that he may bring to pass the resurrection of the dead,",
      "verse": "2:8",
      "lineIndex": 49
    },
    {
      "start": 136.936,
      "end": 139.072,
      "type": "line",
      "text": "being the first that should rise.",
      "verse": "2:8",
      "lineIndex": 50
    },
    {
      "start": 139.752,
      "end": 142.492,
      "type": "line",
      "text": "Wherefore, he is the firstfruits unto God,",
      "verse": "2:9",
      "lineIndex": 51
    },
    {
      "start": 142.672,
      "end": 146.898,
      "type": "line",
      "text": "inasmuch as he shall make intercession for all the children of men;",
      "verse": "2:9",
      "lineIndex": 52
    },
    {
      "start": 147.078,
      "end": 149.493,
      "type": "line",
      "text": "and they that believe in him shall be saved.",
      "verse": "2:9",
      "lineIndex": 53
    },
    {
      "start": 150.173,
      "end": 152.588,
      "type": "line",
      "text": "And because of the intercession for all,",
      "verse": "2:10",
      "lineIndex": 54
    },
    {
      "start": 152.768,
      "end": 154.626,
      "type": "line",
      "text": "all men come unto God;",
      "verse": "2:10",
      "lineIndex": 55
    },
    {
      "start": 154.806,
      "end": 158.057,
      "type": "line",
      "text": "wherefore, they stand in the presence of him,",
      "verse": "2:10",
      "lineIndex": 56
    },
    {
      "start": 158.237,
      "end": 159.909,
      "type": "line",
      "text": "to be judged of him",
      "verse": "2:10",
      "lineIndex": 57
    },
    {
      "start": 160.089,
      "end": 163.061,
      "type": "line",
      "text": "according to the truth and holiness which is in him.",
      "verse": "2:10",
      "lineIndex": 58
    },
    {
      "start": 163.241,
      "end": 166.956,
      "type": "line",
      "text": "Wherefore, the ends of the law which the Holy One hath given,",
      "verse": "2:10",
      "lineIndex": 59
    },
    {
      "start": 167.136,
      "end": 170.712,
      "type": "line",
      "text": "unto the inflicting of the punishment which is affixed,",
      "verse": "2:10",
      "lineIndex": 60
    },
    {
      "start": 170.892,
      "end": 173.26,
      "type": "line",
      "text": "which punishment that is affixed",
      "verse": "2:10",
      "lineIndex": 61
    },
    {
      "start": 173.44,
      "end": 174.88,
      "type": "line",
      "text": "is in opposition",
      "verse": "2:10",
      "lineIndex": 62
    },
    {
      "start": 175.06,
      "end": 177.754,
      "type": "line",
      "text": "to that of the happiness which is affixed,",
      "verse": "2:10",
      "lineIndex": 63
    },
    {
      "start": 177.934,
      "end": 180.07,
      "type": "line",
      "text": "to answer the ends of the atonement\u2014",
      "verse": "2:10",
      "lineIndex": 64
    },
    {
      "start": 180.75,
      "end": 182.375,
      "type": "line",
      "text": "For it must needs be,",
      "verse": "2:11",
      "lineIndex": 66
    },
    {
      "start": 182.555,
      "end": 185.109,
      "type": "line",
      "text": "that there is an opposition in all things.",
      "verse": "2:11",
      "lineIndex": 67
    },
    {
      "start": 185.289,
      "end": 186.45,
      "type": "line",
      "text": "If not so,",
      "verse": "2:11",
      "lineIndex": 68
    },
    {
      "start": 186.63,
      "end": 188.952,
      "type": "line",
      "text": "my firstborn in the wilderness,",
      "verse": "2:11",
      "lineIndex": 69
    },
    {
      "start": 189.132,
      "end": 191.454,
      "type": "line",
      "text": "righteousness could not be brought to pass,",
      "verse": "2:11",
      "lineIndex": 70
    },
    {
      "start": 191.634,
      "end": 193.167,
      "type": "line",
      "text": "neither wickedness,",
      "verse": "2:11",
      "lineIndex": 71
    },
    {
      "start": 193.347,
      "end": 195.344,
      "type": "line",
      "text": "neither holiness nor misery,",
      "verse": "2:11",
      "lineIndex": 72
    },
    {
      "start": 195.524,
      "end": 197.149,
      "type": "line",
      "text": "neither good nor bad.",
      "verse": "2:11",
      "lineIndex": 73
    },
    {
      "start": 197.329,
      "end": 200.58,
      "type": "line",
      "text": "Wherefore, all things must needs be a compound in one;",
      "verse": "2:11",
      "lineIndex": 74
    },
    {
      "start": 200.76,
      "end": 203.036,
      "type": "line",
      "text": "wherefore, if it should be one body",
      "verse": "2:11",
      "lineIndex": 75
    },
    {
      "start": 203.216,
      "end": 205.584,
      "type": "line",
      "text": "it must needs remain as dead,",
      "verse": "2:11",
      "lineIndex": 76
    },
    {
      "start": 205.764,
      "end": 207.668,
      "type": "line",
      "text": "having no life neither death,",
      "verse": "2:11",
      "lineIndex": 77
    },
    {
      "start": 207.848,
      "end": 210.077,
      "type": "line",
      "text": "nor corruption nor incorruption,",
      "verse": "2:11",
      "lineIndex": 78
    },
    {
      "start": 210.257,
      "end": 212.068,
      "type": "line",
      "text": "happiness nor misery,",
      "verse": "2:11",
      "lineIndex": 79
    },
    {
      "start": 212.248,
      "end": 214.477,
      "type": "line",
      "text": "neither sense nor insensibility.",
      "verse": "2:11",
      "lineIndex": 80
    },
    {
      "start": 215.157,
      "end": 219.894,
      "type": "line",
      "text": "Wherefore, it must needs have been created for a thing of naught;",
      "verse": "2:12",
      "lineIndex": 81
    },
    {
      "start": 220.074,
      "end": 224.068,
      "type": "line",
      "text": "wherefore there would have been no purpose in the end of its creation.",
      "verse": "2:12",
      "lineIndex": 82
    },
    {
      "start": 224.248,
      "end": 228.103,
      "type": "line",
      "text": "Wherefore, this thing must needs destroy the wisdom of God",
      "verse": "2:12",
      "lineIndex": 83
    },
    {
      "start": 228.283,
      "end": 230.094,
      "type": "line",
      "text": "and his eternal purposes,",
      "verse": "2:12",
      "lineIndex": 84
    },
    {
      "start": 230.274,
      "end": 233.478,
      "type": "line",
      "text": "and also the power, and the mercy, and the justice of God.",
      "verse": "2:12",
      "lineIndex": 85
    },
    {
      "start": 234.158,
      "end": 236.526,
      "type": "line",
      "text": "And if ye shall say there is no law,",
      "verse": "2:13",
      "lineIndex": 86
    },
    {
      "start": 236.706,
      "end": 238.935,
      "type": "line",
      "text": "ye shall also say there is no sin.",
      "verse": "2:13",
      "lineIndex": 87
    },
    {
      "start": 239.115,
      "end": 241.391,
      "type": "line",
      "text": "If ye shall say there is no sin,",
      "verse": "2:13",
      "lineIndex": 88
    },
    {
      "start": 241.571,
      "end": 244.218,
      "type": "line",
      "text": "ye shall also say there is no righteousness.",
      "verse": "2:13",
      "lineIndex": 89
    },
    {
      "start": 244.398,
      "end": 246.534,
      "type": "line",
      "text": "And if there be no righteousness",
      "verse": "2:13",
      "lineIndex": 90
    },
    {
      "start": 246.714,
      "end": 248.154,
      "type": "line",
      "text": "there be no happiness.",
      "verse": "2:13",
      "lineIndex": 91
    },
    {
      "start": 248.334,
      "end": 251.26,
      "type": "line",
      "text": "And if there be no righteousness nor happiness",
      "verse": "2:13",
      "lineIndex": 92
    },
    {
      "start": 251.44,
      "end": 253.901,
      "type": "line",
      "text": "there be no punishment nor misery.",
      "verse": "2:13",
      "lineIndex": 93
    },
    {
      "start": 254.081,
      "end": 255.799,
      "type": "line",
      "text": "And if these things are not",
      "verse": "2:13",
      "lineIndex": 94
    },
    {
      "start": 255.979,
      "end": 257.372,
      "type": "line",
      "text": "there is no God.",
      "verse": "2:13",
      "lineIndex": 95
    },
    {
      "start": 257.552,
      "end": 259.363,
      "type": "line",
      "text": "And if there is no God",
      "verse": "2:13",
      "lineIndex": 96
    },
    {
      "start": 259.543,
      "end": 260.704,
      "type": "line",
      "text": "we are not,",
      "verse": "2:13",
      "lineIndex": 97
    },
    {
      "start": 260.884,
      "end": 262.417,
      "type": "line",
      "text": "neither the earth;",
      "verse": "2:13",
      "lineIndex": 98
    },
    {
      "start": 262.597,
      "end": 265.383,
      "type": "line",
      "text": "for there could have been no creation of things,",
      "verse": "2:13",
      "lineIndex": 99
    },
    {
      "start": 265.563,
      "end": 267.978,
      "type": "line",
      "text": "neither to act nor to be acted upon;",
      "verse": "2:13",
      "lineIndex": 100
    },
    {
      "start": 268.158,
      "end": 270.573,
      "type": "line",
      "text": "wherefore, all things must have vanished away.",
      "verse": "2:13",
      "lineIndex": 101
    },
    {
      "start": 271.253,
      "end": 272.739,
      "type": "line",
      "text": "And now, my sons,",
      "verse": "2:14",
      "lineIndex": 103
    },
    {
      "start": 272.919,
      "end": 276.263,
      "type": "line",
      "text": "I speak unto you these things for your profit and learning;",
      "verse": "2:14",
      "lineIndex": 104
    },
    {
      "start": 276.443,
      "end": 277.976,
      "type": "line",
      "text": "for there is a God,",
      "verse": "2:14",
      "lineIndex": 105
    },
    {
      "start": 278.156,
      "end": 280.153,
      "type": "line",
      "text": "and he hath created all things,",
      "verse": "2:14",
      "lineIndex": 106
    },
    {
      "start": 280.333,
      "end": 282.469,
      "type": "line",
      "text": "both the heavens and the earth,",
      "verse": "2:14",
      "lineIndex": 107
    },
    {
      "start": 282.649,
      "end": 284.925,
      "type": "line",
      "text": "and all things that in them are,",
      "verse": "2:14",
      "lineIndex": 108
    },
    {
      "start": 285.105,
      "end": 288.309,
      "type": "line",
      "text": "both things to act and things to be acted upon.",
      "verse": "2:14",
      "lineIndex": 109
    },
    {
      "start": 288.989,
      "end": 292.751,
      "type": "line",
      "text": "And to bring about his eternal purposes in the end of man,",
      "verse": "2:15",
      "lineIndex": 110
    },
    {
      "start": 292.931,
      "end": 295.671,
      "type": "line",
      "text": "after he had created our first parents,",
      "verse": "2:15",
      "lineIndex": 111
    },
    {
      "start": 295.851,
      "end": 297.941,
      "type": "line",
      "text": "and the beasts of the field",
      "verse": "2:15",
      "lineIndex": 112
    },
    {
      "start": 298.121,
      "end": 299.886,
      "type": "line",
      "text": "and the fowls of the air,",
      "verse": "2:15",
      "lineIndex": 113
    },
    {
      "start": 300.066,
      "end": 302.899,
      "type": "line",
      "text": "and in fine, all things which are created,",
      "verse": "2:15",
      "lineIndex": 114
    },
    {
      "start": 303.079,
      "end": 306.144,
      "type": "line",
      "text": "it must needs be that there was an opposition;",
      "verse": "2:15",
      "lineIndex": 115
    },
    {
      "start": 306.324,
      "end": 309.946,
      "type": "line",
      "text": "even the forbidden fruit in opposition to the tree of life;",
      "verse": "2:15",
      "lineIndex": 116
    },
    {
      "start": 310.126,
      "end": 312.82,
      "type": "line",
      "text": "the one being sweet and the other bitter.",
      "verse": "2:15",
      "lineIndex": 117
    },
    {
      "start": 313.5,
      "end": 317.912,
      "type": "line",
      "text": "Wherefore, the Lord God gave unto man that he should act for himself.",
      "verse": "2:16",
      "lineIndex": 119
    },
    {
      "start": 318.092,
      "end": 320.832,
      "type": "line",
      "text": "Wherefore, man could not act for himself",
      "verse": "2:16",
      "lineIndex": 120
    },
    {
      "start": 321.012,
      "end": 325.006,
      "type": "line",
      "text": "save it should be that he was enticed by the one or the other.",
      "verse": "2:16",
      "lineIndex": 121
    },
    {
      "start": 325.686,
      "end": 329.355,
      "type": "line",
      "text": "And I, Lehi, according to the things which I have read,",
      "verse": "2:17",
      "lineIndex": 122
    },
    {
      "start": 329.535,
      "end": 332.182,
      "type": "line",
      "text": "must needs suppose that an angel of God,",
      "verse": "2:17",
      "lineIndex": 123
    },
    {
      "start": 332.362,
      "end": 334.638,
      "type": "line",
      "text": "according to that which is written,",
      "verse": "2:17",
      "lineIndex": 124
    },
    {
      "start": 334.818,
      "end": 336.397,
      "type": "line",
      "text": "had fallen from heaven;",
      "verse": "2:17",
      "lineIndex": 125
    },
    {
      "start": 336.577,
      "end": 338.713,
      "type": "line",
      "text": "wherefore, he became a devil,",
      "verse": "2:17",
      "lineIndex": 126
    },
    {
      "start": 338.893,
      "end": 341.772,
      "type": "line",
      "text": "having sought that which was evil before God.",
      "verse": "2:17",
      "lineIndex": 127
    },
    {
      "start": 342.452,
      "end": 344.728,
      "type": "line",
      "text": "And because he had fallen from heaven,",
      "verse": "2:18",
      "lineIndex": 128
    },
    {
      "start": 344.908,
      "end": 347.323,
      "type": "line",
      "text": "and had become miserable forever,",
      "verse": "2:18",
      "lineIndex": 129
    },
    {
      "start": 347.503,
      "end": 350.104,
      "type": "line",
      "text": "he sought also the misery of all mankind.",
      "verse": "2:18",
      "lineIndex": 130
    },
    {
      "start": 350.284,
      "end": 352.281,
      "type": "line",
      "text": "Wherefore, he said unto Eve,",
      "verse": "2:18",
      "lineIndex": 131
    },
    {
      "start": 352.461,
      "end": 354.551,
      "type": "line",
      "text": "yea, even that old serpent,",
      "verse": "2:18",
      "lineIndex": 132
    },
    {
      "start": 354.731,
      "end": 356.031,
      "type": "line",
      "text": "who is the devil,",
      "verse": "2:18",
      "lineIndex": 133
    },
    {
      "start": 356.211,
      "end": 358.487,
      "type": "line",
      "text": "who is the father of all lies,",
      "verse": "2:18",
      "lineIndex": 134
    },
    {
      "start": 358.667,
      "end": 360.2,
      "type": "line",
      "text": "wherefore he said:",
      "verse": "2:18",
      "lineIndex": 135
    },
    {
      "start": 360.38,
      "end": 363.491,
      "type": "line",
      "text": "Partake of the forbidden fruit, and ye shall not die,",
      "verse": "2:18",
      "lineIndex": 136
    },
    {
      "start": 363.671,
      "end": 365.389,
      "type": "line",
      "text": "but ye shall be as God,",
      "verse": "2:18",
      "lineIndex": 137
    },
    {
      "start": 365.569,
      "end": 367.241,
      "type": "line",
      "text": "knowing good and evil.",
      "verse": "2:18",
      "lineIndex": 138
    },
    {
      "start": 367.921,
      "end": 371.311,
      "type": "line",
      "text": "And after Adam and Eve had partaken of the forbidden fruit",
      "verse": "2:19",
      "lineIndex": 139
    },
    {
      "start": 371.491,
      "end": 374.556,
      "type": "line",
      "text": "they were driven out of the garden of Eden,",
      "verse": "2:19",
      "lineIndex": 140
    },
    {
      "start": 374.736,
      "end": 376.408,
      "type": "line",
      "text": "to till the earth.",
      "verse": "2:19",
      "lineIndex": 141
    },
    {
      "start": 377.088,
      "end": 378.992,
      "type": "line",
      "text": "And they have brought forth children;",
      "verse": "2:20",
      "lineIndex": 142
    },
    {
      "start": 379.172,
      "end": 381.726,
      "type": "line",
      "text": "yea, even the family of all the earth.",
      "verse": "2:20",
      "lineIndex": 143
    },
    {
      "start": 382.406,
      "end": 385.471,
      "type": "line",
      "text": "And the days of the children of men were prolonged,",
      "verse": "2:21",
      "lineIndex": 144
    },
    {
      "start": 385.651,
      "end": 387.416,
      "type": "line",
      "text": "according to the will of God,",
      "verse": "2:21",
      "lineIndex": 145
    },
    {
      "start": 387.596,
      "end": 390.243,
      "type": "line",
      "text": "that they might repent while in the flesh;",
      "verse": "2:21",
      "lineIndex": 146
    },
    {
      "start": 390.423,
      "end": 393.627,
      "type": "line",
      "text": "wherefore, their state became a state of probation,",
      "verse": "2:21",
      "lineIndex": 147
    },
    {
      "start": 393.807,
      "end": 395.757,
      "type": "line",
      "text": "and their time was lengthened,",
      "verse": "2:21",
      "lineIndex": 148
    },
    {
      "start": 395.937,
      "end": 401.185,
      "type": "line",
      "text": "according to the commandments which the Lord God gave unto the children of men.",
      "verse": "2:21",
      "lineIndex": 149
    },
    {
      "start": 401.365,
      "end": 404.755,
      "type": "line",
      "text": "For he gave commandment that all men must repent;",
      "verse": "2:21",
      "lineIndex": 150
    },
    {
      "start": 404.935,
      "end": 407.721,
      "type": "line",
      "text": "for he showed unto all men that they were lost,",
      "verse": "2:21",
      "lineIndex": 151
    },
    {
      "start": 407.901,
      "end": 410.92,
      "type": "line",
      "text": "because of the transgression of their parents.",
      "verse": "2:21",
      "lineIndex": 152
    },
    {
      "start": 411.6,
      "end": 414.851,
      "type": "line",
      "text": "And now, behold, if Adam had not transgressed",
      "verse": "2:22",
      "lineIndex": 154
    },
    {
      "start": 415.031,
      "end": 416.61,
      "type": "line",
      "text": "he would not have fallen,",
      "verse": "2:22",
      "lineIndex": 155
    },
    {
      "start": 416.79,
      "end": 419.901,
      "type": "line",
      "text": "but he would have remained in the garden of Eden.",
      "verse": "2:22",
      "lineIndex": 156
    },
    {
      "start": 420.081,
      "end": 422.682,
      "type": "line",
      "text": "And all things which were created",
      "verse": "2:22",
      "lineIndex": 157
    },
    {
      "start": 422.862,
      "end": 425.045,
      "type": "line",
      "text": "must have remained in the same state",
      "verse": "2:22",
      "lineIndex": 158
    },
    {
      "start": 425.225,
      "end": 427.64,
      "type": "line",
      "text": "in which they were after they were created;",
      "verse": "2:22",
      "lineIndex": 159
    },
    {
      "start": 427.82,
      "end": 431.164,
      "type": "line",
      "text": "and they must have remained forever, and had no end.",
      "verse": "2:22",
      "lineIndex": 160
    },
    {
      "start": 431.844,
      "end": 434.027,
      "type": "line",
      "text": "And they would have had no children;",
      "verse": "2:23",
      "lineIndex": 161
    },
    {
      "start": 434.207,
      "end": 437.829,
      "type": "line",
      "text": "wherefore they would have remained in a state of innocence,",
      "verse": "2:23",
      "lineIndex": 162
    },
    {
      "start": 438.009,
      "end": 440.563,
      "type": "line",
      "text": "having no joy, for they knew no misery;",
      "verse": "2:23",
      "lineIndex": 163
    },
    {
      "start": 440.743,
      "end": 443.251,
      "type": "line",
      "text": "doing no good, for they knew no sin.",
      "verse": "2:23",
      "lineIndex": 164
    },
    {
      "start": 443.931,
      "end": 446.253,
      "type": "line",
      "text": "But behold, all things have been done",
      "verse": "2:24",
      "lineIndex": 165
    },
    {
      "start": 446.433,
      "end": 449.127,
      "type": "line",
      "text": "in the wisdom of him who knoweth all things.",
      "verse": "2:24",
      "lineIndex": 166
    },
    {
      "start": 449.807,
      "end": 451.85,
      "type": "line",
      "text": "Adam fell that men might be;",
      "verse": "2:25",
      "lineIndex": 168
    },
    {
      "start": 452.03,
      "end": 453.377,
      "type": "line",
      "text": "and men are,",
      "verse": "2:25",
      "lineIndex": 169
    },
    {
      "start": 453.557,
      "end": 455.322,
      "type": "line",
      "text": "that they might have joy.",
      "verse": "2:25",
      "lineIndex": 170
    },
    {
      "start": 456.002,
      "end": 459.206,
      "type": "line",
      "text": "And the Messiah cometh in the fulness of time,",
      "verse": "2:26",
      "lineIndex": 171
    },
    {
      "start": 459.386,
      "end": 462.544,
      "type": "line",
      "text": "that he may redeem the children of men from the fall.",
      "verse": "2:26",
      "lineIndex": 172
    },
    {
      "start": 462.724,
      "end": 466.346,
      "type": "line",
      "text": "And because that they are redeemed from the fall",
      "verse": "2:26",
      "lineIndex": 173
    },
    {
      "start": 466.526,
      "end": 468.802,
      "type": "line",
      "text": "they have become free forever,",
      "verse": "2:26",
      "lineIndex": 174
    },
    {
      "start": 468.982,
      "end": 470.886,
      "type": "line",
      "text": "knowing good from evil;",
      "verse": "2:26",
      "lineIndex": 175
    },
    {
      "start": 471.066,
      "end": 474.27,
      "type": "line",
      "text": "to act for themselves and not to be acted upon,",
      "verse": "2:26",
      "lineIndex": 176
    },
    {
      "start": 474.45,
      "end": 476.958,
      "type": "line",
      "text": "save it be by the punishment of the law",
      "verse": "2:26",
      "lineIndex": 177
    },
    {
      "start": 477.138,
      "end": 478.996,
      "type": "line",
      "text": "at the great and last day,",
      "verse": "2:26",
      "lineIndex": 178
    },
    {
      "start": 479.176,
      "end": 482.473,
      "type": "line",
      "text": "according to the commandments which God hath given.",
      "verse": "2:26",
      "lineIndex": 179
    },
    {
      "start": 483.153,
      "end": 486.543,
      "type": "line",
      "text": "Wherefore, men are free according to the flesh;",
      "verse": "2:27",
      "lineIndex": 181
    },
    {
      "start": 486.723,
      "end": 490.02,
      "type": "line",
      "text": "and all things are given them which are expedient unto man.",
      "verse": "2:27",
      "lineIndex": 182
    },
    {
      "start": 490.2,
      "end": 493.544,
      "type": "line",
      "text": "And they are free to choose liberty and eternal life,",
      "verse": "2:27",
      "lineIndex": 183
    },
    {
      "start": 493.724,
      "end": 496.603,
      "type": "line",
      "text": "through the great Mediator of all men,",
      "verse": "2:27",
      "lineIndex": 184
    },
    {
      "start": 496.783,
      "end": 499.151,
      "type": "line",
      "text": "or to choose captivity and death,",
      "verse": "2:27",
      "lineIndex": 185
    },
    {
      "start": 499.331,
      "end": 502.768,
      "type": "line",
      "text": "according to the captivity and power of the devil;",
      "verse": "2:27",
      "lineIndex": 186
    },
    {
      "start": 502.948,
      "end": 507.128,
      "type": "line",
      "text": "for he seeketh that all men might be miserable like unto himself.",
      "verse": "2:27",
      "lineIndex": 187
    },
    {
      "start": 507.808,
      "end": 509.294,
      "type": "line",
      "text": "And now, my sons,",
      "verse": "2:28",
      "lineIndex": 188
    },
    {
      "start": 509.474,
      "end": 512.4,
      "type": "line",
      "text": "I would that ye should look to the great Mediator,",
      "verse": "2:28",
      "lineIndex": 189
    },
    {
      "start": 512.58,
      "end": 514.948,
      "type": "line",
      "text": "and hearken unto his great commandments;",
      "verse": "2:28",
      "lineIndex": 190
    },
    {
      "start": 515.128,
      "end": 517.404,
      "type": "line",
      "text": "and be faithful unto his words,",
      "verse": "2:28",
      "lineIndex": 191
    },
    {
      "start": 517.584,
      "end": 519.395,
      "type": "line",
      "text": "and choose eternal life,",
      "verse": "2:28",
      "lineIndex": 192
    },
    {
      "start": 519.575,
      "end": 522.176,
      "type": "line",
      "text": "according to the will of his Holy Spirit;",
      "verse": "2:28",
      "lineIndex": 193
    },
    {
      "start": 522.856,
      "end": 524.992,
      "type": "line",
      "text": "And not choose eternal death,",
      "verse": "2:29",
      "lineIndex": 194
    },
    {
      "start": 525.172,
      "end": 529.073,
      "type": "line",
      "text": "according to the will of the flesh and the evil which is therein,",
      "verse": "2:29",
      "lineIndex": 195
    },
    {
      "start": 529.253,
      "end": 532.875,
      "type": "line",
      "text": "which giveth the spirit of the devil power to captivate,",
      "verse": "2:29",
      "lineIndex": 196
    },
    {
      "start": 533.055,
      "end": 534.634,
      "type": "line",
      "text": "to bring you down to hell,",
      "verse": "2:29",
      "lineIndex": 197
    },
    {
      "start": 534.814,
      "end": 538.018,
      "type": "line",
      "text": "that he may reign over you in his own kingdom.",
      "verse": "2:29",
      "lineIndex": 198
    },
    {
      "start": 538.698,
      "end": 542.181,
      "type": "line",
      "text": "I have spoken these few words unto you all, my sons,",
      "verse": "2:30",
      "lineIndex": 199
    },
    {
      "start": 542.361,
      "end": 544.59,
      "type": "line",
      "text": "in the last days of my probation;",
      "verse": "2:30",
      "lineIndex": 200
    },
    {
      "start": 544.77,
      "end": 546.813,
      "type": "line",
      "text": "and I have chosen the good part,",
      "verse": "2:30",
      "lineIndex": 201
    },
    {
      "start": 546.993,
      "end": 549.315,
      "type": "line",
      "text": "according to the words of the prophet.",
      "verse": "2:30",
      "lineIndex": 202
    },
    {
      "start": 549.495,
      "end": 551.445,
      "type": "line",
      "text": "And I have none other object",
      "verse": "2:30",
      "lineIndex": 203
    },
    {
      "start": 551.625,
      "end": 554.783,
      "type": "line",
      "text": "save it be the everlasting welfare of your souls.",
      "verse": "2:30",
      "lineIndex": 204
    },
    {
      "start": 554.963,
      "end": 555.892,
      "type": "line",
      "text": "Amen.",
      "verse": "2:30",
      "lineIndex": 205
    }
  ]
}