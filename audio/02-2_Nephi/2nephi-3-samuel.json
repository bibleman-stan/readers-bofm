{
  "book": "2nephi",
  "chapter": 3,
  "voice": {
    "provider": "elevenlabs",
    "voice_id": "ddDFRErfhdc2asyySOG5",
    "model_id": "eleven_multilingual_v2",
    "settings": {
      "stability": 0.5,
      "similarity_boost": 0.75,
      "style": 0.35,
      "use_speaker_boost": true
    },
    "name": "Samuel"
  },
  "pauses": {
    "line_ms": 180,
    "verse_ms": 500
  },
  "duration": 423.382,
  "lines": [
    {
      "start": 0.0,
      "end": 2.786,
      "type": "line",
      "text": "And now I speak unto you, Joseph, my last-born.",
      "verse": "3:1",
      "lineIndex": 1
    },
    {
      "start": 2.966,
      "end": 6.542,
      "type": "line",
      "text": "Thou wast born in the wilderness of mine afflictions;",
      "verse": "3:1",
      "lineIndex": 2
    },
    {
      "start": 6.722,
      "end": 10.809,
      "type": "line",
      "text": "yea, in the days of my greatest sorrow did thy mother bear thee.",
      "verse": "3:1",
      "lineIndex": 3
    },
    {
      "start": 11.489,
      "end": 14.926,
      "type": "line",
      "text": "And may the Lord consecrate also unto thee this land,",
      "verse": "3:2",
      "lineIndex": 4
    },
    {
      "start": 15.106,
      "end": 17.149,
      "type": "line",
      "text": "which is a most precious land,",
      "verse": "3:2",
      "lineIndex": 5
    },
    {
      "start": 17.329,
      "end": 22.623,
      "type": "line",
      "text": "for thine inheritance and the inheritance of thy seed with thy brethren,",
      "verse": "3:2",
      "lineIndex": 6
    },
    {
      "start": 22.803,
      "end": 24.893,
      "type": "line",
      "text": "for thy security forever,",
      "verse": "3:2",
      "lineIndex": 7
    },
    {
      "start": 25.073,
      "end": 30.228,
      "type": "line",
      "text": "if it so be that ye shall keep the commandments of the Holy One of Israel.",
      "verse": "3:2",
      "lineIndex": 8
    },
    {
      "start": 30.908,
      "end": 32.858,
      "type": "line",
      "text": "And now, Joseph, my last-born,",
      "verse": "3:3",
      "lineIndex": 9
    },
    {
      "start": 33.038,
      "end": 37.496,
      "type": "line",
      "text": "whom I have brought out of the wilderness of mine afflictions,",
      "verse": "3:3",
      "lineIndex": 10
    },
    {
      "start": 37.676,
      "end": 39.719,
      "type": "line",
      "text": "may the Lord bless thee forever,",
      "verse": "3:3",
      "lineIndex": 11
    },
    {
      "start": 39.899,
      "end": 42.871,
      "type": "line",
      "text": "for thy seed shall not utterly be destroyed.",
      "verse": "3:3",
      "lineIndex": 12
    },
    {
      "start": 43.551,
      "end": 46.477,
      "type": "line",
      "text": "For behold, thou art the fruit of my loins;",
      "verse": "3:4",
      "lineIndex": 14
    },
    {
      "start": 46.657,
      "end": 50.419,
      "type": "line",
      "text": "and I am a descendant of Joseph who was carried captive into Egypt.",
      "verse": "3:4",
      "lineIndex": 15
    },
    {
      "start": 50.599,
      "end": 54.639,
      "type": "line",
      "text": "And great were the covenants of the Lord which he made unto Joseph.",
      "verse": "3:4",
      "lineIndex": 16
    },
    {
      "start": 55.319,
      "end": 57.641,
      "type": "line",
      "text": "Wherefore, Joseph truly saw our day.",
      "verse": "3:5",
      "lineIndex": 17
    },
    {
      "start": 57.821,
      "end": 60.097,
      "type": "line",
      "text": "And he obtained a promise of the Lord,",
      "verse": "3:5",
      "lineIndex": 18
    },
    {
      "start": 60.277,
      "end": 62.785,
      "type": "line",
      "text": "that out of the fruit of his loins",
      "verse": "3:5",
      "lineIndex": 19
    },
    {
      "start": 62.965,
      "end": 67.423,
      "type": "line",
      "text": "the Lord God would raise up a righteous branch unto the house of Israel;",
      "verse": "3:5",
      "lineIndex": 20
    },
    {
      "start": 67.603,
      "end": 71.04,
      "type": "line",
      "text": "not the Messiah, but a branch which was to be broken off,",
      "verse": "3:5",
      "lineIndex": 21
    },
    {
      "start": 71.22,
      "end": 74.749,
      "type": "line",
      "text": "nevertheless, to be remembered in the covenants of the Lord",
      "verse": "3:5",
      "lineIndex": 22
    },
    {
      "start": 74.929,
      "end": 79.341,
      "type": "line",
      "text": "that the Messiah should be made manifest unto them in the latter days,",
      "verse": "3:5",
      "lineIndex": 23
    },
    {
      "start": 79.521,
      "end": 81.239,
      "type": "line",
      "text": "in the spirit of power,",
      "verse": "3:5",
      "lineIndex": 24
    },
    {
      "start": 81.419,
      "end": 84.67,
      "type": "line",
      "text": "unto the bringing of them out of darkness unto light\u2014",
      "verse": "3:5",
      "lineIndex": 25
    },
    {
      "start": 84.85,
      "end": 86.986,
      "type": "line",
      "text": "yea, out of hidden darkness",
      "verse": "3:5",
      "lineIndex": 26
    },
    {
      "start": 87.166,
      "end": 89.395,
      "type": "line",
      "text": "and out of captivity unto freedom.",
      "verse": "3:5",
      "lineIndex": 27
    },
    {
      "start": 90.075,
      "end": 92.536,
      "type": "line",
      "text": "For Joseph truly testified, saying:",
      "verse": "3:6",
      "lineIndex": 29
    },
    {
      "start": 92.716,
      "end": 95.177,
      "type": "line",
      "text": "A seer shall the Lord my God raise up,",
      "verse": "3:6",
      "lineIndex": 30
    },
    {
      "start": 95.357,
      "end": 99.026,
      "type": "line",
      "text": "who shall be a choice seer unto the fruit of my loins.",
      "verse": "3:6",
      "lineIndex": 31
    },
    {
      "start": 99.706,
      "end": 101.378,
      "type": "line",
      "text": "Yea, Joseph truly said:",
      "verse": "3:7",
      "lineIndex": 32
    },
    {
      "start": 101.558,
      "end": 103.416,
      "type": "line",
      "text": "Thus saith the Lord unto me:",
      "verse": "3:7",
      "lineIndex": 33
    },
    {
      "start": 103.596,
      "end": 106.011,
      "type": "line",
      "text": "A choice seer will I raise up",
      "verse": "3:7",
      "lineIndex": 34
    },
    {
      "start": 106.191,
      "end": 108.234,
      "type": "line",
      "text": "out of the fruit of thy loins;",
      "verse": "3:7",
      "lineIndex": 35
    },
    {
      "start": 108.414,
      "end": 110.411,
      "type": "line",
      "text": "and he shall be esteemed highly",
      "verse": "3:7",
      "lineIndex": 36
    },
    {
      "start": 110.591,
      "end": 112.634,
      "type": "line",
      "text": "among the fruit of thy loins.",
      "verse": "3:7",
      "lineIndex": 37
    },
    {
      "start": 112.814,
      "end": 115.554,
      "type": "line",
      "text": "And unto him will I give commandment",
      "verse": "3:7",
      "lineIndex": 38
    },
    {
      "start": 115.734,
      "end": 119.96,
      "type": "line",
      "text": "that he shall do a work for the fruit of thy loins, his brethren,",
      "verse": "3:7",
      "lineIndex": 39
    },
    {
      "start": 120.14,
      "end": 123.019,
      "type": "line",
      "text": "which shall be of great worth unto them,",
      "verse": "3:7",
      "lineIndex": 40
    },
    {
      "start": 123.199,
      "end": 126.821,
      "type": "line",
      "text": "even to the bringing of them to the knowledge of the covenants",
      "verse": "3:7",
      "lineIndex": 41
    },
    {
      "start": 127.001,
      "end": 129.369,
      "type": "line",
      "text": "which I have made with thy fathers.",
      "verse": "3:7",
      "lineIndex": 42
    },
    {
      "start": 130.049,
      "end": 133.996,
      "type": "line",
      "text": "And I will give unto him a commandment that he shall do none other work,",
      "verse": "3:8",
      "lineIndex": 43
    },
    {
      "start": 134.176,
      "end": 136.591,
      "type": "line",
      "text": "save the work which I shall command him.",
      "verse": "3:8",
      "lineIndex": 44
    },
    {
      "start": 136.771,
      "end": 139.232,
      "type": "line",
      "text": "And I will make him great in mine eyes;",
      "verse": "3:8",
      "lineIndex": 45
    },
    {
      "start": 139.412,
      "end": 140.898,
      "type": "line",
      "text": "for he shall do my work.",
      "verse": "3:8",
      "lineIndex": 46
    },
    {
      "start": 141.578,
      "end": 144.132,
      "type": "line",
      "text": "And he shall be great like unto Moses,",
      "verse": "3:9",
      "lineIndex": 47
    },
    {
      "start": 144.312,
      "end": 147.145,
      "type": "line",
      "text": "whom I have said I would raise up unto you,",
      "verse": "3:9",
      "lineIndex": 48
    },
    {
      "start": 147.325,
      "end": 149.693,
      "type": "line",
      "text": "to deliver my people, O house of Israel.",
      "verse": "3:9",
      "lineIndex": 49
    },
    {
      "start": 150.373,
      "end": 152.323,
      "type": "line",
      "text": "And Moses will I raise up,",
      "verse": "3:10",
      "lineIndex": 50
    },
    {
      "start": 152.503,
      "end": 155.522,
      "type": "line",
      "text": "to deliver thy people out of the land of Egypt.",
      "verse": "3:10",
      "lineIndex": 51
    },
    {
      "start": 156.202,
      "end": 158.199,
      "type": "line",
      "text": "But a seer will I raise up",
      "verse": "3:11",
      "lineIndex": 52
    },
    {
      "start": 158.379,
      "end": 160.422,
      "type": "line",
      "text": "out of the fruit of thy loins;",
      "verse": "3:11",
      "lineIndex": 53
    },
    {
      "start": 160.602,
      "end": 162.506,
      "type": "line",
      "text": "and unto him will I give power",
      "verse": "3:11",
      "lineIndex": 54
    },
    {
      "start": 162.686,
      "end": 164.311,
      "type": "line",
      "text": "to bring forth my word",
      "verse": "3:11",
      "lineIndex": 55
    },
    {
      "start": 164.491,
      "end": 166.441,
      "type": "line",
      "text": "unto the seed of thy loins\u2014",
      "verse": "3:11",
      "lineIndex": 56
    },
    {
      "start": 166.621,
      "end": 169.315,
      "type": "line",
      "text": "and not to the bringing forth my word only,",
      "verse": "3:11",
      "lineIndex": 57
    },
    {
      "start": 169.495,
      "end": 170.795,
      "type": "line",
      "text": "saith the Lord,",
      "verse": "3:11",
      "lineIndex": 58
    },
    {
      "start": 170.975,
      "end": 173.529,
      "type": "line",
      "text": "but to the convincing them of my word,",
      "verse": "3:11",
      "lineIndex": 59
    },
    {
      "start": 173.709,
      "end": 176.867,
      "type": "line",
      "text": "which shall have already gone forth among them.",
      "verse": "3:11",
      "lineIndex": 60
    },
    {
      "start": 177.547,
      "end": 180.751,
      "type": "line",
      "text": "Wherefore, the fruit of thy loins shall write;",
      "verse": "3:12",
      "lineIndex": 61
    },
    {
      "start": 180.931,
      "end": 184.089,
      "type": "line",
      "text": "and the fruit of the loins of Judah shall write;",
      "verse": "3:12",
      "lineIndex": 62
    },
    {
      "start": 184.269,
      "end": 186.127,
      "type": "line",
      "text": "and that which shall be written",
      "verse": "3:12",
      "lineIndex": 63
    },
    {
      "start": 186.307,
      "end": 188.257,
      "type": "line",
      "text": "by the fruit of thy loins,",
      "verse": "3:12",
      "lineIndex": 64
    },
    {
      "start": 188.437,
      "end": 190.945,
      "type": "line",
      "text": "and also that which shall be written",
      "verse": "3:12",
      "lineIndex": 65
    },
    {
      "start": 191.125,
      "end": 193.354,
      "type": "line",
      "text": "by the fruit of the loins of Judah,",
      "verse": "3:12",
      "lineIndex": 66
    },
    {
      "start": 193.534,
      "end": 195.113,
      "type": "line",
      "text": "shall grow together,",
      "verse": "3:12",
      "lineIndex": 67
    },
    {
      "start": 195.293,
      "end": 197.847,
      "type": "line",
      "text": "unto the confounding of false doctrines",
      "verse": "3:12",
      "lineIndex": 68
    },
    {
      "start": 198.027,
      "end": 200.21,
      "type": "line",
      "text": "and laying down of contentions,",
      "verse": "3:12",
      "lineIndex": 69
    },
    {
      "start": 200.39,
      "end": 203.501,
      "type": "line",
      "text": "and establishing peace among the fruit of thy loins,",
      "verse": "3:12",
      "lineIndex": 70
    },
    {
      "start": 203.681,
      "end": 208.975,
      "type": "line",
      "text": "and bringing them to the knowledge of their fathers in the latter days,",
      "verse": "3:12",
      "lineIndex": 71
    },
    {
      "start": 209.155,
      "end": 212.684,
      "type": "line",
      "text": "and also to the knowledge of my covenants, saith the Lord.",
      "verse": "3:12",
      "lineIndex": 72
    },
    {
      "start": 213.364,
      "end": 216.522,
      "type": "line",
      "text": "And out of weakness he shall be made strong, in that day",
      "verse": "3:13",
      "lineIndex": 73
    },
    {
      "start": 216.702,
      "end": 219.581,
      "type": "line",
      "text": "when my work shall commence among all my people,",
      "verse": "3:13",
      "lineIndex": 74
    },
    {
      "start": 219.761,
      "end": 221.479,
      "type": "line",
      "text": "unto the restoring thee,",
      "verse": "3:13",
      "lineIndex": 75
    },
    {
      "start": 221.659,
      "end": 224.12,
      "type": "line",
      "text": "O house of Israel, saith the Lord.",
      "verse": "3:13",
      "lineIndex": 76
    },
    {
      "start": 224.8,
      "end": 226.983,
      "type": "line",
      "text": "And thus prophesied Joseph, saying:",
      "verse": "3:14",
      "lineIndex": 77
    },
    {
      "start": 227.163,
      "end": 229.439,
      "type": "line",
      "text": "Behold, that seer will the Lord bless;",
      "verse": "3:14",
      "lineIndex": 78
    },
    {
      "start": 229.619,
      "end": 232.87,
      "type": "line",
      "text": "and they that seek to destroy him shall be confounded;",
      "verse": "3:14",
      "lineIndex": 79
    },
    {
      "start": 233.05,
      "end": 236.115,
      "type": "line",
      "text": "for this promise, which I have obtained of the Lord,",
      "verse": "3:14",
      "lineIndex": 80
    },
    {
      "start": 236.295,
      "end": 239.314,
      "type": "line",
      "text": "of the fruit of my loins, shall be fulfilled.",
      "verse": "3:14",
      "lineIndex": 81
    },
    {
      "start": 239.494,
      "end": 242.605,
      "type": "line",
      "text": "Behold, I am sure of the fulfilling of this promise;",
      "verse": "3:14",
      "lineIndex": 82
    },
    {
      "start": 243.285,
      "end": 245.793,
      "type": "line",
      "text": "And his name shall be called after me;",
      "verse": "3:15",
      "lineIndex": 84
    },
    {
      "start": 245.973,
      "end": 248.341,
      "type": "line",
      "text": "and it shall be after the name of his father.",
      "verse": "3:15",
      "lineIndex": 85
    },
    {
      "start": 248.521,
      "end": 250.518,
      "type": "line",
      "text": "And he shall be like unto me;",
      "verse": "3:15",
      "lineIndex": 86
    },
    {
      "start": 250.698,
      "end": 254.135,
      "type": "line",
      "text": "for the thing, which the Lord shall bring forth by his hand,",
      "verse": "3:15",
      "lineIndex": 87
    },
    {
      "start": 254.315,
      "end": 256.173,
      "type": "line",
      "text": "by the power of the Lord",
      "verse": "3:15",
      "lineIndex": 88
    },
    {
      "start": 256.353,
      "end": 258.907,
      "type": "line",
      "text": "shall bring my people unto salvation.",
      "verse": "3:15",
      "lineIndex": 89
    },
    {
      "start": 259.587,
      "end": 261.584,
      "type": "line",
      "text": "Yea, thus prophesied Joseph:",
      "verse": "3:16",
      "lineIndex": 90
    },
    {
      "start": 261.764,
      "end": 263.529,
      "type": "line",
      "text": "I am sure of this thing,",
      "verse": "3:16",
      "lineIndex": 91
    },
    {
      "start": 263.709,
      "end": 266.356,
      "type": "line",
      "text": "even as I am sure of the promise of Moses;",
      "verse": "3:16",
      "lineIndex": 92
    },
    {
      "start": 266.536,
      "end": 268.533,
      "type": "line",
      "text": "for the Lord hath said unto me,",
      "verse": "3:16",
      "lineIndex": 93
    },
    {
      "start": 268.713,
      "end": 270.942,
      "type": "line",
      "text": "I will preserve thy seed forever.",
      "verse": "3:16",
      "lineIndex": 94
    },
    {
      "start": 271.622,
      "end": 273.247,
      "type": "line",
      "text": "And the Lord hath said:",
      "verse": "3:17",
      "lineIndex": 95
    },
    {
      "start": 273.427,
      "end": 275.145,
      "type": "line",
      "text": "I will raise up a Moses;",
      "verse": "3:17",
      "lineIndex": 96
    },
    {
      "start": 275.325,
      "end": 277.879,
      "type": "line",
      "text": "and I will give power unto him in a rod;",
      "verse": "3:17",
      "lineIndex": 97
    },
    {
      "start": 278.059,
      "end": 280.613,
      "type": "line",
      "text": "and I will give judgment unto him in writing.",
      "verse": "3:17",
      "lineIndex": 98
    },
    {
      "start": 280.793,
      "end": 282.883,
      "type": "line",
      "text": "Yet I will not loose his tongue,",
      "verse": "3:17",
      "lineIndex": 99
    },
    {
      "start": 283.063,
      "end": 284.921,
      "type": "line",
      "text": "that he shall speak much,",
      "verse": "3:17",
      "lineIndex": 100
    },
    {
      "start": 285.101,
      "end": 287.609,
      "type": "line",
      "text": "for I will not make him mighty in speaking.",
      "verse": "3:17",
      "lineIndex": 101
    },
    {
      "start": 287.789,
      "end": 289.786,
      "type": "line",
      "text": "But I will write unto him my law,",
      "verse": "3:17",
      "lineIndex": 102
    },
    {
      "start": 289.966,
      "end": 292.009,
      "type": "line",
      "text": "by the finger of mine own hand;",
      "verse": "3:17",
      "lineIndex": 103
    },
    {
      "start": 292.189,
      "end": 294.465,
      "type": "line",
      "text": "and I will make a spokesman for him.",
      "verse": "3:17",
      "lineIndex": 104
    },
    {
      "start": 295.145,
      "end": 297.235,
      "type": "line",
      "text": "And the Lord said unto me also:",
      "verse": "3:18",
      "lineIndex": 105
    },
    {
      "start": 297.415,
      "end": 300.201,
      "type": "line",
      "text": "I will raise up unto the fruit of thy loins;",
      "verse": "3:18",
      "lineIndex": 106
    },
    {
      "start": 300.381,
      "end": 302.517,
      "type": "line",
      "text": "and I will make for him a spokesman.",
      "verse": "3:18",
      "lineIndex": 107
    },
    {
      "start": 302.697,
      "end": 305.112,
      "type": "line",
      "text": "And I, behold, I will give unto him",
      "verse": "3:18",
      "lineIndex": 108
    },
    {
      "start": 305.292,
      "end": 308.868,
      "type": "line",
      "text": "that he shall write the writing of the fruit of thy loins,",
      "verse": "3:18",
      "lineIndex": 109
    },
    {
      "start": 309.048,
      "end": 311.277,
      "type": "line",
      "text": "unto the fruit of thy loins;",
      "verse": "3:18",
      "lineIndex": 110
    },
    {
      "start": 311.457,
      "end": 314.336,
      "type": "line",
      "text": "and the spokesman of thy loins shall declare it.",
      "verse": "3:18",
      "lineIndex": 111
    },
    {
      "start": 315.016,
      "end": 317.245,
      "type": "line",
      "text": "And the words which he shall write",
      "verse": "3:19",
      "lineIndex": 112
    },
    {
      "start": 317.425,
      "end": 321.837,
      "type": "line",
      "text": "shall be the words which are expedient in my wisdom should go forth",
      "verse": "3:19",
      "lineIndex": 113
    },
    {
      "start": 322.017,
      "end": 323.921,
      "type": "line",
      "text": "unto the fruit of thy loins.",
      "verse": "3:19",
      "lineIndex": 114
    },
    {
      "start": 324.101,
      "end": 329.442,
      "type": "line",
      "text": "And it shall be as if the fruit of thy loins had cried unto them from the dust;",
      "verse": "3:19",
      "lineIndex": 115
    },
    {
      "start": 329.622,
      "end": 331.201,
      "type": "line",
      "text": "for I know their faith.",
      "verse": "3:19",
      "lineIndex": 116
    },
    {
      "start": 331.881,
      "end": 333.971,
      "type": "line",
      "text": "And they shall cry from the dust;",
      "verse": "3:20",
      "lineIndex": 117
    },
    {
      "start": 334.151,
      "end": 337.077,
      "type": "line",
      "text": "yea, even repentance unto their brethren,",
      "verse": "3:20",
      "lineIndex": 118
    },
    {
      "start": 337.257,
      "end": 339.997,
      "type": "line",
      "text": "even after many generations have gone by them.",
      "verse": "3:20",
      "lineIndex": 119
    },
    {
      "start": 340.177,
      "end": 343.242,
      "type": "line",
      "text": "And it shall come to pass that their cry shall go,",
      "verse": "3:20",
      "lineIndex": 120
    },
    {
      "start": 343.422,
      "end": 346.394,
      "type": "line",
      "text": "even according to the simpleness of their words.",
      "verse": "3:20",
      "lineIndex": 121
    },
    {
      "start": 347.074,
      "end": 348.699,
      "type": "line",
      "text": "Because of their faith",
      "verse": "3:21",
      "lineIndex": 122
    },
    {
      "start": 348.879,
      "end": 352.316,
      "type": "line",
      "text": "their words shall proceed forth out of my mouth",
      "verse": "3:21",
      "lineIndex": 123
    },
    {
      "start": 352.496,
      "end": 355.7,
      "type": "line",
      "text": "unto their brethren who are the fruit of thy loins;",
      "verse": "3:21",
      "lineIndex": 124
    },
    {
      "start": 355.88,
      "end": 358.481,
      "type": "line",
      "text": "and the weakness of their words",
      "verse": "3:21",
      "lineIndex": 125
    },
    {
      "start": 358.661,
      "end": 360.844,
      "type": "line",
      "text": "will I make strong in their faith,",
      "verse": "3:21",
      "lineIndex": 126
    },
    {
      "start": 361.024,
      "end": 365.389,
      "type": "line",
      "text": "unto the remembering of my covenant which I made unto thy fathers.",
      "verse": "3:21",
      "lineIndex": 127
    },
    {
      "start": 366.069,
      "end": 368.066,
      "type": "line",
      "text": "And now, behold, my son Joseph,",
      "verse": "3:22",
      "lineIndex": 128
    },
    {
      "start": 368.246,
      "end": 371.45,
      "type": "line",
      "text": "after this manner did my father of old prophesy.",
      "verse": "3:22",
      "lineIndex": 129
    },
    {
      "start": 372.13,
      "end": 375.381,
      "type": "line",
      "text": "Wherefore, because of this covenant thou art blessed;",
      "verse": "3:23",
      "lineIndex": 130
    },
    {
      "start": 375.561,
      "end": 377.837,
      "type": "line",
      "text": "for thy seed shall not be destroyed,",
      "verse": "3:23",
      "lineIndex": 131
    },
    {
      "start": 378.017,
      "end": 380.989,
      "type": "line",
      "text": "for they shall hearken unto the words of the book.",
      "verse": "3:23",
      "lineIndex": 132
    },
    {
      "start": 381.669,
      "end": 384.595,
      "type": "line",
      "text": "And there shall rise up one mighty among them,",
      "verse": "3:24",
      "lineIndex": 133
    },
    {
      "start": 384.775,
      "end": 386.308,
      "type": "line",
      "text": "who shall do much good,",
      "verse": "3:24",
      "lineIndex": 134
    },
    {
      "start": 386.488,
      "end": 388.299,
      "type": "line",
      "text": "both in word and in deed,",
      "verse": "3:24",
      "lineIndex": 135
    },
    {
      "start": 388.479,
      "end": 391.08,
      "type": "line",
      "text": "being an instrument in the hands of God,",
      "verse": "3:24",
      "lineIndex": 136
    },
    {
      "start": 391.26,
      "end": 392.746,
      "type": "line",
      "text": "with exceeding faith,",
      "verse": "3:24",
      "lineIndex": 137
    },
    {
      "start": 392.926,
      "end": 394.644,
      "type": "line",
      "text": "to work mighty wonders,",
      "verse": "3:24",
      "lineIndex": 138
    },
    {
      "start": 394.824,
      "end": 397.889,
      "type": "line",
      "text": "and do that thing which is great in the sight of God,",
      "verse": "3:24",
      "lineIndex": 139
    },
    {
      "start": 398.069,
      "end": 403.038,
      "type": "line",
      "text": "unto the bringing to pass much restoration unto the house of Israel,",
      "verse": "3:24",
      "lineIndex": 140
    },
    {
      "start": 403.218,
      "end": 405.261,
      "type": "line",
      "text": "and unto the seed of thy brethren.",
      "verse": "3:24",
      "lineIndex": 141
    },
    {
      "start": 405.941,
      "end": 408.17,
      "type": "line",
      "text": "And now, blessed art thou, Joseph.",
      "verse": "3:25",
      "lineIndex": 142
    },
    {
      "start": 408.35,
      "end": 410.254,
      "type": "line",
      "text": "Behold, thou art little;",
      "verse": "3:25",
      "lineIndex": 143
    },
    {
      "start": 410.434,
      "end": 413.778,
      "type": "line",
      "text": "wherefore hearken unto the words of thy brother, Nephi,",
      "verse": "3:25",
      "lineIndex": 144
    },
    {
      "start": 413.958,
      "end": 415.955,
      "type": "line",
      "text": "and it shall be done unto thee",
      "verse": "3:25",
      "lineIndex": 145
    },
    {
      "start": 416.135,
      "end": 419.061,
      "type": "line",
      "text": "even according to the words which I have spoken.",
      "verse": "3:25",
      "lineIndex": 146
    },
    {
      "start": 419.241,
      "end": 421.609,
      "type": "line",
      "text": "Remember the words of thy dying father.",
      "verse": "3:25",
      "lineIndex": 147
    },
    {
      "start": 421.789,
      "end": 422.718,
      "type": "line",
      "text": "Amen.",
      "verse": "3:25",
      "lineIndex": 148
    }
  ]
}