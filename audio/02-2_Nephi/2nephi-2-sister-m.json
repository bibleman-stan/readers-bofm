{
  "book": "2nephi",
  "bookName": "2 Nephi",
  "chapter": 2,
  "voice": {
    "provider": "elevenlabs",
    "voice_id": "iJpuSZDxZSBJHFSeavba",
    "model_id": "eleven_multilingual_v2",
    "settings": {
      "stability": 0.5,
      "similarity_boost": 0.75,
      "style": 0.35,
      "use_speaker_boost": true
    },
    "name": "sister-m"
  },
  "pauses": {
    "line_ms": 180,
    "verse_ms": 500
  },
  "duration": 639.716,
  "lines": [
    {
      "start": 0.0,
      "end": 2.833,
      "type": "line",
      "text": "And now, Jacob, I speak unto you:",
      "verse": "2:1",
      "lineIndex": 1
    },
    {
      "start": 3.013,
      "end": 4.917,
      "type": "line",
      "text": "Thou art my firstborn",
      "verse": "2:1",
      "lineIndex": 2
    },
    {
      "start": 5.097,
      "end": 8.301,
      "type": "line",
      "text": "in the days of my tribulation in the wilderness.",
      "verse": "2:1",
      "lineIndex": 3
    },
    {
      "start": 8.481,
      "end": 10.896,
      "type": "line",
      "text": "And behold, in thy childhood",
      "verse": "2:1",
      "lineIndex": 4
    },
    {
      "start": 11.076,
      "end": 14.931,
      "type": "line",
      "text": "thou hast suffered afflictions and much sorrow,",
      "verse": "2:1",
      "lineIndex": 5
    },
    {
      "start": 15.111,
      "end": 17.712,
      "type": "line",
      "text": "because of the rudeness of thy brethren.",
      "verse": "2:1",
      "lineIndex": 6
    },
    {
      "start": 18.392,
      "end": 22.572,
      "type": "line",
      "text": "Nevertheless, Jacob, my firstborn in the wilderness,",
      "verse": "2:2",
      "lineIndex": 7
    },
    {
      "start": 22.752,
      "end": 24.795,
      "type": "line",
      "text": "thou knowest the greatness of God;",
      "verse": "2:2",
      "lineIndex": 8
    },
    {
      "start": 24.975,
      "end": 28.737,
      "type": "line",
      "text": "and he shall consecrate thine afflictions for thy gain.",
      "verse": "2:2",
      "lineIndex": 9
    },
    {
      "start": 29.417,
      "end": 32.111,
      "type": "line",
      "text": "Wherefore, thy soul shall be blessed,",
      "verse": "2:3",
      "lineIndex": 11
    },
    {
      "start": 32.291,
      "end": 36.378,
      "type": "line",
      "text": "and thou shalt dwell safely with thy brother, Nephi;",
      "verse": "2:3",
      "lineIndex": 12
    },
    {
      "start": 36.558,
      "end": 40.738,
      "type": "line",
      "text": "and thy days shall be spent in the service of thy God.",
      "verse": "2:3",
      "lineIndex": 13
    },
    {
      "start": 40.918,
      "end": 44.122,
      "type": "line",
      "text": "Wherefore, I know that thou art redeemed,",
      "verse": "2:3",
      "lineIndex": 14
    },
    {
      "start": 44.302,
      "end": 46.949,
      "type": "line",
      "text": "because of the righteousness of thy Redeemer;",
      "verse": "2:3",
      "lineIndex": 15
    },
    {
      "start": 47.129,
      "end": 50.705,
      "type": "line",
      "text": "for thou hast beheld that in the fulness of time",
      "verse": "2:3",
      "lineIndex": 16
    },
    {
      "start": 50.885,
      "end": 53.486,
      "type": "line",
      "text": "he cometh to bring salvation unto men.",
      "verse": "2:3",
      "lineIndex": 17
    },
    {
      "start": 54.166,
      "end": 58.067,
      "type": "line",
      "text": "And thou hast beheld in thy youth his glory;",
      "verse": "2:4",
      "lineIndex": 18
    },
    {
      "start": 58.247,
      "end": 64.191,
      "type": "line",
      "text": "wherefore, thou art blessed even as they unto whom he shall minister in the flesh;",
      "verse": "2:4",
      "lineIndex": 19
    },
    {
      "start": 64.371,
      "end": 68.969,
      "type": "line",
      "text": "for the Spirit is the same, yesterday, today, and forever.",
      "verse": "2:4",
      "lineIndex": 20
    },
    {
      "start": 69.149,
      "end": 72.075,
      "type": "line",
      "text": "And the way is prepared from the fall of man,",
      "verse": "2:4",
      "lineIndex": 21
    },
    {
      "start": 72.255,
      "end": 74.066,
      "type": "line",
      "text": "and salvation is free.",
      "verse": "2:4",
      "lineIndex": 22
    },
    {
      "start": 74.746,
      "end": 79.344,
      "type": "line",
      "text": "And men are instructed sufficiently that they know good from evil.",
      "verse": "2:5",
      "lineIndex": 24
    },
    {
      "start": 79.524,
      "end": 82.078,
      "type": "line",
      "text": "And the law is given unto men.",
      "verse": "2:5",
      "lineIndex": 25
    },
    {
      "start": 82.258,
      "end": 85.277,
      "type": "line",
      "text": "And by the law no flesh is justified;",
      "verse": "2:5",
      "lineIndex": 26
    },
    {
      "start": 85.457,
      "end": 88.383,
      "type": "line",
      "text": "or, by the law men are cut off.",
      "verse": "2:5",
      "lineIndex": 27
    },
    {
      "start": 88.563,
      "end": 91.442,
      "type": "line",
      "text": "Yea, by the temporal law they were cut off;",
      "verse": "2:5",
      "lineIndex": 28
    },
    {
      "start": 91.622,
      "end": 96.73,
      "type": "line",
      "text": "and also, by the spiritual law they perish from that which is good,",
      "verse": "2:5",
      "lineIndex": 29
    },
    {
      "start": 96.91,
      "end": 98.86,
      "type": "line",
      "text": "and become miserable forever.",
      "verse": "2:5",
      "lineIndex": 30
    },
    {
      "start": 99.54,
      "end": 103.673,
      "type": "line",
      "text": "Wherefore, redemption cometh in and through the Holy Messiah;",
      "verse": "2:6",
      "lineIndex": 32
    },
    {
      "start": 103.853,
      "end": 106.268,
      "type": "line",
      "text": "for he is full of grace and truth.",
      "verse": "2:6",
      "lineIndex": 33
    },
    {
      "start": 106.948,
      "end": 111.313,
      "type": "line",
      "text": "Behold, he offereth himself a sacrifice for sin,",
      "verse": "2:7",
      "lineIndex": 34
    },
    {
      "start": 111.493,
      "end": 113.629,
      "type": "line",
      "text": "to answer the ends of the law,",
      "verse": "2:7",
      "lineIndex": 35
    },
    {
      "start": 113.809,
      "end": 116.874,
      "type": "line",
      "text": "unto all those who have a broken heart",
      "verse": "2:7",
      "lineIndex": 36
    },
    {
      "start": 117.054,
      "end": 118.726,
      "type": "line",
      "text": "and a contrite spirit;",
      "verse": "2:7",
      "lineIndex": 37
    },
    {
      "start": 118.906,
      "end": 122.807,
      "type": "line",
      "text": "and unto none else can the ends of the law be answered.",
      "verse": "2:7",
      "lineIndex": 38
    },
    {
      "start": 123.487,
      "end": 125.995,
      "type": "line",
      "text": "Wherefore, how great the importance",
      "verse": "2:8",
      "lineIndex": 39
    },
    {
      "start": 126.175,
      "end": 130.447,
      "type": "line",
      "text": "to make these things known unto the inhabitants of the earth,",
      "verse": "2:8",
      "lineIndex": 40
    },
    {
      "start": 130.627,
      "end": 133.878,
      "type": "line",
      "text": "that they may know that there is no flesh",
      "verse": "2:8",
      "lineIndex": 41
    },
    {
      "start": 134.058,
      "end": 136.659,
      "type": "line",
      "text": "that can dwell in the presence of God,",
      "verse": "2:8",
      "lineIndex": 42
    },
    {
      "start": 136.839,
      "end": 139.022,
      "type": "line",
      "text": "save it be through the merits,",
      "verse": "2:8",
      "lineIndex": 43
    },
    {
      "start": 139.202,
      "end": 140.456,
      "type": "line",
      "text": "and mercy,",
      "verse": "2:8",
      "lineIndex": 44
    },
    {
      "start": 140.636,
      "end": 141.751,
      "type": "line",
      "text": "and grace",
      "verse": "2:8",
      "lineIndex": 45
    },
    {
      "start": 141.931,
      "end": 143.371,
      "type": "line",
      "text": "of the Holy Messiah,",
      "verse": "2:8",
      "lineIndex": 46
    },
    {
      "start": 143.551,
      "end": 147.173,
      "type": "line",
      "text": "who layeth down his life according to the flesh,",
      "verse": "2:8",
      "lineIndex": 47
    },
    {
      "start": 147.353,
      "end": 150.882,
      "type": "line",
      "text": "and taketh it again by the power of the Spirit,",
      "verse": "2:8",
      "lineIndex": 48
    },
    {
      "start": 151.062,
      "end": 154.638,
      "type": "line",
      "text": "that he may bring to pass the resurrection of the dead,",
      "verse": "2:8",
      "lineIndex": 49
    },
    {
      "start": 154.818,
      "end": 157.326,
      "type": "line",
      "text": "being the first that should rise.",
      "verse": "2:8",
      "lineIndex": 50
    },
    {
      "start": 158.006,
      "end": 161.396,
      "type": "line",
      "text": "Wherefore, he is the firstfruits unto God,",
      "verse": "2:9",
      "lineIndex": 51
    },
    {
      "start": 161.576,
      "end": 166.638,
      "type": "line",
      "text": "inasmuch as he shall make intercession for all the children of men;",
      "verse": "2:9",
      "lineIndex": 52
    },
    {
      "start": 166.818,
      "end": 170.022,
      "type": "line",
      "text": "and they that believe in him shall be saved.",
      "verse": "2:9",
      "lineIndex": 53
    },
    {
      "start": 170.702,
      "end": 173.21,
      "type": "line",
      "text": "And because of the intercession for all,",
      "verse": "2:10",
      "lineIndex": 54
    },
    {
      "start": 173.39,
      "end": 175.015,
      "type": "line",
      "text": "all men come unto God;",
      "verse": "2:10",
      "lineIndex": 55
    },
    {
      "start": 175.195,
      "end": 178.399,
      "type": "line",
      "text": "wherefore, they stand in the presence of him,",
      "verse": "2:10",
      "lineIndex": 56
    },
    {
      "start": 178.579,
      "end": 180.251,
      "type": "line",
      "text": "to be judged of him",
      "verse": "2:10",
      "lineIndex": 57
    },
    {
      "start": 180.431,
      "end": 184.193,
      "type": "line",
      "text": "according to the truth and holiness which is in him.",
      "verse": "2:10",
      "lineIndex": 58
    },
    {
      "start": 184.373,
      "end": 188.413,
      "type": "line",
      "text": "Wherefore, the ends of the law which the Holy One hath given,",
      "verse": "2:10",
      "lineIndex": 59
    },
    {
      "start": 188.593,
      "end": 192.726,
      "type": "line",
      "text": "unto the inflicting of the punishment which is affixed,",
      "verse": "2:10",
      "lineIndex": 60
    },
    {
      "start": 192.906,
      "end": 195.414,
      "type": "line",
      "text": "which punishment that is affixed",
      "verse": "2:10",
      "lineIndex": 61
    },
    {
      "start": 195.594,
      "end": 196.987,
      "type": "line",
      "text": "is in opposition",
      "verse": "2:10",
      "lineIndex": 62
    },
    {
      "start": 197.167,
      "end": 199.907,
      "type": "line",
      "text": "to that of the happiness which is affixed,",
      "verse": "2:10",
      "lineIndex": 63
    },
    {
      "start": 200.087,
      "end": 203.756,
      "type": "line",
      "text": "to answer the ends of the atonement\u2014",
      "verse": "2:10",
      "lineIndex": 64
    },
    {
      "start": 204.436,
      "end": 206.247,
      "type": "line",
      "text": "For it must needs be,",
      "verse": "2:11",
      "lineIndex": 66
    },
    {
      "start": 206.427,
      "end": 209.353,
      "type": "line",
      "text": "that there is an opposition in all things.",
      "verse": "2:11",
      "lineIndex": 67
    },
    {
      "start": 209.533,
      "end": 210.601,
      "type": "line",
      "text": "If not so,",
      "verse": "2:11",
      "lineIndex": 68
    },
    {
      "start": 210.781,
      "end": 213.242,
      "type": "line",
      "text": "my firstborn in the wilderness,",
      "verse": "2:11",
      "lineIndex": 69
    },
    {
      "start": 213.422,
      "end": 216.255,
      "type": "line",
      "text": "righteousness could not be brought to pass,",
      "verse": "2:11",
      "lineIndex": 70
    },
    {
      "start": 216.435,
      "end": 217.875,
      "type": "line",
      "text": "neither wickedness,",
      "verse": "2:11",
      "lineIndex": 71
    },
    {
      "start": 218.055,
      "end": 220.377,
      "type": "line",
      "text": "neither holiness nor misery,",
      "verse": "2:11",
      "lineIndex": 72
    },
    {
      "start": 220.557,
      "end": 222.368,
      "type": "line",
      "text": "neither good nor bad.",
      "verse": "2:11",
      "lineIndex": 73
    },
    {
      "start": 222.548,
      "end": 226.495,
      "type": "line",
      "text": "Wherefore, all things must needs be a compound in one;",
      "verse": "2:11",
      "lineIndex": 74
    },
    {
      "start": 226.675,
      "end": 229.554,
      "type": "line",
      "text": "wherefore, if it should be one body",
      "verse": "2:11",
      "lineIndex": 75
    },
    {
      "start": 229.734,
      "end": 232.288,
      "type": "line",
      "text": "it must needs remain as dead,",
      "verse": "2:11",
      "lineIndex": 76
    },
    {
      "start": 232.468,
      "end": 234.976,
      "type": "line",
      "text": "having no life neither death,",
      "verse": "2:11",
      "lineIndex": 77
    },
    {
      "start": 235.156,
      "end": 237.71,
      "type": "line",
      "text": "nor corruption nor incorruption,",
      "verse": "2:11",
      "lineIndex": 78
    },
    {
      "start": 237.89,
      "end": 239.98,
      "type": "line",
      "text": "happiness nor misery,",
      "verse": "2:11",
      "lineIndex": 79
    },
    {
      "start": 240.16,
      "end": 242.807,
      "type": "line",
      "text": "neither sense nor insensibility.",
      "verse": "2:11",
      "lineIndex": 80
    },
    {
      "start": 243.487,
      "end": 248.131,
      "type": "line",
      "text": "Wherefore, it must needs have been created for a thing of naught;",
      "verse": "2:12",
      "lineIndex": 81
    },
    {
      "start": 248.311,
      "end": 252.955,
      "type": "line",
      "text": "wherefore there would have been no purpose in the end of its creation.",
      "verse": "2:12",
      "lineIndex": 82
    },
    {
      "start": 253.135,
      "end": 257.268,
      "type": "line",
      "text": "Wherefore, this thing must needs destroy the wisdom of God",
      "verse": "2:12",
      "lineIndex": 83
    },
    {
      "start": 257.448,
      "end": 259.677,
      "type": "line",
      "text": "and his eternal purposes,",
      "verse": "2:12",
      "lineIndex": 84
    },
    {
      "start": 259.857,
      "end": 264.269,
      "type": "line",
      "text": "and also the power, and the mercy, and the justice of God.",
      "verse": "2:12",
      "lineIndex": 85
    },
    {
      "start": 264.949,
      "end": 267.643,
      "type": "line",
      "text": "And if ye shall say there is no law,",
      "verse": "2:13",
      "lineIndex": 86
    },
    {
      "start": 267.823,
      "end": 270.517,
      "type": "line",
      "text": "ye shall also say there is no sin.",
      "verse": "2:13",
      "lineIndex": 87
    },
    {
      "start": 270.697,
      "end": 273.53,
      "type": "line",
      "text": "If ye shall say there is no sin,",
      "verse": "2:13",
      "lineIndex": 88
    },
    {
      "start": 273.71,
      "end": 276.914,
      "type": "line",
      "text": "ye shall also say there is no righteousness.",
      "verse": "2:13",
      "lineIndex": 89
    },
    {
      "start": 277.094,
      "end": 279.277,
      "type": "line",
      "text": "And if there be no righteousness",
      "verse": "2:13",
      "lineIndex": 90
    },
    {
      "start": 279.457,
      "end": 281.222,
      "type": "line",
      "text": "there be no happiness.",
      "verse": "2:13",
      "lineIndex": 91
    },
    {
      "start": 281.402,
      "end": 284.885,
      "type": "line",
      "text": "And if there be no righteousness nor happiness",
      "verse": "2:13",
      "lineIndex": 92
    },
    {
      "start": 285.065,
      "end": 287.759,
      "type": "line",
      "text": "there be no punishment nor misery.",
      "verse": "2:13",
      "lineIndex": 93
    },
    {
      "start": 287.939,
      "end": 290.354,
      "type": "line",
      "text": "And if these things are not",
      "verse": "2:13",
      "lineIndex": 94
    },
    {
      "start": 290.534,
      "end": 292.067,
      "type": "line",
      "text": "there is no God.",
      "verse": "2:13",
      "lineIndex": 95
    },
    {
      "start": 292.247,
      "end": 293.872,
      "type": "line",
      "text": "And if there is no God",
      "verse": "2:13",
      "lineIndex": 96
    },
    {
      "start": 294.052,
      "end": 295.12,
      "type": "line",
      "text": "we are not,",
      "verse": "2:13",
      "lineIndex": 97
    },
    {
      "start": 295.3,
      "end": 296.74,
      "type": "line",
      "text": "neither the earth;",
      "verse": "2:13",
      "lineIndex": 98
    },
    {
      "start": 296.92,
      "end": 300.031,
      "type": "line",
      "text": "for there could have been no creation of things,",
      "verse": "2:13",
      "lineIndex": 99
    },
    {
      "start": 300.211,
      "end": 303.137,
      "type": "line",
      "text": "neither to act nor to be acted upon;",
      "verse": "2:13",
      "lineIndex": 100
    },
    {
      "start": 303.317,
      "end": 306.568,
      "type": "line",
      "text": "wherefore, all things must have vanished away.",
      "verse": "2:13",
      "lineIndex": 101
    },
    {
      "start": 307.248,
      "end": 308.966,
      "type": "line",
      "text": "And now, my sons,",
      "verse": "2:14",
      "lineIndex": 103
    },
    {
      "start": 309.146,
      "end": 312.908,
      "type": "line",
      "text": "I speak unto you these things for your profit and learning;",
      "verse": "2:14",
      "lineIndex": 104
    },
    {
      "start": 313.088,
      "end": 314.574,
      "type": "line",
      "text": "for there is a God,",
      "verse": "2:14",
      "lineIndex": 105
    },
    {
      "start": 314.754,
      "end": 317.308,
      "type": "line",
      "text": "and he hath created all things,",
      "verse": "2:14",
      "lineIndex": 106
    },
    {
      "start": 317.488,
      "end": 320.089,
      "type": "line",
      "text": "both the heavens and the earth,",
      "verse": "2:14",
      "lineIndex": 107
    },
    {
      "start": 320.269,
      "end": 323.52,
      "type": "line",
      "text": "and all things that in them are,",
      "verse": "2:14",
      "lineIndex": 108
    },
    {
      "start": 323.7,
      "end": 327.322,
      "type": "line",
      "text": "both things to act and things to be acted upon.",
      "verse": "2:14",
      "lineIndex": 109
    },
    {
      "start": 328.002,
      "end": 332.414,
      "type": "line",
      "text": "And to bring about his eternal purposes in the end of man,",
      "verse": "2:15",
      "lineIndex": 110
    },
    {
      "start": 332.594,
      "end": 335.473,
      "type": "line",
      "text": "after he had created our first parents,",
      "verse": "2:15",
      "lineIndex": 111
    },
    {
      "start": 335.653,
      "end": 345.591,
      "type": "line",
      "text": "and the beasts of the field",
      "verse": "2:15",
      "lineIndex": 112
    },
    {
      "start": 345.771,
      "end": 347.675,
      "type": "line",
      "text": "and the fowls of the air,",
      "verse": "2:15",
      "lineIndex": 113
    },
    {
      "start": 347.855,
      "end": 351.431,
      "type": "line",
      "text": "and in fine, all things which are created,",
      "verse": "2:15",
      "lineIndex": 114
    },
    {
      "start": 351.611,
      "end": 354.955,
      "type": "line",
      "text": "it must needs be that there was an opposition;",
      "verse": "2:15",
      "lineIndex": 115
    },
    {
      "start": 355.135,
      "end": 359.361,
      "type": "line",
      "text": "even the forbidden fruit in opposition to the tree of life;",
      "verse": "2:15",
      "lineIndex": 116
    },
    {
      "start": 359.541,
      "end": 362.699,
      "type": "line",
      "text": "the one being sweet and the other bitter.",
      "verse": "2:15",
      "lineIndex": 117
    },
    {
      "start": 363.379,
      "end": 368.487,
      "type": "line",
      "text": "Wherefore, the Lord God gave unto man that he should act for himself.",
      "verse": "2:16",
      "lineIndex": 119
    },
    {
      "start": 368.667,
      "end": 371.639,
      "type": "line",
      "text": "Wherefore, man could not act for himself",
      "verse": "2:16",
      "lineIndex": 120
    },
    {
      "start": 371.819,
      "end": 376.138,
      "type": "line",
      "text": "save it should be that he was enticed by the one or the other.",
      "verse": "2:16",
      "lineIndex": 121
    },
    {
      "start": 376.818,
      "end": 381.323,
      "type": "line",
      "text": "And I, Lehi, according to the things which I have read,",
      "verse": "2:17",
      "lineIndex": 122
    },
    {
      "start": 381.503,
      "end": 384.336,
      "type": "line",
      "text": "must needs suppose that an angel of God,",
      "verse": "2:17",
      "lineIndex": 123
    },
    {
      "start": 384.516,
      "end": 386.792,
      "type": "line",
      "text": "according to that which is written,",
      "verse": "2:17",
      "lineIndex": 124
    },
    {
      "start": 386.972,
      "end": 388.737,
      "type": "line",
      "text": "had fallen from heaven;",
      "verse": "2:17",
      "lineIndex": 125
    },
    {
      "start": 388.917,
      "end": 391.239,
      "type": "line",
      "text": "wherefore, he became a devil,",
      "verse": "2:17",
      "lineIndex": 126
    },
    {
      "start": 391.419,
      "end": 394.438,
      "type": "line",
      "text": "having sought that which was evil before God.",
      "verse": "2:17",
      "lineIndex": 127
    },
    {
      "start": 395.118,
      "end": 397.486,
      "type": "line",
      "text": "And because he had fallen from heaven,",
      "verse": "2:18",
      "lineIndex": 128
    },
    {
      "start": 397.666,
      "end": 400.127,
      "type": "line",
      "text": "and had become miserable forever,",
      "verse": "2:18",
      "lineIndex": 129
    },
    {
      "start": 400.307,
      "end": 403.697,
      "type": "line",
      "text": "he sought also the misery of all mankind.",
      "verse": "2:18",
      "lineIndex": 130
    },
    {
      "start": 403.877,
      "end": 405.967,
      "type": "line",
      "text": "Wherefore, he said unto Eve,",
      "verse": "2:18",
      "lineIndex": 131
    },
    {
      "start": 406.147,
      "end": 408.562,
      "type": "line",
      "text": "yea, even that old serpent,",
      "verse": "2:18",
      "lineIndex": 132
    },
    {
      "start": 408.742,
      "end": 410.042,
      "type": "line",
      "text": "who is the devil,",
      "verse": "2:18",
      "lineIndex": 133
    },
    {
      "start": 410.222,
      "end": 412.823,
      "type": "line",
      "text": "who is the father of all lies,",
      "verse": "2:18",
      "lineIndex": 134
    },
    {
      "start": 413.003,
      "end": 414.675,
      "type": "line",
      "text": "wherefore he said:",
      "verse": "2:18",
      "lineIndex": 135
    },
    {
      "start": 414.855,
      "end": 418.338,
      "type": "line",
      "text": "Partake of the forbidden fruit, and ye shall not die,",
      "verse": "2:18",
      "lineIndex": 136
    },
    {
      "start": 418.518,
      "end": 420.376,
      "type": "line",
      "text": "but ye shall be as God,",
      "verse": "2:18",
      "lineIndex": 137
    },
    {
      "start": 420.556,
      "end": 422.46,
      "type": "line",
      "text": "knowing good and evil.",
      "verse": "2:18",
      "lineIndex": 138
    },
    {
      "start": 423.14,
      "end": 427.273,
      "type": "line",
      "text": "And after Adam and Eve had partaken of the forbidden fruit",
      "verse": "2:19",
      "lineIndex": 139
    },
    {
      "start": 427.453,
      "end": 430.239,
      "type": "line",
      "text": "they were driven out of the garden of Eden,",
      "verse": "2:19",
      "lineIndex": 140
    },
    {
      "start": 430.419,
      "end": 432.044,
      "type": "line",
      "text": "to till the earth.",
      "verse": "2:19",
      "lineIndex": 141
    },
    {
      "start": 432.724,
      "end": 434.953,
      "type": "line",
      "text": "And they have brought forth children;",
      "verse": "2:20",
      "lineIndex": 142
    },
    {
      "start": 435.133,
      "end": 438.988,
      "type": "line",
      "text": "yea, even the family of all the earth.",
      "verse": "2:20",
      "lineIndex": 143
    },
    {
      "start": 439.668,
      "end": 442.919,
      "type": "line",
      "text": "And the days of the children of men were prolonged,",
      "verse": "2:21",
      "lineIndex": 144
    },
    {
      "start": 443.099,
      "end": 445.189,
      "type": "line",
      "text": "according to the will of God,",
      "verse": "2:21",
      "lineIndex": 145
    },
    {
      "start": 445.369,
      "end": 448.48,
      "type": "line",
      "text": "that they might repent while in the flesh;",
      "verse": "2:21",
      "lineIndex": 146
    },
    {
      "start": 448.66,
      "end": 452.282,
      "type": "line",
      "text": "wherefore, their state became a state of probation,",
      "verse": "2:21",
      "lineIndex": 147
    },
    {
      "start": 452.462,
      "end": 454.412,
      "type": "line",
      "text": "and their time was lengthened,",
      "verse": "2:21",
      "lineIndex": 148
    },
    {
      "start": 454.592,
      "end": 459.654,
      "type": "line",
      "text": "according to the commandments which the Lord God gave unto the children of men.",
      "verse": "2:21",
      "lineIndex": 149
    },
    {
      "start": 459.834,
      "end": 463.735,
      "type": "line",
      "text": "For he gave commandment that all men must repent;",
      "verse": "2:21",
      "lineIndex": 150
    },
    {
      "start": 463.915,
      "end": 467.584,
      "type": "line",
      "text": "for he showed unto all men that they were lost,",
      "verse": "2:21",
      "lineIndex": 151
    },
    {
      "start": 467.764,
      "end": 470.736,
      "type": "line",
      "text": "because of the transgression of their parents.",
      "verse": "2:21",
      "lineIndex": 152
    },
    {
      "start": 471.416,
      "end": 475.085,
      "type": "line",
      "text": "And now, behold, if Adam had not transgressed",
      "verse": "2:22",
      "lineIndex": 154
    },
    {
      "start": 475.265,
      "end": 477.03,
      "type": "line",
      "text": "he would not have fallen,",
      "verse": "2:22",
      "lineIndex": 155
    },
    {
      "start": 477.21,
      "end": 480.414,
      "type": "line",
      "text": "but he would have remained in the garden of Eden.",
      "verse": "2:22",
      "lineIndex": 156
    },
    {
      "start": 480.594,
      "end": 483.148,
      "type": "line",
      "text": "And all things which were created",
      "verse": "2:22",
      "lineIndex": 157
    },
    {
      "start": 483.328,
      "end": 486.068,
      "type": "line",
      "text": "must have remained in the same state",
      "verse": "2:22",
      "lineIndex": 158
    },
    {
      "start": 486.248,
      "end": 488.988,
      "type": "line",
      "text": "in which they were after they were created;",
      "verse": "2:22",
      "lineIndex": 159
    },
    {
      "start": 489.168,
      "end": 492.883,
      "type": "line",
      "text": "and they must have remained forever, and had no end.",
      "verse": "2:22",
      "lineIndex": 160
    },
    {
      "start": 493.563,
      "end": 495.792,
      "type": "line",
      "text": "And they would have had no children;",
      "verse": "2:23",
      "lineIndex": 161
    },
    {
      "start": 495.972,
      "end": 499.548,
      "type": "line",
      "text": "wherefore they would have remained in a state of innocence,",
      "verse": "2:23",
      "lineIndex": 162
    },
    {
      "start": 499.728,
      "end": 502.375,
      "type": "line",
      "text": "having no joy, for they knew no misery;",
      "verse": "2:23",
      "lineIndex": 163
    },
    {
      "start": 502.555,
      "end": 505.341,
      "type": "line",
      "text": "doing no good, for they knew no sin.",
      "verse": "2:23",
      "lineIndex": 164
    },
    {
      "start": 506.021,
      "end": 508.947,
      "type": "line",
      "text": "But behold, all things have been done",
      "verse": "2:24",
      "lineIndex": 165
    },
    {
      "start": 509.127,
      "end": 512.238,
      "type": "line",
      "text": "in the wisdom of him who knoweth all things.",
      "verse": "2:24",
      "lineIndex": 166
    },
    {
      "start": 512.918,
      "end": 514.868,
      "type": "line",
      "text": "Adam fell that men might be;",
      "verse": "2:25",
      "lineIndex": 168
    },
    {
      "start": 515.048,
      "end": 518.81,
      "type": "line",
      "text": "and men are,",
      "verse": "2:25",
      "lineIndex": 169
    },
    {
      "start": 518.99,
      "end": 520.662,
      "type": "line",
      "text": "that they might have joy.",
      "verse": "2:25",
      "lineIndex": 170
    },
    {
      "start": 521.342,
      "end": 528.215,
      "type": "line",
      "text": "And the Messiah cometh in the fulness of time,",
      "verse": "2:26",
      "lineIndex": 171
    },
    {
      "start": 528.395,
      "end": 532.482,
      "type": "line",
      "text": "that he may redeem the children of men from the fall.",
      "verse": "2:26",
      "lineIndex": 172
    },
    {
      "start": 532.662,
      "end": 535.588,
      "type": "line",
      "text": "And because that they are redeemed from the fall",
      "verse": "2:26",
      "lineIndex": 173
    },
    {
      "start": 535.768,
      "end": 538.044,
      "type": "line",
      "text": "they have become free forever,",
      "verse": "2:26",
      "lineIndex": 174
    },
    {
      "start": 538.224,
      "end": 539.942,
      "type": "line",
      "text": "knowing good from evil;",
      "verse": "2:26",
      "lineIndex": 175
    },
    {
      "start": 540.122,
      "end": 543.605,
      "type": "line",
      "text": "to act for themselves and not to be acted upon,",
      "verse": "2:26",
      "lineIndex": 176
    },
    {
      "start": 543.785,
      "end": 546.896,
      "type": "line",
      "text": "save it be by the punishment of the law",
      "verse": "2:26",
      "lineIndex": 177
    },
    {
      "start": 547.076,
      "end": 549.026,
      "type": "line",
      "text": "at the great and last day,",
      "verse": "2:26",
      "lineIndex": 178
    },
    {
      "start": 549.206,
      "end": 552.643,
      "type": "line",
      "text": "according to the commandments which God hath given.",
      "verse": "2:26",
      "lineIndex": 179
    },
    {
      "start": 553.323,
      "end": 556.713,
      "type": "line",
      "text": "Wherefore, men are free according to the flesh;",
      "verse": "2:27",
      "lineIndex": 181
    },
    {
      "start": 556.893,
      "end": 561.537,
      "type": "line",
      "text": "and all things are given them which are expedient unto man.",
      "verse": "2:27",
      "lineIndex": 182
    },
    {
      "start": 561.717,
      "end": 569.24,
      "type": "line",
      "text": "And they are free to choose liberty and eternal life,",
      "verse": "2:27",
      "lineIndex": 183
    },
    {
      "start": 569.42,
      "end": 572.16,
      "type": "line",
      "text": "through the great Mediator of all men,",
      "verse": "2:27",
      "lineIndex": 184
    },
    {
      "start": 572.34,
      "end": 574.755,
      "type": "line",
      "text": "or to choose captivity and death,",
      "verse": "2:27",
      "lineIndex": 185
    },
    {
      "start": 574.935,
      "end": 578.604,
      "type": "line",
      "text": "according to the captivity and power of the devil;",
      "verse": "2:27",
      "lineIndex": 186
    },
    {
      "start": 578.784,
      "end": 583.8,
      "type": "line",
      "text": "for he seeketh that all men might be miserable like unto himself.",
      "verse": "2:27",
      "lineIndex": 187
    },
    {
      "start": 584.48,
      "end": 586.198,
      "type": "line",
      "text": "And now, my sons,",
      "verse": "2:28",
      "lineIndex": 188
    },
    {
      "start": 586.378,
      "end": 589.722,
      "type": "line",
      "text": "I would that ye should look to the great Mediator,",
      "verse": "2:28",
      "lineIndex": 189
    },
    {
      "start": 589.902,
      "end": 592.874,
      "type": "line",
      "text": "and hearken unto his great commandments;",
      "verse": "2:28",
      "lineIndex": 190
    },
    {
      "start": 593.054,
      "end": 595.655,
      "type": "line",
      "text": "and be faithful unto his words,",
      "verse": "2:28",
      "lineIndex": 191
    },
    {
      "start": 595.835,
      "end": 597.832,
      "type": "line",
      "text": "and choose eternal life,",
      "verse": "2:28",
      "lineIndex": 192
    },
    {
      "start": 598.012,
      "end": 600.891,
      "type": "line",
      "text": "according to the will of his Holy Spirit;",
      "verse": "2:28",
      "lineIndex": 193
    },
    {
      "start": 601.571,
      "end": 604.079,
      "type": "line",
      "text": "And not choose eternal death,",
      "verse": "2:29",
      "lineIndex": 194
    },
    {
      "start": 604.259,
      "end": 608.996,
      "type": "line",
      "text": "according to the will of the flesh and the evil which is therein,",
      "verse": "2:29",
      "lineIndex": 195
    },
    {
      "start": 609.176,
      "end": 613.123,
      "type": "line",
      "text": "which giveth the spirit of the devil power to captivate,",
      "verse": "2:29",
      "lineIndex": 196
    },
    {
      "start": 613.303,
      "end": 615.207,
      "type": "line",
      "text": "to bring you down to hell,",
      "verse": "2:29",
      "lineIndex": 197
    },
    {
      "start": 615.387,
      "end": 618.916,
      "type": "line",
      "text": "that he may reign over you in his own kingdom.",
      "verse": "2:29",
      "lineIndex": 198
    },
    {
      "start": 619.596,
      "end": 623.683,
      "type": "line",
      "text": "I have spoken these few words unto you all, my sons,",
      "verse": "2:30",
      "lineIndex": 199
    },
    {
      "start": 623.863,
      "end": 626.185,
      "type": "line",
      "text": "in the last days of my probation;",
      "verse": "2:30",
      "lineIndex": 200
    },
    {
      "start": 626.365,
      "end": 629.151,
      "type": "line",
      "text": "and I have chosen the good part,",
      "verse": "2:30",
      "lineIndex": 201
    },
    {
      "start": 629.331,
      "end": 631.932,
      "type": "line",
      "text": "according to the words of the prophet.",
      "verse": "2:30",
      "lineIndex": 202
    },
    {
      "start": 632.112,
      "end": 634.434,
      "type": "line",
      "text": "And I have none other object",
      "verse": "2:30",
      "lineIndex": 203
    },
    {
      "start": 634.614,
      "end": 638.051,
      "type": "line",
      "text": "save it be the everlasting welfare of your souls.",
      "verse": "2:30",
      "lineIndex": 204
    },
    {
      "start": 638.231,
      "end": 639.067,
      "type": "line",
      "text": "Amen.",
      "verse": "2:30",
      "lineIndex": 205
    }
  ]
}