{
  "book": "2nephi",
  "bookName": "2 Nephi",
  "chapter": 28,
  "voice": {
    "provider": "elevenlabs",
    "voice_id": "iJpuSZDxZSBJHFSeavba",
    "model_id": "eleven_multilingual_v2",
    "settings": {
      "stability": 0.5,
      "similarity_boost": 0.75,
      "style": 0.35,
      "use_speaker_boost": true
    },
    "name": "sister-m"
  },
  "pauses": {
    "line_ms": 180,
    "verse_ms": 500
  },
  "duration": 553.677,
  "lines": [
    {
      "start": 0.0,
      "end": 4.737,
      "type": "line",
      "text": "And now, behold, my brethren, I have spoken unto you,",
      "verse": "28:1",
      "lineIndex": 1
    },
    {
      "start": 4.917,
      "end": 8.028,
      "type": "line",
      "text": "according as the Spirit hath constrained me;",
      "verse": "28:1",
      "lineIndex": 2
    },
    {
      "start": 8.208,
      "end": 11.923,
      "type": "line",
      "text": "wherefore, I know that they must surely come to pass.",
      "verse": "28:1",
      "lineIndex": 3
    },
    {
      "start": 12.603,
      "end": 15.714,
      "type": "line",
      "text": "And the things which shall be written out of the book",
      "verse": "28:2",
      "lineIndex": 4
    },
    {
      "start": 15.894,
      "end": 19.238,
      "type": "line",
      "text": "shall be of great worth unto the children of men,",
      "verse": "28:2",
      "lineIndex": 5
    },
    {
      "start": 19.418,
      "end": 21.694,
      "type": "line",
      "text": "and especially unto our seed,",
      "verse": "28:2",
      "lineIndex": 6
    },
    {
      "start": 21.874,
      "end": 24.8,
      "type": "line",
      "text": "which is a remnant of the house of Israel.",
      "verse": "28:2",
      "lineIndex": 7
    },
    {
      "start": 25.48,
      "end": 28.22,
      "type": "line",
      "text": "For it shall come to pass in that day",
      "verse": "28:3",
      "lineIndex": 9
    },
    {
      "start": 28.4,
      "end": 30.954,
      "type": "line",
      "text": "that the churches which are built up,",
      "verse": "28:3",
      "lineIndex": 10
    },
    {
      "start": 31.134,
      "end": 32.945,
      "type": "line",
      "text": "and not unto the Lord,",
      "verse": "28:3",
      "lineIndex": 11
    },
    {
      "start": 33.125,
      "end": 35.215,
      "type": "line",
      "text": "when the one shall say unto the other:",
      "verse": "28:3",
      "lineIndex": 12
    },
    {
      "start": 35.395,
      "end": 38.646,
      "type": "line",
      "text": "Behold, I, I am the Lord's;",
      "verse": "28:3",
      "lineIndex": 13
    },
    {
      "start": 38.826,
      "end": 40.359,
      "type": "line",
      "text": "and the others shall say:",
      "verse": "28:3",
      "lineIndex": 14
    },
    {
      "start": 40.539,
      "end": 42.489,
      "type": "line",
      "text": "I, I am the Lord's;",
      "verse": "28:3",
      "lineIndex": 15
    },
    {
      "start": 42.669,
      "end": 45.223,
      "type": "line",
      "text": "and thus shall every one say",
      "verse": "28:3",
      "lineIndex": 16
    },
    {
      "start": 45.403,
      "end": 47.4,
      "type": "line",
      "text": "that hath built up churches,",
      "verse": "28:3",
      "lineIndex": 17
    },
    {
      "start": 47.58,
      "end": 52.688,
      "type": "line",
      "text": "and not unto the Lord\u2014",
      "verse": "28:3",
      "lineIndex": 18
    },
    {
      "start": 53.368,
      "end": 56.108,
      "type": "line",
      "text": "And they shall contend one with another;",
      "verse": "28:4",
      "lineIndex": 19
    },
    {
      "start": 56.288,
      "end": 59.725,
      "type": "line",
      "text": "and their priests shall contend one with another,",
      "verse": "28:4",
      "lineIndex": 20
    },
    {
      "start": 59.905,
      "end": 62.506,
      "type": "line",
      "text": "and they shall teach with their learning,",
      "verse": "28:4",
      "lineIndex": 21
    },
    {
      "start": 62.686,
      "end": 66.448,
      "type": "line",
      "text": "and deny the Holy Ghost, which giveth utterance.",
      "verse": "28:4",
      "lineIndex": 22
    },
    {
      "start": 67.128,
      "end": 69.543,
      "type": "line",
      "text": "And they deny the power of God,",
      "verse": "28:5",
      "lineIndex": 23
    },
    {
      "start": 69.723,
      "end": 71.627,
      "type": "line",
      "text": "the Holy One of Israel;",
      "verse": "28:5",
      "lineIndex": 24
    },
    {
      "start": 71.807,
      "end": 73.711,
      "type": "line",
      "text": "and they say unto the people:",
      "verse": "28:5",
      "lineIndex": 25
    },
    {
      "start": 73.891,
      "end": 77.142,
      "type": "line",
      "text": "Hearken unto us, and hear ye our precept;",
      "verse": "28:5",
      "lineIndex": 26
    },
    {
      "start": 77.322,
      "end": 79.737,
      "type": "line",
      "text": "for behold there is no God today,",
      "verse": "28:5",
      "lineIndex": 27
    },
    {
      "start": 79.917,
      "end": 83.446,
      "type": "line",
      "text": "for the Lord and the Redeemer hath done his work,",
      "verse": "28:5",
      "lineIndex": 28
    },
    {
      "start": 83.626,
      "end": 86.412,
      "type": "line",
      "text": "and he hath given his power unto men;",
      "verse": "28:5",
      "lineIndex": 29
    },
    {
      "start": 87.092,
      "end": 90.436,
      "type": "line",
      "text": "Behold, hearken ye unto my precept;",
      "verse": "28:6",
      "lineIndex": 30
    },
    {
      "start": 90.616,
      "end": 94.935,
      "type": "line",
      "text": "if they shall say there is a miracle wrought by the hand of the Lord,",
      "verse": "28:6",
      "lineIndex": 31
    },
    {
      "start": 95.115,
      "end": 96.415,
      "type": "line",
      "text": "believe it not;",
      "verse": "28:6",
      "lineIndex": 32
    },
    {
      "start": 96.595,
      "end": 99.846,
      "type": "line",
      "text": "for this day he is not a God of miracles;",
      "verse": "28:6",
      "lineIndex": 33
    },
    {
      "start": 100.026,
      "end": 101.698,
      "type": "line",
      "text": "he hath done his work.",
      "verse": "28:6",
      "lineIndex": 34
    },
    {
      "start": 102.378,
      "end": 105.536,
      "type": "line",
      "text": "Yea, and there shall be many which shall say:",
      "verse": "28:7",
      "lineIndex": 35
    },
    {
      "start": 105.716,
      "end": 108.27,
      "type": "line",
      "text": "Eat, drink, and be merry,",
      "verse": "28:7",
      "lineIndex": 36
    },
    {
      "start": 108.45,
      "end": 110.215,
      "type": "line",
      "text": "for tomorrow we die;",
      "verse": "28:7",
      "lineIndex": 37
    },
    {
      "start": 110.395,
      "end": 112.345,
      "type": "line",
      "text": "and it shall be well with us.",
      "verse": "28:7",
      "lineIndex": 38
    },
    {
      "start": 113.025,
      "end": 116.554,
      "type": "line",
      "text": "And there shall also be many which shall say:",
      "verse": "28:8",
      "lineIndex": 39
    },
    {
      "start": 116.734,
      "end": 124.536,
      "type": "line",
      "text": "Eat, drink, and be merry; nevertheless, fear God\u2014",
      "verse": "28:8",
      "lineIndex": 40
    },
    {
      "start": 124.716,
      "end": 127.92,
      "type": "line",
      "text": "he will justify in committing a little sin;",
      "verse": "28:8",
      "lineIndex": 41
    },
    {
      "start": 128.1,
      "end": 130.004,
      "type": "line",
      "text": "yea, lie a little,",
      "verse": "28:8",
      "lineIndex": 42
    },
    {
      "start": 130.184,
      "end": 133.435,
      "type": "line",
      "text": "take the advantage of one because of his words,",
      "verse": "28:8",
      "lineIndex": 43
    },
    {
      "start": 133.615,
      "end": 135.519,
      "type": "line",
      "text": "dig a pit for thy neighbor;",
      "verse": "28:8",
      "lineIndex": 44
    },
    {
      "start": 135.699,
      "end": 137.742,
      "type": "line",
      "text": "there is no harm in this;",
      "verse": "28:8",
      "lineIndex": 45
    },
    {
      "start": 137.922,
      "end": 140.012,
      "type": "line",
      "text": "and do all these things,",
      "verse": "28:8",
      "lineIndex": 46
    },
    {
      "start": 140.192,
      "end": 141.957,
      "type": "line",
      "text": "for tomorrow we die;",
      "verse": "28:8",
      "lineIndex": 47
    },
    {
      "start": 142.137,
      "end": 144.645,
      "type": "line",
      "text": "and if it so be that we are guilty,",
      "verse": "28:8",
      "lineIndex": 48
    },
    {
      "start": 144.825,
      "end": 147.193,
      "type": "line",
      "text": "God will beat us with a few stripes,",
      "verse": "28:8",
      "lineIndex": 49
    },
    {
      "start": 147.373,
      "end": 151.274,
      "type": "line",
      "text": "and at last we shall be saved in the kingdom of God.",
      "verse": "28:8",
      "lineIndex": 50
    },
    {
      "start": 151.954,
      "end": 155.112,
      "type": "line",
      "text": "Yea, and there shall be many",
      "verse": "28:9",
      "lineIndex": 51
    },
    {
      "start": 155.292,
      "end": 157.846,
      "type": "line",
      "text": "which shall teach after this manner,",
      "verse": "28:9",
      "lineIndex": 52
    },
    {
      "start": 158.026,
      "end": 160.766,
      "type": "line",
      "text": "false and vain and foolish doctrines,",
      "verse": "28:9",
      "lineIndex": 53
    },
    {
      "start": 160.946,
      "end": 163.686,
      "type": "line",
      "text": "and shall be puffed up in their hearts,",
      "verse": "28:9",
      "lineIndex": 54
    },
    {
      "start": 163.866,
      "end": 167.721,
      "type": "line",
      "text": "and shall seek deep to hide their counsels from the Lord;",
      "verse": "28:9",
      "lineIndex": 55
    },
    {
      "start": 167.901,
      "end": 170.966,
      "type": "line",
      "text": "and their works shall be in the dark.",
      "verse": "28:9",
      "lineIndex": 56
    },
    {
      "start": 171.646,
      "end": 175.872,
      "type": "line",
      "text": "And the blood of the saints shall cry from the ground against them.",
      "verse": "28:10",
      "lineIndex": 57
    },
    {
      "start": 176.552,
      "end": 179.106,
      "type": "line",
      "text": "Yea, they have all gone out of the way;",
      "verse": "28:11",
      "lineIndex": 58
    },
    {
      "start": 179.286,
      "end": 181.236,
      "type": "line",
      "text": "they have become corrupted.",
      "verse": "28:11",
      "lineIndex": 59
    },
    {
      "start": 181.916,
      "end": 183.216,
      "type": "line",
      "text": "Because of pride,",
      "verse": "28:12",
      "lineIndex": 60
    },
    {
      "start": 183.396,
      "end": 187.158,
      "type": "line",
      "text": "and because of false teachers, and false doctrine,",
      "verse": "28:12",
      "lineIndex": 61
    },
    {
      "start": 187.338,
      "end": 190.171,
      "type": "line",
      "text": "their churches have become corrupted,",
      "verse": "28:12",
      "lineIndex": 62
    },
    {
      "start": 190.351,
      "end": 192.905,
      "type": "line",
      "text": "and their churches are lifted up;",
      "verse": "28:12",
      "lineIndex": 63
    },
    {
      "start": 193.085,
      "end": 195.732,
      "type": "line",
      "text": "because of pride they are puffed up.",
      "verse": "28:12",
      "lineIndex": 64
    },
    {
      "start": 196.412,
      "end": 199.849,
      "type": "line",
      "text": "They rob the poor because of their fine sanctuaries;",
      "verse": "28:13",
      "lineIndex": 65
    },
    {
      "start": 200.029,
      "end": 203.187,
      "type": "line",
      "text": "they rob the poor because of their fine clothing;",
      "verse": "28:13",
      "lineIndex": 66
    },
    {
      "start": 203.367,
      "end": 206.804,
      "type": "line",
      "text": "and they persecute the meek and the poor in heart,",
      "verse": "28:13",
      "lineIndex": 67
    },
    {
      "start": 206.984,
      "end": 209.863,
      "type": "line",
      "text": "because in their pride they are puffed up.",
      "verse": "28:13",
      "lineIndex": 68
    },
    {
      "start": 210.543,
      "end": 213.422,
      "type": "line",
      "text": "They wear stiff necks and high heads;",
      "verse": "28:14",
      "lineIndex": 69
    },
    {
      "start": 213.602,
      "end": 217.921,
      "type": "line",
      "text": "yea, and because of pride, and wickedness,",
      "verse": "28:14",
      "lineIndex": 70
    },
    {
      "start": 218.101,
      "end": 220.887,
      "type": "line",
      "text": "and abominations, and whoredoms,",
      "verse": "28:14",
      "lineIndex": 71
    },
    {
      "start": 221.067,
      "end": 222.971,
      "type": "line",
      "text": "they have all gone astray",
      "verse": "28:14",
      "lineIndex": 72
    },
    {
      "start": 223.151,
      "end": 224.776,
      "type": "line",
      "text": "save it be a few,",
      "verse": "28:14",
      "lineIndex": 73
    },
    {
      "start": 224.956,
      "end": 227.557,
      "type": "line",
      "text": "who are the humble followers of Christ;",
      "verse": "28:14",
      "lineIndex": 74
    },
    {
      "start": 227.737,
      "end": 230.013,
      "type": "line",
      "text": "nevertheless, they are led,",
      "verse": "28:14",
      "lineIndex": 75
    },
    {
      "start": 230.193,
      "end": 233.119,
      "type": "line",
      "text": "that in many instances they do err",
      "verse": "28:14",
      "lineIndex": 76
    },
    {
      "start": 233.299,
      "end": 236.457,
      "type": "line",
      "text": "because they are taught by the precepts of men.",
      "verse": "28:14",
      "lineIndex": 77
    },
    {
      "start": 237.137,
      "end": 240.063,
      "type": "line",
      "text": "O the wise, and the learned, and the rich,",
      "verse": "28:15",
      "lineIndex": 79
    },
    {
      "start": 240.243,
      "end": 243.401,
      "type": "line",
      "text": "that are puffed up in the pride of their hearts,",
      "verse": "28:15",
      "lineIndex": 80
    },
    {
      "start": 243.581,
      "end": 246.507,
      "type": "line",
      "text": "and all those who preach false doctrines,",
      "verse": "28:15",
      "lineIndex": 81
    },
    {
      "start": 246.687,
      "end": 249.055,
      "type": "line",
      "text": "and all those who commit whoredoms,",
      "verse": "28:15",
      "lineIndex": 82
    },
    {
      "start": 249.235,
      "end": 251.743,
      "type": "line",
      "text": "and pervert the right way of the Lord,",
      "verse": "28:15",
      "lineIndex": 83
    },
    {
      "start": 251.923,
      "end": 256.706,
      "type": "line",
      "text": "wo, wo, wo be unto them,",
      "verse": "28:15",
      "lineIndex": 84
    },
    {
      "start": 256.886,
      "end": 258.929,
      "type": "line",
      "text": "saith the Lord God Almighty,",
      "verse": "28:15",
      "lineIndex": 85
    },
    {
      "start": 259.109,
      "end": 261.895,
      "type": "line",
      "text": "for they shall be thrust down to hell!",
      "verse": "28:15",
      "lineIndex": 86
    },
    {
      "start": 262.575,
      "end": 267.498,
      "type": "line",
      "text": "Wo unto them that turn aside the just for a thing of naught",
      "verse": "28:16",
      "lineIndex": 87
    },
    {
      "start": 267.678,
      "end": 270.372,
      "type": "line",
      "text": "and revile against that which is good,",
      "verse": "28:16",
      "lineIndex": 88
    },
    {
      "start": 270.552,
      "end": 273.153,
      "type": "line",
      "text": "and say that it is of no worth!",
      "verse": "28:16",
      "lineIndex": 89
    },
    {
      "start": 273.333,
      "end": 274.866,
      "type": "line",
      "text": "For the day shall come",
      "verse": "28:16",
      "lineIndex": 90
    },
    {
      "start": 275.046,
      "end": 279.876,
      "type": "line",
      "text": "that the Lord God will speedily visit the inhabitants of the earth;",
      "verse": "28:16",
      "lineIndex": 91
    },
    {
      "start": 280.056,
      "end": 283.678,
      "type": "line",
      "text": "and in that day that they are fully ripe in iniquity",
      "verse": "28:16",
      "lineIndex": 92
    },
    {
      "start": 283.858,
      "end": 285.437,
      "type": "line",
      "text": "they shall perish.",
      "verse": "28:16",
      "lineIndex": 93
    },
    {
      "start": 286.117,
      "end": 293.455,
      "type": "line",
      "text": "But behold, if the inhabitants of the earth shall repent of their wickedness and abominations",
      "verse": "28:17",
      "lineIndex": 94
    },
    {
      "start": 293.635,
      "end": 295.911,
      "type": "line",
      "text": "they shall not be destroyed,",
      "verse": "28:17",
      "lineIndex": 95
    },
    {
      "start": 296.091,
      "end": 297.716,
      "type": "line",
      "text": "saith the Lord of Hosts.",
      "verse": "28:17",
      "lineIndex": 96
    },
    {
      "start": 298.396,
      "end": 302.111,
      "type": "line",
      "text": "But behold, that great and abominable church,",
      "verse": "28:18",
      "lineIndex": 97
    },
    {
      "start": 302.291,
      "end": 307.353,
      "type": "line",
      "text": "the whore of all the earth,",
      "verse": "28:18",
      "lineIndex": 98
    },
    {
      "start": 307.533,
      "end": 309.251,
      "type": "line",
      "text": "must tumble to the earth,",
      "verse": "28:18",
      "lineIndex": 99
    },
    {
      "start": 309.431,
      "end": 311.985,
      "type": "line",
      "text": "and great must be the fall thereof.",
      "verse": "28:18",
      "lineIndex": 100
    },
    {
      "start": 312.665,
      "end": 315.776,
      "type": "line",
      "text": "For the kingdom of the devil must shake,",
      "verse": "28:19",
      "lineIndex": 101
    },
    {
      "start": 315.956,
      "end": 321.436,
      "type": "line",
      "text": "and they which belong to it must needs be stirred up unto repentance,",
      "verse": "28:19",
      "lineIndex": 102
    },
    {
      "start": 321.616,
      "end": 326.074,
      "type": "line",
      "text": "or the devil will grasp them with his everlasting chains,",
      "verse": "28:19",
      "lineIndex": 103
    },
    {
      "start": 326.254,
      "end": 329.273,
      "type": "line",
      "text": "and they be stirred up to anger, and perish;",
      "verse": "28:19",
      "lineIndex": 104
    },
    {
      "start": 329.953,
      "end": 335.665,
      "type": "line",
      "text": "For behold, at that day shall he rage in the hearts of the children of men,",
      "verse": "28:20",
      "lineIndex": 105
    },
    {
      "start": 335.845,
      "end": 339.978,
      "type": "line",
      "text": "and stir them up to anger against that which is good.",
      "verse": "28:20",
      "lineIndex": 106
    },
    {
      "start": 340.658,
      "end": 342.794,
      "type": "line",
      "text": "And others will he pacify,",
      "verse": "28:21",
      "lineIndex": 107
    },
    {
      "start": 342.974,
      "end": 346.225,
      "type": "line",
      "text": "and lull them away into carnal security,",
      "verse": "28:21",
      "lineIndex": 108
    },
    {
      "start": 346.405,
      "end": 347.891,
      "type": "line",
      "text": "that they will say:",
      "verse": "28:21",
      "lineIndex": 109
    },
    {
      "start": 348.071,
      "end": 349.836,
      "type": "line",
      "text": "All is well in Zion;",
      "verse": "28:21",
      "lineIndex": 110
    },
    {
      "start": 350.016,
      "end": 352.106,
      "type": "line",
      "text": "yea, Zion prospereth,",
      "verse": "28:21",
      "lineIndex": 111
    },
    {
      "start": 352.286,
      "end": 353.493,
      "type": "line",
      "text": "all is well\u2014",
      "verse": "28:21",
      "lineIndex": 112
    },
    {
      "start": 353.673,
      "end": 356.97,
      "type": "line",
      "text": "and thus the devil cheateth their souls,",
      "verse": "28:21",
      "lineIndex": 113
    },
    {
      "start": 357.15,
      "end": 360.912,
      "type": "line",
      "text": "and leadeth them away carefully down to hell.",
      "verse": "28:21",
      "lineIndex": 114
    },
    {
      "start": 361.592,
      "end": 364.657,
      "type": "line",
      "text": "And behold, others he flattereth away,",
      "verse": "28:22",
      "lineIndex": 115
    },
    {
      "start": 364.837,
      "end": 367.484,
      "type": "line",
      "text": "and telleth them there is no hell;",
      "verse": "28:22",
      "lineIndex": 116
    },
    {
      "start": 367.664,
      "end": 369.475,
      "type": "line",
      "text": "and he saith unto them:",
      "verse": "28:22",
      "lineIndex": 117
    },
    {
      "start": 369.655,
      "end": 371.188,
      "type": "line",
      "text": "I am no devil,",
      "verse": "28:22",
      "lineIndex": 118
    },
    {
      "start": 371.368,
      "end": 378.148,
      "type": "line",
      "text": "for there is none\u2014",
      "verse": "28:22",
      "lineIndex": 119
    },
    {
      "start": 378.328,
      "end": 381.439,
      "type": "line",
      "text": "and thus he whispereth in their ears,",
      "verse": "28:22",
      "lineIndex": 120
    },
    {
      "start": 381.619,
      "end": 385.613,
      "type": "line",
      "text": "until he grasps them with his awful chains,",
      "verse": "28:22",
      "lineIndex": 121
    },
    {
      "start": 385.793,
      "end": 388.115,
      "type": "line",
      "text": "from whence there is no deliverance.",
      "verse": "28:22",
      "lineIndex": 122
    },
    {
      "start": 388.795,
      "end": 392.464,
      "type": "line",
      "text": "Yea, they are grasped with death, and hell;",
      "verse": "28:23",
      "lineIndex": 123
    },
    {
      "start": 392.644,
      "end": 399.796,
      "type": "line",
      "text": "and death, and hell, and the devil, and all that have been seized therewith",
      "verse": "28:23",
      "lineIndex": 124
    },
    {
      "start": 399.976,
      "end": 402.298,
      "type": "line",
      "text": "must stand before the throne of God,",
      "verse": "28:23",
      "lineIndex": 125
    },
    {
      "start": 402.478,
      "end": 405.264,
      "type": "line",
      "text": "and be judged according to their works,",
      "verse": "28:23",
      "lineIndex": 126
    },
    {
      "start": 405.444,
      "end": 409.391,
      "type": "line",
      "text": "from whence they must go into the place prepared for them,",
      "verse": "28:23",
      "lineIndex": 127
    },
    {
      "start": 409.571,
      "end": 412.032,
      "type": "line",
      "text": "even a lake of fire and brimstone,",
      "verse": "28:23",
      "lineIndex": 128
    },
    {
      "start": 412.212,
      "end": 413.93,
      "type": "line",
      "text": "which is endless torment.",
      "verse": "28:23",
      "lineIndex": 129
    },
    {
      "start": 414.61,
      "end": 419.022,
      "type": "line",
      "text": "Therefore, wo be unto him that is at ease in Zion!",
      "verse": "28:24",
      "lineIndex": 130
    },
    {
      "start": 419.702,
      "end": 421.652,
      "type": "line",
      "text": "Wo be unto him that crieth:",
      "verse": "28:25",
      "lineIndex": 131
    },
    {
      "start": 421.832,
      "end": 422.993,
      "type": "line",
      "text": "All is well!",
      "verse": "28:25",
      "lineIndex": 132
    },
    {
      "start": 423.673,
      "end": 428.503,
      "type": "line",
      "text": "Yea, wo be unto him that hearkeneth unto the precepts of men,",
      "verse": "28:26",
      "lineIndex": 134
    },
    {
      "start": 428.683,
      "end": 430.866,
      "type": "line",
      "text": "and denieth the power of God,",
      "verse": "28:26",
      "lineIndex": 135
    },
    {
      "start": 431.046,
      "end": 433.414,
      "type": "line",
      "text": "and the gift of the Holy Ghost!",
      "verse": "28:26",
      "lineIndex": 136
    },
    {
      "start": 434.094,
      "end": 436.788,
      "type": "line",
      "text": "Yea, wo be unto him that saith:",
      "verse": "28:27",
      "lineIndex": 137
    },
    {
      "start": 436.968,
      "end": 438.593,
      "type": "line",
      "text": "We have received,",
      "verse": "28:27",
      "lineIndex": 138
    },
    {
      "start": 438.773,
      "end": 440.398,
      "type": "line",
      "text": "and we need no more!",
      "verse": "28:27",
      "lineIndex": 139
    },
    {
      "start": 441.078,
      "end": 444.097,
      "type": "line",
      "text": "And in fine, wo unto all those",
      "verse": "28:28",
      "lineIndex": 140
    },
    {
      "start": 444.277,
      "end": 448.457,
      "type": "line",
      "text": "who tremble, and are angry because of the truth of God!",
      "verse": "28:28",
      "lineIndex": 141
    },
    {
      "start": 448.637,
      "end": 451.934,
      "type": "line",
      "text": "For behold, he that is built upon the rock",
      "verse": "28:28",
      "lineIndex": 142
    },
    {
      "start": 452.114,
      "end": 454.064,
      "type": "line",
      "text": "receiveth it with gladness;",
      "verse": "28:28",
      "lineIndex": 143
    },
    {
      "start": 454.244,
      "end": 457.727,
      "type": "line",
      "text": "and he that is built upon a sandy foundation",
      "verse": "28:28",
      "lineIndex": 144
    },
    {
      "start": 457.907,
      "end": 460.136,
      "type": "line",
      "text": "trembleth lest he shall fall.",
      "verse": "28:28",
      "lineIndex": 145
    },
    {
      "start": 460.816,
      "end": 463.277,
      "type": "line",
      "text": "Wo be unto him that shall say:",
      "verse": "28:29",
      "lineIndex": 146
    },
    {
      "start": 463.457,
      "end": 465.547,
      "type": "line",
      "text": "We have received the word of God,",
      "verse": "28:29",
      "lineIndex": 147
    },
    {
      "start": 465.727,
      "end": 471.3,
      "type": "line",
      "text": "and we need no more of the word of God,",
      "verse": "28:29",
      "lineIndex": 148
    },
    {
      "start": 471.48,
      "end": 473.059,
      "type": "line",
      "text": "for we have enough!",
      "verse": "28:29",
      "lineIndex": 149
    },
    {
      "start": 473.739,
      "end": 476.525,
      "type": "line",
      "text": "For behold, thus saith the Lord God:",
      "verse": "28:30",
      "lineIndex": 150
    },
    {
      "start": 476.705,
      "end": 479.724,
      "type": "line",
      "text": "I will give unto the children of men",
      "verse": "28:30",
      "lineIndex": 151
    },
    {
      "start": 479.904,
      "end": 481.297,
      "type": "line",
      "text": "line upon line,",
      "verse": "28:30",
      "lineIndex": 152
    },
    {
      "start": 481.477,
      "end": 483.381,
      "type": "line",
      "text": "precept upon precept,",
      "verse": "28:30",
      "lineIndex": 153
    },
    {
      "start": 483.561,
      "end": 484.861,
      "type": "line",
      "text": "here a little",
      "verse": "28:30",
      "lineIndex": 154
    },
    {
      "start": 485.041,
      "end": 486.341,
      "type": "line",
      "text": "and there a little;",
      "verse": "28:30",
      "lineIndex": 155
    },
    {
      "start": 486.521,
      "end": 490.468,
      "type": "line",
      "text": "and blessed are those who hearken unto my precepts,",
      "verse": "28:30",
      "lineIndex": 156
    },
    {
      "start": 490.648,
      "end": 493.249,
      "type": "line",
      "text": "and lend an ear unto my counsel,",
      "verse": "28:30",
      "lineIndex": 157
    },
    {
      "start": 493.429,
      "end": 495.519,
      "type": "line",
      "text": "for they shall learn wisdom;",
      "verse": "28:30",
      "lineIndex": 158
    },
    {
      "start": 495.699,
      "end": 498.393,
      "type": "line",
      "text": "for unto him that receiveth",
      "verse": "28:30",
      "lineIndex": 159
    },
    {
      "start": 498.573,
      "end": 500.152,
      "type": "line",
      "text": "I will give more;",
      "verse": "28:30",
      "lineIndex": 160
    },
    {
      "start": 500.332,
      "end": 503.026,
      "type": "line",
      "text": "and from them that shall say,",
      "verse": "28:30",
      "lineIndex": 161
    },
    {
      "start": 503.206,
      "end": 504.553,
      "type": "line",
      "text": "We have enough,",
      "verse": "28:30",
      "lineIndex": 162
    },
    {
      "start": 504.733,
      "end": 507.101,
      "type": "line",
      "text": "from them shall be taken away",
      "verse": "28:30",
      "lineIndex": 163
    },
    {
      "start": 507.281,
      "end": 509.046,
      "type": "line",
      "text": "even that which they have.",
      "verse": "28:30",
      "lineIndex": 164
    },
    {
      "start": 509.726,
      "end": 512.884,
      "type": "line",
      "text": "Cursed is he that putteth his trust in man,",
      "verse": "28:31",
      "lineIndex": 165
    },
    {
      "start": 513.064,
      "end": 515.293,
      "type": "line",
      "text": "or maketh flesh his arm,",
      "verse": "28:31",
      "lineIndex": 166
    },
    {
      "start": 515.473,
      "end": 518.445,
      "type": "line",
      "text": "or shall hearken unto the precepts of men,",
      "verse": "28:31",
      "lineIndex": 167
    },
    {
      "start": 518.625,
      "end": 523.455,
      "type": "line",
      "text": "save their precepts shall be given by the power of the Holy Ghost.",
      "verse": "28:31",
      "lineIndex": 168
    },
    {
      "start": 524.135,
      "end": 526.225,
      "type": "line",
      "text": "Wo be unto the Gentiles,",
      "verse": "28:32",
      "lineIndex": 169
    },
    {
      "start": 526.405,
      "end": 528.355,
      "type": "line",
      "text": "saith the Lord God of Hosts!",
      "verse": "28:32",
      "lineIndex": 170
    },
    {
      "start": 528.535,
      "end": 534.386,
      "type": "line",
      "text": "For notwithstanding I shall lengthen out mine arm unto them from day to day,",
      "verse": "28:32",
      "lineIndex": 171
    },
    {
      "start": 534.566,
      "end": 535.866,
      "type": "line",
      "text": "they will deny me;",
      "verse": "28:32",
      "lineIndex": 172
    },
    {
      "start": 536.046,
      "end": 539.204,
      "type": "line",
      "text": "nevertheless, I will be merciful unto them,",
      "verse": "28:32",
      "lineIndex": 173
    },
    {
      "start": 539.384,
      "end": 543.796,
      "type": "line",
      "text": "saith the Lord God,",
      "verse": "28:32",
      "lineIndex": 174
    },
    {
      "start": 543.976,
      "end": 546.577,
      "type": "line",
      "text": "if they will repent and come unto me;",
      "verse": "28:32",
      "lineIndex": 175
    },
    {
      "start": 546.757,
      "end": 550.565,
      "type": "line",
      "text": "for mine arm is lengthened out all the day long,",
      "verse": "28:32",
      "lineIndex": 176
    },
    {
      "start": 550.745,
      "end": 553.021,
      "type": "line",
      "text": "saith the Lord God of Hosts.",
      "verse": "28:32",
      "lineIndex": 177
    }
  ]
}