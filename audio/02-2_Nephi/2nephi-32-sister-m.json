{
  "book": "2nephi",
  "bookName": "2 Nephi",
  "chapter": 32,
  "voice": {
    "provider": "elevenlabs",
    "voice_id": "iJpuSZDxZSBJHFSeavba",
    "model_id": "eleven_multilingual_v2",
    "settings": {
      "stability": 0.5,
      "similarity_boost": 0.75,
      "style": 0.35,
      "use_speaker_boost": true
    },
    "name": "sister-m"
  },
  "pauses": {
    "line_ms": 180,
    "verse_ms": 500
  },
  "duration": 44.116,
  "lines": [
    {
      "start": 0.0,
      "end": 0.5,
      "type": "line",
      "text": "And now, behold, my beloved brethren,",
      "verse": "32:1",
      "lineIndex": 1
    },
    {
      "start": 0.68,
      "end": 1.18,
      "type": "line",
      "text": "I suppose that ye ponder somewhat in your hearts",
      "verse": "32:1",
      "lineIndex": 2
    },
    {
      "start": 1.36,
      "end": 1.86,
      "type": "line",
      "text": "concerning that which ye should do after ye have entered in by the way.",
      "verse": "32:1",
      "lineIndex": 3
    },
    {
      "start": 2.04,
      "end": 2.54,
      "type": "line",
      "text": "But, behold, why do ye ponder these things in your hearts?",
      "verse": "32:1",
      "lineIndex": 4
    },
    {
      "start": 3.22,
      "end": 3.72,
      "type": "line",
      "text": "Do ye not remember that I said unto you",
      "verse": "32:2",
      "lineIndex": 5
    },
    {
      "start": 3.9,
      "end": 4.4,
      "type": "line",
      "text": "that after ye had received the Holy Ghost",
      "verse": "32:2",
      "lineIndex": 6
    },
    {
      "start": 4.58,
      "end": 5.08,
      "type": "line",
      "text": "ye could speak with the tongue of angels?",
      "verse": "32:2",
      "lineIndex": 7
    },
    {
      "start": 5.26,
      "end": 5.76,
      "type": "line",
      "text": "And now, how could ye speak with the tongue of angels",
      "verse": "32:2",
      "lineIndex": 8
    },
    {
      "start": 5.94,
      "end": 6.44,
      "type": "line",
      "text": "save it were by the Holy Ghost?",
      "verse": "32:2",
      "lineIndex": 9
    },
    {
      "start": 7.12,
      "end": 7.62,
      "type": "line",
      "text": "Angels speak by the power of the Holy Ghost;",
      "verse": "32:3",
      "lineIndex": 11
    },
    {
      "start": 7.8,
      "end": 8.3,
      "type": "line",
      "text": "wherefore, they speak the words of Christ.",
      "verse": "32:3",
      "lineIndex": 12
    },
    {
      "start": 8.48,
      "end": 8.98,
      "type": "line",
      "text": "Wherefore, I said unto you,",
      "verse": "32:3",
      "lineIndex": 13
    },
    {
      "start": 9.16,
      "end": 9.66,
      "type": "line",
      "text": "feast upon the words of Christ;",
      "verse": "32:3",
      "lineIndex": 14
    },
    {
      "start": 9.84,
      "end": 10.34,
      "type": "line",
      "text": "for behold, the words of Christ will tell you all things what ye should do.",
      "verse": "32:3",
      "lineIndex": 15
    },
    {
      "start": 11.02,
      "end": 11.52,
      "type": "line",
      "text": "Wherefore, now after I have spoken these words,",
      "verse": "32:4",
      "lineIndex": 16
    },
    {
      "start": 11.7,
      "end": 12.2,
      "type": "line",
      "text": "if ye cannot understand them",
      "verse": "32:4",
      "lineIndex": 17
    },
    {
      "start": 12.38,
      "end": 12.88,
      "type": "line",
      "text": "it will be because ye ask not,",
      "verse": "32:4",
      "lineIndex": 18
    },
    {
      "start": 13.06,
      "end": 13.56,
      "type": "line",
      "text": "neither do ye knock;",
      "verse": "32:4",
      "lineIndex": 19
    },
    {
      "start": 13.74,
      "end": 14.24,
      "type": "line",
      "text": "wherefore, ye are not brought into the light,",
      "verse": "32:4",
      "lineIndex": 20
    },
    {
      "start": 14.42,
      "end": 14.92,
      "type": "line",
      "text": "but must perish in the dark.",
      "verse": "32:4",
      "lineIndex": 21
    },
    {
      "start": 15.6,
      "end": 16.1,
      "type": "line",
      "text": "For behold, again I say unto you",
      "verse": "32:5",
      "lineIndex": 22
    },
    {
      "start": 16.28,
      "end": 16.78,
      "type": "line",
      "text": "that if ye will enter in by the way,",
      "verse": "32:5",
      "lineIndex": 23
    },
    {
      "start": 16.96,
      "end": 17.46,
      "type": "line",
      "text": "and receive the Holy Ghost,",
      "verse": "32:5",
      "lineIndex": 24
    },
    {
      "start": 17.64,
      "end": 18.14,
      "type": "line",
      "text": "it will show unto you all things what ye should do.",
      "verse": "32:5",
      "lineIndex": 25
    },
    {
      "start": 18.82,
      "end": 19.32,
      "type": "line",
      "text": "Behold, this is the doctrine of Christ,",
      "verse": "32:6",
      "lineIndex": 26
    },
    {
      "start": 19.5,
      "end": 20.0,
      "type": "line",
      "text": "and there will be no more doctrine given",
      "verse": "32:6",
      "lineIndex": 27
    },
    {
      "start": 20.18,
      "end": 20.68,
      "type": "line",
      "text": "until after he shall manifest himself unto you in the flesh.",
      "verse": "32:6",
      "lineIndex": 28
    },
    {
      "start": 20.86,
      "end": 21.36,
      "type": "line",
      "text": "And when he shall manifest himself unto you in the flesh,",
      "verse": "32:6",
      "lineIndex": 29
    },
    {
      "start": 21.54,
      "end": 22.04,
      "type": "line",
      "text": "the things which he shall say unto you shall ye observe to do.",
      "verse": "32:6",
      "lineIndex": 30
    },
    {
      "start": 22.72,
      "end": 23.22,
      "type": "line",
      "text": "And now I, Nephi, cannot say more;",
      "verse": "32:7",
      "lineIndex": 32
    },
    {
      "start": 23.4,
      "end": 23.9,
      "type": "line",
      "text": "the Spirit stoppeth mine utterance,",
      "verse": "32:7",
      "lineIndex": 33
    },
    {
      "start": 24.08,
      "end": 24.58,
      "type": "line",
      "text": "and I am left to mourn",
      "verse": "32:7",
      "lineIndex": 34
    },
    {
      "start": 24.76,
      "end": 25.26,
      "type": "line",
      "text": "because of the unbelief,",
      "verse": "32:7",
      "lineIndex": 35
    },
    {
      "start": 25.44,
      "end": 25.94,
      "type": "line",
      "text": "and the wickedness,",
      "verse": "32:7",
      "lineIndex": 36
    },
    {
      "start": 26.12,
      "end": 26.62,
      "type": "line",
      "text": "and the ignorance,",
      "verse": "32:7",
      "lineIndex": 37
    },
    {
      "start": 26.8,
      "end": 27.3,
      "type": "line",
      "text": "and the stiffneckedness of men;",
      "verse": "32:7",
      "lineIndex": 38
    },
    {
      "start": 27.48,
      "end": 27.98,
      "type": "line",
      "text": "for they will not search knowledge,",
      "verse": "32:7",
      "lineIndex": 39
    },
    {
      "start": 28.16,
      "end": 28.66,
      "type": "line",
      "text": "nor understand great knowledge,",
      "verse": "32:7",
      "lineIndex": 40
    },
    {
      "start": 28.84,
      "end": 29.34,
      "type": "line",
      "text": "when it is given unto them in plainness,",
      "verse": "32:7",
      "lineIndex": 41
    },
    {
      "start": 29.52,
      "end": 30.02,
      "type": "line",
      "text": "even as plain as word can be.",
      "verse": "32:7",
      "lineIndex": 42
    },
    {
      "start": 30.7,
      "end": 32.743,
      "type": "line",
      "text": "And now, my beloved brethren,",
      "verse": "32:8",
      "lineIndex": 43
    },
    {
      "start": 32.923,
      "end": 33.423,
      "type": "line",
      "text": "I perceive that ye ponder still in your hearts;",
      "verse": "32:8",
      "lineIndex": 44
    },
    {
      "start": 33.603,
      "end": 34.103,
      "type": "line",
      "text": "and it grieveth me that I must speak concerning this thing.",
      "verse": "32:8",
      "lineIndex": 45
    },
    {
      "start": 34.283,
      "end": 34.783,
      "type": "line",
      "text": "For if ye would hearken unto the Spirit",
      "verse": "32:8",
      "lineIndex": 46
    },
    {
      "start": 34.963,
      "end": 35.463,
      "type": "line",
      "text": "which teacheth a man to pray,",
      "verse": "32:8",
      "lineIndex": 47
    },
    {
      "start": 35.643,
      "end": 36.143,
      "type": "line",
      "text": "ye would know that ye must pray;",
      "verse": "32:8",
      "lineIndex": 48
    },
    {
      "start": 36.323,
      "end": 36.823,
      "type": "line",
      "text": "for the evil spirit teacheth not a man to pray,",
      "verse": "32:8",
      "lineIndex": 49
    },
    {
      "start": 37.003,
      "end": 37.503,
      "type": "line",
      "text": "but teacheth him that he must not pray.",
      "verse": "32:8",
      "lineIndex": 50
    },
    {
      "start": 38.183,
      "end": 38.683,
      "type": "line",
      "text": "But behold, I say unto you",
      "verse": "32:9",
      "lineIndex": 51
    },
    {
      "start": 38.863,
      "end": 39.363,
      "type": "line",
      "text": "that ye must pray always,",
      "verse": "32:9",
      "lineIndex": 52
    },
    {
      "start": 39.543,
      "end": 40.043,
      "type": "line",
      "text": "and not faint;",
      "verse": "32:9",
      "lineIndex": 53
    },
    {
      "start": 40.223,
      "end": 40.723,
      "type": "line",
      "text": "that ye must not perform any thing unto the Lord",
      "verse": "32:9",
      "lineIndex": 54
    },
    {
      "start": 40.903,
      "end": 41.403,
      "type": "line",
      "text": "save in the first place ye shall pray unto the Father",
      "verse": "32:9",
      "lineIndex": 55
    },
    {
      "start": 41.583,
      "end": 42.083,
      "type": "line",
      "text": "in the name of Christ,",
      "verse": "32:9",
      "lineIndex": 56
    },
    {
      "start": 42.263,
      "end": 42.763,
      "type": "line",
      "text": "that he will consecrate thy performance unto thee,",
      "verse": "32:9",
      "lineIndex": 57
    },
    {
      "start": 42.943,
      "end": 43.443,
      "type": "line",
      "text": "that thy performance may be for the welfare of thy soul.",
      "verse": "32:9",
      "lineIndex": 58
    }
  ]
}