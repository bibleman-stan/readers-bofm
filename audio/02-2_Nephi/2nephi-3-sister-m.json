{
  "book": "2nephi",
  "bookName": "2 Nephi",
  "chapter": 3,
  "voice": {
    "provider": "elevenlabs",
    "voice_id": "iJpuSZDxZSBJHFSeavba",
    "model_id": "eleven_multilingual_v2",
    "settings": {
      "stability": 0.5,
      "similarity_boost": 0.75,
      "style": 0.35,
      "use_speaker_boost": true
    },
    "name": "sister-m"
  },
  "pauses": {
    "line_ms": 180,
    "verse_ms": 500
  },
  "duration": 493.692,
  "lines": [
    {
      "start": 0.0,
      "end": 4.133,
      "type": "line",
      "text": "And now I speak unto you, Joseph, my last-born.",
      "verse": "3:1",
      "lineIndex": 1
    },
    {
      "start": 4.313,
      "end": 8.028,
      "type": "line",
      "text": "Thou wast born in the wilderness of mine afflictions;",
      "verse": "3:1",
      "lineIndex": 2
    },
    {
      "start": 8.208,
      "end": 13.409,
      "type": "line",
      "text": "yea, in the days of my greatest sorrow did thy mother bear thee.",
      "verse": "3:1",
      "lineIndex": 3
    },
    {
      "start": 14.089,
      "end": 18.315,
      "type": "line",
      "text": "And may the Lord consecrate also unto thee this land,",
      "verse": "3:2",
      "lineIndex": 4
    },
    {
      "start": 18.495,
      "end": 20.771,
      "type": "line",
      "text": "which is a most precious land,",
      "verse": "3:2",
      "lineIndex": 5
    },
    {
      "start": 20.951,
      "end": 25.967,
      "type": "line",
      "text": "for thine inheritance and the inheritance of thy seed with thy brethren,",
      "verse": "3:2",
      "lineIndex": 6
    },
    {
      "start": 26.147,
      "end": 28.376,
      "type": "line",
      "text": "for thy security forever,",
      "verse": "3:2",
      "lineIndex": 7
    },
    {
      "start": 28.556,
      "end": 33.804,
      "type": "line",
      "text": "if it so be that ye shall keep the commandments of the Holy One of Israel.",
      "verse": "3:2",
      "lineIndex": 8
    },
    {
      "start": 34.484,
      "end": 37.317,
      "type": "line",
      "text": "And now, Joseph, my last-born,",
      "verse": "3:3",
      "lineIndex": 9
    },
    {
      "start": 37.497,
      "end": 41.862,
      "type": "line",
      "text": "whom I have brought out of the wilderness of mine afflictions,",
      "verse": "3:3",
      "lineIndex": 10
    },
    {
      "start": 42.042,
      "end": 44.178,
      "type": "line",
      "text": "may the Lord bless thee forever,",
      "verse": "3:3",
      "lineIndex": 11
    },
    {
      "start": 44.358,
      "end": 47.655,
      "type": "line",
      "text": "for thy seed shall not utterly be destroyed.",
      "verse": "3:3",
      "lineIndex": 12
    },
    {
      "start": 48.335,
      "end": 51.911,
      "type": "line",
      "text": "For behold, thou art the fruit of my loins;",
      "verse": "3:4",
      "lineIndex": 14
    },
    {
      "start": 52.091,
      "end": 57.432,
      "type": "line",
      "text": "and I am a descendant of Joseph who was carried captive into Egypt.",
      "verse": "3:4",
      "lineIndex": 15
    },
    {
      "start": 57.612,
      "end": 62.442,
      "type": "line",
      "text": "And great were the covenants of the Lord which he made unto Joseph.",
      "verse": "3:4",
      "lineIndex": 16
    },
    {
      "start": 63.122,
      "end": 66.187,
      "type": "line",
      "text": "Wherefore, Joseph truly saw our day.",
      "verse": "3:5",
      "lineIndex": 17
    },
    {
      "start": 66.367,
      "end": 68.782,
      "type": "line",
      "text": "And he obtained a promise of the Lord,",
      "verse": "3:5",
      "lineIndex": 18
    },
    {
      "start": 68.962,
      "end": 71.656,
      "type": "line",
      "text": "that out of the fruit of his loins",
      "verse": "3:5",
      "lineIndex": 19
    },
    {
      "start": 71.836,
      "end": 77.084,
      "type": "line",
      "text": "the Lord God would raise up a righteous branch unto the house of Israel;",
      "verse": "3:5",
      "lineIndex": 20
    },
    {
      "start": 77.264,
      "end": 81.49,
      "type": "line",
      "text": "not the Messiah, but a branch which was to be broken off,",
      "verse": "3:5",
      "lineIndex": 21
    },
    {
      "start": 81.67,
      "end": 85.803,
      "type": "line",
      "text": "nevertheless, to be remembered in the covenants of the Lord",
      "verse": "3:5",
      "lineIndex": 22
    },
    {
      "start": 85.983,
      "end": 90.813,
      "type": "line",
      "text": "that the Messiah should be made manifest unto them in the latter days,",
      "verse": "3:5",
      "lineIndex": 23
    },
    {
      "start": 90.993,
      "end": 92.99,
      "type": "line",
      "text": "in the spirit of power,",
      "verse": "3:5",
      "lineIndex": 24
    },
    {
      "start": 93.17,
      "end": 97.303,
      "type": "line",
      "text": "unto the bringing of them out of darkness unto light\u2014",
      "verse": "3:5",
      "lineIndex": 25
    },
    {
      "start": 97.483,
      "end": 100.084,
      "type": "line",
      "text": "yea, out of hidden darkness",
      "verse": "3:5",
      "lineIndex": 26
    },
    {
      "start": 100.264,
      "end": 103.19,
      "type": "line",
      "text": "and out of captivity unto freedom.",
      "verse": "3:5",
      "lineIndex": 27
    },
    {
      "start": 103.87,
      "end": 106.61,
      "type": "line",
      "text": "For Joseph truly testified, saying:",
      "verse": "3:6",
      "lineIndex": 29
    },
    {
      "start": 106.79,
      "end": 110.087,
      "type": "line",
      "text": "A seer shall the Lord my God raise up,",
      "verse": "3:6",
      "lineIndex": 30
    },
    {
      "start": 110.267,
      "end": 114.075,
      "type": "line",
      "text": "who shall be a choice seer unto the fruit of my loins.",
      "verse": "3:6",
      "lineIndex": 31
    },
    {
      "start": 114.755,
      "end": 116.938,
      "type": "line",
      "text": "Yea, Joseph truly said:",
      "verse": "3:7",
      "lineIndex": 32
    },
    {
      "start": 117.118,
      "end": 119.022,
      "type": "line",
      "text": "Thus saith the Lord unto me:",
      "verse": "3:7",
      "lineIndex": 33
    },
    {
      "start": 119.202,
      "end": 121.756,
      "type": "line",
      "text": "A choice seer will I raise up",
      "verse": "3:7",
      "lineIndex": 34
    },
    {
      "start": 121.936,
      "end": 124.212,
      "type": "line",
      "text": "out of the fruit of thy loins;",
      "verse": "3:7",
      "lineIndex": 35
    },
    {
      "start": 124.392,
      "end": 126.9,
      "type": "line",
      "text": "and he shall be esteemed highly",
      "verse": "3:7",
      "lineIndex": 36
    },
    {
      "start": 127.08,
      "end": 129.356,
      "type": "line",
      "text": "among the fruit of thy loins.",
      "verse": "3:7",
      "lineIndex": 37
    },
    {
      "start": 129.536,
      "end": 132.23,
      "type": "line",
      "text": "And unto him will I give commandment",
      "verse": "3:7",
      "lineIndex": 38
    },
    {
      "start": 132.41,
      "end": 137.193,
      "type": "line",
      "text": "that he shall do a work for the fruit of thy loins, his brethren,",
      "verse": "3:7",
      "lineIndex": 39
    },
    {
      "start": 137.373,
      "end": 140.392,
      "type": "line",
      "text": "which shall be of great worth unto them,",
      "verse": "3:7",
      "lineIndex": 40
    },
    {
      "start": 140.572,
      "end": 144.659,
      "type": "line",
      "text": "even to the bringing of them to the knowledge of the covenants",
      "verse": "3:7",
      "lineIndex": 41
    },
    {
      "start": 144.839,
      "end": 147.161,
      "type": "line",
      "text": "which I have made with thy fathers.",
      "verse": "3:7",
      "lineIndex": 42
    },
    {
      "start": 147.841,
      "end": 153.832,
      "type": "line",
      "text": "And I will give unto him a commandment that he shall do none other work,",
      "verse": "3:8",
      "lineIndex": 43
    },
    {
      "start": 154.012,
      "end": 156.566,
      "type": "line",
      "text": "save the work which I shall command him.",
      "verse": "3:8",
      "lineIndex": 44
    },
    {
      "start": 156.746,
      "end": 159.904,
      "type": "line",
      "text": "And I will make him great in mine eyes;",
      "verse": "3:8",
      "lineIndex": 45
    },
    {
      "start": 160.084,
      "end": 162.127,
      "type": "line",
      "text": "for he shall do my work.",
      "verse": "3:8",
      "lineIndex": 46
    },
    {
      "start": 162.807,
      "end": 165.733,
      "type": "line",
      "text": "And he shall be great like unto Moses,",
      "verse": "3:9",
      "lineIndex": 47
    },
    {
      "start": 165.913,
      "end": 169.164,
      "type": "line",
      "text": "whom I have said I would raise up unto you,",
      "verse": "3:9",
      "lineIndex": 48
    },
    {
      "start": 169.344,
      "end": 172.688,
      "type": "line",
      "text": "to deliver my people, O house of Israel.",
      "verse": "3:9",
      "lineIndex": 49
    },
    {
      "start": 173.368,
      "end": 175.736,
      "type": "line",
      "text": "And Moses will I raise up,",
      "verse": "3:10",
      "lineIndex": 50
    },
    {
      "start": 175.916,
      "end": 179.213,
      "type": "line",
      "text": "to deliver thy people out of the land of Egypt.",
      "verse": "3:10",
      "lineIndex": 51
    },
    {
      "start": 179.893,
      "end": 182.215,
      "type": "line",
      "text": "But a seer will I raise up",
      "verse": "3:11",
      "lineIndex": 52
    },
    {
      "start": 182.395,
      "end": 184.671,
      "type": "line",
      "text": "out of the fruit of thy loins;",
      "verse": "3:11",
      "lineIndex": 53
    },
    {
      "start": 184.851,
      "end": 187.452,
      "type": "line",
      "text": "and unto him will I give power",
      "verse": "3:11",
      "lineIndex": 54
    },
    {
      "start": 187.632,
      "end": 189.35,
      "type": "line",
      "text": "to bring forth my word",
      "verse": "3:11",
      "lineIndex": 55
    },
    {
      "start": 189.53,
      "end": 194.871,
      "type": "line",
      "text": "unto the seed of thy loins\u2014",
      "verse": "3:11",
      "lineIndex": 56
    },
    {
      "start": 195.051,
      "end": 198.162,
      "type": "line",
      "text": "and not to the bringing forth my word only,",
      "verse": "3:11",
      "lineIndex": 57
    },
    {
      "start": 198.342,
      "end": 202.289,
      "type": "line",
      "text": "saith the Lord,",
      "verse": "3:11",
      "lineIndex": 58
    },
    {
      "start": 202.469,
      "end": 205.116,
      "type": "line",
      "text": "but to the convincing them of my word,",
      "verse": "3:11",
      "lineIndex": 59
    },
    {
      "start": 205.296,
      "end": 208.407,
      "type": "line",
      "text": "which shall have already gone forth among them.",
      "verse": "3:11",
      "lineIndex": 60
    },
    {
      "start": 209.087,
      "end": 212.059,
      "type": "line",
      "text": "Wherefore, the fruit of thy loins shall write;",
      "verse": "3:12",
      "lineIndex": 61
    },
    {
      "start": 212.239,
      "end": 215.676,
      "type": "line",
      "text": "and the fruit of the loins of Judah shall write;",
      "verse": "3:12",
      "lineIndex": 62
    },
    {
      "start": 215.856,
      "end": 217.946,
      "type": "line",
      "text": "and that which shall be written",
      "verse": "3:12",
      "lineIndex": 63
    },
    {
      "start": 218.126,
      "end": 220.309,
      "type": "line",
      "text": "by the fruit of thy loins,",
      "verse": "3:12",
      "lineIndex": 64
    },
    {
      "start": 220.489,
      "end": 223.229,
      "type": "line",
      "text": "and also that which shall be written",
      "verse": "3:12",
      "lineIndex": 65
    },
    {
      "start": 223.409,
      "end": 225.777,
      "type": "line",
      "text": "by the fruit of the loins of Judah,",
      "verse": "3:12",
      "lineIndex": 66
    },
    {
      "start": 225.957,
      "end": 227.629,
      "type": "line",
      "text": "shall grow together,",
      "verse": "3:12",
      "lineIndex": 67
    },
    {
      "start": 227.809,
      "end": 231.246,
      "type": "line",
      "text": "unto the confounding of false doctrines",
      "verse": "3:12",
      "lineIndex": 68
    },
    {
      "start": 231.426,
      "end": 233.794,
      "type": "line",
      "text": "and laying down of contentions,",
      "verse": "3:12",
      "lineIndex": 69
    },
    {
      "start": 233.974,
      "end": 237.829,
      "type": "line",
      "text": "and establishing peace among the fruit of thy loins,",
      "verse": "3:12",
      "lineIndex": 70
    },
    {
      "start": 238.009,
      "end": 242.885,
      "type": "line",
      "text": "and bringing them to the knowledge of their fathers in the latter days,",
      "verse": "3:12",
      "lineIndex": 71
    },
    {
      "start": 243.065,
      "end": 247.663,
      "type": "line",
      "text": "and also to the knowledge of my covenants, saith the Lord.",
      "verse": "3:12",
      "lineIndex": 72
    },
    {
      "start": 248.343,
      "end": 252.708,
      "type": "line",
      "text": "And out of weakness he shall be made strong, in that day",
      "verse": "3:13",
      "lineIndex": 73
    },
    {
      "start": 252.888,
      "end": 256.325,
      "type": "line",
      "text": "when my work shall commence among all my people,",
      "verse": "3:13",
      "lineIndex": 74
    },
    {
      "start": 256.505,
      "end": 258.688,
      "type": "line",
      "text": "unto the restoring thee,",
      "verse": "3:13",
      "lineIndex": 75
    },
    {
      "start": 258.868,
      "end": 261.84,
      "type": "line",
      "text": "O house of Israel, saith the Lord.",
      "verse": "3:13",
      "lineIndex": 76
    },
    {
      "start": 262.52,
      "end": 265.074,
      "type": "line",
      "text": "And thus prophesied Joseph, saying:",
      "verse": "3:14",
      "lineIndex": 77
    },
    {
      "start": 265.254,
      "end": 268.365,
      "type": "line",
      "text": "Behold, that seer will the Lord bless;",
      "verse": "3:14",
      "lineIndex": 78
    },
    {
      "start": 268.545,
      "end": 272.214,
      "type": "line",
      "text": "and they that seek to destroy him shall be confounded;",
      "verse": "3:14",
      "lineIndex": 79
    },
    {
      "start": 272.394,
      "end": 275.97,
      "type": "line",
      "text": "for this promise, which I have obtained of the Lord,",
      "verse": "3:14",
      "lineIndex": 80
    },
    {
      "start": 276.15,
      "end": 279.54,
      "type": "line",
      "text": "of the fruit of my loins, shall be fulfilled.",
      "verse": "3:14",
      "lineIndex": 81
    },
    {
      "start": 279.72,
      "end": 283.667,
      "type": "line",
      "text": "Behold, I am sure of the fulfilling of this promise;",
      "verse": "3:14",
      "lineIndex": 82
    },
    {
      "start": 284.347,
      "end": 286.948,
      "type": "line",
      "text": "And his name shall be called after me;",
      "verse": "3:15",
      "lineIndex": 84
    },
    {
      "start": 287.128,
      "end": 290.239,
      "type": "line",
      "text": "and it shall be after the name of his father.",
      "verse": "3:15",
      "lineIndex": 85
    },
    {
      "start": 290.419,
      "end": 292.555,
      "type": "line",
      "text": "And he shall be like unto me;",
      "verse": "3:15",
      "lineIndex": 86
    },
    {
      "start": 292.735,
      "end": 296.961,
      "type": "line",
      "text": "for the thing, which the Lord shall bring forth by his hand,",
      "verse": "3:15",
      "lineIndex": 87
    },
    {
      "start": 297.141,
      "end": 298.813,
      "type": "line",
      "text": "by the power of the Lord",
      "verse": "3:15",
      "lineIndex": 88
    },
    {
      "start": 298.993,
      "end": 301.826,
      "type": "line",
      "text": "shall bring my people unto salvation.",
      "verse": "3:15",
      "lineIndex": 89
    },
    {
      "start": 302.506,
      "end": 305.06,
      "type": "line",
      "text": "Yea, thus prophesied Joseph:",
      "verse": "3:16",
      "lineIndex": 90
    },
    {
      "start": 305.24,
      "end": 307.19,
      "type": "line",
      "text": "I am sure of this thing,",
      "verse": "3:16",
      "lineIndex": 91
    },
    {
      "start": 307.37,
      "end": 310.389,
      "type": "line",
      "text": "even as I am sure of the promise of Moses;",
      "verse": "3:16",
      "lineIndex": 92
    },
    {
      "start": 310.569,
      "end": 312.705,
      "type": "line",
      "text": "for the Lord hath said unto me,",
      "verse": "3:16",
      "lineIndex": 93
    },
    {
      "start": 312.885,
      "end": 315.486,
      "type": "line",
      "text": "I will preserve thy seed forever.",
      "verse": "3:16",
      "lineIndex": 94
    },
    {
      "start": 316.166,
      "end": 317.699,
      "type": "line",
      "text": "And the Lord hath said:",
      "verse": "3:17",
      "lineIndex": 95
    },
    {
      "start": 317.879,
      "end": 320.015,
      "type": "line",
      "text": "I will raise up a Moses;",
      "verse": "3:17",
      "lineIndex": 96
    },
    {
      "start": 320.195,
      "end": 323.167,
      "type": "line",
      "text": "and I will give power unto him in a rod;",
      "verse": "3:17",
      "lineIndex": 97
    },
    {
      "start": 323.347,
      "end": 326.83,
      "type": "line",
      "text": "and I will give judgment unto him in writing.",
      "verse": "3:17",
      "lineIndex": 98
    },
    {
      "start": 327.01,
      "end": 329.332,
      "type": "line",
      "text": "Yet I will not loose his tongue,",
      "verse": "3:17",
      "lineIndex": 99
    },
    {
      "start": 329.512,
      "end": 331.277,
      "type": "line",
      "text": "that he shall speak much,",
      "verse": "3:17",
      "lineIndex": 100
    },
    {
      "start": 331.457,
      "end": 334.336,
      "type": "line",
      "text": "for I will not make him mighty in speaking.",
      "verse": "3:17",
      "lineIndex": 101
    },
    {
      "start": 334.516,
      "end": 337.349,
      "type": "line",
      "text": "But I will write unto him my law,",
      "verse": "3:17",
      "lineIndex": 102
    },
    {
      "start": 337.529,
      "end": 339.944,
      "type": "line",
      "text": "by the finger of mine own hand;",
      "verse": "3:17",
      "lineIndex": 103
    },
    {
      "start": 340.124,
      "end": 342.957,
      "type": "line",
      "text": "and I will make a spokesman for him.",
      "verse": "3:17",
      "lineIndex": 104
    },
    {
      "start": 343.637,
      "end": 346.098,
      "type": "line",
      "text": "And the Lord said unto me also:",
      "verse": "3:18",
      "lineIndex": 105
    },
    {
      "start": 346.278,
      "end": 349.389,
      "type": "line",
      "text": "I will raise up unto the fruit of thy loins;",
      "verse": "3:18",
      "lineIndex": 106
    },
    {
      "start": 349.569,
      "end": 352.448,
      "type": "line",
      "text": "and I will make for him a spokesman.",
      "verse": "3:18",
      "lineIndex": 107
    },
    {
      "start": 352.628,
      "end": 355.925,
      "type": "line",
      "text": "And I, behold, I will give unto him",
      "verse": "3:18",
      "lineIndex": 108
    },
    {
      "start": 356.105,
      "end": 360.424,
      "type": "line",
      "text": "that he shall write the writing of the fruit of thy loins,",
      "verse": "3:18",
      "lineIndex": 109
    },
    {
      "start": 360.604,
      "end": 362.694,
      "type": "line",
      "text": "unto the fruit of thy loins;",
      "verse": "3:18",
      "lineIndex": 110
    },
    {
      "start": 362.874,
      "end": 366.171,
      "type": "line",
      "text": "and the spokesman of thy loins shall declare it.",
      "verse": "3:18",
      "lineIndex": 111
    },
    {
      "start": 366.851,
      "end": 369.08,
      "type": "line",
      "text": "And the words which he shall write",
      "verse": "3:19",
      "lineIndex": 112
    },
    {
      "start": 369.26,
      "end": 374.276,
      "type": "line",
      "text": "shall be the words which are expedient in my wisdom should go forth",
      "verse": "3:19",
      "lineIndex": 113
    },
    {
      "start": 374.456,
      "end": 376.406,
      "type": "line",
      "text": "unto the fruit of thy loins.",
      "verse": "3:19",
      "lineIndex": 114
    },
    {
      "start": 376.586,
      "end": 382.391,
      "type": "line",
      "text": "And it shall be as if the fruit of thy loins had cried unto them from the dust;",
      "verse": "3:19",
      "lineIndex": 115
    },
    {
      "start": 382.571,
      "end": 384.104,
      "type": "line",
      "text": "for I know their faith.",
      "verse": "3:19",
      "lineIndex": 116
    },
    {
      "start": 384.784,
      "end": 386.92,
      "type": "line",
      "text": "And they shall cry from the dust;",
      "verse": "3:20",
      "lineIndex": 117
    },
    {
      "start": 387.1,
      "end": 390.583,
      "type": "line",
      "text": "yea, even repentance unto their brethren,",
      "verse": "3:20",
      "lineIndex": 118
    },
    {
      "start": 390.763,
      "end": 394.153,
      "type": "line",
      "text": "even after many generations have gone by them.",
      "verse": "3:20",
      "lineIndex": 119
    },
    {
      "start": 394.333,
      "end": 397.537,
      "type": "line",
      "text": "And it shall come to pass that their cry shall go,",
      "verse": "3:20",
      "lineIndex": 120
    },
    {
      "start": 397.717,
      "end": 400.921,
      "type": "line",
      "text": "even according to the simpleness of their words.",
      "verse": "3:20",
      "lineIndex": 121
    },
    {
      "start": 401.601,
      "end": 403.087,
      "type": "line",
      "text": "Because of their faith",
      "verse": "3:21",
      "lineIndex": 122
    },
    {
      "start": 403.267,
      "end": 406.843,
      "type": "line",
      "text": "their words shall proceed forth out of my mouth",
      "verse": "3:21",
      "lineIndex": 123
    },
    {
      "start": 407.023,
      "end": 410.599,
      "type": "line",
      "text": "unto their brethren who are the fruit of thy loins;",
      "verse": "3:21",
      "lineIndex": 124
    },
    {
      "start": 410.779,
      "end": 413.101,
      "type": "line",
      "text": "and the weakness of their words",
      "verse": "3:21",
      "lineIndex": 125
    },
    {
      "start": 413.281,
      "end": 415.417,
      "type": "line",
      "text": "will I make strong in their faith,",
      "verse": "3:21",
      "lineIndex": 126
    },
    {
      "start": 415.597,
      "end": 420.613,
      "type": "line",
      "text": "unto the remembering of my covenant which I made unto thy fathers.",
      "verse": "3:21",
      "lineIndex": 127
    },
    {
      "start": 421.293,
      "end": 424.265,
      "type": "line",
      "text": "And now, behold, my son Joseph,",
      "verse": "3:22",
      "lineIndex": 128
    },
    {
      "start": 424.445,
      "end": 428.392,
      "type": "line",
      "text": "after this manner did my father of old prophesy.",
      "verse": "3:22",
      "lineIndex": 129
    },
    {
      "start": 429.072,
      "end": 432.648,
      "type": "line",
      "text": "Wherefore, because of this covenant thou art blessed;",
      "verse": "3:23",
      "lineIndex": 130
    },
    {
      "start": 432.828,
      "end": 434.964,
      "type": "line",
      "text": "for thy seed shall not be destroyed,",
      "verse": "3:23",
      "lineIndex": 131
    },
    {
      "start": 435.144,
      "end": 438.627,
      "type": "line",
      "text": "for they shall hearken unto the words of the book.",
      "verse": "3:23",
      "lineIndex": 132
    },
    {
      "start": 439.307,
      "end": 442.79,
      "type": "line",
      "text": "And there shall rise up one mighty among them,",
      "verse": "3:24",
      "lineIndex": 133
    },
    {
      "start": 442.97,
      "end": 444.642,
      "type": "line",
      "text": "who shall do much good,",
      "verse": "3:24",
      "lineIndex": 134
    },
    {
      "start": 444.822,
      "end": 446.772,
      "type": "line",
      "text": "both in word and in deed,",
      "verse": "3:24",
      "lineIndex": 135
    },
    {
      "start": 446.952,
      "end": 453.5,
      "type": "line",
      "text": "being an instrument in the hands of God,",
      "verse": "3:24",
      "lineIndex": 136
    },
    {
      "start": 453.68,
      "end": 455.305,
      "type": "line",
      "text": "with exceeding faith,",
      "verse": "3:24",
      "lineIndex": 137
    },
    {
      "start": 455.485,
      "end": 457.853,
      "type": "line",
      "text": "to work mighty wonders,",
      "verse": "3:24",
      "lineIndex": 138
    },
    {
      "start": 458.033,
      "end": 464.813,
      "type": "line",
      "text": "and do that thing which is great in the sight of God,",
      "verse": "3:24",
      "lineIndex": 139
    },
    {
      "start": 464.993,
      "end": 470.426,
      "type": "line",
      "text": "unto the bringing to pass much restoration unto the house of Israel,",
      "verse": "3:24",
      "lineIndex": 140
    },
    {
      "start": 470.606,
      "end": 472.974,
      "type": "line",
      "text": "and unto the seed of thy brethren.",
      "verse": "3:24",
      "lineIndex": 141
    },
    {
      "start": 473.654,
      "end": 476.673,
      "type": "line",
      "text": "And now, blessed art thou, Joseph.",
      "verse": "3:25",
      "lineIndex": 142
    },
    {
      "start": 476.853,
      "end": 478.989,
      "type": "line",
      "text": "Behold, thou art little;",
      "verse": "3:25",
      "lineIndex": 143
    },
    {
      "start": 479.169,
      "end": 483.163,
      "type": "line",
      "text": "wherefore hearken unto the words of thy brother, Nephi,",
      "verse": "3:25",
      "lineIndex": 144
    },
    {
      "start": 483.343,
      "end": 485.665,
      "type": "line",
      "text": "and it shall be done unto thee",
      "verse": "3:25",
      "lineIndex": 145
    },
    {
      "start": 485.845,
      "end": 488.956,
      "type": "line",
      "text": "even according to the words which I have spoken.",
      "verse": "3:25",
      "lineIndex": 146
    },
    {
      "start": 489.136,
      "end": 492.015,
      "type": "line",
      "text": "Remember the words of thy dying father.",
      "verse": "3:25",
      "lineIndex": 147
    },
    {
      "start": 492.195,
      "end": 493.031,
      "type": "line",
      "text": "Amen.",
      "verse": "3:25",
      "lineIndex": 148
    }
  ]
}