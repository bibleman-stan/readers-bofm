{
  "book": "2nephi",
  "bookName": "2 Nephi",
  "chapter": 26,
  "voice": {
    "provider": "elevenlabs",
    "voice_id": "iJpuSZDxZSBJHFSeavba",
    "model_id": "eleven_multilingual_v2",
    "settings": {
      "stability": 0.5,
      "similarity_boost": 0.75,
      "style": 0.35,
      "use_speaker_boost": true
    },
    "name": "sister-m"
  },
  "pauses": {
    "line_ms": 180,
    "verse_ms": 500
  },
  "duration": 653.291,
  "lines": [
    {
      "start": 0.0,
      "end": 3.39,
      "type": "line",
      "text": "And after Christ shall have risen from the dead",
      "verse": "26:1",
      "lineIndex": 1
    },
    {
      "start": 3.57,
      "end": 6.124,
      "type": "line",
      "text": "he shall show himself unto you,",
      "verse": "26:1",
      "lineIndex": 2
    },
    {
      "start": 6.304,
      "end": 8.998,
      "type": "line",
      "text": "my children, and my beloved brethren;",
      "verse": "26:1",
      "lineIndex": 3
    },
    {
      "start": 9.178,
      "end": 11.779,
      "type": "line",
      "text": "and the words which he shall speak",
      "verse": "26:1",
      "lineIndex": 4
    },
    {
      "start": 11.959,
      "end": 15.303,
      "type": "line",
      "text": "unto you shall be the law which ye shall do.",
      "verse": "26:1",
      "lineIndex": 5
    },
    {
      "start": 15.983,
      "end": 18.351,
      "type": "line",
      "text": "For behold, I say unto you",
      "verse": "26:2",
      "lineIndex": 6
    },
    {
      "start": 18.531,
      "end": 23.082,
      "type": "line",
      "text": "that I have beheld that many generations shall pass away,",
      "verse": "26:2",
      "lineIndex": 7
    },
    {
      "start": 23.262,
      "end": 28.138,
      "type": "line",
      "text": "and there shall be great wars and contentions among my people.",
      "verse": "26:2",
      "lineIndex": 8
    },
    {
      "start": 28.818,
      "end": 31.419,
      "type": "line",
      "text": "And after the Messiah shall come",
      "verse": "26:3",
      "lineIndex": 9
    },
    {
      "start": 31.599,
      "end": 35.546,
      "type": "line",
      "text": "there shall be signs given unto my people of his birth,",
      "verse": "26:3",
      "lineIndex": 10
    },
    {
      "start": 35.726,
      "end": 38.512,
      "type": "line",
      "text": "and also of his death and resurrection;",
      "verse": "26:3",
      "lineIndex": 11
    },
    {
      "start": 38.692,
      "end": 43.243,
      "type": "line",
      "text": "and great and terrible shall that day be unto the wicked,",
      "verse": "26:3",
      "lineIndex": 12
    },
    {
      "start": 43.423,
      "end": 45.002,
      "type": "line",
      "text": "for they shall perish;",
      "verse": "26:3",
      "lineIndex": 13
    },
    {
      "start": 45.182,
      "end": 50.244,
      "type": "line",
      "text": "and they perish because they cast out the prophets, and the saints,",
      "verse": "26:3",
      "lineIndex": 14
    },
    {
      "start": 50.424,
      "end": 53.118,
      "type": "line",
      "text": "and stone them, and slay them;",
      "verse": "26:3",
      "lineIndex": 15
    },
    {
      "start": 53.298,
      "end": 56.224,
      "type": "line",
      "text": "wherefore the cry of the blood of the saints",
      "verse": "26:3",
      "lineIndex": 16
    },
    {
      "start": 56.404,
      "end": 60.259,
      "type": "line",
      "text": "shall ascend up to God from the ground against them.",
      "verse": "26:3",
      "lineIndex": 17
    },
    {
      "start": 60.939,
      "end": 63.493,
      "type": "line",
      "text": "Wherefore, all those who are proud,",
      "verse": "26:4",
      "lineIndex": 18
    },
    {
      "start": 63.673,
      "end": 65.438,
      "type": "line",
      "text": "and that do wickedly,",
      "verse": "26:4",
      "lineIndex": 19
    },
    {
      "start": 65.618,
      "end": 68.683,
      "type": "line",
      "text": "the day that cometh shall burn them up,",
      "verse": "26:4",
      "lineIndex": 20
    },
    {
      "start": 68.863,
      "end": 70.674,
      "type": "line",
      "text": "saith the Lord of Hosts,",
      "verse": "26:4",
      "lineIndex": 21
    },
    {
      "start": 70.854,
      "end": 72.944,
      "type": "line",
      "text": "for they shall be as stubble.",
      "verse": "26:4",
      "lineIndex": 22
    },
    {
      "start": 73.624,
      "end": 77.107,
      "type": "line",
      "text": "And they that kill the prophets, and the saints,",
      "verse": "26:5",
      "lineIndex": 24
    },
    {
      "start": 77.287,
      "end": 80.631,
      "type": "line",
      "text": "the depths of the earth shall swallow them up,",
      "verse": "26:5",
      "lineIndex": 25
    },
    {
      "start": 80.811,
      "end": 82.436,
      "type": "line",
      "text": "saith the Lord of Hosts;",
      "verse": "26:5",
      "lineIndex": 26
    },
    {
      "start": 82.616,
      "end": 84.706,
      "type": "line",
      "text": "and mountains shall cover them,",
      "verse": "26:5",
      "lineIndex": 27
    },
    {
      "start": 84.886,
      "end": 87.672,
      "type": "line",
      "text": "and whirlwinds shall carry them away,",
      "verse": "26:5",
      "lineIndex": 28
    },
    {
      "start": 87.852,
      "end": 90.499,
      "type": "line",
      "text": "and buildings shall fall upon them",
      "verse": "26:5",
      "lineIndex": 29
    },
    {
      "start": 90.679,
      "end": 94.208,
      "type": "line",
      "text": "and crush them to pieces and grind them to powder.",
      "verse": "26:5",
      "lineIndex": 30
    },
    {
      "start": 94.888,
      "end": 98.928,
      "type": "line",
      "text": "And they shall be visited with thunderings, and lightnings,",
      "verse": "26:6",
      "lineIndex": 31
    },
    {
      "start": 99.108,
      "end": 103.009,
      "type": "line",
      "text": "and earthquakes, and all manner of destructions,",
      "verse": "26:6",
      "lineIndex": 32
    },
    {
      "start": 103.189,
      "end": 107.647,
      "type": "line",
      "text": "for the fire of the anger of the Lord shall be kindled against them,",
      "verse": "26:6",
      "lineIndex": 33
    },
    {
      "start": 107.827,
      "end": 110.01,
      "type": "line",
      "text": "and they shall be as stubble,",
      "verse": "26:6",
      "lineIndex": 34
    },
    {
      "start": 110.19,
      "end": 113.441,
      "type": "line",
      "text": "and the day that cometh shall consume them,",
      "verse": "26:6",
      "lineIndex": 35
    },
    {
      "start": 113.621,
      "end": 115.246,
      "type": "line",
      "text": "saith the Lord of Hosts.",
      "verse": "26:6",
      "lineIndex": 36
    },
    {
      "start": 115.926,
      "end": 119.13,
      "type": "line",
      "text": "O the pain, and the anguish of my soul",
      "verse": "26:7",
      "lineIndex": 37
    },
    {
      "start": 119.31,
      "end": 121.818,
      "type": "line",
      "text": "for the loss of the slain of my people!",
      "verse": "26:7",
      "lineIndex": 38
    },
    {
      "start": 121.998,
      "end": 124.459,
      "type": "line",
      "text": "For I, Nephi, have seen it,",
      "verse": "26:7",
      "lineIndex": 39
    },
    {
      "start": 124.639,
      "end": 129.144,
      "type": "line",
      "text": "and it well nigh consumeth me before the presence of the Lord;",
      "verse": "26:7",
      "lineIndex": 40
    },
    {
      "start": 129.324,
      "end": 131.274,
      "type": "line",
      "text": "but I must cry unto my God:",
      "verse": "26:7",
      "lineIndex": 41
    },
    {
      "start": 131.454,
      "end": 133.312,
      "type": "line",
      "text": "Thy ways are just.",
      "verse": "26:7",
      "lineIndex": 42
    },
    {
      "start": 133.992,
      "end": 138.59,
      "type": "line",
      "text": "But behold, the righteous that hearken unto the words of the prophets,",
      "verse": "26:8",
      "lineIndex": 43
    },
    {
      "start": 138.77,
      "end": 140.628,
      "type": "line",
      "text": "and destroy them not,",
      "verse": "26:8",
      "lineIndex": 44
    },
    {
      "start": 140.808,
      "end": 143.037,
      "type": "line",
      "text": "but look forward unto Christ",
      "verse": "26:8",
      "lineIndex": 45
    },
    {
      "start": 143.217,
      "end": 146.514,
      "type": "line",
      "text": "with steadfastness for the signs which are given,",
      "verse": "26:8",
      "lineIndex": 46
    },
    {
      "start": 146.694,
      "end": 150.734,
      "type": "line",
      "text": "notwithstanding all persecution\u2014",
      "verse": "26:8",
      "lineIndex": 47
    },
    {
      "start": 150.914,
      "end": 154.397,
      "type": "line",
      "text": "behold, they are they which shall not perish.",
      "verse": "26:8",
      "lineIndex": 48
    },
    {
      "start": 155.077,
      "end": 158.746,
      "type": "line",
      "text": "But the Son of Righteousness shall appear unto them;",
      "verse": "26:9",
      "lineIndex": 49
    },
    {
      "start": 158.926,
      "end": 160.83,
      "type": "line",
      "text": "and he shall heal them,",
      "verse": "26:9",
      "lineIndex": 50
    },
    {
      "start": 161.01,
      "end": 163.239,
      "type": "line",
      "text": "and they shall have peace with him,",
      "verse": "26:9",
      "lineIndex": 51
    },
    {
      "start": 163.419,
      "end": 166.298,
      "type": "line",
      "text": "until three generations shall have passed away,",
      "verse": "26:9",
      "lineIndex": 52
    },
    {
      "start": 166.478,
      "end": 171.586,
      "type": "line",
      "text": "and many of the fourth generation shall have passed away in righteousness.",
      "verse": "26:9",
      "lineIndex": 53
    },
    {
      "start": 172.266,
      "end": 174.634,
      "type": "line",
      "text": "And when these things have passed away",
      "verse": "26:10",
      "lineIndex": 54
    },
    {
      "start": 174.814,
      "end": 177.925,
      "type": "line",
      "text": "a speedy destruction cometh unto my people;",
      "verse": "26:10",
      "lineIndex": 55
    },
    {
      "start": 178.105,
      "end": 181.356,
      "type": "line",
      "text": "for, notwithstanding the pains of my soul,",
      "verse": "26:10",
      "lineIndex": 56
    },
    {
      "start": 181.536,
      "end": 183.069,
      "type": "line",
      "text": "I have seen it;",
      "verse": "26:10",
      "lineIndex": 57
    },
    {
      "start": 183.249,
      "end": 186.5,
      "type": "line",
      "text": "wherefore, I know that it shall come to pass;",
      "verse": "26:10",
      "lineIndex": 58
    },
    {
      "start": 186.68,
      "end": 189.141,
      "type": "line",
      "text": "and they sell themselves for naught;",
      "verse": "26:10",
      "lineIndex": 59
    },
    {
      "start": 189.321,
      "end": 193.315,
      "type": "line",
      "text": "for, for the reward of their pride and their foolishness",
      "verse": "26:10",
      "lineIndex": 60
    },
    {
      "start": 193.495,
      "end": 195.399,
      "type": "line",
      "text": "they shall reap destruction;",
      "verse": "26:10",
      "lineIndex": 61
    },
    {
      "start": 195.579,
      "end": 201.059,
      "type": "line",
      "text": "for because they yield unto the devil",
      "verse": "26:10",
      "lineIndex": 62
    },
    {
      "start": 201.239,
      "end": 205.14,
      "type": "line",
      "text": "and choose works of darkness rather than light,",
      "verse": "26:10",
      "lineIndex": 63
    },
    {
      "start": 205.32,
      "end": 208.106,
      "type": "line",
      "text": "therefore they must go down to hell.",
      "verse": "26:10",
      "lineIndex": 64
    },
    {
      "start": 208.786,
      "end": 212.687,
      "type": "line",
      "text": "For the Spirit of the Lord will not always strive with man.",
      "verse": "26:11",
      "lineIndex": 65
    },
    {
      "start": 212.867,
      "end": 215.653,
      "type": "line",
      "text": "And when the Spirit ceaseth to strive",
      "verse": "26:11",
      "lineIndex": 66
    },
    {
      "start": 215.833,
      "end": 219.641,
      "type": "line",
      "text": "with man then cometh speedy destruction,",
      "verse": "26:11",
      "lineIndex": 67
    },
    {
      "start": 219.821,
      "end": 221.679,
      "type": "line",
      "text": "and this grieveth my soul.",
      "verse": "26:11",
      "lineIndex": 68
    },
    {
      "start": 222.359,
      "end": 226.028,
      "type": "line",
      "text": "And as I spake concerning the convincing of the Jews,",
      "verse": "26:12",
      "lineIndex": 70
    },
    {
      "start": 226.208,
      "end": 228.762,
      "type": "line",
      "text": "that Jesus is the very Christ,",
      "verse": "26:12",
      "lineIndex": 71
    },
    {
      "start": 228.942,
      "end": 232.75,
      "type": "line",
      "text": "it must needs be that the Gentiles be convinced also",
      "verse": "26:12",
      "lineIndex": 72
    },
    {
      "start": 232.93,
      "end": 235.113,
      "type": "line",
      "text": "that Jesus is the Christ,",
      "verse": "26:12",
      "lineIndex": 73
    },
    {
      "start": 235.293,
      "end": 236.733,
      "type": "line",
      "text": "the Eternal God;",
      "verse": "26:12",
      "lineIndex": 74
    },
    {
      "start": 237.413,
      "end": 242.289,
      "type": "line",
      "text": "And that he manifesteth himself unto all those who believe in him,",
      "verse": "26:13",
      "lineIndex": 75
    },
    {
      "start": 242.469,
      "end": 244.791,
      "type": "line",
      "text": "by the power of the Holy Ghost;",
      "verse": "26:13",
      "lineIndex": 76
    },
    {
      "start": 244.971,
      "end": 250.079,
      "type": "line",
      "text": "yea, unto every nation, kindred, tongue, and people,",
      "verse": "26:13",
      "lineIndex": 77
    },
    {
      "start": 250.259,
      "end": 254.299,
      "type": "line",
      "text": "working mighty miracles, signs, and wonders,",
      "verse": "26:13",
      "lineIndex": 78
    },
    {
      "start": 254.479,
      "end": 256.383,
      "type": "line",
      "text": "among the children of men",
      "verse": "26:13",
      "lineIndex": 79
    },
    {
      "start": 256.563,
      "end": 258.188,
      "type": "line",
      "text": "according to their faith.",
      "verse": "26:13",
      "lineIndex": 80
    },
    {
      "start": 258.868,
      "end": 263.187,
      "type": "line",
      "text": "But behold, I prophesy unto you concerning the last days;",
      "verse": "26:14",
      "lineIndex": 81
    },
    {
      "start": 263.367,
      "end": 268.104,
      "type": "line",
      "text": "concerning the days when the Lord God shall bring these things forth",
      "verse": "26:14",
      "lineIndex": 82
    },
    {
      "start": 268.284,
      "end": 269.817,
      "type": "line",
      "text": "unto the children of men.",
      "verse": "26:14",
      "lineIndex": 83
    },
    {
      "start": 270.497,
      "end": 276.07,
      "type": "line",
      "text": "After my seed and the seed of my brethren shall have dwindled in unbelief,",
      "verse": "26:15",
      "lineIndex": 84
    },
    {
      "start": 276.25,
      "end": 279.269,
      "type": "line",
      "text": "and shall have been smitten by the Gentiles;",
      "verse": "26:15",
      "lineIndex": 85
    },
    {
      "start": 279.449,
      "end": 284.186,
      "type": "line",
      "text": "yea, after the Lord God shall have camped against them round about,",
      "verse": "26:15",
      "lineIndex": 86
    },
    {
      "start": 284.366,
      "end": 287.895,
      "type": "line",
      "text": "and shall have laid siege against them with a mount,",
      "verse": "26:15",
      "lineIndex": 87
    },
    {
      "start": 288.075,
      "end": 290.536,
      "type": "line",
      "text": "and raised forts against them;",
      "verse": "26:15",
      "lineIndex": 88
    },
    {
      "start": 290.716,
      "end": 294.942,
      "type": "line",
      "text": "and after they shall have been brought down low in the dust,",
      "verse": "26:15",
      "lineIndex": 89
    },
    {
      "start": 295.122,
      "end": 296.747,
      "type": "line",
      "text": "even that they are not,",
      "verse": "26:15",
      "lineIndex": 90
    },
    {
      "start": 296.927,
      "end": 300.503,
      "type": "line",
      "text": "yet the words of the righteous shall be written,",
      "verse": "26:15",
      "lineIndex": 91
    },
    {
      "start": 300.683,
      "end": 304.027,
      "type": "line",
      "text": "and the prayers of the faithful shall be heard,",
      "verse": "26:15",
      "lineIndex": 92
    },
    {
      "start": 304.207,
      "end": 310.058,
      "type": "line",
      "text": "and all those who have dwindled in unbelief shall not be forgotten.",
      "verse": "26:15",
      "lineIndex": 93
    },
    {
      "start": 310.738,
      "end": 316.032,
      "type": "line",
      "text": "For those who shall be destroyed shall speak unto them out of the ground,",
      "verse": "26:16",
      "lineIndex": 94
    },
    {
      "start": 316.212,
      "end": 319.741,
      "type": "line",
      "text": "and their speech shall be low out of the dust,",
      "verse": "26:16",
      "lineIndex": 95
    },
    {
      "start": 319.921,
      "end": 324.519,
      "type": "line",
      "text": "and their voice shall be as one that hath a familiar spirit;",
      "verse": "26:16",
      "lineIndex": 96
    },
    {
      "start": 324.699,
      "end": 327.671,
      "type": "line",
      "text": "for the Lord God will give unto him power,",
      "verse": "26:16",
      "lineIndex": 97
    },
    {
      "start": 327.851,
      "end": 330.359,
      "type": "line",
      "text": "that he may whisper concerning them,",
      "verse": "26:16",
      "lineIndex": 98
    },
    {
      "start": 330.539,
      "end": 332.768,
      "type": "line",
      "text": "even as it were out of the ground;",
      "verse": "26:16",
      "lineIndex": 99
    },
    {
      "start": 332.948,
      "end": 336.756,
      "type": "line",
      "text": "and their speech shall whisper out of the dust.",
      "verse": "26:16",
      "lineIndex": 100
    },
    {
      "start": 337.436,
      "end": 339.526,
      "type": "line",
      "text": "For thus saith the Lord God:",
      "verse": "26:17",
      "lineIndex": 101
    },
    {
      "start": 339.706,
      "end": 343.421,
      "type": "line",
      "text": "They shall write the things which shall be done among them,",
      "verse": "26:17",
      "lineIndex": 102
    },
    {
      "start": 343.601,
      "end": 347.13,
      "type": "line",
      "text": "and they shall be written and sealed up in a book,",
      "verse": "26:17",
      "lineIndex": 103
    },
    {
      "start": 347.31,
      "end": 351.815,
      "type": "line",
      "text": "and those who have dwindled in unbelief shall not have them,",
      "verse": "26:17",
      "lineIndex": 104
    },
    {
      "start": 351.995,
      "end": 355.432,
      "type": "line",
      "text": "for they seek to destroy the things of God.",
      "verse": "26:17",
      "lineIndex": 105
    },
    {
      "start": 356.112,
      "end": 361.081,
      "type": "line",
      "text": "Wherefore, as those who have been destroyed have been destroyed speedily;",
      "verse": "26:18",
      "lineIndex": 106
    },
    {
      "start": 361.261,
      "end": 370.038,
      "type": "line",
      "text": "and the multitude of their terrible ones shall be as chaff that passeth away\u2014",
      "verse": "26:18",
      "lineIndex": 107
    },
    {
      "start": 370.218,
      "end": 372.494,
      "type": "line",
      "text": "yea, thus saith the Lord God:",
      "verse": "26:18",
      "lineIndex": 108
    },
    {
      "start": 372.674,
      "end": 378.154,
      "type": "line",
      "text": "It shall be at an instant, suddenly\u2014",
      "verse": "26:18",
      "lineIndex": 109
    },
    {
      "start": 378.834,
      "end": 380.599,
      "type": "line",
      "text": "And it shall come to pass,",
      "verse": "26:19",
      "lineIndex": 110
    },
    {
      "start": 380.779,
      "end": 383.798,
      "type": "line",
      "text": "that those who have dwindled in unbelief",
      "verse": "26:19",
      "lineIndex": 111
    },
    {
      "start": 383.978,
      "end": 386.95,
      "type": "line",
      "text": "shall be smitten by the hand of the Gentiles.",
      "verse": "26:19",
      "lineIndex": 112
    },
    {
      "start": 387.63,
      "end": 392.088,
      "type": "line",
      "text": "And the Gentiles are lifted up in the pride of their eyes,",
      "verse": "26:20",
      "lineIndex": 113
    },
    {
      "start": 392.268,
      "end": 393.661,
      "type": "line",
      "text": "and have stumbled,",
      "verse": "26:20",
      "lineIndex": 114
    },
    {
      "start": 393.841,
      "end": 397.185,
      "type": "line",
      "text": "because of the greatness of their stumbling block,",
      "verse": "26:20",
      "lineIndex": 115
    },
    {
      "start": 397.365,
      "end": 399.966,
      "type": "line",
      "text": "that they have built up many churches;",
      "verse": "26:20",
      "lineIndex": 116
    },
    {
      "start": 400.146,
      "end": 404.418,
      "type": "line",
      "text": "nevertheless, they put down the power and miracles of God,",
      "verse": "26:20",
      "lineIndex": 117
    },
    {
      "start": 404.598,
      "end": 410.264,
      "type": "line",
      "text": "and preach up unto themselves their own wisdom and their own learning,",
      "verse": "26:20",
      "lineIndex": 118
    },
    {
      "start": 410.444,
      "end": 414.67,
      "type": "line",
      "text": "that they may get gain and grind upon the face of the poor.",
      "verse": "26:20",
      "lineIndex": 119
    },
    {
      "start": 415.35,
      "end": 421.434,
      "type": "line",
      "text": "And there are many churches built up which cause envyings, and strifes, and malice.",
      "verse": "26:21",
      "lineIndex": 120
    },
    {
      "start": 422.114,
      "end": 425.086,
      "type": "line",
      "text": "And there are also secret combinations,",
      "verse": "26:22",
      "lineIndex": 121
    },
    {
      "start": 425.266,
      "end": 427.031,
      "type": "line",
      "text": "even as in times of old,",
      "verse": "26:22",
      "lineIndex": 122
    },
    {
      "start": 427.211,
      "end": 429.951,
      "type": "line",
      "text": "according to the combinations of the devil,",
      "verse": "26:22",
      "lineIndex": 123
    },
    {
      "start": 430.131,
      "end": 433.428,
      "type": "line",
      "text": "for he is the founder of all these things;",
      "verse": "26:22",
      "lineIndex": 124
    },
    {
      "start": 433.608,
      "end": 438.159,
      "type": "line",
      "text": "yea, the founder of murder, and works of darkness;",
      "verse": "26:22",
      "lineIndex": 125
    },
    {
      "start": 438.339,
      "end": 442.751,
      "type": "line",
      "text": "yea, and he leadeth them by the neck with a flaxen cord,",
      "verse": "26:22",
      "lineIndex": 126
    },
    {
      "start": 442.931,
      "end": 446.693,
      "type": "line",
      "text": "until he bindeth them with his strong cords forever.",
      "verse": "26:22",
      "lineIndex": 127
    },
    {
      "start": 447.373,
      "end": 451.042,
      "type": "line",
      "text": "For behold, my beloved brethren, I say unto you",
      "verse": "26:23",
      "lineIndex": 128
    },
    {
      "start": 451.222,
      "end": 454.844,
      "type": "line",
      "text": "that the Lord God worketh not in darkness.",
      "verse": "26:23",
      "lineIndex": 129
    },
    {
      "start": 455.524,
      "end": 460.029,
      "type": "line",
      "text": "He doeth not anything save it be for the benefit of the world;",
      "verse": "26:24",
      "lineIndex": 131
    },
    {
      "start": 460.209,
      "end": 462.02,
      "type": "line",
      "text": "for he loveth the world,",
      "verse": "26:24",
      "lineIndex": 132
    },
    {
      "start": 462.2,
      "end": 465.219,
      "type": "line",
      "text": "even that he layeth down his own life",
      "verse": "26:24",
      "lineIndex": 133
    },
    {
      "start": 465.399,
      "end": 468.418,
      "type": "line",
      "text": "that he may draw all men unto him.",
      "verse": "26:24",
      "lineIndex": 134
    },
    {
      "start": 468.598,
      "end": 473.614,
      "type": "line",
      "text": "Wherefore, he commandeth none that they shall not partake of his salvation.",
      "verse": "26:24",
      "lineIndex": 135
    },
    {
      "start": 474.294,
      "end": 477.452,
      "type": "line",
      "text": "Behold, doth he cry unto any, saying:",
      "verse": "26:25",
      "lineIndex": 136
    },
    {
      "start": 477.632,
      "end": 478.886,
      "type": "line",
      "text": "Depart from me?",
      "verse": "26:25",
      "lineIndex": 137
    },
    {
      "start": 479.066,
      "end": 482.27,
      "type": "line",
      "text": "Behold, I say unto you, Nay;",
      "verse": "26:25",
      "lineIndex": 138
    },
    {
      "start": 482.45,
      "end": 484.029,
      "type": "line",
      "text": "but he saith:",
      "verse": "26:25",
      "lineIndex": 139
    },
    {
      "start": 484.209,
      "end": 486.949,
      "type": "line",
      "text": "Come unto me all ye ends of the earth,",
      "verse": "26:25",
      "lineIndex": 140
    },
    {
      "start": 487.129,
      "end": 488.708,
      "type": "line",
      "text": "buy milk and honey,",
      "verse": "26:25",
      "lineIndex": 141
    },
    {
      "start": 488.888,
      "end": 491.21,
      "type": "line",
      "text": "without money and without price.",
      "verse": "26:25",
      "lineIndex": 142
    },
    {
      "start": 491.89,
      "end": 495.977,
      "type": "line",
      "text": "Behold, hath he commanded any that they should depart",
      "verse": "26:26",
      "lineIndex": 143
    },
    {
      "start": 496.157,
      "end": 497.69,
      "type": "line",
      "text": "out of the synagogues,",
      "verse": "26:26",
      "lineIndex": 144
    },
    {
      "start": 497.87,
      "end": 500.471,
      "type": "line",
      "text": "or out of the houses of worship?",
      "verse": "26:26",
      "lineIndex": 145
    },
    {
      "start": 500.651,
      "end": 503.623,
      "type": "line",
      "text": "Behold, I say unto you, Nay.",
      "verse": "26:26",
      "lineIndex": 146
    },
    {
      "start": 504.303,
      "end": 508.668,
      "type": "line",
      "text": "Hath he commanded any that they should not partake of his salvation?",
      "verse": "26:27",
      "lineIndex": 147
    },
    {
      "start": 508.848,
      "end": 510.984,
      "type": "line",
      "text": "Behold I say unto you, Nay;",
      "verse": "26:27",
      "lineIndex": 148
    },
    {
      "start": 511.164,
      "end": 513.95,
      "type": "line",
      "text": "but he hath given it free for all men;",
      "verse": "26:27",
      "lineIndex": 149
    },
    {
      "start": 514.13,
      "end": 516.266,
      "type": "line",
      "text": "and he hath commanded his people",
      "verse": "26:27",
      "lineIndex": 150
    },
    {
      "start": 516.446,
      "end": 519.604,
      "type": "line",
      "text": "that they should persuade all men to repentance.",
      "verse": "26:27",
      "lineIndex": 151
    },
    {
      "start": 520.284,
      "end": 523.767,
      "type": "line",
      "text": "Behold, hath the Lord commanded any",
      "verse": "26:28",
      "lineIndex": 152
    },
    {
      "start": 523.947,
      "end": 526.873,
      "type": "line",
      "text": "that they should not partake of his goodness?",
      "verse": "26:28",
      "lineIndex": 153
    },
    {
      "start": 527.053,
      "end": 529.189,
      "type": "line",
      "text": "Behold I say unto you, Nay;",
      "verse": "26:28",
      "lineIndex": 154
    },
    {
      "start": 529.369,
      "end": 533.827,
      "type": "line",
      "text": "but all men are privileged the one like unto the other",
      "verse": "26:28",
      "lineIndex": 155
    },
    {
      "start": 534.007,
      "end": 535.818,
      "type": "line",
      "text": "and none are forbidden.",
      "verse": "26:28",
      "lineIndex": 156
    },
    {
      "start": 536.498,
      "end": 539.795,
      "type": "line",
      "text": "He commandeth that there shall be no priestcrafts;",
      "verse": "26:29",
      "lineIndex": 157
    },
    {
      "start": 539.975,
      "end": 543.551,
      "type": "line",
      "text": "for, behold, priestcrafts are that men preach",
      "verse": "26:29",
      "lineIndex": 158
    },
    {
      "start": 543.731,
      "end": 550.279,
      "type": "line",
      "text": "and set themselves up for a light unto the world,",
      "verse": "26:29",
      "lineIndex": 159
    },
    {
      "start": 550.459,
      "end": 554.174,
      "type": "line",
      "text": "that they may get gain and praise of the world;",
      "verse": "26:29",
      "lineIndex": 160
    },
    {
      "start": 554.354,
      "end": 556.862,
      "type": "line",
      "text": "but they seek not the welfare of Zion.",
      "verse": "26:29",
      "lineIndex": 161
    },
    {
      "start": 557.542,
      "end": 560.793,
      "type": "line",
      "text": "Behold, the Lord hath forbidden this thing;",
      "verse": "26:30",
      "lineIndex": 162
    },
    {
      "start": 560.973,
      "end": 564.549,
      "type": "line",
      "text": "wherefore, the Lord God hath given a commandment",
      "verse": "26:30",
      "lineIndex": 163
    },
    {
      "start": 564.729,
      "end": 567.423,
      "type": "line",
      "text": "that all men should have charity,",
      "verse": "26:30",
      "lineIndex": 164
    },
    {
      "start": 567.603,
      "end": 569.507,
      "type": "line",
      "text": "which charity is love.",
      "verse": "26:30",
      "lineIndex": 165
    },
    {
      "start": 569.687,
      "end": 574.145,
      "type": "line",
      "text": "And except they should have charity they were nothing.",
      "verse": "26:30",
      "lineIndex": 166
    },
    {
      "start": 574.325,
      "end": 577.065,
      "type": "line",
      "text": "Wherefore, if they should have charity",
      "verse": "26:30",
      "lineIndex": 167
    },
    {
      "start": 577.245,
      "end": 580.774,
      "type": "line",
      "text": "they would not suffer the laborer in Zion to perish.",
      "verse": "26:30",
      "lineIndex": 168
    },
    {
      "start": 581.454,
      "end": 584.891,
      "type": "line",
      "text": "But the laborer in Zion shall labor for Zion;",
      "verse": "26:31",
      "lineIndex": 169
    },
    {
      "start": 585.071,
      "end": 588.508,
      "type": "line",
      "text": "for if they labor for money they shall perish.",
      "verse": "26:31",
      "lineIndex": 170
    },
    {
      "start": 589.188,
      "end": 594.111,
      "type": "line",
      "text": "And again, the Lord God hath commanded that men should not murder;",
      "verse": "26:32",
      "lineIndex": 171
    },
    {
      "start": 594.291,
      "end": 595.916,
      "type": "line",
      "text": "that they should not lie;",
      "verse": "26:32",
      "lineIndex": 172
    },
    {
      "start": 596.096,
      "end": 598.232,
      "type": "line",
      "text": "that they should not steal;",
      "verse": "26:32",
      "lineIndex": 173
    },
    {
      "start": 598.412,
      "end": 602.499,
      "type": "line",
      "text": "that they should not take the name of the Lord their God in vain;",
      "verse": "26:32",
      "lineIndex": 174
    },
    {
      "start": 602.679,
      "end": 604.629,
      "type": "line",
      "text": "that they should not envy;",
      "verse": "26:32",
      "lineIndex": 175
    },
    {
      "start": 604.809,
      "end": 607.038,
      "type": "line",
      "text": "that they should not have malice;",
      "verse": "26:32",
      "lineIndex": 176
    },
    {
      "start": 607.218,
      "end": 610.283,
      "type": "line",
      "text": "that they should not contend one with another;",
      "verse": "26:32",
      "lineIndex": 177
    },
    {
      "start": 610.463,
      "end": 612.924,
      "type": "line",
      "text": "that they should not commit whoredoms;",
      "verse": "26:32",
      "lineIndex": 178
    },
    {
      "start": 613.104,
      "end": 616.123,
      "type": "line",
      "text": "and that they should do none of these things;",
      "verse": "26:32",
      "lineIndex": 179
    },
    {
      "start": 616.303,
      "end": 619.043,
      "type": "line",
      "text": "for whoso doeth them shall perish.",
      "verse": "26:32",
      "lineIndex": 180
    },
    {
      "start": 619.723,
      "end": 622.927,
      "type": "line",
      "text": "For none of these iniquities come of the Lord;",
      "verse": "26:33",
      "lineIndex": 181
    },
    {
      "start": 623.107,
      "end": 626.869,
      "type": "line",
      "text": "for he doeth that which is good among the children of men;",
      "verse": "26:33",
      "lineIndex": 182
    },
    {
      "start": 627.049,
      "end": 632.157,
      "type": "line",
      "text": "and he doeth nothing save it be plain unto the children of men;",
      "verse": "26:33",
      "lineIndex": 183
    },
    {
      "start": 632.337,
      "end": 637.353,
      "type": "line",
      "text": "and he inviteth them all to come unto him and partake of his goodness;",
      "verse": "26:33",
      "lineIndex": 184
    },
    {
      "start": 637.533,
      "end": 640.459,
      "type": "line",
      "text": "and he denieth none that come unto him,",
      "verse": "26:33",
      "lineIndex": 185
    },
    {
      "start": 640.639,
      "end": 642.032,
      "type": "line",
      "text": "black and white,",
      "verse": "26:33",
      "lineIndex": 186
    },
    {
      "start": 642.212,
      "end": 643.559,
      "type": "line",
      "text": "bond and free,",
      "verse": "26:33",
      "lineIndex": 187
    },
    {
      "start": 643.739,
      "end": 645.411,
      "type": "line",
      "text": "male and female;",
      "verse": "26:33",
      "lineIndex": 188
    },
    {
      "start": 645.591,
      "end": 647.681,
      "type": "line",
      "text": "and he remembereth the heathen;",
      "verse": "26:33",
      "lineIndex": 189
    },
    {
      "start": 647.861,
      "end": 650.276,
      "type": "line",
      "text": "and all are alike unto God,",
      "verse": "26:33",
      "lineIndex": 190
    },
    {
      "start": 650.456,
      "end": 652.639,
      "type": "line",
      "text": "both Jew and Gentile.",
      "verse": "26:33",
      "lineIndex": 191
    }
  ]
}