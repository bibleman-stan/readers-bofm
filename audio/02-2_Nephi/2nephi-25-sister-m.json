{
  "book": "2nephi",
  "bookName": "2 Nephi",
  "chapter": 25,
  "voice": {
    "provider": "elevenlabs",
    "voice_id": "iJpuSZDxZSBJHFSeavba",
    "model_id": "eleven_multilingual_v2",
    "settings": {
      "stability": 0.5,
      "similarity_boost": 0.75,
      "style": 0.35,
      "use_speaker_boost": true
    },
    "name": "sister-m"
  },
  "pauses": {
    "line_ms": 180,
    "verse_ms": 500
  },
  "duration": 736.357,
  "lines": [
    {
      "start": 0.0,
      "end": 4.319,
      "type": "line",
      "text": "Now I, Nephi, do speak somewhat",
      "verse": "25:1",
      "lineIndex": 1
    },
    {
      "start": 4.499,
      "end": 6.821,
      "type": "line",
      "text": "concerning the words which I have written,",
      "verse": "25:1",
      "lineIndex": 2
    },
    {
      "start": 7.001,
      "end": 10.298,
      "type": "line",
      "text": "which have been spoken by the mouth of Isaiah.",
      "verse": "25:1",
      "lineIndex": 3
    },
    {
      "start": 10.478,
      "end": 13.357,
      "type": "line",
      "text": "For behold, Isaiah spake many things",
      "verse": "25:1",
      "lineIndex": 4
    },
    {
      "start": 13.537,
      "end": 17.206,
      "type": "line",
      "text": "which were hard for many of my people to understand;",
      "verse": "25:1",
      "lineIndex": 5
    },
    {
      "start": 17.386,
      "end": 22.262,
      "type": "line",
      "text": "for they know not concerning the manner of prophesying among the Jews.",
      "verse": "25:1",
      "lineIndex": 6
    },
    {
      "start": 22.942,
      "end": 27.261,
      "type": "line",
      "text": "For I, Nephi, have not taught them many things",
      "verse": "25:2",
      "lineIndex": 7
    },
    {
      "start": 27.441,
      "end": 29.67,
      "type": "line",
      "text": "concerning the manner of the Jews;",
      "verse": "25:2",
      "lineIndex": 8
    },
    {
      "start": 29.85,
      "end": 32.729,
      "type": "line",
      "text": "for their works were works of darkness,",
      "verse": "25:2",
      "lineIndex": 9
    },
    {
      "start": 32.909,
      "end": 35.881,
      "type": "line",
      "text": "and their doings were doings of abominations.",
      "verse": "25:2",
      "lineIndex": 10
    },
    {
      "start": 36.561,
      "end": 38.976,
      "type": "line",
      "text": "Wherefore, I write unto my people,",
      "verse": "25:3",
      "lineIndex": 12
    },
    {
      "start": 39.156,
      "end": 42.267,
      "type": "line",
      "text": "unto all those that shall receive hereafter",
      "verse": "25:3",
      "lineIndex": 13
    },
    {
      "start": 42.447,
      "end": 48.206,
      "type": "line",
      "text": "these things which I write,",
      "verse": "25:3",
      "lineIndex": 14
    },
    {
      "start": 48.386,
      "end": 50.801,
      "type": "line",
      "text": "that they may know the judgments of God,",
      "verse": "25:3",
      "lineIndex": 15
    },
    {
      "start": 50.981,
      "end": 53.582,
      "type": "line",
      "text": "that they come upon all nations,",
      "verse": "25:3",
      "lineIndex": 16
    },
    {
      "start": 53.762,
      "end": 56.502,
      "type": "line",
      "text": "according to the word which he hath spoken.",
      "verse": "25:3",
      "lineIndex": 17
    },
    {
      "start": 57.182,
      "end": 59.876,
      "type": "line",
      "text": "Wherefore, hearken, O my people,",
      "verse": "25:4",
      "lineIndex": 18
    },
    {
      "start": 60.056,
      "end": 62.099,
      "type": "line",
      "text": "which are of the house of Israel,",
      "verse": "25:4",
      "lineIndex": 19
    },
    {
      "start": 62.279,
      "end": 64.508,
      "type": "line",
      "text": "and give ear unto my words;",
      "verse": "25:4",
      "lineIndex": 20
    },
    {
      "start": 64.688,
      "end": 68.496,
      "type": "line",
      "text": "for because the words of Isaiah are not plain unto you,",
      "verse": "25:4",
      "lineIndex": 21
    },
    {
      "start": 68.676,
      "end": 74.342,
      "type": "line",
      "text": "nevertheless they are plain unto all those that are filled with the spirit of prophecy.",
      "verse": "25:4",
      "lineIndex": 22
    },
    {
      "start": 74.522,
      "end": 77.03,
      "type": "line",
      "text": "But I give unto you a prophecy,",
      "verse": "25:4",
      "lineIndex": 23
    },
    {
      "start": 77.21,
      "end": 79.718,
      "type": "line",
      "text": "according to the spirit which is in me;",
      "verse": "25:4",
      "lineIndex": 24
    },
    {
      "start": 79.898,
      "end": 85.099,
      "type": "line",
      "text": "wherefore I shall prophesy according to the plainness which hath been with me",
      "verse": "25:4",
      "lineIndex": 25
    },
    {
      "start": 85.279,
      "end": 88.901,
      "type": "line",
      "text": "from the time that I came out from Jerusalem with my father;",
      "verse": "25:4",
      "lineIndex": 26
    },
    {
      "start": 89.081,
      "end": 94.422,
      "type": "line",
      "text": "for behold, my soul delighteth in plainness unto my people,",
      "verse": "25:4",
      "lineIndex": 27
    },
    {
      "start": 94.602,
      "end": 95.949,
      "type": "line",
      "text": "that they may learn.",
      "verse": "25:4",
      "lineIndex": 28
    },
    {
      "start": 96.629,
      "end": 100.809,
      "type": "line",
      "text": "Yea, and my soul delighteth in the words of Isaiah,",
      "verse": "25:5",
      "lineIndex": 29
    },
    {
      "start": 100.989,
      "end": 103.218,
      "type": "line",
      "text": "for I came out from Jerusalem,",
      "verse": "25:5",
      "lineIndex": 30
    },
    {
      "start": 103.398,
      "end": 107.299,
      "type": "line",
      "text": "and mine eyes hath beheld the things of the Jews,",
      "verse": "25:5",
      "lineIndex": 31
    },
    {
      "start": 107.479,
      "end": 112.169,
      "type": "line",
      "text": "and I know that the Jews do understand the things of the prophets,",
      "verse": "25:5",
      "lineIndex": 32
    },
    {
      "start": 112.349,
      "end": 118.293,
      "type": "line",
      "text": "and there is none other people that understand the things which were spoken unto the Jews",
      "verse": "25:5",
      "lineIndex": 33
    },
    {
      "start": 118.473,
      "end": 119.959,
      "type": "line",
      "text": "like unto them,",
      "verse": "25:5",
      "lineIndex": 34
    },
    {
      "start": 120.139,
      "end": 125.294,
      "type": "line",
      "text": "save it be that they are taught after the manner of the things of the Jews.",
      "verse": "25:5",
      "lineIndex": 35
    },
    {
      "start": 125.974,
      "end": 132.383,
      "type": "line",
      "text": "But behold, I, Nephi, have not taught my children after the manner of the Jews;",
      "verse": "25:6",
      "lineIndex": 36
    },
    {
      "start": 132.563,
      "end": 136.975,
      "type": "line",
      "text": "but behold, I, of myself, have dwelt at Jerusalem,",
      "verse": "25:6",
      "lineIndex": 37
    },
    {
      "start": 137.155,
      "end": 140.545,
      "type": "line",
      "text": "wherefore I know concerning the regions round about;",
      "verse": "25:6",
      "lineIndex": 38
    },
    {
      "start": 140.725,
      "end": 145.741,
      "type": "line",
      "text": "and I have made mention unto my children concerning the judgments of God,",
      "verse": "25:6",
      "lineIndex": 39
    },
    {
      "start": 145.921,
      "end": 149.729,
      "type": "line",
      "text": "which hath come to pass among the Jews, unto my children,",
      "verse": "25:6",
      "lineIndex": 40
    },
    {
      "start": 149.909,
      "end": 153.206,
      "type": "line",
      "text": "according to all that which Isaiah hath spoken,",
      "verse": "25:6",
      "lineIndex": 41
    },
    {
      "start": 153.386,
      "end": 155.151,
      "type": "line",
      "text": "and I do not write them.",
      "verse": "25:6",
      "lineIndex": 42
    },
    {
      "start": 155.831,
      "end": 159.407,
      "type": "line",
      "text": "But behold, I proceed with mine own prophecy,",
      "verse": "25:7",
      "lineIndex": 43
    },
    {
      "start": 159.587,
      "end": 161.491,
      "type": "line",
      "text": "according to my plainness;",
      "verse": "25:7",
      "lineIndex": 44
    },
    {
      "start": 161.671,
      "end": 164.597,
      "type": "line",
      "text": "in the which I know that no man can err;",
      "verse": "25:7",
      "lineIndex": 45
    },
    {
      "start": 164.777,
      "end": 169.746,
      "type": "line",
      "text": "nevertheless, in the days that the prophecies of Isaiah shall be fulfilled",
      "verse": "25:7",
      "lineIndex": 46
    },
    {
      "start": 169.926,
      "end": 171.969,
      "type": "line",
      "text": "men shall know of a surety,",
      "verse": "25:7",
      "lineIndex": 47
    },
    {
      "start": 172.149,
      "end": 174.889,
      "type": "line",
      "text": "at the times when they shall come to pass.",
      "verse": "25:7",
      "lineIndex": 48
    },
    {
      "start": 175.569,
      "end": 179.238,
      "type": "line",
      "text": "Wherefore, they are of worth unto the children of men,",
      "verse": "25:8",
      "lineIndex": 50
    },
    {
      "start": 179.418,
      "end": 182.251,
      "type": "line",
      "text": "and he that supposeth that they are not,",
      "verse": "25:8",
      "lineIndex": 51
    },
    {
      "start": 182.431,
      "end": 184.846,
      "type": "line",
      "text": "unto them will I speak particularly,",
      "verse": "25:8",
      "lineIndex": 52
    },
    {
      "start": 185.026,
      "end": 188.137,
      "type": "line",
      "text": "and confine the words unto mine own people;",
      "verse": "25:8",
      "lineIndex": 53
    },
    {
      "start": 188.317,
      "end": 193.611,
      "type": "line",
      "text": "for I know that they shall be of great worth unto them in the last days;",
      "verse": "25:8",
      "lineIndex": 54
    },
    {
      "start": 193.791,
      "end": 197.088,
      "type": "line",
      "text": "for in that day shall they understand them;",
      "verse": "25:8",
      "lineIndex": 55
    },
    {
      "start": 197.268,
      "end": 200.519,
      "type": "line",
      "text": "wherefore, for their good have I written them.",
      "verse": "25:8",
      "lineIndex": 56
    },
    {
      "start": 201.199,
      "end": 204.403,
      "type": "line",
      "text": "And as one generation hath been destroyed",
      "verse": "25:9",
      "lineIndex": 57
    },
    {
      "start": 204.583,
      "end": 207.137,
      "type": "line",
      "text": "among the Jews because of iniquity,",
      "verse": "25:9",
      "lineIndex": 58
    },
    {
      "start": 207.317,
      "end": 210.103,
      "type": "line",
      "text": "even so have they been destroyed",
      "verse": "25:9",
      "lineIndex": 59
    },
    {
      "start": 210.283,
      "end": 214.463,
      "type": "line",
      "text": "from generation to generation according to their iniquities;",
      "verse": "25:9",
      "lineIndex": 60
    },
    {
      "start": 214.643,
      "end": 217.429,
      "type": "line",
      "text": "and never hath any of them been destroyed",
      "verse": "25:9",
      "lineIndex": 61
    },
    {
      "start": 217.609,
      "end": 221.649,
      "type": "line",
      "text": "save it were foretold them by the prophets of the Lord.",
      "verse": "25:9",
      "lineIndex": 62
    },
    {
      "start": 222.329,
      "end": 228.18,
      "type": "line",
      "text": "Wherefore, it hath been told them concerning the destruction which should come upon them,",
      "verse": "25:10",
      "lineIndex": 63
    },
    {
      "start": 228.36,
      "end": 231.332,
      "type": "line",
      "text": "immediately after my father left Jerusalem;",
      "verse": "25:10",
      "lineIndex": 64
    },
    {
      "start": 231.512,
      "end": 234.159,
      "type": "line",
      "text": "nevertheless, they hardened their hearts;",
      "verse": "25:10",
      "lineIndex": 65
    },
    {
      "start": 234.339,
      "end": 237.961,
      "type": "line",
      "text": "and according to my prophecy they have been destroyed,",
      "verse": "25:10",
      "lineIndex": 66
    },
    {
      "start": 238.141,
      "end": 242.553,
      "type": "line",
      "text": "save it be those which are carried away captive into Babylon.",
      "verse": "25:10",
      "lineIndex": 67
    },
    {
      "start": 243.233,
      "end": 247.831,
      "type": "line",
      "text": "And now this I speak because of the spirit which is in me.",
      "verse": "25:11",
      "lineIndex": 68
    },
    {
      "start": 248.011,
      "end": 251.215,
      "type": "line",
      "text": "And notwithstanding they have been carried away",
      "verse": "25:11",
      "lineIndex": 69
    },
    {
      "start": 251.395,
      "end": 253.206,
      "type": "line",
      "text": "they shall return again,",
      "verse": "25:11",
      "lineIndex": 70
    },
    {
      "start": 253.386,
      "end": 255.662,
      "type": "line",
      "text": "and possess the land of Jerusalem;",
      "verse": "25:11",
      "lineIndex": 71
    },
    {
      "start": 255.842,
      "end": 260.904,
      "type": "line",
      "text": "wherefore, they shall be restored again to the land of their inheritance.",
      "verse": "25:11",
      "lineIndex": 72
    },
    {
      "start": 261.584,
      "end": 265.717,
      "type": "line",
      "text": "But, behold, they shall have wars, and rumors of wars;",
      "verse": "25:12",
      "lineIndex": 73
    },
    {
      "start": 265.897,
      "end": 270.448,
      "type": "line",
      "text": "and when the day cometh that the Only Begotten of the Father,",
      "verse": "25:12",
      "lineIndex": 74
    },
    {
      "start": 270.628,
      "end": 274.436,
      "type": "line",
      "text": "yea, even the Father of heaven and of earth,",
      "verse": "25:12",
      "lineIndex": 75
    },
    {
      "start": 274.616,
      "end": 278.192,
      "type": "line",
      "text": "shall manifest himself unto them in the flesh,",
      "verse": "25:12",
      "lineIndex": 76
    },
    {
      "start": 278.372,
      "end": 281.205,
      "type": "line",
      "text": "behold, they will reject him,",
      "verse": "25:12",
      "lineIndex": 77
    },
    {
      "start": 281.385,
      "end": 283.568,
      "type": "line",
      "text": "because of their iniquities,",
      "verse": "25:12",
      "lineIndex": 78
    },
    {
      "start": 283.748,
      "end": 286.07,
      "type": "line",
      "text": "and the hardness of their hearts,",
      "verse": "25:12",
      "lineIndex": 79
    },
    {
      "start": 286.25,
      "end": 288.758,
      "type": "line",
      "text": "and the stiffness of their necks.",
      "verse": "25:12",
      "lineIndex": 80
    },
    {
      "start": 289.438,
      "end": 291.806,
      "type": "line",
      "text": "Behold, they will crucify him;",
      "verse": "25:13",
      "lineIndex": 81
    },
    {
      "start": 291.986,
      "end": 297.002,
      "type": "line",
      "text": "and after he is laid in a sepulchre for the space of three days",
      "verse": "25:13",
      "lineIndex": 82
    },
    {
      "start": 297.182,
      "end": 300.851,
      "type": "line",
      "text": "he shall rise from the dead, with healing in his wings;",
      "verse": "25:13",
      "lineIndex": 83
    },
    {
      "start": 301.031,
      "end": 306.65,
      "type": "line",
      "text": "and all those who shall believe on his name shall be saved in the kingdom of God.",
      "verse": "25:13",
      "lineIndex": 84
    },
    {
      "start": 306.83,
      "end": 310.917,
      "type": "line",
      "text": "Wherefore, my soul delighteth to prophesy concerning him,",
      "verse": "25:13",
      "lineIndex": 85
    },
    {
      "start": 311.097,
      "end": 312.908,
      "type": "line",
      "text": "for I have seen his day,",
      "verse": "25:13",
      "lineIndex": 86
    },
    {
      "start": 313.088,
      "end": 316.199,
      "type": "line",
      "text": "and my heart doth magnify his holy name.",
      "verse": "25:13",
      "lineIndex": 87
    },
    {
      "start": 316.879,
      "end": 322.87,
      "type": "line",
      "text": "And behold it shall come to pass that after the Messiah hath risen from the dead,",
      "verse": "25:14",
      "lineIndex": 88
    },
    {
      "start": 323.05,
      "end": 326.394,
      "type": "line",
      "text": "and hath manifested himself unto his people,",
      "verse": "25:14",
      "lineIndex": 89
    },
    {
      "start": 326.574,
      "end": 329.36,
      "type": "line",
      "text": "unto as many as will believe on his name,",
      "verse": "25:14",
      "lineIndex": 90
    },
    {
      "start": 329.54,
      "end": 333.395,
      "type": "line",
      "text": "behold, Jerusalem shall be destroyed again;",
      "verse": "25:14",
      "lineIndex": 91
    },
    {
      "start": 333.575,
      "end": 339.008,
      "type": "line",
      "text": "for wo unto them that fight against God and the people of his church.",
      "verse": "25:14",
      "lineIndex": 92
    },
    {
      "start": 339.688,
      "end": 343.821,
      "type": "line",
      "text": "Wherefore, the Jews shall be scattered among all nations;",
      "verse": "25:15",
      "lineIndex": 93
    },
    {
      "start": 344.001,
      "end": 347.484,
      "type": "line",
      "text": "yea, and also Babylon shall be destroyed;",
      "verse": "25:15",
      "lineIndex": 94
    },
    {
      "start": 347.664,
      "end": 351.658,
      "type": "line",
      "text": "wherefore, the Jews shall be scattered by other nations.",
      "verse": "25:15",
      "lineIndex": 95
    },
    {
      "start": 352.338,
      "end": 354.521,
      "type": "line",
      "text": "And after they have been scattered,",
      "verse": "25:16",
      "lineIndex": 97
    },
    {
      "start": 354.701,
      "end": 357.905,
      "type": "line",
      "text": "and the Lord God hath scourged them",
      "verse": "25:16",
      "lineIndex": 98
    },
    {
      "start": 358.085,
      "end": 361.847,
      "type": "line",
      "text": "by other nations for the space of many generations,",
      "verse": "25:16",
      "lineIndex": 99
    },
    {
      "start": 362.027,
      "end": 365.882,
      "type": "line",
      "text": "yea, even down from generation to generation",
      "verse": "25:16",
      "lineIndex": 100
    },
    {
      "start": 366.062,
      "end": 371.774,
      "type": "line",
      "text": "until they shall be persuaded to believe in Christ, the Son of God,",
      "verse": "25:16",
      "lineIndex": 101
    },
    {
      "start": 371.954,
      "end": 379.756,
      "type": "line",
      "text": "and the atonement, which is infinite for all mankind\u2014",
      "verse": "25:16",
      "lineIndex": 102
    },
    {
      "start": 379.936,
      "end": 383.976,
      "type": "line",
      "text": "and when that day shall come that they shall believe in Christ,",
      "verse": "25:16",
      "lineIndex": 103
    },
    {
      "start": 384.156,
      "end": 390.518,
      "type": "line",
      "text": "and worship the Father in his name,",
      "verse": "25:16",
      "lineIndex": 104
    },
    {
      "start": 390.698,
      "end": 393.113,
      "type": "line",
      "text": "with pure hearts and clean hands,",
      "verse": "25:16",
      "lineIndex": 105
    },
    {
      "start": 393.293,
      "end": 397.751,
      "type": "line",
      "text": "and look not forward any more for another Messiah,",
      "verse": "25:16",
      "lineIndex": 106
    },
    {
      "start": 397.931,
      "end": 401.135,
      "type": "line",
      "text": "then, at that time, the day will come",
      "verse": "25:16",
      "lineIndex": 107
    },
    {
      "start": 401.315,
      "end": 405.82,
      "type": "line",
      "text": "that it must needs be expedient that they should believe these things.",
      "verse": "25:16",
      "lineIndex": 108
    },
    {
      "start": 406.5,
      "end": 410.215,
      "type": "line",
      "text": "And the Lord will set his hand again the second time",
      "verse": "25:17",
      "lineIndex": 109
    },
    {
      "start": 410.395,
      "end": 414.342,
      "type": "line",
      "text": "to restore his people from their lost and fallen state.",
      "verse": "25:17",
      "lineIndex": 110
    },
    {
      "start": 414.522,
      "end": 419.352,
      "type": "line",
      "text": "Wherefore, he will proceed to do a marvelous work and a wonder",
      "verse": "25:17",
      "lineIndex": 111
    },
    {
      "start": 419.532,
      "end": 421.157,
      "type": "line",
      "text": "among the children of men.",
      "verse": "25:17",
      "lineIndex": 112
    },
    {
      "start": 421.837,
      "end": 425.552,
      "type": "line",
      "text": "Wherefore, he shall bring forth his words unto them,",
      "verse": "25:18",
      "lineIndex": 113
    },
    {
      "start": 425.732,
      "end": 428.797,
      "type": "line",
      "text": "which words shall judge them at the last day,",
      "verse": "25:18",
      "lineIndex": 114
    },
    {
      "start": 428.977,
      "end": 430.927,
      "type": "line",
      "text": "for they shall be given them",
      "verse": "25:18",
      "lineIndex": 115
    },
    {
      "start": 431.107,
      "end": 434.59,
      "type": "line",
      "text": "for the purpose of convincing them of the true Messiah,",
      "verse": "25:18",
      "lineIndex": 116
    },
    {
      "start": 434.77,
      "end": 436.581,
      "type": "line",
      "text": "who was rejected by them;",
      "verse": "25:18",
      "lineIndex": 117
    },
    {
      "start": 436.761,
      "end": 439.501,
      "type": "line",
      "text": "and unto the convincing of them",
      "verse": "25:18",
      "lineIndex": 118
    },
    {
      "start": 439.681,
      "end": 443.861,
      "type": "line",
      "text": "that they need not look forward any more for a Messiah to come,",
      "verse": "25:18",
      "lineIndex": 119
    },
    {
      "start": 444.041,
      "end": 446.781,
      "type": "line",
      "text": "for there should not any come,",
      "verse": "25:18",
      "lineIndex": 120
    },
    {
      "start": 446.961,
      "end": 450.63,
      "type": "line",
      "text": "save it should be a false Messiah",
      "verse": "25:18",
      "lineIndex": 121
    },
    {
      "start": 450.81,
      "end": 452.76,
      "type": "line",
      "text": "which should deceive the people;",
      "verse": "25:18",
      "lineIndex": 122
    },
    {
      "start": 452.94,
      "end": 456.841,
      "type": "line",
      "text": "for there is save one Messiah spoken of by the prophets,",
      "verse": "25:18",
      "lineIndex": 123
    },
    {
      "start": 457.021,
      "end": 461.386,
      "type": "line",
      "text": "and that Messiah is he who should be rejected of the Jews.",
      "verse": "25:18",
      "lineIndex": 124
    },
    {
      "start": 462.066,
      "end": 464.76,
      "type": "line",
      "text": "For according to the words of the prophets,",
      "verse": "25:19",
      "lineIndex": 125
    },
    {
      "start": 464.94,
      "end": 471.86,
      "type": "line",
      "text": "the Messiah cometh in six hundred years",
      "verse": "25:19",
      "lineIndex": 126
    },
    {
      "start": 472.04,
      "end": 474.78,
      "type": "line",
      "text": "from the time that my father left Jerusalem;",
      "verse": "25:19",
      "lineIndex": 127
    },
    {
      "start": 474.96,
      "end": 477.7,
      "type": "line",
      "text": "and according to the words of the prophets,",
      "verse": "25:19",
      "lineIndex": 128
    },
    {
      "start": 477.88,
      "end": 480.899,
      "type": "line",
      "text": "and also the word of the angel of God,",
      "verse": "25:19",
      "lineIndex": 129
    },
    {
      "start": 481.079,
      "end": 484.655,
      "type": "line",
      "text": "his name shall be Jesus Christ, the Son of God.",
      "verse": "25:19",
      "lineIndex": 130
    },
    {
      "start": 485.335,
      "end": 486.775,
      "type": "line",
      "text": "And now, my brethren,",
      "verse": "25:20",
      "lineIndex": 131
    },
    {
      "start": 486.955,
      "end": 490.159,
      "type": "line",
      "text": "I have spoken plainly that ye cannot err.",
      "verse": "25:20",
      "lineIndex": 132
    },
    {
      "start": 490.339,
      "end": 492.382,
      "type": "line",
      "text": "And as the Lord God liveth",
      "verse": "25:20",
      "lineIndex": 133
    },
    {
      "start": 492.562,
      "end": 495.999,
      "type": "line",
      "text": "that brought Israel up out of the land of Egypt,",
      "verse": "25:20",
      "lineIndex": 134
    },
    {
      "start": 496.179,
      "end": 500.73,
      "type": "line",
      "text": "and gave unto Moses power that he should heal the nations",
      "verse": "25:20",
      "lineIndex": 135
    },
    {
      "start": 500.91,
      "end": 504.068,
      "type": "line",
      "text": "after they had been bitten by the poisonous serpents,",
      "verse": "25:20",
      "lineIndex": 136
    },
    {
      "start": 504.248,
      "end": 507.685,
      "type": "line",
      "text": "if they would cast their eyes unto the serpent",
      "verse": "25:20",
      "lineIndex": 137
    },
    {
      "start": 507.865,
      "end": 510.048,
      "type": "line",
      "text": "which he did raise up before them,",
      "verse": "25:20",
      "lineIndex": 138
    },
    {
      "start": 510.228,
      "end": 514.779,
      "type": "line",
      "text": "and also gave him power that he should smite the rock",
      "verse": "25:20",
      "lineIndex": 139
    },
    {
      "start": 514.959,
      "end": 517.188,
      "type": "line",
      "text": "and the water should come forth;",
      "verse": "25:20",
      "lineIndex": 140
    },
    {
      "start": 517.368,
      "end": 520.34,
      "type": "line",
      "text": "yea, behold I say unto you",
      "verse": "25:20",
      "lineIndex": 141
    },
    {
      "start": 520.52,
      "end": 522.842,
      "type": "line",
      "text": "that as these things are true,",
      "verse": "25:20",
      "lineIndex": 142
    },
    {
      "start": 523.022,
      "end": 525.112,
      "type": "line",
      "text": "and as the Lord God liveth,",
      "verse": "25:20",
      "lineIndex": 143
    },
    {
      "start": 525.292,
      "end": 528.311,
      "type": "line",
      "text": "there is none other name given under heaven",
      "verse": "25:20",
      "lineIndex": 144
    },
    {
      "start": 528.491,
      "end": 530.767,
      "type": "line",
      "text": "save it be this Jesus Christ,",
      "verse": "25:20",
      "lineIndex": 145
    },
    {
      "start": 530.947,
      "end": 532.665,
      "type": "line",
      "text": "of which I have spoken,",
      "verse": "25:20",
      "lineIndex": 146
    },
    {
      "start": 532.845,
      "end": 534.888,
      "type": "line",
      "text": "whereby man can be saved.",
      "verse": "25:20",
      "lineIndex": 147
    },
    {
      "start": 535.568,
      "end": 539.562,
      "type": "line",
      "text": "Wherefore, for this cause hath the Lord God promised unto me",
      "verse": "25:21",
      "lineIndex": 148
    },
    {
      "start": 539.742,
      "end": 544.154,
      "type": "line",
      "text": "that these things which I write shall be kept and preserved,",
      "verse": "25:21",
      "lineIndex": 149
    },
    {
      "start": 544.334,
      "end": 546.702,
      "type": "line",
      "text": "and handed down unto my seed,",
      "verse": "25:21",
      "lineIndex": 150
    },
    {
      "start": 546.882,
      "end": 549.111,
      "type": "line",
      "text": "from generation to generation,",
      "verse": "25:21",
      "lineIndex": 151
    },
    {
      "start": 549.291,
      "end": 552.681,
      "type": "line",
      "text": "that the promise may be fulfilled unto Joseph,",
      "verse": "25:21",
      "lineIndex": 152
    },
    {
      "start": 552.861,
      "end": 557.969,
      "type": "line",
      "text": "that his seed should never perish as long as the earth should stand.",
      "verse": "25:21",
      "lineIndex": 153
    },
    {
      "start": 558.649,
      "end": 563.432,
      "type": "line",
      "text": "Wherefore, these things shall go from generation to generation",
      "verse": "25:22",
      "lineIndex": 154
    },
    {
      "start": 563.612,
      "end": 566.027,
      "type": "line",
      "text": "as long as the earth shall stand;",
      "verse": "25:22",
      "lineIndex": 155
    },
    {
      "start": 566.207,
      "end": 570.247,
      "type": "line",
      "text": "and they shall go according to the will and pleasure of God;",
      "verse": "25:22",
      "lineIndex": 156
    },
    {
      "start": 570.427,
      "end": 574.421,
      "type": "line",
      "text": "and the nations who shall possess them shall be judged of them",
      "verse": "25:22",
      "lineIndex": 157
    },
    {
      "start": 574.601,
      "end": 576.969,
      "type": "line",
      "text": "according to the words which are written.",
      "verse": "25:22",
      "lineIndex": 158
    },
    {
      "start": 577.649,
      "end": 580.203,
      "type": "line",
      "text": "For we labor diligently to write,",
      "verse": "25:23",
      "lineIndex": 159
    },
    {
      "start": 580.383,
      "end": 582.333,
      "type": "line",
      "text": "to persuade our children,",
      "verse": "25:23",
      "lineIndex": 160
    },
    {
      "start": 582.513,
      "end": 584.371,
      "type": "line",
      "text": "and also our brethren,",
      "verse": "25:23",
      "lineIndex": 161
    },
    {
      "start": 584.551,
      "end": 586.13,
      "type": "line",
      "text": "to believe in Christ,",
      "verse": "25:23",
      "lineIndex": 162
    },
    {
      "start": 586.31,
      "end": 588.307,
      "type": "line",
      "text": "and to be reconciled to God;",
      "verse": "25:23",
      "lineIndex": 163
    },
    {
      "start": 588.487,
      "end": 591.877,
      "type": "line",
      "text": "for we know that it is by grace that we are saved,",
      "verse": "25:23",
      "lineIndex": 164
    },
    {
      "start": 592.057,
      "end": 593.636,
      "type": "line",
      "text": "after all we can do.",
      "verse": "25:23",
      "lineIndex": 165
    },
    {
      "start": 594.316,
      "end": 597.474,
      "type": "line",
      "text": "And, notwithstanding we believe in Christ,",
      "verse": "25:24",
      "lineIndex": 166
    },
    {
      "start": 597.654,
      "end": 599.604,
      "type": "line",
      "text": "we keep the law of Moses,",
      "verse": "25:24",
      "lineIndex": 167
    },
    {
      "start": 599.784,
      "end": 603.731,
      "type": "line",
      "text": "and look forward with steadfastness unto Christ,",
      "verse": "25:24",
      "lineIndex": 168
    },
    {
      "start": 603.911,
      "end": 606.744,
      "type": "line",
      "text": "until the law shall be fulfilled.",
      "verse": "25:24",
      "lineIndex": 169
    },
    {
      "start": 607.424,
      "end": 610.721,
      "type": "line",
      "text": "For, for this end was the law given;",
      "verse": "25:25",
      "lineIndex": 170
    },
    {
      "start": 610.901,
      "end": 614.523,
      "type": "line",
      "text": "wherefore the law hath become dead unto us,",
      "verse": "25:25",
      "lineIndex": 171
    },
    {
      "start": 614.703,
      "end": 618.186,
      "type": "line",
      "text": "and we are made alive in Christ because of our faith;",
      "verse": "25:25",
      "lineIndex": 172
    },
    {
      "start": 618.366,
      "end": 621.385,
      "type": "line",
      "text": "yet we keep the law because of the commandments.",
      "verse": "25:25",
      "lineIndex": 173
    },
    {
      "start": 622.065,
      "end": 623.737,
      "type": "line",
      "text": "And we talk of Christ,",
      "verse": "25:26",
      "lineIndex": 174
    },
    {
      "start": 623.917,
      "end": 625.682,
      "type": "line",
      "text": "we rejoice in Christ,",
      "verse": "25:26",
      "lineIndex": 175
    },
    {
      "start": 625.862,
      "end": 627.441,
      "type": "line",
      "text": "we preach of Christ,",
      "verse": "25:26",
      "lineIndex": 176
    },
    {
      "start": 627.621,
      "end": 629.432,
      "type": "line",
      "text": "we prophesy of Christ,",
      "verse": "25:26",
      "lineIndex": 177
    },
    {
      "start": 629.612,
      "end": 632.631,
      "type": "line",
      "text": "and we write according to our prophecies,",
      "verse": "25:26",
      "lineIndex": 178
    },
    {
      "start": 632.811,
      "end": 636.387,
      "type": "line",
      "text": "that our children may know to what source they may look",
      "verse": "25:26",
      "lineIndex": 179
    },
    {
      "start": 636.567,
      "end": 638.982,
      "type": "line",
      "text": "for a remission of their sins.",
      "verse": "25:26",
      "lineIndex": 180
    },
    {
      "start": 639.662,
      "end": 642.216,
      "type": "line",
      "text": "Wherefore, we speak concerning the law",
      "verse": "25:27",
      "lineIndex": 181
    },
    {
      "start": 642.396,
      "end": 645.786,
      "type": "line",
      "text": "that our children may know the deadness of the law;",
      "verse": "25:27",
      "lineIndex": 182
    },
    {
      "start": 645.966,
      "end": 647.452,
      "type": "line",
      "text": "and they,",
      "verse": "25:27",
      "lineIndex": 183
    },
    {
      "start": 647.632,
      "end": 649.908,
      "type": "line",
      "text": "by knowing the deadness of the law,",
      "verse": "25:27",
      "lineIndex": 184
    },
    {
      "start": 650.088,
      "end": 653.943,
      "type": "line",
      "text": "may look forward unto that life which is in Christ,",
      "verse": "25:27",
      "lineIndex": 185
    },
    {
      "start": 654.123,
      "end": 657.002,
      "type": "line",
      "text": "and know for what end the law was given.",
      "verse": "25:27",
      "lineIndex": 186
    },
    {
      "start": 657.182,
      "end": 660.386,
      "type": "line",
      "text": "And after the law is fulfilled in Christ,",
      "verse": "25:27",
      "lineIndex": 187
    },
    {
      "start": 660.566,
      "end": 666.65,
      "type": "line",
      "text": "that they need not harden their hearts against him",
      "verse": "25:27",
      "lineIndex": 188
    },
    {
      "start": 666.83,
      "end": 669.013,
      "type": "line",
      "text": "when the law ought to be done away.",
      "verse": "25:27",
      "lineIndex": 189
    },
    {
      "start": 669.693,
      "end": 674.058,
      "type": "line",
      "text": "And now behold, my people, ye are a stiffnecked people;",
      "verse": "25:28",
      "lineIndex": 190
    },
    {
      "start": 674.238,
      "end": 677.442,
      "type": "line",
      "text": "wherefore, I have spoken plainly unto you,",
      "verse": "25:28",
      "lineIndex": 191
    },
    {
      "start": 677.622,
      "end": 679.665,
      "type": "line",
      "text": "that ye cannot misunderstand.",
      "verse": "25:28",
      "lineIndex": 192
    },
    {
      "start": 679.845,
      "end": 685.093,
      "type": "line",
      "text": "And the words which I have spoken shall stand as a testimony against you;",
      "verse": "25:28",
      "lineIndex": 193
    },
    {
      "start": 685.273,
      "end": 688.895,
      "type": "line",
      "text": "for they are sufficient to teach any man the right way;",
      "verse": "25:28",
      "lineIndex": 194
    },
    {
      "start": 689.075,
      "end": 693.719,
      "type": "line",
      "text": "for the right way is to believe in Christ and deny him not;",
      "verse": "25:28",
      "lineIndex": 195
    },
    {
      "start": 693.899,
      "end": 698.125,
      "type": "line",
      "text": "for by denying him ye also deny the prophets and the law.",
      "verse": "25:28",
      "lineIndex": 196
    },
    {
      "start": 698.805,
      "end": 701.777,
      "type": "line",
      "text": "And now behold, I say unto you",
      "verse": "25:29",
      "lineIndex": 197
    },
    {
      "start": 701.957,
      "end": 705.254,
      "type": "line",
      "text": "that the right way is to believe in Christ,",
      "verse": "25:29",
      "lineIndex": 198
    },
    {
      "start": 705.434,
      "end": 707.106,
      "type": "line",
      "text": "and deny him not;",
      "verse": "25:29",
      "lineIndex": 199
    },
    {
      "start": 707.286,
      "end": 710.305,
      "type": "line",
      "text": "and Christ is the Holy One of Israel;",
      "verse": "25:29",
      "lineIndex": 200
    },
    {
      "start": 710.485,
      "end": 712.853,
      "type": "line",
      "text": "wherefore ye must bow down before him,",
      "verse": "25:29",
      "lineIndex": 201
    },
    {
      "start": 713.033,
      "end": 717.445,
      "type": "line",
      "text": "and worship him with all your might, mind and strength,",
      "verse": "25:29",
      "lineIndex": 202
    },
    {
      "start": 717.625,
      "end": 719.204,
      "type": "line",
      "text": "and your whole soul;",
      "verse": "25:29",
      "lineIndex": 203
    },
    {
      "start": 719.384,
      "end": 723.099,
      "type": "line",
      "text": "and if ye do this ye shall in nowise be cast out.",
      "verse": "25:29",
      "lineIndex": 204
    },
    {
      "start": 723.779,
      "end": 726.798,
      "type": "line",
      "text": "And, inasmuch as it shall be expedient,",
      "verse": "25:30",
      "lineIndex": 205
    },
    {
      "start": 726.978,
      "end": 730.972,
      "type": "line",
      "text": "ye must keep the performances and ordinances of God",
      "verse": "25:30",
      "lineIndex": 206
    },
    {
      "start": 731.152,
      "end": 735.703,
      "type": "line",
      "text": "until the law shall be fulfilled which was given unto Moses.",
      "verse": "25:30",
      "lineIndex": 207
    }
  ]
}