{
  "book": "2nephi",
  "bookName": "2 Nephi",
  "chapter": 26,
  "voice": {
    "provider": "elevenlabs",
    "voice_id": "ddDFRErfhdc2asyySOG5",
    "model_id": "eleven_multilingual_v2",
    "settings": {
      "stability": 0.5,
      "similarity_boost": 0.75,
      "style": 0.35,
      "use_speaker_boost": true
    },
    "name": "samuel"
  },
  "pauses": {
    "line_ms": 180,
    "verse_ms": 500
  },
  "duration": 559.111,
  "lines": [
    {
      "start": 0.0,
      "end": 2.694,
      "type": "line",
      "text": "And after Christ shall have risen from the dead",
      "verse": "26:1",
      "lineIndex": 1
    },
    {
      "start": 2.874,
      "end": 4.964,
      "type": "line",
      "text": "he shall show himself unto you,",
      "verse": "26:1",
      "lineIndex": 2
    },
    {
      "start": 5.144,
      "end": 7.93,
      "type": "line",
      "text": "my children, and my beloved brethren;",
      "verse": "26:1",
      "lineIndex": 3
    },
    {
      "start": 8.11,
      "end": 10.293,
      "type": "line",
      "text": "and the words which he shall speak",
      "verse": "26:1",
      "lineIndex": 4
    },
    {
      "start": 10.473,
      "end": 13.213,
      "type": "line",
      "text": "unto you shall be the law which ye shall do.",
      "verse": "26:1",
      "lineIndex": 5
    },
    {
      "start": 13.893,
      "end": 15.843,
      "type": "line",
      "text": "For behold, I say unto you",
      "verse": "26:2",
      "lineIndex": 6
    },
    {
      "start": 16.023,
      "end": 19.367,
      "type": "line",
      "text": "that I have beheld that many generations shall pass away,",
      "verse": "26:2",
      "lineIndex": 7
    },
    {
      "start": 19.547,
      "end": 23.587,
      "type": "line",
      "text": "and there shall be great wars and contentions among my people.",
      "verse": "26:2",
      "lineIndex": 8
    },
    {
      "start": 24.267,
      "end": 26.543,
      "type": "line",
      "text": "And after the Messiah shall come",
      "verse": "26:3",
      "lineIndex": 9
    },
    {
      "start": 26.723,
      "end": 30.345,
      "type": "line",
      "text": "there shall be signs given unto my people of his birth,",
      "verse": "26:3",
      "lineIndex": 10
    },
    {
      "start": 30.525,
      "end": 33.126,
      "type": "line",
      "text": "and also of his death and resurrection;",
      "verse": "26:3",
      "lineIndex": 11
    },
    {
      "start": 33.306,
      "end": 36.789,
      "type": "line",
      "text": "and great and terrible shall that day be unto the wicked,",
      "verse": "26:3",
      "lineIndex": 12
    },
    {
      "start": 36.969,
      "end": 38.548,
      "type": "line",
      "text": "for they shall perish;",
      "verse": "26:3",
      "lineIndex": 13
    },
    {
      "start": 38.728,
      "end": 43.047,
      "type": "line",
      "text": "and they perish because they cast out the prophets, and the saints,",
      "verse": "26:3",
      "lineIndex": 14
    },
    {
      "start": 43.227,
      "end": 45.224,
      "type": "line",
      "text": "and stone them, and slay them;",
      "verse": "26:3",
      "lineIndex": 15
    },
    {
      "start": 45.404,
      "end": 48.051,
      "type": "line",
      "text": "wherefore the cry of the blood of the saints",
      "verse": "26:3",
      "lineIndex": 16
    },
    {
      "start": 48.231,
      "end": 51.435,
      "type": "line",
      "text": "shall ascend up to God from the ground against them.",
      "verse": "26:3",
      "lineIndex": 17
    },
    {
      "start": 52.115,
      "end": 54.298,
      "type": "line",
      "text": "Wherefore, all those who are proud,",
      "verse": "26:4",
      "lineIndex": 18
    },
    {
      "start": 54.478,
      "end": 56.103,
      "type": "line",
      "text": "and that do wickedly,",
      "verse": "26:4",
      "lineIndex": 19
    },
    {
      "start": 56.283,
      "end": 58.651,
      "type": "line",
      "text": "the day that cometh shall burn them up,",
      "verse": "26:4",
      "lineIndex": 20
    },
    {
      "start": 58.831,
      "end": 60.503,
      "type": "line",
      "text": "saith the Lord of Hosts,",
      "verse": "26:4",
      "lineIndex": 21
    },
    {
      "start": 60.683,
      "end": 62.587,
      "type": "line",
      "text": "for they shall be as stubble.",
      "verse": "26:4",
      "lineIndex": 22
    },
    {
      "start": 63.267,
      "end": 65.868,
      "type": "line",
      "text": "And they that kill the prophets, and the saints,",
      "verse": "26:5",
      "lineIndex": 24
    },
    {
      "start": 66.048,
      "end": 68.788,
      "type": "line",
      "text": "the depths of the earth shall swallow them up,",
      "verse": "26:5",
      "lineIndex": 25
    },
    {
      "start": 68.968,
      "end": 70.779,
      "type": "line",
      "text": "saith the Lord of Hosts;",
      "verse": "26:5",
      "lineIndex": 26
    },
    {
      "start": 70.959,
      "end": 73.002,
      "type": "line",
      "text": "and mountains shall cover them,",
      "verse": "26:5",
      "lineIndex": 27
    },
    {
      "start": 73.182,
      "end": 75.643,
      "type": "line",
      "text": "and whirlwinds shall carry them away,",
      "verse": "26:5",
      "lineIndex": 28
    },
    {
      "start": 75.823,
      "end": 78.191,
      "type": "line",
      "text": "and buildings shall fall upon them",
      "verse": "26:5",
      "lineIndex": 29
    },
    {
      "start": 78.371,
      "end": 81.297,
      "type": "line",
      "text": "and crush them to pieces and grind them to powder.",
      "verse": "26:5",
      "lineIndex": 30
    },
    {
      "start": 81.977,
      "end": 85.228,
      "type": "line",
      "text": "And they shall be visited with thunderings, and lightnings,",
      "verse": "26:6",
      "lineIndex": 31
    },
    {
      "start": 85.408,
      "end": 88.891,
      "type": "line",
      "text": "and earthquakes, and all manner of destructions,",
      "verse": "26:6",
      "lineIndex": 32
    },
    {
      "start": 89.071,
      "end": 93.483,
      "type": "line",
      "text": "for the fire of the anger of the Lord shall be kindled against them,",
      "verse": "26:6",
      "lineIndex": 33
    },
    {
      "start": 93.663,
      "end": 95.66,
      "type": "line",
      "text": "and they shall be as stubble,",
      "verse": "26:6",
      "lineIndex": 34
    },
    {
      "start": 95.84,
      "end": 98.626,
      "type": "line",
      "text": "and the day that cometh shall consume them,",
      "verse": "26:6",
      "lineIndex": 35
    },
    {
      "start": 98.806,
      "end": 100.524,
      "type": "line",
      "text": "saith the Lord of Hosts.",
      "verse": "26:6",
      "lineIndex": 36
    },
    {
      "start": 101.204,
      "end": 103.944,
      "type": "line",
      "text": "O the pain, and the anguish of my soul",
      "verse": "26:7",
      "lineIndex": 37
    },
    {
      "start": 104.124,
      "end": 106.632,
      "type": "line",
      "text": "for the loss of the slain of my people!",
      "verse": "26:7",
      "lineIndex": 38
    },
    {
      "start": 106.812,
      "end": 108.902,
      "type": "line",
      "text": "For I, Nephi, have seen it,",
      "verse": "26:7",
      "lineIndex": 39
    },
    {
      "start": 109.082,
      "end": 112.797,
      "type": "line",
      "text": "and it well nigh consumeth me before the presence of the Lord;",
      "verse": "26:7",
      "lineIndex": 40
    },
    {
      "start": 112.977,
      "end": 114.881,
      "type": "line",
      "text": "but I must cry unto my God:",
      "verse": "26:7",
      "lineIndex": 41
    },
    {
      "start": 115.061,
      "end": 116.64,
      "type": "line",
      "text": "Thy ways are just.",
      "verse": "26:7",
      "lineIndex": 42
    },
    {
      "start": 117.32,
      "end": 121.592,
      "type": "line",
      "text": "But behold, the righteous that hearken unto the words of the prophets,",
      "verse": "26:8",
      "lineIndex": 43
    },
    {
      "start": 121.772,
      "end": 123.537,
      "type": "line",
      "text": "and destroy them not,",
      "verse": "26:8",
      "lineIndex": 44
    },
    {
      "start": 123.717,
      "end": 125.714,
      "type": "line",
      "text": "but look forward unto Christ",
      "verse": "26:8",
      "lineIndex": 45
    },
    {
      "start": 125.894,
      "end": 128.959,
      "type": "line",
      "text": "with steadfastness for the signs which are given,",
      "verse": "26:8",
      "lineIndex": 46
    },
    {
      "start": 129.139,
      "end": 131.368,
      "type": "line",
      "text": "notwithstanding all persecution\u2014",
      "verse": "26:8",
      "lineIndex": 47
    },
    {
      "start": 131.548,
      "end": 133.916,
      "type": "line",
      "text": "behold, they are they which shall not perish.",
      "verse": "26:8",
      "lineIndex": 48
    },
    {
      "start": 134.596,
      "end": 137.754,
      "type": "line",
      "text": "But the Son of Righteousness shall appear unto them;",
      "verse": "26:9",
      "lineIndex": 49
    },
    {
      "start": 137.934,
      "end": 139.374,
      "type": "line",
      "text": "and he shall heal them,",
      "verse": "26:9",
      "lineIndex": 50
    },
    {
      "start": 139.554,
      "end": 141.644,
      "type": "line",
      "text": "and they shall have peace with him,",
      "verse": "26:9",
      "lineIndex": 51
    },
    {
      "start": 141.824,
      "end": 144.657,
      "type": "line",
      "text": "until three generations shall have passed away,",
      "verse": "26:9",
      "lineIndex": 52
    },
    {
      "start": 144.837,
      "end": 149.017,
      "type": "line",
      "text": "and many of the fourth generation shall have passed away in righteousness.",
      "verse": "26:9",
      "lineIndex": 53
    },
    {
      "start": 149.697,
      "end": 151.926,
      "type": "line",
      "text": "And when these things have passed away",
      "verse": "26:10",
      "lineIndex": 54
    },
    {
      "start": 152.106,
      "end": 155.032,
      "type": "line",
      "text": "a speedy destruction cometh unto my people;",
      "verse": "26:10",
      "lineIndex": 55
    },
    {
      "start": 155.212,
      "end": 158.045,
      "type": "line",
      "text": "for, notwithstanding the pains of my soul,",
      "verse": "26:10",
      "lineIndex": 56
    },
    {
      "start": 158.225,
      "end": 159.897,
      "type": "line",
      "text": "I have seen it;",
      "verse": "26:10",
      "lineIndex": 57
    },
    {
      "start": 160.077,
      "end": 163.049,
      "type": "line",
      "text": "wherefore, I know that it shall come to pass;",
      "verse": "26:10",
      "lineIndex": 58
    },
    {
      "start": 163.229,
      "end": 165.458,
      "type": "line",
      "text": "and they sell themselves for naught;",
      "verse": "26:10",
      "lineIndex": 59
    },
    {
      "start": 165.638,
      "end": 169.26,
      "type": "line",
      "text": "for, for the reward of their pride and their foolishness",
      "verse": "26:10",
      "lineIndex": 60
    },
    {
      "start": 169.44,
      "end": 171.158,
      "type": "line",
      "text": "they shall reap destruction;",
      "verse": "26:10",
      "lineIndex": 61
    },
    {
      "start": 171.338,
      "end": 174.124,
      "type": "line",
      "text": "for because they yield unto the devil",
      "verse": "26:10",
      "lineIndex": 62
    },
    {
      "start": 174.304,
      "end": 177.415,
      "type": "line",
      "text": "and choose works of darkness rather than light,",
      "verse": "26:10",
      "lineIndex": 63
    },
    {
      "start": 177.595,
      "end": 179.638,
      "type": "line",
      "text": "therefore they must go down to hell.",
      "verse": "26:10",
      "lineIndex": 64
    },
    {
      "start": 180.318,
      "end": 183.615,
      "type": "line",
      "text": "For the Spirit of the Lord will not always strive with man.",
      "verse": "26:11",
      "lineIndex": 65
    },
    {
      "start": 183.795,
      "end": 186.256,
      "type": "line",
      "text": "And when the Spirit ceaseth to strive",
      "verse": "26:11",
      "lineIndex": 66
    },
    {
      "start": 186.436,
      "end": 189.13,
      "type": "line",
      "text": "with man then cometh speedy destruction,",
      "verse": "26:11",
      "lineIndex": 67
    },
    {
      "start": 189.31,
      "end": 191.028,
      "type": "line",
      "text": "and this grieveth my soul.",
      "verse": "26:11",
      "lineIndex": 68
    },
    {
      "start": 191.708,
      "end": 194.819,
      "type": "line",
      "text": "And as I spake concerning the convincing of the Jews,",
      "verse": "26:12",
      "lineIndex": 70
    },
    {
      "start": 194.999,
      "end": 196.996,
      "type": "line",
      "text": "that Jesus is the very Christ,",
      "verse": "26:12",
      "lineIndex": 71
    },
    {
      "start": 197.176,
      "end": 200.52,
      "type": "line",
      "text": "it must needs be that the Gentiles be convinced also",
      "verse": "26:12",
      "lineIndex": 72
    },
    {
      "start": 200.7,
      "end": 202.558,
      "type": "line",
      "text": "that Jesus is the Christ,",
      "verse": "26:12",
      "lineIndex": 73
    },
    {
      "start": 202.738,
      "end": 204.224,
      "type": "line",
      "text": "the Eternal God;",
      "verse": "26:12",
      "lineIndex": 74
    },
    {
      "start": 204.904,
      "end": 209.037,
      "type": "line",
      "text": "And that he manifesteth himself unto all those who believe in him,",
      "verse": "26:13",
      "lineIndex": 75
    },
    {
      "start": 209.217,
      "end": 211.121,
      "type": "line",
      "text": "by the power of the Holy Ghost;",
      "verse": "26:13",
      "lineIndex": 76
    },
    {
      "start": 211.301,
      "end": 214.877,
      "type": "line",
      "text": "yea, unto every nation, kindred, tongue, and people,",
      "verse": "26:13",
      "lineIndex": 77
    },
    {
      "start": 215.057,
      "end": 218.215,
      "type": "line",
      "text": "working mighty miracles, signs, and wonders,",
      "verse": "26:13",
      "lineIndex": 78
    },
    {
      "start": 218.395,
      "end": 220.345,
      "type": "line",
      "text": "among the children of men",
      "verse": "26:13",
      "lineIndex": 79
    },
    {
      "start": 220.525,
      "end": 222.011,
      "type": "line",
      "text": "according to their faith.",
      "verse": "26:13",
      "lineIndex": 80
    },
    {
      "start": 222.691,
      "end": 226.778,
      "type": "line",
      "text": "But behold, I prophesy unto you concerning the last days;",
      "verse": "26:14",
      "lineIndex": 81
    },
    {
      "start": 226.958,
      "end": 230.58,
      "type": "line",
      "text": "concerning the days when the Lord God shall bring these things forth",
      "verse": "26:14",
      "lineIndex": 82
    },
    {
      "start": 230.76,
      "end": 232.2,
      "type": "line",
      "text": "unto the children of men.",
      "verse": "26:14",
      "lineIndex": 83
    },
    {
      "start": 232.88,
      "end": 237.71,
      "type": "line",
      "text": "After my seed and the seed of my brethren shall have dwindled in unbelief,",
      "verse": "26:15",
      "lineIndex": 84
    },
    {
      "start": 237.89,
      "end": 240.816,
      "type": "line",
      "text": "and shall have been smitten by the Gentiles;",
      "verse": "26:15",
      "lineIndex": 85
    },
    {
      "start": 240.996,
      "end": 245.176,
      "type": "line",
      "text": "yea, after the Lord God shall have camped against them round about,",
      "verse": "26:15",
      "lineIndex": 86
    },
    {
      "start": 245.356,
      "end": 248.467,
      "type": "line",
      "text": "and shall have laid siege against them with a mount,",
      "verse": "26:15",
      "lineIndex": 87
    },
    {
      "start": 248.647,
      "end": 250.597,
      "type": "line",
      "text": "and raised forts against them;",
      "verse": "26:15",
      "lineIndex": 88
    },
    {
      "start": 250.777,
      "end": 254.585,
      "type": "line",
      "text": "and after they shall have been brought down low in the dust,",
      "verse": "26:15",
      "lineIndex": 89
    },
    {
      "start": 254.765,
      "end": 256.437,
      "type": "line",
      "text": "even that they are not,",
      "verse": "26:15",
      "lineIndex": 90
    },
    {
      "start": 256.617,
      "end": 259.264,
      "type": "line",
      "text": "yet the words of the righteous shall be written,",
      "verse": "26:15",
      "lineIndex": 91
    },
    {
      "start": 259.444,
      "end": 261.952,
      "type": "line",
      "text": "and the prayers of the faithful shall be heard,",
      "verse": "26:15",
      "lineIndex": 92
    },
    {
      "start": 262.132,
      "end": 265.847,
      "type": "line",
      "text": "and all those who have dwindled in unbelief shall not be forgotten.",
      "verse": "26:15",
      "lineIndex": 93
    },
    {
      "start": 266.527,
      "end": 270.846,
      "type": "line",
      "text": "For those who shall be destroyed shall speak unto them out of the ground,",
      "verse": "26:16",
      "lineIndex": 94
    },
    {
      "start": 271.026,
      "end": 273.812,
      "type": "line",
      "text": "and their speech shall be low out of the dust,",
      "verse": "26:16",
      "lineIndex": 95
    },
    {
      "start": 273.992,
      "end": 277.475,
      "type": "line",
      "text": "and their voice shall be as one that hath a familiar spirit;",
      "verse": "26:16",
      "lineIndex": 96
    },
    {
      "start": 277.655,
      "end": 280.349,
      "type": "line",
      "text": "for the Lord God will give unto him power,",
      "verse": "26:16",
      "lineIndex": 97
    },
    {
      "start": 280.529,
      "end": 282.897,
      "type": "line",
      "text": "that he may whisper concerning them,",
      "verse": "26:16",
      "lineIndex": 98
    },
    {
      "start": 283.077,
      "end": 285.353,
      "type": "line",
      "text": "even as it were out of the ground;",
      "verse": "26:16",
      "lineIndex": 99
    },
    {
      "start": 285.533,
      "end": 289.155,
      "type": "line",
      "text": "and their speech shall whisper out of the dust.",
      "verse": "26:16",
      "lineIndex": 100
    },
    {
      "start": 289.835,
      "end": 291.739,
      "type": "line",
      "text": "For thus saith the Lord God:",
      "verse": "26:17",
      "lineIndex": 101
    },
    {
      "start": 291.919,
      "end": 295.216,
      "type": "line",
      "text": "They shall write the things which shall be done among them,",
      "verse": "26:17",
      "lineIndex": 102
    },
    {
      "start": 295.396,
      "end": 298.182,
      "type": "line",
      "text": "and they shall be written and sealed up in a book,",
      "verse": "26:17",
      "lineIndex": 103
    },
    {
      "start": 298.362,
      "end": 301.845,
      "type": "line",
      "text": "and those who have dwindled in unbelief shall not have them,",
      "verse": "26:17",
      "lineIndex": 104
    },
    {
      "start": 302.025,
      "end": 304.672,
      "type": "line",
      "text": "for they seek to destroy the things of God.",
      "verse": "26:17",
      "lineIndex": 105
    },
    {
      "start": 305.352,
      "end": 310.739,
      "type": "line",
      "text": "Wherefore, as those who have been destroyed have been destroyed speedily;",
      "verse": "26:18",
      "lineIndex": 106
    },
    {
      "start": 310.919,
      "end": 315.935,
      "type": "line",
      "text": "and the multitude of their terrible ones shall be as chaff that passeth away\u2014",
      "verse": "26:18",
      "lineIndex": 107
    },
    {
      "start": 316.115,
      "end": 318.112,
      "type": "line",
      "text": "yea, thus saith the Lord God:",
      "verse": "26:18",
      "lineIndex": 108
    },
    {
      "start": 318.292,
      "end": 320.614,
      "type": "line",
      "text": "It shall be at an instant, suddenly\u2014",
      "verse": "26:18",
      "lineIndex": 109
    },
    {
      "start": 321.294,
      "end": 323.337,
      "type": "line",
      "text": "And it shall come to pass,",
      "verse": "26:19",
      "lineIndex": 110
    },
    {
      "start": 323.517,
      "end": 326.025,
      "type": "line",
      "text": "that those who have dwindled in unbelief",
      "verse": "26:19",
      "lineIndex": 111
    },
    {
      "start": 326.205,
      "end": 329.177,
      "type": "line",
      "text": "shall be smitten by the hand of the Gentiles.",
      "verse": "26:19",
      "lineIndex": 112
    },
    {
      "start": 329.857,
      "end": 333.061,
      "type": "line",
      "text": "And the Gentiles are lifted up in the pride of their eyes,",
      "verse": "26:20",
      "lineIndex": 113
    },
    {
      "start": 333.241,
      "end": 334.588,
      "type": "line",
      "text": "and have stumbled,",
      "verse": "26:20",
      "lineIndex": 114
    },
    {
      "start": 334.768,
      "end": 337.879,
      "type": "line",
      "text": "because of the greatness of their stumbling block,",
      "verse": "26:20",
      "lineIndex": 115
    },
    {
      "start": 338.059,
      "end": 340.66,
      "type": "line",
      "text": "that they have built up many churches;",
      "verse": "26:20",
      "lineIndex": 116
    },
    {
      "start": 340.84,
      "end": 344.416,
      "type": "line",
      "text": "nevertheless, they put down the power and miracles of God,",
      "verse": "26:20",
      "lineIndex": 117
    },
    {
      "start": 344.596,
      "end": 348.636,
      "type": "line",
      "text": "and preach up unto themselves their own wisdom and their own learning,",
      "verse": "26:20",
      "lineIndex": 118
    },
    {
      "start": 348.816,
      "end": 352.299,
      "type": "line",
      "text": "that they may get gain and grind upon the face of the poor.",
      "verse": "26:20",
      "lineIndex": 119
    },
    {
      "start": 352.979,
      "end": 358.227,
      "type": "line",
      "text": "And there are many churches built up which cause envyings, and strifes, and malice.",
      "verse": "26:21",
      "lineIndex": 120
    },
    {
      "start": 358.907,
      "end": 361.322,
      "type": "line",
      "text": "And there are also secret combinations,",
      "verse": "26:22",
      "lineIndex": 121
    },
    {
      "start": 361.502,
      "end": 363.267,
      "type": "line",
      "text": "even as in times of old,",
      "verse": "26:22",
      "lineIndex": 122
    },
    {
      "start": 363.447,
      "end": 365.955,
      "type": "line",
      "text": "according to the combinations of the devil,",
      "verse": "26:22",
      "lineIndex": 123
    },
    {
      "start": 366.135,
      "end": 368.921,
      "type": "line",
      "text": "for he is the founder of all these things;",
      "verse": "26:22",
      "lineIndex": 124
    },
    {
      "start": 369.101,
      "end": 372.398,
      "type": "line",
      "text": "yea, the founder of murder, and works of darkness;",
      "verse": "26:22",
      "lineIndex": 125
    },
    {
      "start": 372.578,
      "end": 376.433,
      "type": "line",
      "text": "yea, and he leadeth them by the neck with a flaxen cord,",
      "verse": "26:22",
      "lineIndex": 126
    },
    {
      "start": 376.613,
      "end": 380.05,
      "type": "line",
      "text": "until he bindeth them with his strong cords forever.",
      "verse": "26:22",
      "lineIndex": 127
    },
    {
      "start": 380.73,
      "end": 384.074,
      "type": "line",
      "text": "For behold, my beloved brethren, I say unto you",
      "verse": "26:23",
      "lineIndex": 128
    },
    {
      "start": 384.254,
      "end": 386.715,
      "type": "line",
      "text": "that the Lord God worketh not in darkness.",
      "verse": "26:23",
      "lineIndex": 129
    },
    {
      "start": 387.395,
      "end": 391.017,
      "type": "line",
      "text": "He doeth not anything save it be for the benefit of the world;",
      "verse": "26:24",
      "lineIndex": 131
    },
    {
      "start": 391.197,
      "end": 393.008,
      "type": "line",
      "text": "for he loveth the world,",
      "verse": "26:24",
      "lineIndex": 132
    },
    {
      "start": 393.188,
      "end": 395.649,
      "type": "line",
      "text": "even that he layeth down his own life",
      "verse": "26:24",
      "lineIndex": 133
    },
    {
      "start": 395.829,
      "end": 398.29,
      "type": "line",
      "text": "that he may draw all men unto him.",
      "verse": "26:24",
      "lineIndex": 134
    },
    {
      "start": 398.47,
      "end": 403.021,
      "type": "line",
      "text": "Wherefore, he commandeth none that they shall not partake of his salvation.",
      "verse": "26:24",
      "lineIndex": 135
    },
    {
      "start": 403.701,
      "end": 406.023,
      "type": "line",
      "text": "Behold, doth he cry unto any, saying:",
      "verse": "26:25",
      "lineIndex": 136
    },
    {
      "start": 406.203,
      "end": 407.55,
      "type": "line",
      "text": "Depart from me?",
      "verse": "26:25",
      "lineIndex": 137
    },
    {
      "start": 407.73,
      "end": 409.588,
      "type": "line",
      "text": "Behold, I say unto you, Nay;",
      "verse": "26:25",
      "lineIndex": 138
    },
    {
      "start": 409.768,
      "end": 411.208,
      "type": "line",
      "text": "but he saith:",
      "verse": "26:25",
      "lineIndex": 139
    },
    {
      "start": 411.388,
      "end": 414.082,
      "type": "line",
      "text": "Come unto me all ye ends of the earth,",
      "verse": "26:25",
      "lineIndex": 140
    },
    {
      "start": 414.262,
      "end": 415.98,
      "type": "line",
      "text": "buy milk and honey,",
      "verse": "26:25",
      "lineIndex": 141
    },
    {
      "start": 416.16,
      "end": 418.343,
      "type": "line",
      "text": "without money and without price.",
      "verse": "26:25",
      "lineIndex": 142
    },
    {
      "start": 419.023,
      "end": 422.042,
      "type": "line",
      "text": "Behold, hath he commanded any that they should depart",
      "verse": "26:26",
      "lineIndex": 143
    },
    {
      "start": 422.222,
      "end": 423.662,
      "type": "line",
      "text": "out of the synagogues,",
      "verse": "26:26",
      "lineIndex": 144
    },
    {
      "start": 423.842,
      "end": 426.536,
      "type": "line",
      "text": "or out of the houses of worship?",
      "verse": "26:26",
      "lineIndex": 145
    },
    {
      "start": 426.716,
      "end": 428.666,
      "type": "line",
      "text": "Behold, I say unto you, Nay.",
      "verse": "26:26",
      "lineIndex": 146
    },
    {
      "start": 429.346,
      "end": 433.386,
      "type": "line",
      "text": "Hath he commanded any that they should not partake of his salvation?",
      "verse": "26:27",
      "lineIndex": 147
    },
    {
      "start": 433.566,
      "end": 435.377,
      "type": "line",
      "text": "Behold I say unto you, Nay;",
      "verse": "26:27",
      "lineIndex": 148
    },
    {
      "start": 435.557,
      "end": 437.925,
      "type": "line",
      "text": "but he hath given it free for all men;",
      "verse": "26:27",
      "lineIndex": 149
    },
    {
      "start": 438.105,
      "end": 440.055,
      "type": "line",
      "text": "and he hath commanded his people",
      "verse": "26:27",
      "lineIndex": 150
    },
    {
      "start": 440.235,
      "end": 443.672,
      "type": "line",
      "text": "that they should persuade all men to repentance.",
      "verse": "26:27",
      "lineIndex": 151
    },
    {
      "start": 444.352,
      "end": 446.767,
      "type": "line",
      "text": "Behold, hath the Lord commanded any",
      "verse": "26:28",
      "lineIndex": 152
    },
    {
      "start": 446.947,
      "end": 449.408,
      "type": "line",
      "text": "that they should not partake of his goodness?",
      "verse": "26:28",
      "lineIndex": 153
    },
    {
      "start": 449.588,
      "end": 451.399,
      "type": "line",
      "text": "Behold I say unto you, Nay;",
      "verse": "26:28",
      "lineIndex": 154
    },
    {
      "start": 451.579,
      "end": 455.294,
      "type": "line",
      "text": "but all men are privileged the one like unto the other",
      "verse": "26:28",
      "lineIndex": 155
    },
    {
      "start": 455.474,
      "end": 456.914,
      "type": "line",
      "text": "and none are forbidden.",
      "verse": "26:28",
      "lineIndex": 156
    },
    {
      "start": 457.594,
      "end": 460.845,
      "type": "line",
      "text": "He commandeth that there shall be no priestcrafts;",
      "verse": "26:29",
      "lineIndex": 157
    },
    {
      "start": 461.025,
      "end": 464.229,
      "type": "line",
      "text": "for, behold, priestcrafts are that men preach",
      "verse": "26:29",
      "lineIndex": 158
    },
    {
      "start": 464.409,
      "end": 467.52,
      "type": "line",
      "text": "and set themselves up for a light unto the world,",
      "verse": "26:29",
      "lineIndex": 159
    },
    {
      "start": 467.7,
      "end": 470.997,
      "type": "line",
      "text": "that they may get gain and praise of the world;",
      "verse": "26:29",
      "lineIndex": 160
    },
    {
      "start": 471.177,
      "end": 473.406,
      "type": "line",
      "text": "but they seek not the welfare of Zion.",
      "verse": "26:29",
      "lineIndex": 161
    },
    {
      "start": 474.086,
      "end": 476.362,
      "type": "line",
      "text": "Behold, the Lord hath forbidden this thing;",
      "verse": "26:30",
      "lineIndex": 162
    },
    {
      "start": 476.542,
      "end": 479.7,
      "type": "line",
      "text": "wherefore, the Lord God hath given a commandment",
      "verse": "26:30",
      "lineIndex": 163
    },
    {
      "start": 479.88,
      "end": 482.248,
      "type": "line",
      "text": "that all men should have charity,",
      "verse": "26:30",
      "lineIndex": 164
    },
    {
      "start": 482.428,
      "end": 484.146,
      "type": "line",
      "text": "which charity is love.",
      "verse": "26:30",
      "lineIndex": 165
    },
    {
      "start": 484.326,
      "end": 487.112,
      "type": "line",
      "text": "And except they should have charity they were nothing.",
      "verse": "26:30",
      "lineIndex": 166
    },
    {
      "start": 487.292,
      "end": 490.078,
      "type": "line",
      "text": "Wherefore, if they should have charity",
      "verse": "26:30",
      "lineIndex": 167
    },
    {
      "start": 490.258,
      "end": 493.555,
      "type": "line",
      "text": "they would not suffer the laborer in Zion to perish.",
      "verse": "26:30",
      "lineIndex": 168
    },
    {
      "start": 494.235,
      "end": 497.254,
      "type": "line",
      "text": "But the laborer in Zion shall labor for Zion;",
      "verse": "26:31",
      "lineIndex": 169
    },
    {
      "start": 497.434,
      "end": 500.406,
      "type": "line",
      "text": "for if they labor for money they shall perish.",
      "verse": "26:31",
      "lineIndex": 170
    },
    {
      "start": 501.086,
      "end": 504.801,
      "type": "line",
      "text": "And again, the Lord God hath commanded that men should not murder;",
      "verse": "26:32",
      "lineIndex": 171
    },
    {
      "start": 504.981,
      "end": 506.56,
      "type": "line",
      "text": "that they should not lie;",
      "verse": "26:32",
      "lineIndex": 172
    },
    {
      "start": 506.74,
      "end": 508.505,
      "type": "line",
      "text": "that they should not steal;",
      "verse": "26:32",
      "lineIndex": 173
    },
    {
      "start": 508.685,
      "end": 512.4,
      "type": "line",
      "text": "that they should not take the name of the Lord their God in vain;",
      "verse": "26:32",
      "lineIndex": 174
    },
    {
      "start": 512.58,
      "end": 514.345,
      "type": "line",
      "text": "that they should not envy;",
      "verse": "26:32",
      "lineIndex": 175
    },
    {
      "start": 514.525,
      "end": 516.847,
      "type": "line",
      "text": "that they should not have malice;",
      "verse": "26:32",
      "lineIndex": 176
    },
    {
      "start": 517.027,
      "end": 520.046,
      "type": "line",
      "text": "that they should not contend one with another;",
      "verse": "26:32",
      "lineIndex": 177
    },
    {
      "start": 520.226,
      "end": 522.455,
      "type": "line",
      "text": "that they should not commit whoredoms;",
      "verse": "26:32",
      "lineIndex": 178
    },
    {
      "start": 522.635,
      "end": 525.282,
      "type": "line",
      "text": "and that they should do none of these things;",
      "verse": "26:32",
      "lineIndex": 179
    },
    {
      "start": 525.462,
      "end": 527.784,
      "type": "line",
      "text": "for whoso doeth them shall perish.",
      "verse": "26:32",
      "lineIndex": 180
    },
    {
      "start": 528.464,
      "end": 531.343,
      "type": "line",
      "text": "For none of these iniquities come of the Lord;",
      "verse": "26:33",
      "lineIndex": 181
    },
    {
      "start": 531.523,
      "end": 534.867,
      "type": "line",
      "text": "for he doeth that which is good among the children of men;",
      "verse": "26:33",
      "lineIndex": 182
    },
    {
      "start": 535.047,
      "end": 539.366,
      "type": "line",
      "text": "and he doeth nothing save it be plain unto the children of men;",
      "verse": "26:33",
      "lineIndex": 183
    },
    {
      "start": 539.546,
      "end": 544.562,
      "type": "line",
      "text": "and he inviteth them all to come unto him and partake of his goodness;",
      "verse": "26:33",
      "lineIndex": 184
    },
    {
      "start": 544.742,
      "end": 547.11,
      "type": "line",
      "text": "and he denieth none that come unto him,",
      "verse": "26:33",
      "lineIndex": 185
    },
    {
      "start": 547.29,
      "end": 548.776,
      "type": "line",
      "text": "black and white,",
      "verse": "26:33",
      "lineIndex": 186
    },
    {
      "start": 548.956,
      "end": 550.256,
      "type": "line",
      "text": "bond and free,",
      "verse": "26:33",
      "lineIndex": 187
    },
    {
      "start": 550.436,
      "end": 551.969,
      "type": "line",
      "text": "male and female;",
      "verse": "26:33",
      "lineIndex": 188
    },
    {
      "start": 552.149,
      "end": 554.053,
      "type": "line",
      "text": "and he remembereth the heathen;",
      "verse": "26:33",
      "lineIndex": 189
    },
    {
      "start": 554.233,
      "end": 556.462,
      "type": "line",
      "text": "and all are alike unto God,",
      "verse": "26:33",
      "lineIndex": 190
    },
    {
      "start": 556.642,
      "end": 558.453,
      "type": "line",
      "text": "both Jew and Gentile.",
      "verse": "26:33",
      "lineIndex": 191
    }
  ]
}