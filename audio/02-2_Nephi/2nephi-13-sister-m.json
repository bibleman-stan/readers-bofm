      "text": "the Lord of Hosts, doth take away",
      "verse": "13:1",
      "lineIndex": 2
    },
    {
      "start": 5.329,
      "end": 9.741,
      "type": "line",
      "text": "from Jerusalem, and from Judah, the stay and the staff,",
      "verse": "13:1",
      "lineIndex": 3
    },
    {
      "start": 9.921,
      "end": 13.45,
      "type": "line",
      "text": "the whole staff of bread, and the whole stay of water\u2014",
      "verse": "13:1",
      "lineIndex": 4
    },
    {
      "start": 13.63,
      "end": 29.745,
      "type": "line",
      "text": "For behold, the Lord, the Lord of Hosts, doth take away from Jerusalem, and from Judah, the stay and the staff, the whole stay staff of bread, and the whole stay of water--",
      "verse": "13:1",
      "lineIndex": 5
    },
    {
      "start": 30.425,
      "end": 32.793,
