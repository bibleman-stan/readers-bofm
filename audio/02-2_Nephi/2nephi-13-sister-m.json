      "text": "The mighty man, and the man of war,",
      "verse": "13:2",
      "lineIndex": 6
    },
    {
      "start": 32.973,
      "end": 35.063,
      "type": "line",
      "text": "the judge, and the prophet,",
      "verse": "13:2",
      "lineIndex": 7
    },
    {
      "start": 35.243,
      "end": 37.937,
      "type": "line",
      "text": "and the prudent, and the ancient;",
      "verse": "13:2",
      "lineIndex": 8
    },
    {
      "start": 38.117,
      "end": 45.083,
      "type": "line",
      "text": "The mighty man, and the man of war, the judge, and the prophet, and the prudent, and the ancient;",
      "verse": "13:2",
      "lineIndex": 9
    },
    {
      "start": 45.763,
      "end": 48.828,
