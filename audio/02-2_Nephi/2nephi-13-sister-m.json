      "start": 337.313,
      "end": 341.353,
      "type": "line",
      "text": "and walk with stretched-forth necks and wanton eyes,",
      "verse": "13:16",
      "lineIndex": 78
    },
    {
      "start": 341.533,
      "end": 344.134,
      "type": "line",
      "text": "walking and mincing as they go,",
      "verse": "13:16",
