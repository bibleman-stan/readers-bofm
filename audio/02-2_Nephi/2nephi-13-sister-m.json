  "lines": [
    {
      "start": 0.0,
      "end": 1.997,
      "type": "line",
      "text": "For behold, the Lord,",
      "verse": "13:1",
      "lineIndex": 1
    },
    {
      "start": 2.177,
      "end": 5.149,
