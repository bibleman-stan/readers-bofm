    },
    {
      "start": 49.008,
      "end": 52.491,
      "type": "line",
      "text": "and the counselor, and the cunning artificer,",
      "verse": "13:3",
      "lineIndex": 11
    },
    {
      "start": 52.671,
      "end": 54.575,
      "type": "line",
      "text": "and the eloquent orator.",
      "verse": "13:3",
      "lineIndex": 12
    },
    {
      "start": 54.755,
      "end": 63.997,
      "type": "line",
      "text": "The captain of fifty, and the honourable honorable man, and the counsellor, counselor, and the cunning artificer, and the eloquent orator.",
      "verse": "13:3",
      "lineIndex": 13
    },
    {
      "start": 64.677,
      "end": 68.578,
      "type": "line",
      "text": "And I will give children unto them to be their princes,",
      "verse": "13:4",
      "lineIndex": 14
    },
    {
      "start": 68.758,
      "end": 71.452,
