{
  "book": "2nephi",
  "bookName": "2 Nephi",
  "chapter": 28,
  "voice": {
    "provider": "elevenlabs",
    "voice_id": "ddDFRErfhdc2asyySOG5",
    "model_id": "eleven_multilingual_v2",
    "settings": {
      "stability": 0.5,
      "similarity_boost": 0.75,
      "style": 0.35,
      "use_speaker_boost": true
    },
    "name": "samuel"
  },
  "pauses": {
    "line_ms": 180,
    "verse_ms": 500
  },
  "duration": 467.346,
  "lines": [
    {
      "start": 0.0,
      "end": 3.251,
      "type": "line",
      "text": "And now, behold, my brethren, I have spoken unto you,",
      "verse": "28:1",
      "lineIndex": 1
    },
    {
      "start": 3.431,
      "end": 6.032,
      "type": "line",
      "text": "according as the Spirit hath constrained me;",
      "verse": "28:1",
      "lineIndex": 2
    },
    {
      "start": 6.212,
      "end": 9.741,
      "type": "line",
      "text": "wherefore, I know that they must surely come to pass.",
      "verse": "28:1",
      "lineIndex": 3
    },
    {
      "start": 10.421,
      "end": 13.997,
      "type": "line",
      "text": "And the things which shall be written out of the book",
      "verse": "28:2",
      "lineIndex": 4
    },
    {
      "start": 14.177,
      "end": 17.288,
      "type": "line",
      "text": "shall be of great worth unto the children of men,",
      "verse": "28:2",
      "lineIndex": 5
    },
    {
      "start": 17.468,
      "end": 19.651,
      "type": "line",
      "text": "and especially unto our seed,",
      "verse": "28:2",
      "lineIndex": 6
    },
    {
      "start": 19.831,
      "end": 22.571,
      "type": "line",
      "text": "which is a remnant of the house of Israel.",
      "verse": "28:2",
      "lineIndex": 7
    },
    {
      "start": 23.251,
      "end": 25.619,
      "type": "line",
      "text": "For it shall come to pass in that day",
      "verse": "28:3",
      "lineIndex": 9
    },
    {
      "start": 25.799,
      "end": 28.26,
      "type": "line",
      "text": "that the churches which are built up,",
      "verse": "28:3",
      "lineIndex": 10
    },
    {
      "start": 28.44,
      "end": 30.019,
      "type": "line",
      "text": "and not unto the Lord,",
      "verse": "28:3",
      "lineIndex": 11
    },
    {
      "start": 30.199,
      "end": 32.475,
      "type": "line",
      "text": "when the one shall say unto the other:",
      "verse": "28:3",
      "lineIndex": 12
    },
    {
      "start": 32.655,
      "end": 34.698,
      "type": "line",
      "text": "Behold, I, I am the Lord's;",
      "verse": "28:3",
      "lineIndex": 13
    },
    {
      "start": 34.878,
      "end": 36.596,
      "type": "line",
      "text": "and the others shall say:",
      "verse": "28:3",
      "lineIndex": 14
    },
    {
      "start": 36.776,
      "end": 38.309,
      "type": "line",
      "text": "I, I am the Lord's;",
      "verse": "28:3",
      "lineIndex": 15
    },
    {
      "start": 38.489,
      "end": 40.393,
      "type": "line",
      "text": "and thus shall every one say",
      "verse": "28:3",
      "lineIndex": 16
    },
    {
      "start": 40.573,
      "end": 42.57,
      "type": "line",
      "text": "that hath built up churches,",
      "verse": "28:3",
      "lineIndex": 17
    },
    {
      "start": 42.75,
      "end": 44.283,
      "type": "line",
      "text": "and not unto the Lord\u2014",
      "verse": "28:3",
      "lineIndex": 18
    },
    {
      "start": 44.963,
      "end": 47.378,
      "type": "line",
      "text": "And they shall contend one with another;",
      "verse": "28:4",
      "lineIndex": 19
    },
    {
      "start": 47.558,
      "end": 50.948,
      "type": "line",
      "text": "and their priests shall contend one with another,",
      "verse": "28:4",
      "lineIndex": 20
    },
    {
      "start": 51.128,
      "end": 53.729,
      "type": "line",
      "text": "and they shall teach with their learning,",
      "verse": "28:4",
      "lineIndex": 21
    },
    {
      "start": 53.909,
      "end": 56.788,
      "type": "line",
      "text": "and deny the Holy Ghost, which giveth utterance.",
      "verse": "28:4",
      "lineIndex": 22
    },
    {
      "start": 57.468,
      "end": 59.651,
      "type": "line",
      "text": "And they deny the power of God,",
      "verse": "28:5",
      "lineIndex": 23
    },
    {
      "start": 59.831,
      "end": 61.503,
      "type": "line",
      "text": "the Holy One of Israel;",
      "verse": "28:5",
      "lineIndex": 24
    },
    {
      "start": 61.683,
      "end": 63.494,
      "type": "line",
      "text": "and they say unto the people:",
      "verse": "28:5",
      "lineIndex": 25
    },
    {
      "start": 63.674,
      "end": 66.6,
      "type": "line",
      "text": "Hearken unto us, and hear ye our precept;",
      "verse": "28:5",
      "lineIndex": 26
    },
    {
      "start": 66.78,
      "end": 69.009,
      "type": "line",
      "text": "for behold there is no God today,",
      "verse": "28:5",
      "lineIndex": 27
    },
    {
      "start": 69.189,
      "end": 72.672,
      "type": "line",
      "text": "for the Lord and the Redeemer hath done his work,",
      "verse": "28:5",
      "lineIndex": 28
    },
    {
      "start": 72.852,
      "end": 75.499,
      "type": "line",
      "text": "and he hath given his power unto men;",
      "verse": "28:5",
      "lineIndex": 29
    },
    {
      "start": 76.179,
      "end": 78.64,
      "type": "line",
      "text": "Behold, hearken ye unto my precept;",
      "verse": "28:6",
      "lineIndex": 30
    },
    {
      "start": 78.82,
      "end": 83.185,
      "type": "line",
      "text": "if they shall say there is a miracle wrought by the hand of the Lord,",
      "verse": "28:6",
      "lineIndex": 31
    },
    {
      "start": 83.365,
      "end": 84.526,
      "type": "line",
      "text": "believe it not;",
      "verse": "28:6",
      "lineIndex": 32
    },
    {
      "start": 84.706,
      "end": 87.4,
      "type": "line",
      "text": "for this day he is not a God of miracles;",
      "verse": "28:6",
      "lineIndex": 33
    },
    {
      "start": 87.58,
      "end": 89.252,
      "type": "line",
      "text": "he hath done his work.",
      "verse": "28:6",
      "lineIndex": 34
    },
    {
      "start": 89.932,
      "end": 92.811,
      "type": "line",
      "text": "Yea, and there shall be many which shall say:",
      "verse": "28:7",
      "lineIndex": 35
    },
    {
      "start": 92.991,
      "end": 94.988,
      "type": "line",
      "text": "Eat, drink, and be merry,",
      "verse": "28:7",
      "lineIndex": 36
    },
    {
      "start": 95.168,
      "end": 96.747,
      "type": "line",
      "text": "for tomorrow we die;",
      "verse": "28:7",
      "lineIndex": 37
    },
    {
      "start": 96.927,
      "end": 98.877,
      "type": "line",
      "text": "and it shall be well with us.",
      "verse": "28:7",
      "lineIndex": 38
    },
    {
      "start": 99.557,
      "end": 102.343,
      "type": "line",
      "text": "And there shall also be many which shall say:",
      "verse": "28:8",
      "lineIndex": 39
    },
    {
      "start": 102.523,
      "end": 105.82,
      "type": "line",
      "text": "Eat, drink, and be merry; nevertheless, fear God\u2014",
      "verse": "28:8",
      "lineIndex": 40
    },
    {
      "start": 106.0,
      "end": 108.786,
      "type": "line",
      "text": "he will justify in committing a little sin;",
      "verse": "28:8",
      "lineIndex": 41
    },
    {
      "start": 108.966,
      "end": 110.499,
      "type": "line",
      "text": "yea, lie a little,",
      "verse": "28:8",
      "lineIndex": 42
    },
    {
      "start": 110.679,
      "end": 113.512,
      "type": "line",
      "text": "take the advantage of one because of his words,",
      "verse": "28:8",
      "lineIndex": 43
    },
    {
      "start": 113.692,
      "end": 115.364,
      "type": "line",
      "text": "dig a pit for thy neighbor;",
      "verse": "28:8",
      "lineIndex": 44
    },
    {
      "start": 115.544,
      "end": 117.216,
      "type": "line",
      "text": "there is no harm in this;",
      "verse": "28:8",
      "lineIndex": 45
    },
    {
      "start": 117.396,
      "end": 119.068,
      "type": "line",
      "text": "and do all these things,",
      "verse": "28:8",
      "lineIndex": 46
    },
    {
      "start": 119.248,
      "end": 120.827,
      "type": "line",
      "text": "for tomorrow we die;",
      "verse": "28:8",
      "lineIndex": 47
    },
    {
      "start": 121.007,
      "end": 123.515,
      "type": "line",
      "text": "and if it so be that we are guilty,",
      "verse": "28:8",
      "lineIndex": 48
    },
    {
      "start": 123.695,
      "end": 126.017,
      "type": "line",
      "text": "God will beat us with a few stripes,",
      "verse": "28:8",
      "lineIndex": 49
    },
    {
      "start": 126.197,
      "end": 129.169,
      "type": "line",
      "text": "and at last we shall be saved in the kingdom of God.",
      "verse": "28:8",
      "lineIndex": 50
    },
    {
      "start": 129.849,
      "end": 131.66,
      "type": "line",
      "text": "Yea, and there shall be many",
      "verse": "28:9",
      "lineIndex": 51
    },
    {
      "start": 131.84,
      "end": 134.301,
      "type": "line",
      "text": "which shall teach after this manner,",
      "verse": "28:9",
      "lineIndex": 52
    },
    {
      "start": 134.481,
      "end": 137.221,
      "type": "line",
      "text": "false and vain and foolish doctrines,",
      "verse": "28:9",
      "lineIndex": 53
    },
    {
      "start": 137.401,
      "end": 139.677,
      "type": "line",
      "text": "and shall be puffed up in their hearts,",
      "verse": "28:9",
      "lineIndex": 54
    },
    {
      "start": 139.857,
      "end": 143.247,
      "type": "line",
      "text": "and shall seek deep to hide their counsels from the Lord;",
      "verse": "28:9",
      "lineIndex": 55
    },
    {
      "start": 143.427,
      "end": 145.888,
      "type": "line",
      "text": "and their works shall be in the dark.",
      "verse": "28:9",
      "lineIndex": 56
    },
    {
      "start": 146.568,
      "end": 150.283,
      "type": "line",
      "text": "And the blood of the saints shall cry from the ground against them.",
      "verse": "28:10",
      "lineIndex": 57
    },
    {
      "start": 150.963,
      "end": 153.053,
      "type": "line",
      "text": "Yea, they have all gone out of the way;",
      "verse": "28:11",
      "lineIndex": 58
    },
    {
      "start": 153.233,
      "end": 154.951,
      "type": "line",
      "text": "they have become corrupted.",
      "verse": "28:11",
      "lineIndex": 59
    },
    {
      "start": 155.631,
      "end": 156.978,
      "type": "line",
      "text": "Because of pride,",
      "verse": "28:12",
      "lineIndex": 60
    },
    {
      "start": 157.158,
      "end": 160.595,
      "type": "line",
      "text": "and because of false teachers, and false doctrine,",
      "verse": "28:12",
      "lineIndex": 61
    },
    {
      "start": 160.775,
      "end": 163.097,
      "type": "line",
      "text": "their churches have become corrupted,",
      "verse": "28:12",
      "lineIndex": 62
    },
    {
      "start": 163.277,
      "end": 165.599,
      "type": "line",
      "text": "and their churches are lifted up;",
      "verse": "28:12",
      "lineIndex": 63
    },
    {
      "start": 165.779,
      "end": 168.287,
      "type": "line",
      "text": "because of pride they are puffed up.",
      "verse": "28:12",
      "lineIndex": 64
    },
    {
      "start": 168.967,
      "end": 171.846,
      "type": "line",
      "text": "They rob the poor because of their fine sanctuaries;",
      "verse": "28:13",
      "lineIndex": 65
    },
    {
      "start": 172.026,
      "end": 174.766,
      "type": "line",
      "text": "they rob the poor because of their fine clothing;",
      "verse": "28:13",
      "lineIndex": 66
    },
    {
      "start": 174.946,
      "end": 178.522,
      "type": "line",
      "text": "and they persecute the meek and the poor in heart,",
      "verse": "28:13",
      "lineIndex": 67
    },
    {
      "start": 178.702,
      "end": 181.117,
      "type": "line",
      "text": "because in their pride they are puffed up.",
      "verse": "28:13",
      "lineIndex": 68
    },
    {
      "start": 181.797,
      "end": 184.351,
      "type": "line",
      "text": "They wear stiff necks and high heads;",
      "verse": "28:14",
      "lineIndex": 69
    },
    {
      "start": 184.531,
      "end": 187.225,
      "type": "line",
      "text": "yea, and because of pride, and wickedness,",
      "verse": "28:14",
      "lineIndex": 70
    },
    {
      "start": 187.405,
      "end": 189.634,
      "type": "line",
      "text": "and abominations, and whoredoms,",
      "verse": "28:14",
      "lineIndex": 71
    },
    {
      "start": 189.814,
      "end": 191.439,
      "type": "line",
      "text": "they have all gone astray",
      "verse": "28:14",
      "lineIndex": 72
    },
    {
      "start": 191.619,
      "end": 192.966,
      "type": "line",
      "text": "save it be a few,",
      "verse": "28:14",
      "lineIndex": 73
    },
    {
      "start": 193.146,
      "end": 195.7,
      "type": "line",
      "text": "who are the humble followers of Christ;",
      "verse": "28:14",
      "lineIndex": 74
    },
    {
      "start": 195.88,
      "end": 197.83,
      "type": "line",
      "text": "nevertheless, they are led,",
      "verse": "28:14",
      "lineIndex": 75
    },
    {
      "start": 198.01,
      "end": 200.471,
      "type": "line",
      "text": "that in many instances they do err",
      "verse": "28:14",
      "lineIndex": 76
    },
    {
      "start": 200.651,
      "end": 203.205,
      "type": "line",
      "text": "because they are taught by the precepts of men.",
      "verse": "28:14",
      "lineIndex": 77
    },
    {
      "start": 203.885,
      "end": 206.532,
      "type": "line",
      "text": "O the wise, and the learned, and the rich,",
      "verse": "28:15",
      "lineIndex": 79
    },
    {
      "start": 206.712,
      "end": 209.591,
      "type": "line",
      "text": "that are puffed up in the pride of their hearts,",
      "verse": "28:15",
      "lineIndex": 80
    },
    {
      "start": 209.771,
      "end": 212.279,
      "type": "line",
      "text": "and all those who preach false doctrines,",
      "verse": "28:15",
      "lineIndex": 81
    },
    {
      "start": 212.459,
      "end": 214.688,
      "type": "line",
      "text": "and all those who commit whoredoms,",
      "verse": "28:15",
      "lineIndex": 82
    },
    {
      "start": 214.868,
      "end": 217.329,
      "type": "line",
      "text": "and pervert the right way of the Lord,",
      "verse": "28:15",
      "lineIndex": 83
    },
    {
      "start": 217.509,
      "end": 219.738,
      "type": "line",
      "text": "wo, wo, wo be unto them,",
      "verse": "28:15",
      "lineIndex": 84
    },
    {
      "start": 219.918,
      "end": 221.915,
      "type": "line",
      "text": "saith the Lord God Almighty,",
      "verse": "28:15",
      "lineIndex": 85
    },
    {
      "start": 222.095,
      "end": 224.603,
      "type": "line",
      "text": "for they shall be thrust down to hell!",
      "verse": "28:15",
      "lineIndex": 86
    },
    {
      "start": 225.283,
      "end": 228.859,
      "type": "line",
      "text": "Wo unto them that turn aside the just for a thing of naught",
      "verse": "28:16",
      "lineIndex": 87
    },
    {
      "start": 229.039,
      "end": 231.547,
      "type": "line",
      "text": "and revile against that which is good,",
      "verse": "28:16",
      "lineIndex": 88
    },
    {
      "start": 231.727,
      "end": 233.445,
      "type": "line",
      "text": "and say that it is of no worth!",
      "verse": "28:16",
      "lineIndex": 89
    },
    {
      "start": 233.625,
      "end": 235.111,
      "type": "line",
      "text": "For the day shall come",
      "verse": "28:16",
      "lineIndex": 90
    },
    {
      "start": 235.291,
      "end": 239.796,
      "type": "line",
      "text": "that the Lord God will speedily visit the inhabitants of the earth;",
      "verse": "28:16",
      "lineIndex": 91
    },
    {
      "start": 239.976,
      "end": 243.505,
      "type": "line",
      "text": "and in that day that they are fully ripe in iniquity",
      "verse": "28:16",
      "lineIndex": 92
    },
    {
      "start": 243.685,
      "end": 245.032,
      "type": "line",
      "text": "they shall perish.",
      "verse": "28:16",
      "lineIndex": 93
    },
    {
      "start": 245.712,
      "end": 252.167,
      "type": "line",
      "text": "But behold, if the inhabitants of the earth shall repent of their wickedness and abominations",
      "verse": "28:17",
      "lineIndex": 94
    },
    {
      "start": 252.347,
      "end": 254.065,
      "type": "line",
      "text": "they shall not be destroyed,",
      "verse": "28:17",
      "lineIndex": 95
    },
    {
      "start": 254.245,
      "end": 255.963,
      "type": "line",
      "text": "saith the Lord of Hosts.",
      "verse": "28:17",
      "lineIndex": 96
    },
    {
      "start": 256.643,
      "end": 259.754,
      "type": "line",
      "text": "But behold, that great and abominable church,",
      "verse": "28:18",
      "lineIndex": 97
    },
    {
      "start": 259.934,
      "end": 262.024,
      "type": "line",
      "text": "the whore of all the earth,",
      "verse": "28:18",
      "lineIndex": 98
    },
    {
      "start": 262.204,
      "end": 263.969,
      "type": "line",
      "text": "must tumble to the earth,",
      "verse": "28:18",
      "lineIndex": 99
    },
    {
      "start": 264.149,
      "end": 266.471,
      "type": "line",
      "text": "and great must be the fall thereof.",
      "verse": "28:18",
      "lineIndex": 100
    },
    {
      "start": 267.151,
      "end": 269.659,
      "type": "line",
      "text": "For the kingdom of the devil must shake,",
      "verse": "28:19",
      "lineIndex": 101
    },
    {
      "start": 269.839,
      "end": 274.111,
      "type": "line",
      "text": "and they which belong to it must needs be stirred up unto repentance,",
      "verse": "28:19",
      "lineIndex": 102
    },
    {
      "start": 274.291,
      "end": 277.82,
      "type": "line",
      "text": "or the devil will grasp them with his everlasting chains,",
      "verse": "28:19",
      "lineIndex": 103
    },
    {
      "start": 278.0,
      "end": 281.111,
      "type": "line",
      "text": "and they be stirred up to anger, and perish;",
      "verse": "28:19",
      "lineIndex": 104
    },
    {
      "start": 281.791,
      "end": 286.203,
      "type": "line",
      "text": "For behold, at that day shall he rage in the hearts of the children of men,",
      "verse": "28:20",
      "lineIndex": 105
    },
    {
      "start": 286.383,
      "end": 290.052,
      "type": "line",
      "text": "and stir them up to anger against that which is good.",
      "verse": "28:20",
      "lineIndex": 106
    },
    {
      "start": 290.732,
      "end": 292.59,
      "type": "line",
      "text": "And others will he pacify,",
      "verse": "28:21",
      "lineIndex": 107
    },
    {
      "start": 292.77,
      "end": 295.835,
      "type": "line",
      "text": "and lull them away into carnal security,",
      "verse": "28:21",
      "lineIndex": 108
    },
    {
      "start": 296.015,
      "end": 297.501,
      "type": "line",
      "text": "that they will say:",
      "verse": "28:21",
      "lineIndex": 109
    },
    {
      "start": 297.681,
      "end": 299.121,
      "type": "line",
      "text": "All is well in Zion;",
      "verse": "28:21",
      "lineIndex": 110
    },
    {
      "start": 299.301,
      "end": 301.066,
      "type": "line",
      "text": "yea, Zion prospereth,",
      "verse": "28:21",
      "lineIndex": 111
    },
    {
      "start": 301.246,
      "end": 302.546,
      "type": "line",
      "text": "all is well\u2014",
      "verse": "28:21",
      "lineIndex": 112
    },
    {
      "start": 302.726,
      "end": 305.141,
      "type": "line",
      "text": "and thus the devil cheateth their souls,",
      "verse": "28:21",
      "lineIndex": 113
    },
    {
      "start": 305.321,
      "end": 308.154,
      "type": "line",
      "text": "and leadeth them away carefully down to hell.",
      "verse": "28:21",
      "lineIndex": 114
    },
    {
      "start": 308.834,
      "end": 311.667,
      "type": "line",
      "text": "And behold, others he flattereth away,",
      "verse": "28:22",
      "lineIndex": 115
    },
    {
      "start": 311.847,
      "end": 314.076,
      "type": "line",
      "text": "and telleth them there is no hell;",
      "verse": "28:22",
      "lineIndex": 116
    },
    {
      "start": 314.256,
      "end": 316.067,
      "type": "line",
      "text": "and he saith unto them:",
      "verse": "28:22",
      "lineIndex": 117
    },
    {
      "start": 316.247,
      "end": 317.594,
      "type": "line",
      "text": "I am no devil,",
      "verse": "28:22",
      "lineIndex": 118
    },
    {
      "start": 317.774,
      "end": 319.307,
      "type": "line",
      "text": "for there is none\u2014",
      "verse": "28:22",
      "lineIndex": 119
    },
    {
      "start": 319.487,
      "end": 321.809,
      "type": "line",
      "text": "and thus he whispereth in their ears,",
      "verse": "28:22",
      "lineIndex": 120
    },
    {
      "start": 321.989,
      "end": 324.915,
      "type": "line",
      "text": "until he grasps them with his awful chains,",
      "verse": "28:22",
      "lineIndex": 121
    },
    {
      "start": 325.095,
      "end": 327.417,
      "type": "line",
      "text": "from whence there is no deliverance.",
      "verse": "28:22",
      "lineIndex": 122
    },
    {
      "start": 328.097,
      "end": 330.744,
      "type": "line",
      "text": "Yea, they are grasped with death, and hell;",
      "verse": "28:23",
      "lineIndex": 123
    },
    {
      "start": 330.924,
      "end": 335.104,
      "type": "line",
      "text": "and death, and hell, and the devil, and all that have been seized therewith",
      "verse": "28:23",
      "lineIndex": 124
    },
    {
      "start": 335.284,
      "end": 337.931,
      "type": "line",
      "text": "must stand before the throne of God,",
      "verse": "28:23",
      "lineIndex": 125
    },
    {
      "start": 338.111,
      "end": 340.479,
      "type": "line",
      "text": "and be judged according to their works,",
      "verse": "28:23",
      "lineIndex": 126
    },
    {
      "start": 340.659,
      "end": 344.096,
      "type": "line",
      "text": "from whence they must go into the place prepared for them,",
      "verse": "28:23",
      "lineIndex": 127
    },
    {
      "start": 344.276,
      "end": 346.691,
      "type": "line",
      "text": "even a lake of fire and brimstone,",
      "verse": "28:23",
      "lineIndex": 128
    },
    {
      "start": 346.871,
      "end": 348.729,
      "type": "line",
      "text": "which is endless torment.",
      "verse": "28:23",
      "lineIndex": 129
    },
    {
      "start": 349.409,
      "end": 352.474,
      "type": "line",
      "text": "Therefore, wo be unto him that is at ease in Zion!",
      "verse": "28:24",
      "lineIndex": 130
    },
    {
      "start": 353.154,
      "end": 355.012,
      "type": "line",
      "text": "Wo be unto him that crieth:",
      "verse": "28:25",
      "lineIndex": 131
    },
    {
      "start": 355.192,
      "end": 356.26,
      "type": "line",
      "text": "All is well!",
      "verse": "28:25",
      "lineIndex": 132
    },
    {
      "start": 356.94,
      "end": 360.934,
      "type": "line",
      "text": "Yea, wo be unto him that hearkeneth unto the precepts of men,",
      "verse": "28:26",
      "lineIndex": 134
    },
    {
      "start": 361.114,
      "end": 363.064,
      "type": "line",
      "text": "and denieth the power of God,",
      "verse": "28:26",
      "lineIndex": 135
    },
    {
      "start": 363.244,
      "end": 365.427,
      "type": "line",
      "text": "and the gift of the Holy Ghost!",
      "verse": "28:26",
      "lineIndex": 136
    },
    {
      "start": 366.107,
      "end": 368.197,
      "type": "line",
      "text": "Yea, wo be unto him that saith:",
      "verse": "28:27",
      "lineIndex": 137
    },
    {
      "start": 368.377,
      "end": 369.863,
      "type": "line",
      "text": "We have received,",
      "verse": "28:27",
      "lineIndex": 138
    },
    {
      "start": 370.043,
      "end": 371.39,
      "type": "line",
      "text": "and we need no more!",
      "verse": "28:27",
      "lineIndex": 139
    },
    {
      "start": 372.07,
      "end": 374.113,
      "type": "line",
      "text": "And in fine, wo unto all those",
      "verse": "28:28",
      "lineIndex": 140
    },
    {
      "start": 374.293,
      "end": 377.59,
      "type": "line",
      "text": "who tremble, and are angry because of the truth of God!",
      "verse": "28:28",
      "lineIndex": 141
    },
    {
      "start": 377.77,
      "end": 380.649,
      "type": "line",
      "text": "For behold, he that is built upon the rock",
      "verse": "28:28",
      "lineIndex": 142
    },
    {
      "start": 380.829,
      "end": 382.779,
      "type": "line",
      "text": "receiveth it with gladness;",
      "verse": "28:28",
      "lineIndex": 143
    },
    {
      "start": 382.959,
      "end": 385.885,
      "type": "line",
      "text": "and he that is built upon a sandy foundation",
      "verse": "28:28",
      "lineIndex": 144
    },
    {
      "start": 386.065,
      "end": 388.294,
      "type": "line",
      "text": "trembleth lest he shall fall.",
      "verse": "28:28",
      "lineIndex": 145
    },
    {
      "start": 388.974,
      "end": 390.785,
      "type": "line",
      "text": "Wo be unto him that shall say:",
      "verse": "28:29",
      "lineIndex": 146
    },
    {
      "start": 390.965,
      "end": 393.101,
      "type": "line",
      "text": "We have received the word of God,",
      "verse": "28:29",
      "lineIndex": 147
    },
    {
      "start": 393.281,
      "end": 395.464,
      "type": "line",
      "text": "and we need no more of the word of God,",
      "verse": "28:29",
      "lineIndex": 148
    },
    {
      "start": 395.644,
      "end": 397.177,
      "type": "line",
      "text": "for we have enough!",
      "verse": "28:29",
      "lineIndex": 149
    },
    {
      "start": 397.857,
      "end": 400.365,
      "type": "line",
      "text": "For behold, thus saith the Lord God:",
      "verse": "28:30",
      "lineIndex": 150
    },
    {
      "start": 400.545,
      "end": 402.867,
      "type": "line",
      "text": "I will give unto the children of men",
      "verse": "28:30",
      "lineIndex": 151
    },
    {
      "start": 403.047,
      "end": 404.487,
      "type": "line",
      "text": "line upon line,",
      "verse": "28:30",
      "lineIndex": 152
    },
    {
      "start": 404.667,
      "end": 406.2,
      "type": "line",
      "text": "precept upon precept,",
      "verse": "28:30",
      "lineIndex": 153
    },
    {
      "start": 406.38,
      "end": 407.773,
      "type": "line",
      "text": "here a little",
      "verse": "28:30",
      "lineIndex": 154
    },
    {
      "start": 407.953,
      "end": 409.439,
      "type": "line",
      "text": "and there a little;",
      "verse": "28:30",
      "lineIndex": 155
    },
    {
      "start": 409.619,
      "end": 412.963,
      "type": "line",
      "text": "and blessed are those who hearken unto my precepts,",
      "verse": "28:30",
      "lineIndex": 156
    },
    {
      "start": 413.143,
      "end": 415.697,
      "type": "line",
      "text": "and lend an ear unto my counsel,",
      "verse": "28:30",
      "lineIndex": 157
    },
    {
      "start": 415.877,
      "end": 417.92,
      "type": "line",
      "text": "for they shall learn wisdom;",
      "verse": "28:30",
      "lineIndex": 158
    },
    {
      "start": 418.1,
      "end": 420.19,
      "type": "line",
      "text": "for unto him that receiveth",
      "verse": "28:30",
      "lineIndex": 159
    },
    {
      "start": 420.37,
      "end": 421.81,
      "type": "line",
      "text": "I will give more;",
      "verse": "28:30",
      "lineIndex": 160
    },
    {
      "start": 421.99,
      "end": 423.894,
      "type": "line",
      "text": "and from them that shall say,",
      "verse": "28:30",
      "lineIndex": 161
    },
    {
      "start": 424.074,
      "end": 425.514,
      "type": "line",
      "text": "We have enough,",
      "verse": "28:30",
      "lineIndex": 162
    },
    {
      "start": 425.694,
      "end": 427.877,
      "type": "line",
      "text": "from them shall be taken away",
      "verse": "28:30",
      "lineIndex": 163
    },
    {
      "start": 428.057,
      "end": 429.729,
      "type": "line",
      "text": "even that which they have.",
      "verse": "28:30",
      "lineIndex": 164
    },
    {
      "start": 430.409,
      "end": 433.01,
      "type": "line",
      "text": "Cursed is he that putteth his trust in man,",
      "verse": "28:31",
      "lineIndex": 165
    },
    {
      "start": 433.19,
      "end": 434.955,
      "type": "line",
      "text": "or maketh flesh his arm,",
      "verse": "28:31",
      "lineIndex": 166
    },
    {
      "start": 435.135,
      "end": 437.968,
      "type": "line",
      "text": "or shall hearken unto the precepts of men,",
      "verse": "28:31",
      "lineIndex": 167
    },
    {
      "start": 438.148,
      "end": 442.328,
      "type": "line",
      "text": "save their precepts shall be given by the power of the Holy Ghost.",
      "verse": "28:31",
      "lineIndex": 168
    },
    {
      "start": 443.008,
      "end": 444.819,
      "type": "line",
      "text": "Wo be unto the Gentiles,",
      "verse": "28:32",
      "lineIndex": 169
    },
    {
      "start": 444.999,
      "end": 446.717,
      "type": "line",
      "text": "saith the Lord God of Hosts!",
      "verse": "28:32",
      "lineIndex": 170
    },
    {
      "start": 446.897,
      "end": 451.773,
      "type": "line",
      "text": "For notwithstanding I shall lengthen out mine arm unto them from day to day,",
      "verse": "28:32",
      "lineIndex": 171
    },
    {
      "start": 451.953,
      "end": 453.439,
      "type": "line",
      "text": "they will deny me;",
      "verse": "28:32",
      "lineIndex": 172
    },
    {
      "start": 453.619,
      "end": 456.591,
      "type": "line",
      "text": "nevertheless, I will be merciful unto them,",
      "verse": "28:32",
      "lineIndex": 173
    },
    {
      "start": 456.771,
      "end": 458.257,
      "type": "line",
      "text": "saith the Lord God,",
      "verse": "28:32",
      "lineIndex": 174
    },
    {
      "start": 458.437,
      "end": 460.805,
      "type": "line",
      "text": "if they will repent and come unto me;",
      "verse": "28:32",
      "lineIndex": 175
    },
    {
      "start": 460.985,
      "end": 464.282,
      "type": "line",
      "text": "for mine arm is lengthened out all the day long,",
      "verse": "28:32",
      "lineIndex": 176
    },
    {
      "start": 464.462,
      "end": 466.691,
      "type": "line",
      "text": "saith the Lord God of Hosts.",
      "verse": "28:32",
      "lineIndex": 177
    }
  ]
}