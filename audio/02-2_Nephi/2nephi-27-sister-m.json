{
  "book": "2nephi",
  "bookName": "2 Nephi",
  "chapter": 27,
  "voice": {
    "provider": "elevenlabs",
    "voice_id": "iJpuSZDxZSBJHFSeavba",
    "model_id": "eleven_multilingual_v2",
    "settings": {
      "stability": 0.5,
      "similarity_boost": 0.75,
      "style": 0.35,
      "use_speaker_boost": true
    },
    "name": "sister-m"
  },
  "pauses": {
    "line_ms": 180,
    "verse_ms": 500
  },
  "duration": 618.776,
  "lines": [
    {
      "start": 0.0,
      "end": 2.647,
      "type": "line",
      "text": "But, behold, in the last days,",
      "verse": "27:1",
      "lineIndex": 1
    },
    {
      "start": 2.827,
      "end": 5.335,
      "type": "line",
      "text": "or in the days of the Gentiles\u2014",
      "verse": "27:1",
      "lineIndex": 2
    },
    {
      "start": 5.515,
      "end": 10.902,
      "type": "line",
      "text": "yea, behold all the nations of the Gentiles and also the Jews,",
      "verse": "27:1",
      "lineIndex": 3
    },
    {
      "start": 11.082,
      "end": 13.822,
      "type": "line",
      "text": "both those who shall come upon this land",
      "verse": "27:1",
      "lineIndex": 4
    },
    {
      "start": 14.002,
      "end": 17.113,
      "type": "line",
      "text": "and those who shall be upon other lands,",
      "verse": "27:1",
      "lineIndex": 5
    },
    {
      "start": 17.293,
      "end": 21.008,
      "type": "line",
      "text": "yea, even upon all the lands of the earth,",
      "verse": "27:1",
      "lineIndex": 6
    },
    {
      "start": 21.188,
      "end": 24.578,
      "type": "line",
      "text": "behold, they will be drunken with iniquity",
      "verse": "27:1",
      "lineIndex": 7
    },
    {
      "start": 24.758,
      "end": 30.099,
      "type": "line",
      "text": "and all manner of abominations\u2014",
      "verse": "27:1",
      "lineIndex": 8
    },
    {
      "start": 30.779,
      "end": 33.101,
      "type": "line",
      "text": "And when that day shall come",
      "verse": "27:2",
      "lineIndex": 9
    },
    {
      "start": 33.281,
      "end": 36.3,
      "type": "line",
      "text": "they shall be visited of the Lord of Hosts,",
      "verse": "27:2",
      "lineIndex": 10
    },
    {
      "start": 36.48,
      "end": 42.935,
      "type": "line",
      "text": "with thunder and with earthquake,",
      "verse": "27:2",
      "lineIndex": 11
    },
    {
      "start": 43.115,
      "end": 47.852,
      "type": "line",
      "text": "and with a great noise,",
      "verse": "27:2",
      "lineIndex": 12
    },
    {
      "start": 48.032,
      "end": 51.283,
      "type": "line",
      "text": "and with storm, and with tempest,",
      "verse": "27:2",
      "lineIndex": 13
    },
    {
      "start": 51.463,
      "end": 53.971,
      "type": "line",
      "text": "and with the flame of devouring fire.",
      "verse": "27:2",
      "lineIndex": 14
    },
    {
      "start": 54.651,
      "end": 57.716,
      "type": "line",
      "text": "And all the nations that fight against Zion,",
      "verse": "27:3",
      "lineIndex": 15
    },
    {
      "start": 57.896,
      "end": 59.382,
      "type": "line",
      "text": "and that distress her,",
      "verse": "27:3",
      "lineIndex": 16
    },
    {
      "start": 59.562,
      "end": 62.163,
      "type": "line",
      "text": "shall be as a dream of a night vision;",
      "verse": "27:3",
      "lineIndex": 17
    },
    {
      "start": 62.343,
      "end": 65.083,
      "type": "line",
      "text": "yea, it shall be unto them,",
      "verse": "27:3",
      "lineIndex": 18
    },
    {
      "start": 65.263,
      "end": 68.235,
      "type": "line",
      "text": "even as unto a hungry man which dreameth,",
      "verse": "27:3",
      "lineIndex": 19
    },
    {
      "start": 68.415,
      "end": 70.412,
      "type": "line",
      "text": "and behold he eateth",
      "verse": "27:3",
      "lineIndex": 20
    },
    {
      "start": 70.592,
      "end": 73.564,
      "type": "line",
      "text": "but he awaketh and his soul is empty;",
      "verse": "27:3",
      "lineIndex": 21
    },
    {
      "start": 73.744,
      "end": 77.134,
      "type": "line",
      "text": "or like unto a thirsty man which dreameth,",
      "verse": "27:3",
      "lineIndex": 22
    },
    {
      "start": 77.314,
      "end": 79.125,
      "type": "line",
      "text": "and behold he drinketh",
      "verse": "27:3",
      "lineIndex": 23
    },
    {
      "start": 79.305,
      "end": 82.649,
      "type": "line",
      "text": "but he awaketh and behold he is faint,",
      "verse": "27:3",
      "lineIndex": 24
    },
    {
      "start": 82.829,
      "end": 85.012,
      "type": "line",
      "text": "and his soul hath appetite;",
      "verse": "27:3",
      "lineIndex": 25
    },
    {
      "start": 85.192,
      "end": 88.396,
      "type": "line",
      "text": "yea, even so shall the multitude",
      "verse": "27:3",
      "lineIndex": 26
    },
    {
      "start": 88.576,
      "end": 92.802,
      "type": "line",
      "text": "of all the nations be that fight against Mount Zion.",
      "verse": "27:3",
      "lineIndex": 27
    },
    {
      "start": 93.482,
      "end": 96.64,
      "type": "line",
      "text": "For behold, all ye that doeth iniquity,",
      "verse": "27:4",
      "lineIndex": 29
    },
    {
      "start": 96.82,
      "end": 99.096,
      "type": "line",
      "text": "stay yourselves and wonder,",
      "verse": "27:4",
      "lineIndex": 30
    },
    {
      "start": 99.276,
      "end": 100.809,
      "type": "line",
      "text": "for ye shall cry out,",
      "verse": "27:4",
      "lineIndex": 31
    },
    {
      "start": 100.989,
      "end": 102.057,
      "type": "line",
      "text": "and cry;",
      "verse": "27:4",
      "lineIndex": 32
    },
    {
      "start": 102.237,
      "end": 104.605,
      "type": "line",
      "text": "yea, ye shall be drunken",
      "verse": "27:4",
      "lineIndex": 33
    },
    {
      "start": 104.785,
      "end": 106.225,
      "type": "line",
      "text": "but not with wine,",
      "verse": "27:4",
      "lineIndex": 34
    },
    {
      "start": 106.405,
      "end": 107.798,
      "type": "line",
      "text": "ye shall stagger",
      "verse": "27:4",
      "lineIndex": 35
    },
    {
      "start": 107.978,
      "end": 109.836,
      "type": "line",
      "text": "but not with strong drink.",
      "verse": "27:4",
      "lineIndex": 36
    },
    {
      "start": 110.516,
      "end": 115.903,
      "type": "line",
      "text": "For behold, the Lord hath poured out upon you the spirit of deep sleep.",
      "verse": "27:5",
      "lineIndex": 37
    },
    {
      "start": 116.083,
      "end": 119.334,
      "type": "line",
      "text": "For behold, ye have closed your eyes,",
      "verse": "27:5",
      "lineIndex": 38
    },
    {
      "start": 119.514,
      "end": 123.926,
      "type": "line",
      "text": "and ye have rejected the prophets; and your rulers,",
      "verse": "27:5",
      "lineIndex": 39
    },
    {
      "start": 124.106,
      "end": 127.728,
      "type": "line",
      "text": "and the seers hath he covered because of your iniquity.",
      "verse": "27:5",
      "lineIndex": 40
    },
    {
      "start": 128.408,
      "end": 134.863,
      "type": "line",
      "text": "And it shall come to pass that the Lord God shall bring forth unto you the words of a book,",
      "verse": "27:6",
      "lineIndex": 41
    },
    {
      "start": 135.043,
      "end": 139.176,
      "type": "line",
      "text": "and they shall be the words of them which have slumbered.",
      "verse": "27:6",
      "lineIndex": 42
    },
    {
      "start": 139.856,
      "end": 142.41,
      "type": "line",
      "text": "And behold the book shall be sealed;",
      "verse": "27:7",
      "lineIndex": 43
    },
    {
      "start": 142.59,
      "end": 146.352,
      "type": "line",
      "text": "and in the book shall be a revelation from God,",
      "verse": "27:7",
      "lineIndex": 44
    },
    {
      "start": 146.532,
      "end": 150.015,
      "type": "line",
      "text": "from the beginning of the world to the ending thereof.",
      "verse": "27:7",
      "lineIndex": 45
    },
    {
      "start": 150.695,
      "end": 154.503,
      "type": "line",
      "text": "Wherefore, because of the things which are sealed up,",
      "verse": "27:8",
      "lineIndex": 46
    },
    {
      "start": 154.683,
      "end": 158.073,
      "type": "line",
      "text": "the things which are sealed shall not be delivered",
      "verse": "27:8",
      "lineIndex": 47
    },
    {
      "start": 158.253,
      "end": 162.479,
      "type": "line",
      "text": "in the day of the wickedness and abominations of the people.",
      "verse": "27:8",
      "lineIndex": 48
    },
    {
      "start": 162.659,
      "end": 165.167,
      "type": "line",
      "text": "Wherefore the book shall be kept from them.",
      "verse": "27:8",
      "lineIndex": 49
    },
    {
      "start": 165.847,
      "end": 168.633,
      "type": "line",
      "text": "But the book shall be delivered unto a man,",
      "verse": "27:9",
      "lineIndex": 51
    },
    {
      "start": 168.813,
      "end": 171.878,
      "type": "line",
      "text": "and he shall deliver the words of the book,",
      "verse": "27:9",
      "lineIndex": 52
    },
    {
      "start": 172.058,
      "end": 175.913,
      "type": "line",
      "text": "which are the words of those who have slumbered in the dust,",
      "verse": "27:9",
      "lineIndex": 53
    },
    {
      "start": 176.093,
      "end": 179.576,
      "type": "line",
      "text": "and he shall deliver these words unto another;",
      "verse": "27:9",
      "lineIndex": 54
    },
    {
      "start": 180.256,
      "end": 183.878,
      "type": "line",
      "text": "But the words which are sealed he shall not deliver,",
      "verse": "27:10",
      "lineIndex": 55
    },
    {
      "start": 184.058,
      "end": 186.38,
      "type": "line",
      "text": "neither shall he deliver the book.",
      "verse": "27:10",
      "lineIndex": 56
    },
    {
      "start": 186.56,
      "end": 189.997,
      "type": "line",
      "text": "For the book shall be sealed by the power of God,",
      "verse": "27:10",
      "lineIndex": 57
    },
    {
      "start": 190.177,
      "end": 194.496,
      "type": "line",
      "text": "and the revelation which was sealed shall be kept in the book",
      "verse": "27:10",
      "lineIndex": 58
    },
    {
      "start": 194.676,
      "end": 197.23,
      "type": "line",
      "text": "until the own due time of the Lord,",
      "verse": "27:10",
      "lineIndex": 59
    },
    {
      "start": 197.41,
      "end": 199.175,
      "type": "line",
      "text": "that they may come forth;",
      "verse": "27:10",
      "lineIndex": 60
    },
    {
      "start": 199.355,
      "end": 202.606,
      "type": "line",
      "text": "for behold, they reveal all things",
      "verse": "27:10",
      "lineIndex": 61
    },
    {
      "start": 202.786,
      "end": 206.687,
      "type": "line",
      "text": "from the foundation of the world unto the end thereof.",
      "verse": "27:10",
      "lineIndex": 62
    },
    {
      "start": 207.367,
      "end": 211.686,
      "type": "line",
      "text": "And the day cometh that the words of the book which were sealed",
      "verse": "27:11",
      "lineIndex": 63
    },
    {
      "start": 211.866,
      "end": 214.234,
      "type": "line",
      "text": "shall be read upon the house tops;",
      "verse": "27:11",
      "lineIndex": 64
    },
    {
      "start": 214.414,
      "end": 217.897,
      "type": "line",
      "text": "and they shall be read by the power of Christ;",
      "verse": "27:11",
      "lineIndex": 65
    },
    {
      "start": 218.077,
      "end": 222.675,
      "type": "line",
      "text": "and all things shall be revealed unto the children of men",
      "verse": "27:11",
      "lineIndex": 66
    },
    {
      "start": 222.855,
      "end": 225.874,
      "type": "line",
      "text": "which ever have been among the children of men,",
      "verse": "27:11",
      "lineIndex": 67
    },
    {
      "start": 226.054,
      "end": 230.141,
      "type": "line",
      "text": "and which ever will be even unto the end of the earth.",
      "verse": "27:11",
      "lineIndex": 68
    },
    {
      "start": 230.821,
      "end": 234.583,
      "type": "line",
      "text": "Wherefore, at that day when the book shall be delivered",
      "verse": "27:12",
      "lineIndex": 69
    },
    {
      "start": 234.763,
      "end": 237.178,
      "type": "line",
      "text": "unto the man of whom I have spoken,",
      "verse": "27:12",
      "lineIndex": 70
    },
    {
      "start": 237.358,
      "end": 240.98,
      "type": "line",
      "text": "the book shall be hid from the eyes of the world,",
      "verse": "27:12",
      "lineIndex": 71
    },
    {
      "start": 241.16,
      "end": 243.761,
      "type": "line",
      "text": "that the eyes of none shall behold it",
      "verse": "27:12",
      "lineIndex": 72
    },
    {
      "start": 243.941,
      "end": 247.796,
      "type": "line",
      "text": "save it be that three witnesses shall behold it,",
      "verse": "27:12",
      "lineIndex": 73
    },
    {
      "start": 247.976,
      "end": 249.741,
      "type": "line",
      "text": "by the power of God,",
      "verse": "27:12",
      "lineIndex": 74
    },
    {
      "start": 249.921,
      "end": 253.218,
      "type": "line",
      "text": "besides him to whom the book shall be delivered;",
      "verse": "27:12",
      "lineIndex": 75
    },
    {
      "start": 253.398,
      "end": 258.042,
      "type": "line",
      "text": "and they shall testify to the truth of the book and the things therein.",
      "verse": "27:12",
      "lineIndex": 76
    },
    {
      "start": 258.722,
      "end": 261.508,
      "type": "line",
      "text": "And there is none other which shall view it,",
      "verse": "27:13",
      "lineIndex": 77
    },
    {
      "start": 261.688,
      "end": 267.539,
      "type": "line",
      "text": "save it be a few according to the will of God,",
      "verse": "27:13",
      "lineIndex": 78
    },
    {
      "start": 267.719,
      "end": 271.806,
      "type": "line",
      "text": "to bear testimony of his word unto the children of men;",
      "verse": "27:13",
      "lineIndex": 79
    },
    {
      "start": 271.986,
      "end": 274.029,
      "type": "line",
      "text": "for the Lord God hath said",
      "verse": "27:13",
      "lineIndex": 80
    },
    {
      "start": 274.209,
      "end": 277.274,
      "type": "line",
      "text": "that the words of the faithful should speak",
      "verse": "27:13",
      "lineIndex": 81
    },
    {
      "start": 277.454,
      "end": 279.312,
      "type": "line",
      "text": "as if it were from the dead.",
      "verse": "27:13",
      "lineIndex": 82
    },
    {
      "start": 279.992,
      "end": 284.915,
      "type": "line",
      "text": "Wherefore, the Lord God will proceed to bring forth the words of the book;",
      "verse": "27:14",
      "lineIndex": 83
    },
    {
      "start": 285.095,
      "end": 289.367,
      "type": "line",
      "text": "and in the mouth of as many witnesses as seemeth him good",
      "verse": "27:14",
      "lineIndex": 84
    },
    {
      "start": 289.547,
      "end": 291.497,
      "type": "line",
      "text": "will he establish his word;",
      "verse": "27:14",
      "lineIndex": 85
    },
    {
      "start": 291.677,
      "end": 295.532,
      "type": "line",
      "text": "and wo be unto him that rejecteth the word of God!",
      "verse": "27:14",
      "lineIndex": 86
    },
    {
      "start": 296.212,
      "end": 300.206,
      "type": "line",
      "text": "But behold, it shall come to pass that the Lord God",
      "verse": "27:15",
      "lineIndex": 88
    },
    {
      "start": 300.386,
      "end": 304.008,
      "type": "line",
      "text": "shall say unto him to whom he shall deliver the book:",
      "verse": "27:15",
      "lineIndex": 89
    },
    {
      "start": 304.188,
      "end": 307.16,
      "type": "line",
      "text": "Take these words which are not sealed",
      "verse": "27:15",
      "lineIndex": 90
    },
    {
      "start": 307.34,
      "end": 309.337,
      "type": "line",
      "text": "and deliver them to another,",
      "verse": "27:15",
      "lineIndex": 91
    },
    {
      "start": 309.517,
      "end": 312.814,
      "type": "line",
      "text": "that he may show them unto the learned, saying:",
      "verse": "27:15",
      "lineIndex": 92
    },
    {
      "start": 312.994,
      "end": 314.666,
      "type": "line",
      "text": "Read this, I pray thee.",
      "verse": "27:15",
      "lineIndex": 93
    },
    {
      "start": 314.846,
      "end": 316.379,
      "type": "line",
      "text": "And the learned shall say:",
      "verse": "27:15",
      "lineIndex": 94
    },
    {
      "start": 316.559,
      "end": 319.438,
      "type": "line",
      "text": "Bring hither the book, and I will read them.",
      "verse": "27:15",
      "lineIndex": 95
    },
    {
      "start": 320.118,
      "end": 323.787,
      "type": "line",
      "text": "And now, because of the glory of the world and",
      "verse": "27:16",
      "lineIndex": 96
    },
    {
      "start": 323.967,
      "end": 326.382,
      "type": "line",
      "text": "to get gain will they say this,",
      "verse": "27:16",
      "lineIndex": 97
    },
    {
      "start": 326.562,
      "end": 328.791,
      "type": "line",
      "text": "and not for the glory of God.",
      "verse": "27:16",
      "lineIndex": 98
    },
    {
      "start": 329.471,
      "end": 331.096,
      "type": "line",
      "text": "And the man shall say:",
      "verse": "27:17",
      "lineIndex": 99
    },
    {
      "start": 331.276,
      "end": 334.016,
      "type": "line",
      "text": "I cannot bring the book, for it is sealed.",
      "verse": "27:17",
      "lineIndex": 100
    },
    {
      "start": 334.696,
      "end": 336.368,
      "type": "line",
      "text": "Then shall the learned say:",
      "verse": "27:18",
      "lineIndex": 101
    },
    {
      "start": 336.548,
      "end": 337.988,
      "type": "line",
      "text": "I cannot read it.",
      "verse": "27:18",
      "lineIndex": 102
    },
    {
      "start": 338.668,
      "end": 345.123,
      "type": "line",
      "text": "Wherefore it shall come to pass that the Lord God will deliver again the book and the words thereof",
      "verse": "27:19",
      "lineIndex": 104
    },
    {
      "start": 345.303,
      "end": 347.3,
      "type": "line",
      "text": "to him that is not learned;",
      "verse": "27:19",
      "lineIndex": 105
    },
    {
      "start": 347.48,
      "end": 350.406,
      "type": "line",
      "text": "and the man that is not learned shall say:",
      "verse": "27:19",
      "lineIndex": 106
    },
    {
      "start": 350.586,
      "end": 352.211,
      "type": "line",
      "text": "I am not learned.",
      "verse": "27:19",
      "lineIndex": 107
    },
    {
      "start": 352.891,
      "end": 355.445,
      "type": "line",
      "text": "Then shall the Lord God say unto him:",
      "verse": "27:20",
      "lineIndex": 108
    },
    {
      "start": 355.625,
      "end": 357.901,
      "type": "line",
      "text": "The learned shall not read them,",
      "verse": "27:20",
      "lineIndex": 109
    },
    {
      "start": 358.081,
      "end": 360.357,
      "type": "line",
      "text": "for they have rejected them,",
      "verse": "27:20",
      "lineIndex": 110
    },
    {
      "start": 360.537,
      "end": 363.556,
      "type": "line",
      "text": "and I am able to do mine own work;",
      "verse": "27:20",
      "lineIndex": 111
    },
    {
      "start": 363.736,
      "end": 368.101,
      "type": "line",
      "text": "wherefore thou shalt read the words which I shall give unto thee.",
      "verse": "27:20",
      "lineIndex": 112
    },
    {
      "start": 368.781,
      "end": 371.428,
      "type": "line",
      "text": "Touch not the things which are sealed,",
      "verse": "27:21",
      "lineIndex": 113
    },
    {
      "start": 371.608,
      "end": 375.323,
      "type": "line",
      "text": "for I will bring them forth in mine own due time;",
      "verse": "27:21",
      "lineIndex": 114
    },
    {
      "start": 375.503,
      "end": 378.382,
      "type": "line",
      "text": "for I will show unto the children of men",
      "verse": "27:21",
      "lineIndex": 115
    },
    {
      "start": 378.562,
      "end": 381.581,
      "type": "line",
      "text": "that I am able to do mine own work.",
      "verse": "27:21",
      "lineIndex": 116
    },
    {
      "start": 382.261,
      "end": 386.719,
      "type": "line",
      "text": "Wherefore, when thou hast read the words which I have commanded thee,",
      "verse": "27:22",
      "lineIndex": 117
    },
    {
      "start": 386.899,
      "end": 394.887,
      "type": "line",
      "text": "and obtained the witnesses which I have promised unto thee,",
      "verse": "27:22",
      "lineIndex": 118
    },
    {
      "start": 395.067,
      "end": 397.668,
      "type": "line",
      "text": "then shalt thou seal up the book again,",
      "verse": "27:22",
      "lineIndex": 119
    },
    {
      "start": 397.848,
      "end": 399.798,
      "type": "line",
      "text": "and hide it up unto me,",
      "verse": "27:22",
      "lineIndex": 120
    },
    {
      "start": 399.978,
      "end": 404.065,
      "type": "line",
      "text": "that I may preserve the words which thou hast not read,",
      "verse": "27:22",
      "lineIndex": 121
    },
    {
      "start": 404.245,
      "end": 407.356,
      "type": "line",
      "text": "until I shall see fit in mine own wisdom",
      "verse": "27:22",
      "lineIndex": 122
    },
    {
      "start": 407.536,
      "end": 411.112,
      "type": "line",
      "text": "to reveal all things unto the children of men.",
      "verse": "27:22",
      "lineIndex": 123
    },
    {
      "start": 411.792,
      "end": 413.928,
      "type": "line",
      "text": "For behold, I am God;",
      "verse": "27:23",
      "lineIndex": 125
    },
    {
      "start": 414.108,
      "end": 416.894,
      "type": "line",
      "text": "and I am a God of miracles;",
      "verse": "27:23",
      "lineIndex": 126
    },
    {
      "start": 417.074,
      "end": 419.814,
      "type": "line",
      "text": "and I will show unto the world",
      "verse": "27:23",
      "lineIndex": 127
    },
    {
      "start": 419.994,
      "end": 424.127,
      "type": "line",
      "text": "that I am the same yesterday, today, and forever;",
      "verse": "27:23",
      "lineIndex": 128
    },
    {
      "start": 424.307,
      "end": 427.326,
      "type": "line",
      "text": "and I work not among the children of men",
      "verse": "27:23",
      "lineIndex": 129
    },
    {
      "start": 427.506,
      "end": 429.967,
      "type": "line",
      "text": "save it be according to their faith.",
      "verse": "27:23",
      "lineIndex": 130
    },
    {
      "start": 430.647,
      "end": 434.734,
      "type": "line",
      "text": "And again it shall come to pass that the Lord shall say",
      "verse": "27:24",
      "lineIndex": 131
    },
    {
      "start": 434.914,
      "end": 439.604,
      "type": "line",
      "text": "unto him that shall read the words that shall be delivered him:",
      "verse": "27:24",
      "lineIndex": 132
    },
    {
      "start": 440.284,
      "end": 445.021,
      "type": "line",
      "text": "Forasmuch as this people draw near unto me with their mouth,",
      "verse": "27:25",
      "lineIndex": 134
    },
    {
      "start": 445.201,
      "end": 447.755,
      "type": "line",
      "text": "and with their lips do honor me,",
      "verse": "27:25",
      "lineIndex": 135
    },
    {
      "start": 447.935,
      "end": 450.675,
      "type": "line",
      "text": "but have removed their hearts far from me,",
      "verse": "27:25",
      "lineIndex": 136
    },
    {
      "start": 450.855,
      "end": 457.867,
      "type": "line",
      "text": "and their fear towards me is taught by the precepts of men\u2014",
      "verse": "27:25",
      "lineIndex": 137
    },
    {
      "start": 458.547,
      "end": 463.191,
      "type": "line",
      "text": "Therefore, I will proceed to do a marvelous work among this people,",
      "verse": "27:26",
      "lineIndex": 138
    },
    {
      "start": 463.371,
      "end": 466.668,
      "type": "line",
      "text": "yea, a marvelous work and a wonder,",
      "verse": "27:26",
      "lineIndex": 139
    },
    {
      "start": 466.848,
      "end": 470.842,
      "type": "line",
      "text": "for the wisdom of their wise and learned shall perish,",
      "verse": "27:26",
      "lineIndex": 140
    },
    {
      "start": 471.022,
      "end": 474.737,
      "type": "line",
      "text": "and the understanding of their prudent shall be hid.",
      "verse": "27:26",
      "lineIndex": 141
    },
    {
      "start": 475.417,
      "end": 480.665,
      "type": "line",
      "text": "And wo unto them that seek deep to hide their counsel from the Lord!",
      "verse": "27:27",
      "lineIndex": 142
    },
    {
      "start": 480.845,
      "end": 483.213,
      "type": "line",
      "text": "And their works are in the dark;",
      "verse": "27:27",
      "lineIndex": 143
    },
    {
      "start": 483.393,
      "end": 484.879,
      "type": "line",
      "text": "and they say:",
      "verse": "27:27",
      "lineIndex": 144
    },
    {
      "start": 485.059,
      "end": 486.359,
      "type": "line",
      "text": "Who seeth us,",
      "verse": "27:27",
      "lineIndex": 145
    },
    {
      "start": 486.539,
      "end": 488.397,
      "type": "line",
      "text": "and who knoweth us?",
      "verse": "27:27",
      "lineIndex": 146
    },
    {
      "start": 488.577,
      "end": 490.388,
      "type": "line",
      "text": "And they also say:",
      "verse": "27:27",
      "lineIndex": 147
    },
    {
      "start": 490.568,
      "end": 495.955,
      "type": "line",
      "text": "Surely, your turning of things upside down shall be esteemed as the potter's clay.",
      "verse": "27:27",
      "lineIndex": 148
    },
    {
      "start": 496.135,
      "end": 498.875,
      "type": "line",
      "text": "But behold, I will show unto them,",
      "verse": "27:27",
      "lineIndex": 149
    },
    {
      "start": 499.055,
      "end": 500.866,
      "type": "line",
      "text": "saith the Lord of Hosts,",
      "verse": "27:27",
      "lineIndex": 150
    },
    {
      "start": 501.046,
      "end": 503.043,
      "type": "line",
      "text": "that I know all their works.",
      "verse": "27:27",
      "lineIndex": 151
    },
    {
      "start": 503.223,
      "end": 506.056,
      "type": "line",
      "text": "For shall the work say of him that made it,",
      "verse": "27:27",
      "lineIndex": 152
    },
    {
      "start": 506.236,
      "end": 507.676,
      "type": "line",
      "text": "he made me not?",
      "verse": "27:27",
      "lineIndex": 153
    },
    {
      "start": 507.856,
      "end": 511.014,
      "type": "line",
      "text": "Or shall the thing framed say of him that framed it,",
      "verse": "27:27",
      "lineIndex": 154
    },
    {
      "start": 511.194,
      "end": 512.866,
      "type": "line",
      "text": "he had no understanding?",
      "verse": "27:27",
      "lineIndex": 155
    },
    {
      "start": 513.546,
      "end": 516.1,
      "type": "line",
      "text": "But behold, saith the Lord of Hosts:",
      "verse": "27:28",
      "lineIndex": 156
    },
    {
      "start": 516.28,
      "end": 518.927,
      "type": "line",
      "text": "I will show unto the children of men",
      "verse": "27:28",
      "lineIndex": 157
    },
    {
      "start": 519.107,
      "end": 521.661,
      "type": "line",
      "text": "that it is yet a very little while",
      "verse": "27:28",
      "lineIndex": 158
    },
    {
      "start": 521.841,
      "end": 525.417,
      "type": "line",
      "text": "and Lebanon shall be turned into a fruitful field;",
      "verse": "27:28",
      "lineIndex": 159
    },
    {
      "start": 525.597,
      "end": 529.684,
      "type": "line",
      "text": "and the fruitful field shall be esteemed as a forest.",
      "verse": "27:28",
      "lineIndex": 160
    },
    {
      "start": 530.364,
      "end": 534.311,
      "type": "line",
      "text": "And in that day shall the deaf hear the words of the book,",
      "verse": "27:29",
      "lineIndex": 162
    },
    {
      "start": 534.491,
      "end": 538.346,
      "type": "line",
      "text": "and the eyes of the blind shall see out of obscurity",
      "verse": "27:29",
      "lineIndex": 163
    },
    {
      "start": 538.526,
      "end": 540.059,
      "type": "line",
      "text": "and out of darkness.",
      "verse": "27:29",
      "lineIndex": 164
    },
    {
      "start": 540.739,
      "end": 545.801,
      "type": "line",
      "text": "And the meek also shall increase,",
      "verse": "27:30",
      "lineIndex": 165
    },
    {
      "start": 545.981,
      "end": 548.628,
      "type": "line",
      "text": "and their joy shall be in the Lord,",
      "verse": "27:30",
      "lineIndex": 166
    },
    {
      "start": 548.808,
      "end": 554.149,
      "type": "line",
      "text": "and the poor among men shall rejoice in the Holy One of Israel.",
      "verse": "27:30",
      "lineIndex": 167
    },
    {
      "start": 554.829,
      "end": 557.476,
      "type": "line",
      "text": "For assuredly as the Lord liveth",
      "verse": "27:31",
      "lineIndex": 168
    },
    {
      "start": 557.656,
      "end": 561.418,
      "type": "line",
      "text": "they shall see that the terrible one is brought to naught,",
      "verse": "27:31",
      "lineIndex": 169
    },
    {
      "start": 561.598,
      "end": 563.827,
      "type": "line",
      "text": "and the scorner is consumed,",
      "verse": "27:31",
      "lineIndex": 170
    },
    {
      "start": 564.007,
      "end": 567.397,
      "type": "line",
      "text": "and all that watch for iniquity are cut off;",
      "verse": "27:31",
      "lineIndex": 171
    },
    {
      "start": 568.077,
      "end": 571.699,
      "type": "line",
      "text": "And they that make a man an offender for a word,",
      "verse": "27:32",
      "lineIndex": 172
    },
    {
      "start": 571.879,
      "end": 579.727,
      "type": "line",
      "text": "and lay a snare for him that reproveth in the gate,",
      "verse": "27:32",
      "lineIndex": 173
    },
    {
      "start": 579.907,
      "end": 583.436,
      "type": "line",
      "text": "and turn aside the just for a thing of naught.",
      "verse": "27:32",
      "lineIndex": 174
    },
    {
      "start": 584.116,
      "end": 587.924,
      "type": "line",
      "text": "Therefore, thus saith the Lord, who redeemed Abraham,",
      "verse": "27:33",
      "lineIndex": 176
    },
    {
      "start": 588.104,
      "end": 590.24,
      "type": "line",
      "text": "concerning the house of Jacob:",
      "verse": "27:33",
      "lineIndex": 177
    },
    {
      "start": 590.42,
      "end": 592.742,
      "type": "line",
      "text": "Jacob shall not now be ashamed,",
      "verse": "27:33",
      "lineIndex": 178
    },
    {
      "start": 592.922,
      "end": 595.569,
      "type": "line",
      "text": "neither shall his face now wax pale.",
      "verse": "27:33",
      "lineIndex": 179
    },
    {
      "start": 596.249,
      "end": 598.478,
      "type": "line",
      "text": "But when he seeth his children,",
      "verse": "27:34",
      "lineIndex": 180
    },
    {
      "start": 598.658,
      "end": 601.816,
      "type": "line",
      "text": "the work of my hands, in the midst of him,",
      "verse": "27:34",
      "lineIndex": 181
    },
    {
      "start": 601.996,
      "end": 604.132,
      "type": "line",
      "text": "they shall sanctify my name,",
      "verse": "27:34",
      "lineIndex": 182
    },
    {
      "start": 604.312,
      "end": 606.82,
      "type": "line",
      "text": "and sanctify the Holy One of Jacob,",
      "verse": "27:34",
      "lineIndex": 183
    },
    {
      "start": 607.0,
      "end": 609.926,
      "type": "line",
      "text": "and shall fear the God of Israel.",
      "verse": "27:34",
      "lineIndex": 184
    },
    {
      "start": 610.606,
      "end": 614.832,
      "type": "line",
      "text": "They also that erred in spirit shall come to understanding,",
      "verse": "27:35",
      "lineIndex": 185
    },
    {
      "start": 615.012,
      "end": 618.123,
      "type": "line",
      "text": "and they that murmured shall learn doctrine.",
      "verse": "27:35",
      "lineIndex": 186
    }
  ]
}