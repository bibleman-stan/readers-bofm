{
  "book": "1nephi",
  "bookName": "1 Nephi",
  "chapter": 11,
  "voice": {
    "provider": "elevenlabs",
    "voice_id": "ddDFRErfhdc2asyySOG5",
    "model_id": "eleven_multilingual_v2",
    "settings": {
      "stability": 0.5,
      "similarity_boost": 0.75,
      "style": 0.35,
      "use_speaker_boost": true
    },
    "name": "Samuel"
  },
  "pauses": {
    "line_ms": 180,
    "verse_ms": 500
  },
  "duration": 471.894,
  "lines": [
    {
      "start": 0.0,
      "end": 3.39,
      "type": "line",
      "text": "For it came to pass after I had desired to know",
      "verse": "11:1",
      "lineIndex": 1
    },
    {
      "start": 3.57,
      "end": 5.753,
      "type": "line",
      "text": "the things that my father had seen,",
      "verse": "11:1",
      "lineIndex": 2
    },
    {
      "start": 5.933,
      "end": 9.323,
      "type": "line",
      "text": "and believing that the Lord was able to make them known unto me,",
      "verse": "11:1",
      "lineIndex": 3
    },
    {
      "start": 9.503,
      "end": 11.964,
      "type": "line",
      "text": "as I sat pondering in mine heart",
      "verse": "11:1",
      "lineIndex": 4
    },
    {
      "start": 12.144,
      "end": 14.791,
      "type": "line",
      "text": "I was caught away in the Spirit of the Lord,",
      "verse": "11:1",
      "lineIndex": 5
    },
    {
      "start": 14.971,
      "end": 17.339,
      "type": "line",
      "text": "yea, into a exceedingly high mountain,",
      "verse": "11:1",
      "lineIndex": 6
    },
    {
      "start": 17.519,
      "end": 19.469,
      "type": "line",
      "text": "which I never had before seen,",
      "verse": "11:1",
      "lineIndex": 7
    },
    {
      "start": 19.649,
      "end": 22.343,
      "type": "line",
      "text": "and upon which I never had before set my foot.",
      "verse": "11:1",
      "lineIndex": 8
    },
    {
      "start": 23.023,
      "end": 24.788,
      "type": "line",
      "text": "And the Spirit said unto me:",
      "verse": "11:2",
      "lineIndex": 9
    },
    {
      "start": 24.968,
      "end": 26.686,
      "type": "line",
      "text": "Behold, what desirest thou?",
      "verse": "11:2",
      "lineIndex": 10
    },
    {
      "start": 27.366,
      "end": 28.573,
      "type": "line",
      "text": "And I said:",
      "verse": "11:3",
      "lineIndex": 11
    },
    {
      "start": 28.753,
      "end": 31.818,
      "type": "line",
      "text": "I desire to behold the things which my father saw.",
      "verse": "11:3",
      "lineIndex": 12
    },
    {
      "start": 32.498,
      "end": 34.263,
      "type": "line",
      "text": "And the Spirit said unto me:",
      "verse": "11:4",
      "lineIndex": 13
    },
    {
      "start": 34.443,
      "end": 38.483,
      "type": "line",
      "text": "Believest thou that thy father saw the tree of which he hath spoken?",
      "verse": "11:4",
      "lineIndex": 14
    },
    {
      "start": 39.163,
      "end": 40.37,
      "type": "line",
      "text": "And I said:",
      "verse": "11:5",
      "lineIndex": 15
    },
    {
      "start": 40.55,
      "end": 43.987,
      "type": "line",
      "text": "Yea, thou knowest that I believe all the words of my father.",
      "verse": "11:5",
      "lineIndex": 16
    },
    {
      "start": 44.667,
      "end": 47.175,
      "type": "line",
      "text": "And when I had spoken these words,",
      "verse": "11:6",
      "lineIndex": 18
    },
    {
      "start": 47.355,
      "end": 49.723,
      "type": "line",
      "text": "the Spirit cried with a loud voice, saying:",
      "verse": "11:6",
      "lineIndex": 19
    },
    {
      "start": 49.903,
      "end": 52.364,
      "type": "line",
      "text": "Hosanna to the Lord, the most high God;",
      "verse": "11:6",
      "lineIndex": 20
    },
    {
      "start": 52.544,
      "end": 54.912,
      "type": "line",
      "text": "for he is God over all the earth,",
      "verse": "11:6",
      "lineIndex": 21
    },
    {
      "start": 55.092,
      "end": 56.764,
      "type": "line",
      "text": "yea, even above all.",
      "verse": "11:6",
      "lineIndex": 22
    },
    {
      "start": 56.944,
      "end": 58.894,
      "type": "line",
      "text": "And blessed art thou, Nephi,",
      "verse": "11:6",
      "lineIndex": 23
    },
    {
      "start": 59.074,
      "end": 62.743,
      "type": "line",
      "text": "because thou believest in the Son of the most high God;",
      "verse": "11:6",
      "lineIndex": 24
    },
    {
      "start": 62.923,
      "end": 67.103,
      "type": "line",
      "text": "wherefore, thou shalt behold the things which thou hast desired.",
      "verse": "11:6",
      "lineIndex": 25
    },
    {
      "start": 67.783,
      "end": 71.452,
      "type": "line",
      "text": "And behold this thing shall be given unto thee for a sign,",
      "verse": "11:7",
      "lineIndex": 26
    },
    {
      "start": 71.632,
      "end": 73.768,
      "type": "line",
      "text": "that after thou hast beheld the tree",
      "verse": "11:7",
      "lineIndex": 27
    },
    {
      "start": 73.948,
      "end": 77.013,
      "type": "line",
      "text": "which bore the fruit which thy father tasted,",
      "verse": "11:7",
      "lineIndex": 28
    },
    {
      "start": 77.193,
      "end": 80.351,
      "type": "line",
      "text": "thou shalt also behold a man descending out of heaven",
      "verse": "11:7",
      "lineIndex": 29
    },
    {
      "start": 80.531,
      "end": 82.156,
      "type": "line",
      "text": "and him shall ye witness;",
      "verse": "11:7",
      "lineIndex": 30
    },
    {
      "start": 82.336,
      "end": 84.286,
      "type": "line",
      "text": "and after ye have witnessed him",
      "verse": "11:7",
      "lineIndex": 31
    },
    {
      "start": 84.466,
      "end": 87.485,
      "type": "line",
      "text": "ye shall bear record that it is the Son of God.",
      "verse": "11:7",
      "lineIndex": 32
    },
    {
      "start": 88.165,
      "end": 91.044,
      "type": "line",
      "text": "And it came to pass that the Spirit said unto me:",
      "verse": "11:8",
      "lineIndex": 33
    },
    {
      "start": 91.224,
      "end": 92.06,
      "type": "line",
      "text": "Look!",
      "verse": "11:8",
      "lineIndex": 34
    },
    {
      "start": 92.24,
      "end": 94.701,
      "type": "line",
      "text": "And I looked and beheld a tree;",
      "verse": "11:8",
      "lineIndex": 35
    },
    {
      "start": 94.881,
      "end": 98.225,
      "type": "line",
      "text": "and it was like unto the tree which my father had seen;",
      "verse": "11:8",
      "lineIndex": 36
    },
    {
      "start": 98.405,
      "end": 100.866,
      "type": "line",
      "text": "and the beauty thereof was far beyond,",
      "verse": "11:8",
      "lineIndex": 37
    },
    {
      "start": 101.046,
      "end": 103.229,
      "type": "line",
      "text": "yea, exceeding of all beauty;",
      "verse": "11:8",
      "lineIndex": 38
    },
    {
      "start": 103.409,
      "end": 107.635,
      "type": "line",
      "text": "and the whiteness thereof did exceed the whiteness of the driven snow.",
      "verse": "11:8",
      "lineIndex": 39
    },
    {
      "start": 108.315,
      "end": 111.148,
      "type": "line",
      "text": "And it came to pass after I had seen the tree,",
      "verse": "11:9",
      "lineIndex": 40
    },
    {
      "start": 111.328,
      "end": 112.861,
      "type": "line",
      "text": "I said unto the Spirit:",
      "verse": "11:9",
      "lineIndex": 41
    },
    {
      "start": 113.041,
      "end": 116.06,
      "type": "line",
      "text": "I behold thou hast shown unto me the tree",
      "verse": "11:9",
      "lineIndex": 42
    },
    {
      "start": 116.24,
      "end": 118.098,
      "type": "line",
      "text": "which is precious above all.",
      "verse": "11:9",
      "lineIndex": 43
    },
    {
      "start": 118.778,
      "end": 120.311,
      "type": "line",
      "text": "And he said unto me:",
      "verse": "11:10",
      "lineIndex": 44
    },
    {
      "start": 120.491,
      "end": 121.838,
      "type": "line",
      "text": "What desirest thou?",
      "verse": "11:10",
      "lineIndex": 45
    },
    {
      "start": 122.518,
      "end": 124.097,
      "type": "line",
      "text": "And I said unto him:",
      "verse": "11:11",
      "lineIndex": 46
    },
    {
      "start": 124.277,
      "end": 126.553,
      "type": "line",
      "text": "To know the interpretation thereof\u2014",
      "verse": "11:11",
      "lineIndex": 47
    },
    {
      "start": 126.733,
      "end": 129.566,
      "type": "line",
      "text": "for I spake unto him as a man speaketh;",
      "verse": "11:11",
      "lineIndex": 48
    },
    {
      "start": 129.746,
      "end": 132.857,
      "type": "line",
      "text": "for I beheld that he was in the form of a man;",
      "verse": "11:11",
      "lineIndex": 49
    },
    {
      "start": 133.037,
      "end": 136.659,
      "type": "line",
      "text": "yet nevertheless, I knew that it was the Spirit of the Lord;",
      "verse": "11:11",
      "lineIndex": 50
    },
    {
      "start": 136.839,
      "end": 140.322,
      "type": "line",
      "text": "and he spake unto me as a man speaketh with another.",
      "verse": "11:11",
      "lineIndex": 51
    },
    {
      "start": 141.002,
      "end": 143.556,
      "type": "line",
      "text": "And it came to pass that he said unto me:",
      "verse": "11:12",
      "lineIndex": 52
    },
    {
      "start": 143.736,
      "end": 144.572,
      "type": "line",
      "text": "Look!",
      "verse": "11:12",
      "lineIndex": 53
    },
    {
      "start": 144.752,
      "end": 148.003,
      "type": "line",
      "text": "And I looked as if to look upon him, and I saw him not;",
      "verse": "11:12",
      "lineIndex": 54
    },
    {
      "start": 148.183,
      "end": 150.551,
      "type": "line",
      "text": "for he had gone from before my presence.",
      "verse": "11:12",
      "lineIndex": 55
    },
    {
      "start": 151.231,
      "end": 153.507,
      "type": "line",
      "text": "And it came to pass that I looked",
      "verse": "11:13",
      "lineIndex": 57
    },
    {
      "start": 153.687,
      "end": 156.381,
      "type": "line",
      "text": "and beheld the great city of Jerusalem,",
      "verse": "11:13",
      "lineIndex": 58
    },
    {
      "start": 156.561,
      "end": 158.14,
      "type": "line",
      "text": "and also other cities.",
      "verse": "11:13",
      "lineIndex": 59
    },
    {
      "start": 158.32,
      "end": 160.503,
      "type": "line",
      "text": "And I beheld the city of Nazareth;",
      "verse": "11:13",
      "lineIndex": 60
    },
    {
      "start": 160.683,
      "end": 163.98,
      "type": "line",
      "text": "and in the city of Nazareth I beheld a virgin,",
      "verse": "11:13",
      "lineIndex": 61
    },
    {
      "start": 164.16,
      "end": 166.343,
      "type": "line",
      "text": "and she was exceedingly fair and white.",
      "verse": "11:13",
      "lineIndex": 62
    },
    {
      "start": 167.023,
      "end": 169.809,
      "type": "line",
      "text": "And it came to pass that I saw the heavens open;",
      "verse": "11:14",
      "lineIndex": 63
    },
    {
      "start": 169.989,
      "end": 172.543,
      "type": "line",
      "text": "and an angel came down and stood before me;",
      "verse": "11:14",
      "lineIndex": 64
    },
    {
      "start": 172.723,
      "end": 174.395,
      "type": "line",
      "text": "and he said unto me:",
      "verse": "11:14",
      "lineIndex": 65
    },
    {
      "start": 174.575,
      "end": 176.433,
      "type": "line",
      "text": "Nephi, what beholdest thou?",
      "verse": "11:14",
      "lineIndex": 66
    },
    {
      "start": 177.113,
      "end": 178.692,
      "type": "line",
      "text": "And I said unto him:",
      "verse": "11:15",
      "lineIndex": 67
    },
    {
      "start": 178.872,
      "end": 180.033,
      "type": "line",
      "text": "A virgin,",
      "verse": "11:15",
      "lineIndex": 68
    },
    {
      "start": 180.213,
      "end": 183.371,
      "type": "line",
      "text": "most beautiful and fair above all other virgins.",
      "verse": "11:15",
      "lineIndex": 69
    },
    {
      "start": 184.051,
      "end": 185.584,
      "type": "line",
      "text": "And he said unto me:",
      "verse": "11:16",
      "lineIndex": 70
    },
    {
      "start": 185.764,
      "end": 188.132,
      "type": "line",
      "text": "Knowest thou the condescension of God?",
      "verse": "11:16",
      "lineIndex": 71
    },
    {
      "start": 188.812,
      "end": 190.391,
      "type": "line",
      "text": "And I said unto him:",
      "verse": "11:17",
      "lineIndex": 72
    },
    {
      "start": 190.571,
      "end": 192.847,
      "type": "line",
      "text": "I know that he loveth his children;",
      "verse": "11:17",
      "lineIndex": 73
    },
    {
      "start": 193.027,
      "end": 196.371,
      "type": "line",
      "text": "nevertheless, I do not know the meaning of all things.",
      "verse": "11:17",
      "lineIndex": 74
    },
    {
      "start": 197.051,
      "end": 198.584,
      "type": "line",
      "text": "And he said unto me:",
      "verse": "11:18",
      "lineIndex": 75
    },
    {
      "start": 198.764,
      "end": 201.318,
      "type": "line",
      "text": "Behold, the virgin whom thou seest",
      "verse": "11:18",
      "lineIndex": 76
    },
    {
      "start": 201.498,
      "end": 203.727,
      "type": "line",
      "text": "is the mother of the Son of God,",
      "verse": "11:18",
      "lineIndex": 77
    },
    {
      "start": 203.907,
      "end": 205.811,
      "type": "line",
      "text": "after the manner of the flesh.",
      "verse": "11:18",
      "lineIndex": 78
    },
    {
      "start": 206.491,
      "end": 211.599,
      "type": "line",
      "text": "And it came to pass that I beheld that she was carried away in the Spirit;",
      "verse": "11:19",
      "lineIndex": 79
    },
    {
      "start": 211.779,
      "end": 215.912,
      "type": "line",
      "text": "and after she had been carried away in the Spirit for the space of a time",
      "verse": "11:19",
      "lineIndex": 80
    },
    {
      "start": 216.092,
      "end": 218.228,
      "type": "line",
      "text": "the angel spake unto me, saying:",
      "verse": "11:19",
      "lineIndex": 81
    },
    {
      "start": 218.408,
      "end": 219.244,
      "type": "line",
      "text": "Look!",
      "verse": "11:19",
      "lineIndex": 82
    },
    {
      "start": 219.924,
      "end": 224.429,
      "type": "line",
      "text": "And I looked and beheld the virgin again, bearing a child in her arms.",
      "verse": "11:20",
      "lineIndex": 83
    },
    {
      "start": 225.109,
      "end": 226.92,
      "type": "line",
      "text": "And the angel said unto me:",
      "verse": "11:21",
      "lineIndex": 84
    },
    {
      "start": 227.1,
      "end": 228.865,
      "type": "line",
      "text": "Behold the Lamb of God,",
      "verse": "11:21",
      "lineIndex": 85
    },
    {
      "start": 229.045,
      "end": 231.553,
      "type": "line",
      "text": "yea, even the Son of the Eternal Father!",
      "verse": "11:21",
      "lineIndex": 86
    },
    {
      "start": 231.733,
      "end": 234.984,
      "type": "line",
      "text": "Knowest thou the meaning of the tree which thy father saw?",
      "verse": "11:21",
      "lineIndex": 87
    },
    {
      "start": 235.664,
      "end": 237.614,
      "type": "line",
      "text": "And I answered him, saying:",
      "verse": "11:22",
      "lineIndex": 88
    },
    {
      "start": 237.794,
      "end": 239.698,
      "type": "line",
      "text": "Yea, it is the love of God,",
      "verse": "11:22",
      "lineIndex": 89
    },
    {
      "start": 239.878,
      "end": 241.921,
      "type": "line",
      "text": "which sheddeth itself abroad",
      "verse": "11:22",
      "lineIndex": 90
    },
    {
      "start": 242.101,
      "end": 244.562,
      "type": "line",
      "text": "in the hearts of the children of men;",
      "verse": "11:22",
      "lineIndex": 91
    },
    {
      "start": 244.742,
      "end": 248.039,
      "type": "line",
      "text": "wherefore, it is the most desirable above all things.",
      "verse": "11:22",
      "lineIndex": 92
    },
    {
      "start": 248.719,
      "end": 250.623,
      "type": "line",
      "text": "And he spake unto me, saying:",
      "verse": "11:23",
      "lineIndex": 93
    },
    {
      "start": 250.803,
      "end": 253.264,
      "type": "line",
      "text": "Yea, and the most joyous to the soul.",
      "verse": "11:23",
      "lineIndex": 94
    },
    {
      "start": 253.944,
      "end": 256.87,
      "type": "line",
      "text": "And after he had said these words, he said unto me:",
      "verse": "11:24",
      "lineIndex": 96
    },
    {
      "start": 257.05,
      "end": 257.886,
      "type": "line",
      "text": "Look!",
      "verse": "11:24",
      "lineIndex": 97
    },
    {
      "start": 258.066,
      "end": 262.756,
      "type": "line",
      "text": "And I looked, and I beheld the Son of God going forth among the children of men;",
      "verse": "11:24",
      "lineIndex": 98
    },
    {
      "start": 262.936,
      "end": 266.419,
      "type": "line",
      "text": "and I saw many fall down at his feet and worship him.",
      "verse": "11:24",
      "lineIndex": 99
    },
    {
      "start": 267.099,
      "end": 270.536,
      "type": "line",
      "text": "And it came to pass that I beheld that the rod of iron,",
      "verse": "11:25",
      "lineIndex": 100
    },
    {
      "start": 270.716,
      "end": 272.527,
      "type": "line",
      "text": "which my father had seen,",
      "verse": "11:25",
      "lineIndex": 101
    },
    {
      "start": 272.707,
      "end": 274.286,
      "type": "line",
      "text": "was the word of God,",
      "verse": "11:25",
      "lineIndex": 102
    },
    {
      "start": 274.466,
      "end": 277.345,
      "type": "line",
      "text": "which led to the fountain of living waters,",
      "verse": "11:25",
      "lineIndex": 103
    },
    {
      "start": 277.525,
      "end": 279.94,
      "type": "line",
      "text": "or to the tree of life; which waters",
      "verse": "11:25",
      "lineIndex": 104
    },
    {
      "start": 280.12,
      "end": 282.814,
      "type": "line",
      "text": "are a representation of the love of God;",
      "verse": "11:25",
      "lineIndex": 105
    },
    {
      "start": 282.994,
      "end": 285.362,
      "type": "line",
      "text": "and I also beheld that the tree of life",
      "verse": "11:25",
      "lineIndex": 106
    },
    {
      "start": 285.542,
      "end": 288.143,
      "type": "line",
      "text": "was a representation of the love of God.",
      "verse": "11:25",
      "lineIndex": 107
    },
    {
      "start": 288.823,
      "end": 290.773,
      "type": "line",
      "text": "And the angel said unto me again:",
      "verse": "11:26",
      "lineIndex": 108
    },
    {
      "start": 290.953,
      "end": 293.321,
      "type": "line",
      "text": "Look and behold the condescension of God!",
      "verse": "11:26",
      "lineIndex": 109
    },
    {
      "start": 294.001,
      "end": 297.67,
      "type": "line",
      "text": "And I looked and beheld the Redeemer of the world,",
      "verse": "11:27",
      "lineIndex": 110
    },
    {
      "start": 297.85,
      "end": 299.847,
      "type": "line",
      "text": "of whom my father had spoken;",
      "verse": "11:27",
      "lineIndex": 111
    },
    {
      "start": 300.027,
      "end": 302.349,
      "type": "line",
      "text": "and I also beheld the prophet",
      "verse": "11:27",
      "lineIndex": 112
    },
    {
      "start": 302.529,
      "end": 304.758,
      "type": "line",
      "text": "who should prepare the way before him.",
      "verse": "11:27",
      "lineIndex": 113
    },
    {
      "start": 304.938,
      "end": 306.935,
      "type": "line",
      "text": "And the Lamb of God went forth",
      "verse": "11:27",
      "lineIndex": 114
    },
    {
      "start": 307.115,
      "end": 308.787,
      "type": "line",
      "text": "and was baptized of him;",
      "verse": "11:27",
      "lineIndex": 115
    },
    {
      "start": 308.967,
      "end": 310.639,
      "type": "line",
      "text": "and after he was baptized,",
      "verse": "11:27",
      "lineIndex": 116
    },
    {
      "start": 310.819,
      "end": 312.769,
      "type": "line",
      "text": "I beheld the heavens open,",
      "verse": "11:27",
      "lineIndex": 117
    },
    {
      "start": 312.949,
      "end": 315.457,
      "type": "line",
      "text": "and the Holy Ghost come down out of heaven",
      "verse": "11:27",
      "lineIndex": 118
    },
    {
      "start": 315.637,
      "end": 318.191,
      "type": "line",
      "text": "and abide upon him in the form of a dove.",
      "verse": "11:27",
      "lineIndex": 119
    },
    {
      "start": 318.871,
      "end": 321.1,
      "type": "line",
      "text": "And I beheld that he went forth",
      "verse": "11:28",
      "lineIndex": 120
    },
    {
      "start": 321.28,
      "end": 324.438,
      "type": "line",
      "text": "ministering unto the people, in power and great glory;",
      "verse": "11:28",
      "lineIndex": 121
    },
    {
      "start": 324.618,
      "end": 327.915,
      "type": "line",
      "text": "and the multitudes were gathered together to hear him;",
      "verse": "11:28",
      "lineIndex": 122
    },
    {
      "start": 328.095,
      "end": 331.717,
      "type": "line",
      "text": "and I beheld that they cast him out from among them.",
      "verse": "11:28",
      "lineIndex": 123
    },
    {
      "start": 332.397,
      "end": 335.323,
      "type": "line",
      "text": "And I also beheld twelve others following him.",
      "verse": "11:29",
      "lineIndex": 124
    },
    {
      "start": 335.503,
      "end": 338.661,
      "type": "line",
      "text": "And it came to pass that they were carried away in the Spirit",
      "verse": "11:29",
      "lineIndex": 125
    },
    {
      "start": 338.841,
      "end": 340.374,
      "type": "line",
      "text": "from before my face,",
      "verse": "11:29",
      "lineIndex": 126
    },
    {
      "start": 340.554,
      "end": 342.087,
      "type": "line",
      "text": "and I saw them not.",
      "verse": "11:29",
      "lineIndex": 127
    },
    {
      "start": 342.767,
      "end": 346.714,
      "type": "line",
      "text": "And it came to pass that the angel spake unto me again, saying:",
      "verse": "11:30",
      "lineIndex": 128
    },
    {
      "start": 346.894,
      "end": 347.73,
      "type": "line",
      "text": "Look!",
      "verse": "11:30",
      "lineIndex": 129
    },
    {
      "start": 347.91,
      "end": 351.347,
      "type": "line",
      "text": "And I looked, and I beheld the heavens open again,",
      "verse": "11:30",
      "lineIndex": 130
    },
    {
      "start": 351.527,
      "end": 354.871,
      "type": "line",
      "text": "and I saw angels descending upon the children of men;",
      "verse": "11:30",
      "lineIndex": 131
    },
    {
      "start": 355.051,
      "end": 357.373,
      "type": "line",
      "text": "and they did minister unto them.",
      "verse": "11:30",
      "lineIndex": 132
    },
    {
      "start": 358.053,
      "end": 360.561,
      "type": "line",
      "text": "And he spake unto me again, saying:",
      "verse": "11:31",
      "lineIndex": 133
    },
    {
      "start": 360.741,
      "end": 361.577,
      "type": "line",
      "text": "Look!",
      "verse": "11:31",
      "lineIndex": 134
    },
    {
      "start": 361.757,
      "end": 364.358,
      "type": "line",
      "text": "And I looked, and I beheld the Lamb of God",
      "verse": "11:31",
      "lineIndex": 135
    },
    {
      "start": 364.538,
      "end": 366.86,
      "type": "line",
      "text": "going forth among the children of men.",
      "verse": "11:31",
      "lineIndex": 136
    },
    {
      "start": 367.04,
      "end": 370.151,
      "type": "line",
      "text": "And I beheld multitudes of people who were sick,",
      "verse": "11:31",
      "lineIndex": 137
    },
    {
      "start": 370.331,
      "end": 373.257,
      "type": "line",
      "text": "and who were afflicted with all manner of diseases,",
      "verse": "11:31",
      "lineIndex": 138
    },
    {
      "start": 373.437,
      "end": 375.852,
      "type": "line",
      "text": "and with devils and unclean spirits;",
      "verse": "11:31",
      "lineIndex": 139
    },
    {
      "start": 376.032,
      "end": 379.376,
      "type": "line",
      "text": "and the angel spake and showed all these things unto me.",
      "verse": "11:31",
      "lineIndex": 140
    },
    {
      "start": 379.556,
      "end": 383.085,
      "type": "line",
      "text": "And they were healed by the power of the Lamb of God;",
      "verse": "11:31",
      "lineIndex": 141
    },
    {
      "start": 383.265,
      "end": 386.516,
      "type": "line",
      "text": "and the devils and the unclean spirits were cast out.",
      "verse": "11:31",
      "lineIndex": 142
    },
    {
      "start": 387.196,
      "end": 391.143,
      "type": "line",
      "text": "And it came to pass that the angel spake unto me again, saying:",
      "verse": "11:32",
      "lineIndex": 144
    },
    {
      "start": 391.323,
      "end": 392.159,
      "type": "line",
      "text": "Look!",
      "verse": "11:32",
      "lineIndex": 145
    },
    {
      "start": 392.339,
      "end": 394.615,
      "type": "line",
      "text": "And I looked and beheld the Lamb of God,",
      "verse": "11:32",
      "lineIndex": 146
    },
    {
      "start": 394.795,
      "end": 396.745,
      "type": "line",
      "text": "that he was taken by the people;",
      "verse": "11:32",
      "lineIndex": 147
    },
    {
      "start": 396.925,
      "end": 400.547,
      "type": "line",
      "text": "yea, the Son of the everlasting God was judged of the world;",
      "verse": "11:32",
      "lineIndex": 148
    },
    {
      "start": 400.727,
      "end": 402.445,
      "type": "line",
      "text": "and I saw and bear record.",
      "verse": "11:32",
      "lineIndex": 149
    },
    {
      "start": 403.125,
      "end": 406.98,
      "type": "line",
      "text": "And I, Nephi, saw that he was lifted up upon the cross",
      "verse": "11:33",
      "lineIndex": 150
    },
    {
      "start": 407.16,
      "end": 409.621,
      "type": "line",
      "text": "and slain for the sins of the world.",
      "verse": "11:33",
      "lineIndex": 151
    },
    {
      "start": 410.301,
      "end": 412.019,
      "type": "line",
      "text": "And after he was slain",
      "verse": "11:34",
      "lineIndex": 152
    },
    {
      "start": 412.199,
      "end": 414.521,
      "type": "line",
      "text": "I saw the multitudes of the earth,",
      "verse": "11:34",
      "lineIndex": 153
    },
    {
      "start": 414.701,
      "end": 417.58,
      "type": "line",
      "text": "that they were gathered together",
      "verse": "11:34",
      "lineIndex": 154
    },
    {
      "start": 417.76,
      "end": 420.686,
      "type": "line",
      "text": "to fight against the apostles of the Lamb;",
      "verse": "11:34",
      "lineIndex": 155
    },
    {
      "start": 420.866,
      "end": 423.931,
      "type": "line",
      "text": "for thus were the twelve called by the angel of the Lord.",
      "verse": "11:34",
      "lineIndex": 156
    },
    {
      "start": 424.611,
      "end": 428.001,
      "type": "line",
      "text": "And the multitude of the earth was gathered together;",
      "verse": "11:35",
      "lineIndex": 157
    },
    {
      "start": 428.181,
      "end": 432.082,
      "type": "line",
      "text": "and I beheld that they were in a large and spacious building,",
      "verse": "11:35",
      "lineIndex": 158
    },
    {
      "start": 432.262,
      "end": 434.909,
      "type": "line",
      "text": "like unto the building which my father saw.",
      "verse": "11:35",
      "lineIndex": 159
    },
    {
      "start": 435.089,
      "end": 438.2,
      "type": "line",
      "text": "And the angel of the Lord spake unto me again, saying:",
      "verse": "11:35",
      "lineIndex": 160
    },
    {
      "start": 438.38,
      "end": 440.841,
      "type": "line",
      "text": "Behold the world and the wisdom thereof;",
      "verse": "11:35",
      "lineIndex": 161
    },
    {
      "start": 441.021,
      "end": 443.993,
      "type": "line",
      "text": "yea, behold the house of Israel hath gathered together",
      "verse": "11:35",
      "lineIndex": 162
    },
    {
      "start": 444.173,
      "end": 447.331,
      "type": "line",
      "text": "to fight against the twelve apostles of the Lamb.",
      "verse": "11:35",
      "lineIndex": 163
    },
    {
      "start": 448.011,
      "end": 451.355,
      "type": "line",
      "text": "And it came to pass that I saw and bear record,",
      "verse": "11:36",
      "lineIndex": 164
    },
    {
      "start": 451.535,
      "end": 454.925,
      "type": "line",
      "text": "the great and spacious building was the pride of the world;",
      "verse": "11:36",
      "lineIndex": 165
    },
    {
      "start": 455.105,
      "end": 456.266,
      "type": "line",
      "text": "and it fell,",
      "verse": "11:36",
      "lineIndex": 166
    },
    {
      "start": 456.446,
      "end": 458.907,
      "type": "line",
      "text": "and the fall thereof was exceedingly great.",
      "verse": "11:36",
      "lineIndex": 167
    },
    {
      "start": 459.087,
      "end": 462.198,
      "type": "line",
      "text": "And the angel of the Lord spake unto me again, saying:",
      "verse": "11:36",
      "lineIndex": 168
    },
    {
      "start": 462.378,
      "end": 464.7,
      "type": "line",
      "text": "Thus shall be the destruction",
      "verse": "11:36",
      "lineIndex": 169
    },
    {
      "start": 464.88,
      "end": 467.574,
      "type": "line",
      "text": "of all nations, kindreds, tongues, and people,",
      "verse": "11:36",
      "lineIndex": 170
    },
    {
      "start": 467.754,
      "end": 471.237,
      "type": "line",
      "text": "that shall fight against the twelve apostles of the Lamb.",
      "verse": "11:36",
      "lineIndex": 171
    }
  ]
}