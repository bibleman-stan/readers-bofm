{
  "book": "1nephi",
  "bookName": "1 Nephi",
  "chapter": 21,
  "voice": {
    "provider": "elevenlabs",
    "voice_id": "ddDFRErfhdc2asyySOG5",
    "model_id": "eleven_multilingual_v2",
    "settings": {
      "stability": 0.5,
      "similarity_boost": 0.75,
      "style": 0.35,
      "use_speaker_boost": true
    },
    "name": "Samuel"
  },
  "pauses": {
    "line_ms": 180,
    "verse_ms": 500
  },
  "duration": 354.328,
  "lines": [
    {
      "start": 0.0,
      "end": 1.765,
      "type": "line",
      "text": "And again: Hearken,",
      "verse": "21:1",
      "lineIndex": 1
    },
    {
      "start": 1.945,
      "end": 6.728,
      "type": "line",
      "text": "O ye house of Israel, all ye that are broken off and are driven out",
      "verse": "21:1",
      "lineIndex": 2
    },
    {
      "start": 6.908,
      "end": 10.112,
      "type": "line",
      "text": "because of the wickedness of the pastors of my people;",
      "verse": "21:1",
      "lineIndex": 3
    },
    {
      "start": 10.292,
      "end": 12.242,
      "type": "line",
      "text": "yea, all ye that are broken off,",
      "verse": "21:1",
      "lineIndex": 4
    },
    {
      "start": 12.422,
      "end": 16.044,
      "type": "line",
      "text": "that are scattered abroad, who are of my people,",
      "verse": "21:1",
      "lineIndex": 5
    },
    {
      "start": 16.224,
      "end": 17.71,
      "type": "line",
      "text": "O house of Israel.",
      "verse": "21:1",
      "lineIndex": 6
    },
    {
      "start": 17.89,
      "end": 19.887,
      "type": "line",
      "text": "Listen, O isles, unto me,",
      "verse": "21:1",
      "lineIndex": 7
    },
    {
      "start": 20.067,
      "end": 22.435,
      "type": "line",
      "text": "and hearken ye people from far;",
      "verse": "21:1",
      "lineIndex": 8
    },
    {
      "start": 22.615,
      "end": 24.751,
      "type": "line",
      "text": "the Lord hath called me from the womb;",
      "verse": "21:1",
      "lineIndex": 9
    },
    {
      "start": 24.931,
      "end": 27.021,
      "type": "line",
      "text": "from the bowels of my mother",
      "verse": "21:1",
      "lineIndex": 10
    },
    {
      "start": 27.201,
      "end": 29.291,
      "type": "line",
      "text": "hath he made mention of my name.",
      "verse": "21:1",
      "lineIndex": 11
    },
    {
      "start": 29.971,
      "end": 32.525,
      "type": "line",
      "text": "And he hath made my mouth like a sharp sword;",
      "verse": "21:2",
      "lineIndex": 12
    },
    {
      "start": 32.705,
      "end": 34.423,
      "type": "line",
      "text": "in the shadow of his hand",
      "verse": "21:2",
      "lineIndex": 13
    },
    {
      "start": 34.603,
      "end": 37.482,
      "type": "line",
      "text": "hath he hid me, and made me a polished shaft;",
      "verse": "21:2",
      "lineIndex": 14
    },
    {
      "start": 37.662,
      "end": 39.659,
      "type": "line",
      "text": "in his quiver hath he hid me;",
      "verse": "21:2",
      "lineIndex": 15
    },
    {
      "start": 40.339,
      "end": 41.872,
      "type": "line",
      "text": "And said unto me:",
      "verse": "21:3",
      "lineIndex": 16
    },
    {
      "start": 42.052,
      "end": 44.42,
      "type": "line",
      "text": "Thou art my servant, O Israel,",
      "verse": "21:3",
      "lineIndex": 17
    },
    {
      "start": 44.6,
      "end": 46.458,
      "type": "line",
      "text": "in whom I will be glorified.",
      "verse": "21:3",
      "lineIndex": 18
    },
    {
      "start": 47.138,
      "end": 48.299,
      "type": "line",
      "text": "Then I said,",
      "verse": "21:4",
      "lineIndex": 20
    },
    {
      "start": 48.479,
      "end": 50.151,
      "type": "line",
      "text": "I have labored in vain,",
      "verse": "21:4",
      "lineIndex": 21
    },
    {
      "start": 50.331,
      "end": 53.117,
      "type": "line",
      "text": "I have spent my strength for naught and in vain;",
      "verse": "21:4",
      "lineIndex": 22
    },
    {
      "start": 53.297,
      "end": 55.665,
      "type": "line",
      "text": "surely my judgment is with the Lord,",
      "verse": "21:4",
      "lineIndex": 23
    },
    {
      "start": 55.845,
      "end": 57.563,
      "type": "line",
      "text": "and my work with my God.",
      "verse": "21:4",
      "lineIndex": 24
    },
    {
      "start": 58.243,
      "end": 63.305,
      "type": "line",
      "text": "And now, saith the Lord\u2014 that formed me from the womb that I should be his servant,",
      "verse": "21:5",
      "lineIndex": 25
    },
    {
      "start": 63.485,
      "end": 65.435,
      "type": "line",
      "text": "to bring Jacob again to him\u2014",
      "verse": "21:5",
      "lineIndex": 26
    },
    {
      "start": 65.615,
      "end": 67.658,
      "type": "line",
      "text": "though Israel be not gathered,",
      "verse": "21:5",
      "lineIndex": 27
    },
    {
      "start": 67.838,
      "end": 70.671,
      "type": "line",
      "text": "yet shall I be glorious in the eyes of the Lord,",
      "verse": "21:5",
      "lineIndex": 28
    },
    {
      "start": 70.851,
      "end": 72.848,
      "type": "line",
      "text": "and my God shall be my strength.",
      "verse": "21:5",
      "lineIndex": 29
    },
    {
      "start": 73.528,
      "end": 78.033,
      "type": "line",
      "text": "And he said: It is a light thing that thou shouldst be my servant",
      "verse": "21:6",
      "lineIndex": 31
    },
    {
      "start": 78.213,
      "end": 80.489,
      "type": "line",
      "text": "to raise up the tribes of Jacob,",
      "verse": "21:6",
      "lineIndex": 32
    },
    {
      "start": 80.669,
      "end": 83.223,
      "type": "line",
      "text": "and to restore the preserved of Israel.",
      "verse": "21:6",
      "lineIndex": 33
    },
    {
      "start": 83.403,
      "end": 86.561,
      "type": "line",
      "text": "I will also give thee for a light to the Gentiles,",
      "verse": "21:6",
      "lineIndex": 34
    },
    {
      "start": 86.741,
      "end": 90.456,
      "type": "line",
      "text": "that thou mayest be my salvation unto the ends of the earth.",
      "verse": "21:6",
      "lineIndex": 35
    },
    {
      "start": 91.136,
      "end": 92.576,
      "type": "line",
      "text": "Thus saith the Lord,",
      "verse": "21:7",
      "lineIndex": 36
    },
    {
      "start": 92.756,
      "end": 95.45,
      "type": "line",
      "text": "the Redeemer of Israel, his Holy One,",
      "verse": "21:7",
      "lineIndex": 37
    },
    {
      "start": 95.63,
      "end": 97.952,
      "type": "line",
      "text": "to him whom man despiseth,",
      "verse": "21:7",
      "lineIndex": 38
    },
    {
      "start": 98.132,
      "end": 100.222,
      "type": "line",
      "text": "to him whom the nations abhorreth,",
      "verse": "21:7",
      "lineIndex": 39
    },
    {
      "start": 100.402,
      "end": 101.981,
      "type": "line",
      "text": "to servant of rulers:",
      "verse": "21:7",
      "lineIndex": 40
    },
    {
      "start": 102.161,
      "end": 105.876,
      "type": "line",
      "text": "Kings shall see and arise, princes also shall worship,",
      "verse": "21:7",
      "lineIndex": 41
    },
    {
      "start": 106.056,
      "end": 108.61,
      "type": "line",
      "text": "because of the Lord that is faithful.",
      "verse": "21:7",
      "lineIndex": 42
    },
    {
      "start": 109.29,
      "end": 110.776,
      "type": "line",
      "text": "Thus saith the Lord:",
      "verse": "21:8",
      "lineIndex": 44
    },
    {
      "start": 110.956,
      "end": 113.417,
      "type": "line",
      "text": "In an acceptable time have I heard thee,",
      "verse": "21:8",
      "lineIndex": 45
    },
    {
      "start": 113.597,
      "end": 115.269,
      "type": "line",
      "text": "O isles of the sea,",
      "verse": "21:8",
      "lineIndex": 46
    },
    {
      "start": 115.449,
      "end": 118.282,
      "type": "line",
      "text": "and in a day of salvation have I helped thee;",
      "verse": "21:8",
      "lineIndex": 47
    },
    {
      "start": 118.462,
      "end": 120.273,
      "type": "line",
      "text": "and I will preserve thee,",
      "verse": "21:8",
      "lineIndex": 48
    },
    {
      "start": 120.453,
      "end": 123.89,
      "type": "line",
      "text": "and give thee my servant for a covenant of the people,",
      "verse": "21:8",
      "lineIndex": 49
    },
    {
      "start": 124.07,
      "end": 125.603,
      "type": "line",
      "text": "to establish the earth,",
      "verse": "21:8",
      "lineIndex": 50
    },
    {
      "start": 125.783,
      "end": 128.894,
      "type": "line",
      "text": "to cause to inherit the desolate heritages;",
      "verse": "21:8",
      "lineIndex": 51
    },
    {
      "start": 129.574,
      "end": 132.639,
      "type": "line",
      "text": "That thou mayest say to the prisoners: Go forth;",
      "verse": "21:9",
      "lineIndex": 52
    },
    {
      "start": 132.819,
      "end": 134.723,
      "type": "line",
      "text": "to them that sit in darkness:",
      "verse": "21:9",
      "lineIndex": 53
    },
    {
      "start": 134.903,
      "end": 136.157,
      "type": "line",
      "text": "Show yourselves.",
      "verse": "21:9",
      "lineIndex": 54
    },
    {
      "start": 136.337,
      "end": 138.195,
      "type": "line",
      "text": "They shall feed in the ways,",
      "verse": "21:9",
      "lineIndex": 55
    },
    {
      "start": 138.375,
      "end": 141.672,
      "type": "line",
      "text": "and their pastures shall be in all high places.",
      "verse": "21:9",
      "lineIndex": 56
    },
    {
      "start": 142.352,
      "end": 144.535,
      "type": "line",
      "text": "They shall not hunger nor thirst,",
      "verse": "21:10",
      "lineIndex": 57
    },
    {
      "start": 144.715,
      "end": 147.687,
      "type": "line",
      "text": "neither shall the heat nor the sun smite them;",
      "verse": "21:10",
      "lineIndex": 58
    },
    {
      "start": 147.867,
      "end": 150.839,
      "type": "line",
      "text": "for he that hath mercy on them shall lead them,",
      "verse": "21:10",
      "lineIndex": 59
    },
    {
      "start": 151.019,
      "end": 153.155,
      "type": "line",
      "text": "even by the springs of water",
      "verse": "21:10",
      "lineIndex": 60
    },
    {
      "start": 153.335,
      "end": 154.821,
      "type": "line",
      "text": "shall he guide them.",
      "verse": "21:10",
      "lineIndex": 61
    },
    {
      "start": 155.501,
      "end": 157.916,
      "type": "line",
      "text": "And I will make all my mountains a way,",
      "verse": "21:11",
      "lineIndex": 62
    },
    {
      "start": 158.096,
      "end": 160.604,
      "type": "line",
      "text": "and my highways shall be exalted.",
      "verse": "21:11",
      "lineIndex": 63
    },
    {
      "start": 161.284,
      "end": 163.42,
      "type": "line",
      "text": "And then, O house of Israel,",
      "verse": "21:12",
      "lineIndex": 64
    },
    {
      "start": 163.6,
      "end": 165.829,
      "type": "line",
      "text": "behold, these shall come from far;",
      "verse": "21:12",
      "lineIndex": 65
    },
    {
      "start": 166.009,
      "end": 169.167,
      "type": "line",
      "text": "and lo, these from the north and from the west;",
      "verse": "21:12",
      "lineIndex": 66
    },
    {
      "start": 169.347,
      "end": 171.437,
      "type": "line",
      "text": "and these from the land of Sinim.",
      "verse": "21:12",
      "lineIndex": 67
    },
    {
      "start": 172.117,
      "end": 174.903,
      "type": "line",
      "text": "Sing, O heavens; and be joyful, O earth;",
      "verse": "21:13",
      "lineIndex": 69
    },
    {
      "start": 175.083,
      "end": 178.752,
      "type": "line",
      "text": "for the feet of those who are in the east shall be established;",
      "verse": "21:13",
      "lineIndex": 70
    },
    {
      "start": 178.932,
      "end": 181.626,
      "type": "line",
      "text": "and break forth into singing, O mountains;",
      "verse": "21:13",
      "lineIndex": 71
    },
    {
      "start": 181.806,
      "end": 183.896,
      "type": "line",
      "text": "for they shall be smitten no more;",
      "verse": "21:13",
      "lineIndex": 72
    },
    {
      "start": 184.076,
      "end": 186.491,
      "type": "line",
      "text": "for the Lord hath comforted his people,",
      "verse": "21:13",
      "lineIndex": 73
    },
    {
      "start": 186.671,
      "end": 188.947,
      "type": "line",
      "text": "and will have mercy upon his afflicted.",
      "verse": "21:13",
      "lineIndex": 74
    },
    {
      "start": 189.627,
      "end": 194.271,
      "type": "line",
      "text": "But, behold, Zion hath said: The Lord hath forsaken me,",
      "verse": "21:14",
      "lineIndex": 76
    },
    {
      "start": 194.451,
      "end": 196.262,
      "type": "line",
      "text": "and my Lord hath forgotten me\u2014",
      "verse": "21:14",
      "lineIndex": 77
    },
    {
      "start": 196.442,
      "end": 198.3,
      "type": "line",
      "text": "but he will show that he hath not.",
      "verse": "21:14",
      "lineIndex": 78
    },
    {
      "start": 198.98,
      "end": 201.72,
      "type": "line",
      "text": "For can a woman forget her sucking child,",
      "verse": "21:15",
      "lineIndex": 79
    },
    {
      "start": 201.9,
      "end": 205.383,
      "type": "line",
      "text": "that she should not have compassion on the son of her womb?",
      "verse": "21:15",
      "lineIndex": 80
    },
    {
      "start": 205.563,
      "end": 207.142,
      "type": "line",
      "text": "Yea, they may forget,",
      "verse": "21:15",
      "lineIndex": 81
    },
    {
      "start": 207.322,
      "end": 210.155,
      "type": "line",
      "text": "yet will I not forget thee, O house of Israel.",
      "verse": "21:15",
      "lineIndex": 82
    },
    {
      "start": 210.835,
      "end": 214.132,
      "type": "line",
      "text": "Behold, I have graven thee upon the palms of my hands;",
      "verse": "21:16",
      "lineIndex": 83
    },
    {
      "start": 214.312,
      "end": 216.68,
      "type": "line",
      "text": "thy walls are continually before me.",
      "verse": "21:16",
      "lineIndex": 84
    },
    {
      "start": 217.36,
      "end": 220.75,
      "type": "line",
      "text": "Thy children shall make haste against thy destroyers;",
      "verse": "21:17",
      "lineIndex": 85
    },
    {
      "start": 220.93,
      "end": 222.88,
      "type": "line",
      "text": "and they that made thee waste",
      "verse": "21:17",
      "lineIndex": 86
    },
    {
      "start": 223.06,
      "end": 224.685,
      "type": "line",
      "text": "shall go forth of thee.",
      "verse": "21:17",
      "lineIndex": 87
    },
    {
      "start": 225.365,
      "end": 227.966,
      "type": "line",
      "text": "Lift up thine eyes round about and behold;",
      "verse": "21:18",
      "lineIndex": 88
    },
    {
      "start": 228.146,
      "end": 230.7,
      "type": "line",
      "text": "all these gather themselves together,",
      "verse": "21:18",
      "lineIndex": 89
    },
    {
      "start": 230.88,
      "end": 232.738,
      "type": "line",
      "text": "and they shall come to thee.",
      "verse": "21:18",
      "lineIndex": 90
    },
    {
      "start": 232.918,
      "end": 234.776,
      "type": "line",
      "text": "And as I live, saith the Lord,",
      "verse": "21:18",
      "lineIndex": 91
    },
    {
      "start": 234.956,
      "end": 239.321,
      "type": "line",
      "text": "thou shalt surely clothe thee with them all, as with an ornament,",
      "verse": "21:18",
      "lineIndex": 92
    },
    {
      "start": 239.501,
      "end": 242.287,
      "type": "line",
      "text": "and bind them on even as a bride.",
      "verse": "21:18",
      "lineIndex": 93
    },
    {
      "start": 242.967,
      "end": 245.661,
      "type": "line",
      "text": "For thy waste and thy desolate places,",
      "verse": "21:19",
      "lineIndex": 95
    },
    {
      "start": 245.841,
      "end": 249.742,
      "type": "line",
      "text": "and the land of thy destruction, shall even now be too narrow",
      "verse": "21:19",
      "lineIndex": 96
    },
    {
      "start": 249.922,
      "end": 252.012,
      "type": "line",
      "text": "by reason of the inhabitants;",
      "verse": "21:19",
      "lineIndex": 97
    },
    {
      "start": 252.192,
      "end": 255.257,
      "type": "line",
      "text": "and they that swallowed thee up shall be far away.",
      "verse": "21:19",
      "lineIndex": 98
    },
    {
      "start": 255.937,
      "end": 258.073,
      "type": "line",
      "text": "The children whom thou shalt have,",
      "verse": "21:20",
      "lineIndex": 99
    },
    {
      "start": 258.253,
      "end": 260.389,
      "type": "line",
      "text": "after thou hast lost the first,",
      "verse": "21:20",
      "lineIndex": 100
    },
    {
      "start": 260.569,
      "end": 262.705,
      "type": "line",
      "text": "shall again in thine ears say:",
      "verse": "21:20",
      "lineIndex": 101
    },
    {
      "start": 262.885,
      "end": 265.161,
      "type": "line",
      "text": "The place is too strait for me;",
      "verse": "21:20",
      "lineIndex": 102
    },
    {
      "start": 265.341,
      "end": 267.477,
      "type": "line",
      "text": "give place to me that I may dwell.",
      "verse": "21:20",
      "lineIndex": 103
    },
    {
      "start": 268.157,
      "end": 272.708,
      "type": "line",
      "text": "Then shalt thou say in thine heart: Who hath begotten me these,",
      "verse": "21:21",
      "lineIndex": 104
    },
    {
      "start": 272.888,
      "end": 274.792,
      "type": "line",
      "text": "seeing I have lost my children,",
      "verse": "21:21",
      "lineIndex": 105
    },
    {
      "start": 274.972,
      "end": 278.455,
      "type": "line",
      "text": "and am desolate, a captive, and removing to and fro?",
      "verse": "21:21",
      "lineIndex": 106
    },
    {
      "start": 278.635,
      "end": 280.446,
      "type": "line",
      "text": "And who hath brought up these?",
      "verse": "21:21",
      "lineIndex": 107
    },
    {
      "start": 280.626,
      "end": 282.251,
      "type": "line",
      "text": "Behold, I was left alone;",
      "verse": "21:21",
      "lineIndex": 108
    },
    {
      "start": 282.431,
      "end": 284.056,
      "type": "line",
      "text": "these, where have they been?",
      "verse": "21:21",
      "lineIndex": 109
    },
    {
      "start": 284.736,
      "end": 286.454,
      "type": "line",
      "text": "Thus saith the Lord God:",
      "verse": "21:22",
      "lineIndex": 111
    },
    {
      "start": 286.634,
      "end": 289.838,
      "type": "line",
      "text": "Behold, I will lift up mine hand to the Gentiles,",
      "verse": "21:22",
      "lineIndex": 112
    },
    {
      "start": 290.018,
      "end": 292.479,
      "type": "line",
      "text": "and set up my standard to the people;",
      "verse": "21:22",
      "lineIndex": 113
    },
    {
      "start": 292.659,
      "end": 295.492,
      "type": "line",
      "text": "and they shall bring thy sons in their arms,",
      "verse": "21:22",
      "lineIndex": 114
    },
    {
      "start": 295.672,
      "end": 298.923,
      "type": "line",
      "text": "and thy daughters shall be carried upon their shoulders.",
      "verse": "21:22",
      "lineIndex": 115
    },
    {
      "start": 299.603,
      "end": 302.297,
      "type": "line",
      "text": "And kings shall be thy nursing fathers,",
      "verse": "21:23",
      "lineIndex": 116
    },
    {
      "start": 302.477,
      "end": 304.706,
      "type": "line",
      "text": "and their queens thy nursing mothers;",
      "verse": "21:23",
      "lineIndex": 117
    },
    {
      "start": 304.886,
      "end": 306.883,
      "type": "line",
      "text": "they shall bow down to thee",
      "verse": "21:23",
      "lineIndex": 118
    },
    {
      "start": 307.063,
      "end": 309.524,
      "type": "line",
      "text": "with their face towards the earth,",
      "verse": "21:23",
      "lineIndex": 119
    },
    {
      "start": 309.704,
      "end": 312.072,
      "type": "line",
      "text": "and lick up the dust of thy feet;",
      "verse": "21:23",
      "lineIndex": 120
    },
    {
      "start": 312.252,
      "end": 314.528,
      "type": "line",
      "text": "and thou shalt know that I am the Lord;",
      "verse": "21:23",
      "lineIndex": 121
    },
    {
      "start": 314.708,
      "end": 317.494,
      "type": "line",
      "text": "for they shall not be ashamed that wait for me.",
      "verse": "21:23",
      "lineIndex": 122
    },
    {
      "start": 318.174,
      "end": 321.1,
      "type": "line",
      "text": "For shall the prey be taken from the mighty,",
      "verse": "21:24",
      "lineIndex": 124
    },
    {
      "start": 321.28,
      "end": 323.37,
      "type": "line",
      "text": "or the lawful captives delivered?",
      "verse": "21:24",
      "lineIndex": 125
    },
    {
      "start": 324.05,
      "end": 325.722,
      "type": "line",
      "text": "But thus saith the Lord,",
      "verse": "21:25",
      "lineIndex": 126
    },
    {
      "start": 325.902,
      "end": 329.199,
      "type": "line",
      "text": "even the captives of the mighty shall be taken away,",
      "verse": "21:25",
      "lineIndex": 127
    },
    {
      "start": 329.379,
      "end": 331.19,
      "type": "line",
      "text": "and the prey of the terrible",
      "verse": "21:25",
      "lineIndex": 128
    },
    {
      "start": 331.37,
      "end": 332.763,
      "type": "line",
      "text": "shall be delivered;",
      "verse": "21:25",
      "lineIndex": 129
    },
    {
      "start": 332.943,
      "end": 336.194,
      "type": "line",
      "text": "for I will contend with him that contendeth with thee,",
      "verse": "21:25",
      "lineIndex": 130
    },
    {
      "start": 336.374,
      "end": 338.232,
      "type": "line",
      "text": "and I will save thy children.",
      "verse": "21:25",
      "lineIndex": 131
    },
    {
      "start": 338.912,
      "end": 342.534,
      "type": "line",
      "text": "And I will feed them that oppress thee with their own flesh;",
      "verse": "21:26",
      "lineIndex": 132
    },
    {
      "start": 342.714,
      "end": 346.243,
      "type": "line",
      "text": "they shall be drunken with their own blood as with sweet wine;",
      "verse": "21:26",
      "lineIndex": 133
    },
    {
      "start": 346.423,
      "end": 348.513,
      "type": "line",
      "text": "and all flesh shall know",
      "verse": "21:26",
      "lineIndex": 134
    },
    {
      "start": 348.693,
      "end": 353.662,
      "type": "line",
      "text": "that I, the Lord, am thy Savior and thy Redeemer, the Mighty One of Jacob.",
      "verse": "21:26",
      "lineIndex": 135
    }
  ]
}